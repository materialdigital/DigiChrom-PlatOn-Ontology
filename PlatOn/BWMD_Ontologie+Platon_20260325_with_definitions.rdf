    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cleaning -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cleaning">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating"/>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2018-08; DIN EN ISO 9587:2007-02</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-03; DIN EN ISO 9587:2007-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cleaning</rdfs:label>
        <rdfs:label xml:lang="de">Reinigung</rdfs:label>
        <skos:definition xml:lang="en">A cleaning process</skos:definition>
        <skos:definition xml:lang="de">Reinigen ist ein Prozessschritt der Oberflächenvorbehandlung, bei dem Verunreinigungen (z. B. Öle, Fette, Partikel, Bearbeitungsrückstände) von der Werkstückoberfläche entfernt werden. Hauptzweck ist es, eine definierte, benetzbare und haftfähige Oberfläche als Voraussetzung für nachfolgende Prozesse wie Beizen, Aktivieren und galvanisches Abscheiden zu schaffen. Je nach Verfahren kann das Reinigen chemisch, elektrochemisch (elektrolytisches Entfetten) und/oder mechanisch erfolgen und ist von Beizen/Ätzen (gezielter Materialabtrag) abzugrenzen.</skos:definition>
        <skos:definition xml:lang="de">Reinigung ist ein Prozessschritt der Oberflächenvorbehandlung, bei dem Verunreinigungen (z. B. Öle, Fette, Partikel, Oxide oder Rückstände) von der Werkstückoberfläche entfernt werden. Hauptzweck ist es, eine definierte, benetzbare und haftfähige Oberfläche als Voraussetzung für nachfolgende Prozesse wie Beizen, Aktivieren oder Abscheiden von metallischen Überzügen zu schaffen. Je nach Verfahren wird zwischen mechanischer, wässrig-alkalischer, lösemittelbasierter oder elektrolytischer Reinigung unterschieden.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CleaningAgent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CleaningAgent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator xml:lang="en">Elena. G. Trelles</dc:creator>
        <rdfs:comment xml:lang="en">Chemicals for surface preparation, such as alkaline cleaners or acid solutions.</rdfs:comment>
        <rdfs:label xml:lang="en">Cleaning Agent</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CleaningMethod -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CleaningMethod">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-03; DIN EN ISO 9587:2007-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cleaning Method</rdfs:label>
        <rdfs:label xml:lang="de">Reinigungsmethode</rdfs:label>
        <skos:definition xml:lang="de">Eine Reinigungsmethode ist ein festgelegtes Verfahren zur Entfernung von Verunreinigungen (z. B. Öle, Fette, Partikel, Oxide) von Werkstückoberflächen im Rahmen der Vorbehandlung vor galvanischen oder chemischen Beschichtungsprozessen. Hauptzweck ist es, eine definierte Oberflächenreinheit und Benetzbarkeit zu erreichen, um Haftfestigkeit, Schichtqualität und Prozesssicherheit der nachfolgenden Beschichtung sicherzustellen. Reinigungsmethoden können mechanisch, chemisch oder elektrochemisch (z. B. elektrolytisches Entfetten) ausgeführt werden und sind von nachfolgenden Aktivierungs-/Beizschritten abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CleaningSolution -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CleaningSolution">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-03; DIN EN ISO 9587:2007-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cleaning Solution</rdfs:label>
        <rdfs:label xml:lang="de">Reinigungslösung</rdfs:label>
        <skos:definition xml:lang="de">Eine Reinigungslösung ist ein flüssiges Reinigungsmedium (wässrig oder lösemittelbasiert), das zur Entfernung von Verunreinigungen wie Ölen, Fetten, Partikeln oder Bearbeitungsrückständen von Werkstückoberflächen eingesetzt wird. Ihr Hauptzweck ist die Herstellung eines definierten, sauberen Oberflächenzustands als Voraussetzung für nachfolgende Prozesse wie Beizen, Aktivieren oder galvanische Abscheidung. Reinigungslösungen können je nach Verfahren chemisch, elektrolytisch (z. B. anodisch/kathodisch) oder durch Tenside/Komplexbildner unterstützt wirken.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProduct"/>
        <rdfs:comment xml:lang="en">a coating is a protective or decorative layer applied to a surface to improve its durability, appearance, or functionality, and it can be made from various materials, including paints, varnishes, polymers, and metals.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; DIN EN ISO 2080:2022-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Coating</rdfs:label>
        <skos:definition xml:lang="de">Eine Beschichtung ist eine auf ein Substrat aufgebrachte Schicht aus einem oder mehreren Werkstoffen, die die Oberfläche gezielt verändert. Hauptzweck ist es, dem Substrat definierte Eigenschaften wie Korrosionsschutz, Verschleißschutz, elektrische/chemische Funktion oder dekoratives Aussehen zu verleihen. Beschichtungen können durch verschiedene Verfahren (z. B. galvanisch, chemisch, thermisch, organisch) erzeugt werden und sind von der Grundwerkstoffoberfläche abzugrenzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingDefect -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingDefect">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialDefect"/>
        <rdfs:comment xml:lang="en">a coating degradation</rdfs:comment>
        <rdfs:label xml:lang="en">Coating Defect</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4042:2018-12; DIN EN ISO 4520:2007-11; DIN EN ISO 9587:2007-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Beschichtungsparameter</rdfs:label>
        <rdfs:label xml:lang="en">Coating related quantities</rdfs:label>
        <skos:definition xml:lang="de">Beschichtungsparameter sind festgelegte und überwachte Prozessgrößen, die die Abscheidung und die Eigenschaften einer galvanisch erzeugten Schicht während der Beschichtung bestimmen. Sie dienen der reproduzierbaren Einstellung des Beschichtungsprozesses und der Sicherstellung, dass die geforderten Schichteigenschaften (z. B. Schichtdicke, Zusammensetzung, Erscheinungsbild, Korrosionsverhalten) erreicht werden. Typische Beschichtungsparameter sind u. a. Stromdichte, Badtemperatur, pH-Wert, Elektrolytzusammensetzung, Beschichtungszeit sowie Bewegung/Umwälzung und Anoden-/Kathodenanordnung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:comment xml:lang="en">a quantity related with a coating process</rdfs:comment>
        <rdfs:label xml:lang="en">Coating Related Quantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingSurface -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingSurface">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Oberfläche, die mit einer Beschichtung versehen ist</rdfs:comment>
        <rdfs:comment xml:lang="en">Surface that has been coated</rdfs:comment>
        <rdfs:label xml:lang="de">Beschichtungsfläche</rdfs:label>
        <rdfs:label xml:lang="en">Coating Surface</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoaxialLightIntensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoaxialLightIntensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 12665:2018-08 (Licht und Beleuchtung – Grundlegende Begriffe und Kriterien zur Festlegung von Anforderungen an die Beleuchtung); DIN EN ISO/CIE 11664-2:2022-03 (Farbmetrik – Teil 2: Normfarbwertfunktionen)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Coaxial light intensity</rdfs:label>
        <rdfs:label xml:lang="de">Koaxialbeleuchtungsintensität</rdfs:label>
        <skos:definition xml:lang="de">Koaxialbeleuchtungsintensität bezeichnet die Stärke der Beleuchtung in einer koaxialen Anordnung, bei der Beleuchtungsrichtung und Beobachtungs-/Messrichtung (optische Achse) zusammenfallen. Zweck ist die reproduzierbare Ausleuchtung einer Oberfläche entlang der Messachse, um z. B. Reflexions- und Strukturmerkmale (Glanz, Mikrostruktur) unter definierter Geometrie zu erfassen. Abzugrenzen ist dies von der normativen Größe „Beleuchtungsstärke“ (Illuminance) sowie von „Lichtstärke“ (Luminous intensity), die photometrisch eindeutig definiert sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoaxialLightingTechnology -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoaxialLightingTechnology">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 11145:2018-02 (Optik und Photonik – Laser und laserbezogene Geräte – Vokabular und Symbole), DIN EN ISO 20473:2007-11 (Optik und Photonik – Spektrale Bänder)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Coaxial lighting technology</rdfs:label>
        <rdfs:label xml:lang="de">Koaxialbeleuchtungstechnologie</rdfs:label>
        <skos:definition xml:lang="de">Koaxialbeleuchtungstechnologie ist ein Beleuchtungsprinzip in der optischen Inspektion, bei dem das Beleuchtungslicht über einen Strahlteiler entlang derselben optischen Achse wie die Beobachtungs-/Kameraoptik auf das Prüfobjekt eingekoppelt wird. Hauptzweck ist die reproduzierbare Ausleuchtung zur Hervorhebung spiegelnder/planarer Oberflächenmerkmale (z. B. Defekte, Struktur- oder Schichtunterschiede) bei gleichzeitiger Minimierung von Schatten und Richtungsartefakten. Typisch ist die Verwendung eines semitransparenten Spiegels (Beam-Splitter), wodurch sich koaxiale Beleuchtung von schräger (Dark-Field) oder diffuser (Dome) Beleuchtung abgrenzt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cobalt -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cobalt">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Cobalt</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CognitiveProcess -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CognitiveProcess">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <rdfs:label xml:lang="en">CognitiveProcess</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Collimator -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Collimator">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3497:2000-03, Metallische Überzüge — Messung der Schichtdicke — Röntgenfluoreszenzverfahren; DIN EN ISO 12772:2011-12, Oberflächenchemische Analyse — Röntgenphotoelektronenspektroskopie — Kalibrierung der Energieachsen (Begriffe/Strahlführung im Messaufbau)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Collimator</rdfs:label>
        <rdfs:label xml:lang="de">Kollimator</rdfs:label>
        <skos:definition xml:lang="de">Ein Kollimator ist ein optisches bzw. strahlungsführendes Bauteil, das einen Strahl (z. B. Licht oder Röntgenstrahlung) geometrisch begrenzt und dadurch dessen Divergenz reduziert bzw. eine definierte Strahlgeometrie erzeugt. Hauptzweck ist die räumliche Selektion und Formung des Strahls, um Messungen oder Abbildungen mit definierter Messfleckgröße und reduziertem Streulicht/Untergrundanteil zu ermöglichen. In der galvanotechnischen Praxis ist der Kollimator insbesondere Bestandteil von Röntgenfluoreszenz-(XRF)-Messsystemen zur lokalen Schichtdicken- und Zusammensetzungsbestimmung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColorMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColorMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of the color of an object</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung der Farbe eines Objekts</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-1:2020-12, DIN EN ISO/CIE 11664-2:2020-12, DIN EN ISO/CIE 11664-4:2020-12, DIN EN ISO/CIE 11664-5:2020-12, DIN 5033-7:2017-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Color Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Farbmessung</rdfs:label>
        <skos:definition xml:lang="de">Farbmessung ist die instrumentelle Bestimmung von Farbkennwerten eines Prüfkörpers bzw. einer Oberfläche durch Messung der spektralen Reflexion/Transmission und Umrechnung in ein genormtes Farbsystem (z. B. CIE). Hauptzweck ist die objektive, reproduzierbare Bewertung und der Vergleich von Farben (z. B. zur Qualitätsprüfung von galvanischen Oberflächen hinsichtlich Farbton und Farbabweichung). Die Ergebnisse sind von festgelegten Messbedingungen wie Normlichtart, Beobachter, Messgeometrie und ggf. Glanzeinfluss abhängig.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColorMeasurementDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColorMeasurementDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-4:2019-03; DIN EN ISO/CIE 11664-5:2017-01; DIN 5033-7:2017-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Color Measurement Device</rdfs:label>
        <rdfs:label xml:lang="de">Farbmessgerät</rdfs:label>
        <skos:definition xml:lang="de">Ein Farbmessgerät ist ein Messgerät zur instrumentellen Bestimmung von Farbkennwerten eines Objekts oder einer Oberfläche unter festgelegten Messbedingungen (z. B. Beleuchtungsart, Beobachter, Geometrie). Hauptzweck ist die objektive, reproduzierbare Erfassung und der Vergleich von Farben, z. B. zur Qualitätsüberwachung von galvanischen Oberflächen hinsichtlich Farbton und Farbabweichung. Je nach Geräteprinzip erfolgt die Farbbestimmung als tristimulusbasierte Messung (Kolorimeter) oder spektral aufgelöst (Spektralphotometer) mit anschließender Berechnung von Farbkoordinaten.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColorMeasurementModus -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColorMeasurementModus">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 11664-1:2019-06; DIN EN ISO 11664-2:2022-01; DIN EN ISO 11664-4:2019-06; DIN EN ISO 11664-5:2017-01; DIN EN ISO 13655:2017-05; ASTM E1164-22</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-1:2019-03; DIN EN ISO/CIE 11664-2:2022-03; DIN EN ISO/CIE 11664-4:2019-03; DIN EN ISO 7724-1:2021-12; DIN EN ISO 7724-2:2021-12; DIN EN ISO 7724-3:2021-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Color Measurement Modus</rdfs:label>
        <rdfs:label xml:lang="de">Farbmessmodus</rdfs:label>
        <skos:definition xml:lang="de">Ein Farbmessmodus ist die festgelegte Kombination aus Messgeometrie und Messbedingungen, unter denen Farbwerte eines Prüflings mit einem Farbmessgerät bestimmt werden. Zweck ist die reproduzierbare und vergleichbare Farbmessung, indem Einflussgrößen wie Beleuchtungs-/Beobachtungsgeometrie, spektrale Bedingungen, Normlichtart und Beobachter standardisiert festgelegt werden. Häufige Abgrenzungen innerhalb des Messmodus sind z. B. Messung mit/ohne Glanzeinfluss (SCI/SCE) sowie unterschiedliche Geometrien (45°/0° bzw. d/8°).</skos:definition>
        <skos:definition xml:lang="de">Ein Farbmessungsmodus ist die festgelegte Kombination von Messbedingungen und Auswerteparametern, unter denen eine instrumentelle Farbmessung durchgeführt und angegeben wird. Zweck ist die eindeutige, reproduzierbare Bestimmung und Vergleichbarkeit von Farbkennwerten (z. B. CIE XYZ, CIELAB) zwischen Geräten, Laboren und Spezifikationen. Typische Elemente sind Messgeometrie (z. B. 45/0, d/8), Normlichtart und Normalbeobachter sowie die Behandlung von Glanzanteilen (z. B. SCI/SCE).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColorMode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColorMode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-1:2020-12; DIN EN ISO/CIE 11664-4:2020-12; DIN EN ISO 3668:2017-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Color Mode</rdfs:label>
        <rdfs:label xml:lang="de">Farbmodus</rdfs:label>
        <skos:definition xml:lang="de">Ein Farbmodus ist eine festgelegte Art der Farbdarstellung bzw. Farbcodierung, die definiert, wie Farbe numerisch oder kategorisch beschrieben und wiedergegeben wird (z. B. über einen Farbraum und zugehörige Bedingungen). Hauptzweck ist die reproduzierbare Erfassung, Kommunikation und Bewertung von Farbe, z. B. bei der visuellen Beurteilung oder messtechnischen Charakterisierung von Oberflächen. In der galvanotechnischen Praxis ist der Farbmodus von der Beschichtungsart zu unterscheiden; er beschreibt die Darstellung/Messbedingung der Farbe, nicht deren Ursache.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coloumetry -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coloumetry">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Coloumetry</rdfs:label>
        <rdfs:label xml:lang="de">Kolorimetrie</rdfs:label>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColoumetryDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColoumetryDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-4:2019-03; DIN EN ISO/CIE 11664-6:2016-12; DIN EN ISO 7724-1:2021-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Coloumetry Device</rdfs:label>
        <rdfs:label xml:lang="de">Kolorimetriergerät</rdfs:label>
        <skos:definition xml:lang="de">Ein Kolorimetriergerät ist ein Messgerät zur instrumentellen Bestimmung von Farbkennwerten eines Prüfkörpers durch Messung des reflektierten oder transmittierten Lichts unter definierten Beleuchtungs- und Beobachtungsbedingungen. Hauptzweck ist die objektive, reproduzierbare Farbbewertung und der Vergleich von Farben über normierte Farbräume und Farbunterschiedsformeln. Es ist von Spektralphotometern abzugrenzen, wenn es Farbwerte direkt (ohne vollständige spektrale Auflösung) aus festgelegten Messkanälen bzw. Filterfunktionen ableitet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColoumetryMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ColoumetryMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-4:2019-03, DIN EN ISO/CIE 11664-6:2016-12, DIN EN ISO/CIE 11664-2:2022-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Coloumetry</rdfs:label>
        <rdfs:label xml:lang="de">Kolorimetrie</rdfs:label>
        <skos:definition xml:lang="de">Kolorimetrie ist ein Messverfahren zur quantitativen Bestimmung von Farben bzw. Farbunterschieden auf Basis standardisierter Beleuchtungs-, Beobachter- und Auswertebedingungen. Hauptzweck ist die objektive, reproduzierbare Beschreibung von Farborten und Farbdifferenzen (z. B. zur Qualitätsprüfung von Oberflächen und Beschichtungen). Sie ist von der visuellen Beurteilung abzugrenzen, da sie auf instrumenteller Messung und normierten Farbräumen/Farbdifferenzformeln beruht.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Column -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Column">
