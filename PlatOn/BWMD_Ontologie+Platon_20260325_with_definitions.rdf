        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator xml:lang="en">Elena G. Trelles (Fraunhofer IWM)</dc:creator>
        <rdfs:comment xml:lang="en">a symbolic representation of a chemical compound that indicates the types and numbers of atoms present in the molecule. It uses element symbols from the periodic table, along with numerical subscripts to denote the quantity of each type of atom. For example, the chemical formula for water is H₂O, which indicates that each molecule contains two hydrogen atoms and one oxygen atom.</rdfs:comment>
        <rdfs:label xml:lang="en">Chemical Formula</rdfs:label>
    </owl:Class>
    


