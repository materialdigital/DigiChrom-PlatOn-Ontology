    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealingTemperatureAsSupposed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealingTemperatureAsSupposed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealingTemperature"/>
        <rdfs:comment>The solution heat treatment temperature as supposed</rdfs:comment>
        <rdfs:label xml:lang="en">SolutionAnnealingTemperatureAsSupposed</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolventDegreasing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolventDegreasing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Entfernung von Fett und Öl von den Oberflächen durch Eintauchen in organische Lösungsmittel</rdfs:comment>
        <rdfs:comment xml:lang="en">removal of grease and oil from surfaces by immersion in organic solvents</rdfs:comment>
        <rdfs:label xml:lang="de">Lösungsmittelreinigung</rdfs:label>
        <rdfs:label xml:lang="en">Solvent Degreasing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Spalling -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Spalling">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingDefect"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Splittern oder Abbrechen eines Überzugs von einer Oberfläche, das üblicherweise durch unterschied- liche thermische Ausdehnung oder Zusammen- ziehung oder aufgrund von Eigenspannung im Überzug auftritt</rdfs:comment>
        <rdfs:comment xml:lang="en">chipping or fragmenting of a surface coating that usually occurs by differential thermal expansion or contraction or due to internal stress in the coating</rdfs:comment>
        <rdfs:label xml:lang="de">Abplatzen</rdfs:label>
        <rdfs:label xml:lang="en">Spalling</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpatialRegion -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpatialRegion">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImmaterialEntity"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">SpatialRegion</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpatiotemporalRegion -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpatiotemporalRegion">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Occurrent"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemporalRegion"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">SpatiotemporalRegion</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificDataFormat -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificDataFormat">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <rdfs:comment>Any kind of specific data format, e.g. file types like .txt, .xls, .png, .pdf, ...</rdfs:comment>
        <rdfs:label xml:lang="en">SpecificDataFormat</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificHeatCapacity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificHeatCapacity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">SpecificHeatCapacity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificWearRate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificWearRate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Maß für den Verschleiß eines Materials pro Zeiteinheit</rdfs:comment>
        <rdfs:comment xml:lang="en">Measure of wear of a material per unit time</rdfs:comment>
        <rdfs:label xml:lang="en">Specific Wear Rate</rdfs:label>
        <rdfs:label xml:lang="de">Spezifische Verschleißrate</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificallyDependentContinuant -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificallyDependentContinuant">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Continuant"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">SpecificallyDependentContinuant</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificationOfAnalysedChemicalElementsInLIBSProcess -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificationOfAnalysedChemicalElementsInLIBSProcess">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Spectroscopy"/>
        <rdfs:comment>Specification of the analysed chemical elements in a LIBS (laser induced plasma spectroscopy) process.</rdfs:comment>
        <rdfs:label xml:lang="en">SpecificationOfAnalysedChemicalElementsInLIBSProcess</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Specimen -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Specimen">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProduct"/>
        <rdfs:label xml:lang="en">Specimen</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenCooling -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenCooling">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GenerelExperimentRelatedProcess"/>
        <rdfs:comment>The process of cooling a specimen</rdfs:comment>
        <rdfs:label xml:lang="en">SpecimenCooling</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenCrossSectionArea -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenCrossSectionArea">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenRelatedQuantity"/>
        <rdfs:label xml:lang="en">SpecimenCrossSectionArea</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenCrossSectionAreaAtFracture -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenCrossSectionAreaAtFracture">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenCrossSectionArea"/>
        <rdfs:label xml:lang="en">SpecimenCrossSectionAreaAtFracture</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenDiameter -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenDiameter">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2177:2019-06, DIN EN ISO 3497:2000-03, DIN EN ISO 2064:2020-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Probendurchmesser</rdfs:label>
        <rdfs:label xml:lang="en">SpecimenDiameter</rdfs:label>
        <skos:definition xml:lang="de">Der Probendurchmesser ist der festgelegte Durchmesser einer Probe bzw. eines Prüfkörpers, der für eine Prüfung oder Messung verwendet wird. Er dient der eindeutigen Festlegung der Probengeometrie und damit der Vergleichbarkeit und Reproduzierbarkeit von Prüfergebnissen (z. B. bei Schichtdickenmessungen an zylindrischen Teilen). Je nach Prüfverfahren kann der Probendurchmesser Einfluss auf Messanordnung, Auswertebedingungen und die Gültigkeit von Verfahrensvorgaben haben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenDiameterAtFracture -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenDiameterAtFracture">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenDiameter"/>
        <rdfs:label xml:lang="en">SpecimenDiameterAtFracture</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenGeometryParameter -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenGeometryParameter">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GeometryInfo"/>
        <rdfs:label xml:lang="en">SpecimenGeometryParameter</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenHeating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenHeating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Heating"/>
        <rdfs:comment>The process of heating a specimen</rdfs:comment>
        <rdfs:label xml:lang="en">SpecimenHeating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenHeight -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenHeight">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; DIN EN ISO 9227:2023-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Probenhöhe</rdfs:label>
        <rdfs:label xml:lang="en">SpecimenHeight</rdfs:label>
        <skos:definition xml:lang="de">Probenhöhe ist die senkrechte Abmessung einer Probe bzw. eines Probekörpers in definierter Orientierung, üblicherweise als Abstand zwischen Unter- und Oberseite entlang der Höhenrichtung. Sie dient der eindeutigen Festlegung der Probengeometrie und damit der Vergleichbarkeit von Prüf- und Messergebnissen (z. B. bei Schichtdicken-, Korrosions- oder mechanischen Prüfungen). Die Probenhöhe ist von der Schichtdicke zu unterscheiden, da sie eine Abmessung des Substrats/Probekörpers und nicht der aufgebrachten Schicht beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenLength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenLength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenRelatedQuantity"/>
        <rdfs:label xml:lang="en">SpecimenLength</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenName -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenName">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <rdfs:label xml:lang="en">SpecimenName</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenPreparation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenPreparation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Preparation"/>
        <rdfs:label xml:lang="en">SpecimenPreparation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructuralQuantity"/>
        <rdfs:label xml:lang="en">SpecimenRelatedQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenThickness -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenThickness">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2020-03; DIN EN ISO 9227:2023-09; DIN EN ISO 2178:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Probendicke</rdfs:label>
        <rdfs:label xml:lang="en">Specimen Thickness</rdfs:label>
        <skos:definition xml:lang="de">Probendicke ist die Dicke eines Probenkörpers/Prüfstücks, die als geometrische Kenngröße für eine Prüfung oder Messung festgelegt bzw. ermittelt wird. Sie dient dazu, Prüfbedingungen und Messergebnisse (z. B. bei Schichtdickenmessung, Korrosions- oder mechanischen Prüfungen) vergleichbar und reproduzierbar zu machen. Die Probendicke ist von der Schichtdicke zu unterscheiden, da sie sich auf das Substrat bzw. den gesamten Probenkörper und nicht auf die aufgebrachte Überzugsdicke bezieht.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenWidth -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenWidth">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6892-1:2020-06; DIN EN ISO 9227:2023-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Probenbreite</rdfs:label>
        <rdfs:label xml:lang="en">SpecimenWidth</rdfs:label>
        <skos:definition xml:lang="de">Die Probenbreite ist die Breite einer Probe bzw. eines Probekörpers als festgelegte geometrische Abmessung, üblicherweise senkrecht zur Probenlängsrichtung. Sie dient der eindeutigen Festlegung der Probengeometrie für die Durchführung und Vergleichbarkeit von Prüfungen (z. B. mechanische Prüfungen oder Korrosionsprüfungen) an beschichteten oder unbeschichteten Werkstoffen. Die Probenbreite ist von der Schichtdicke zu unterscheiden und wird in der Regel in Millimetern angegeben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Spectroscopy -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Spectroscopy">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <rdfs:comment>Some kind of spectroscopy (interaction between matter and electromagnetic radiation) process</rdfs:comment>
        <rdfs:label xml:lang="en">Spectroscopy</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SphereGeometry -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SphereGeometry">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 4760:1983-06 (Geometrische Grundbegriffe; Kugel – Begriffe und Definitionen); DIN EN ISO 80000-3:2020-09 (Größen und Einheiten – Teil 3: Raum und Zeit)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Kugelgeometrie</rdfs:label>
        <rdfs:label xml:lang="en">Sphere Geometry</rdfs:label>
        <skos:definition xml:lang="de">Kugelgeometrie bezeichnet die geometrische Formbeschreibung eines kugelförmigen Körpers durch definierte Parameter wie Durchmesser bzw. Radius und die idealisierte Kugelfläche. Hauptzweck ist die eindeutige, reproduzierbare Spezifikation der Form als Grundlage für Auslegung, Prüfung und Vergleich (z. B. bei Kontaktkörpern, Messkörpern oder Bauteilgeometrien). In der Galvanotechnik ist die Kugelgeometrie insbesondere relevant, wenn Beschichtungsanforderungen (z. B. Schichtdickenverteilung) auf gekrümmten Oberflächen bewertet oder Prüfgeometrien festgelegt werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpindleSpeed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpindleSpeed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-3:2020-09 (Größen und Einheiten – Teil 3: Raum und Zeit)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Spindeldrehzahl</rdfs:label>
        <rdfs:label xml:lang="en">Spindle speed</rdfs:label>
        <skos:definition xml:lang="de">Die Spindeldrehzahl ist die Drehzahl einer Spindel, angegeben als Anzahl der Umdrehungen pro Zeiteinheit (typisch min⁻¹). Sie dient zur Festlegung und Überwachung der Rotationsbewegung einer Spindel, z. B. in Antrieben von Trommeln, Gestellen oder Rühr-/Bewegungseinrichtungen, um definierte Prozessbedingungen zu erreichen. Sie ist von der Umfangsgeschwindigkeit zu unterscheiden, die zusätzlich den wirksamen Radius berücksichtigt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpotSize -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpotSize">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3497:2000-03, DIN EN ISO 22453:2020-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Spot size</rdfs:label>
        <rdfs:label xml:lang="de">Spotgröße</rdfs:label>
        <skos:definition xml:lang="de">Die Spotgröße ist die wirksame Abmessung (z. B. Durchmesser oder Kantenlänge) des Mess- oder Anregungsflecks, mit dem eine Oberfläche bei einem Messverfahren lokal erfasst bzw. angeregt wird. Ihr Hauptzweck ist die Festlegung der lateralen Auflösung und der repräsentativen Messfläche, insbesondere bei der Schichtdicken- oder Zusammensetzungsbestimmung auf galvanisch beschichteten Oberflächen. Sie ist vom Messfeld/Analysebereich abzugrenzen, der je nach Verfahren und Auswertebedingungen von der reinen Anregungs-Spotgröße abweichen kann.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpottingOut -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpottingOut">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingDefect"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">delayed appearance of spots and blemishes on electroplated or otherwise finished (3.2.120) surfaces</rdfs:comment>
        <rdfs:comment xml:lang="de">verzögertes Erscheinen von Flecken und Mängeln an galvanischen Metallüberzügen oder anderen veredelten (3.2.120) Oberflächen</rdfs:comment>
        <rdfs:label xml:lang="de">Fleckenbildung</rdfs:label>
        <rdfs:label xml:lang="en">Spotting Out</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Stabilizer -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Stabilizer">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Substance that increases the stability of a solution</rdfs:comment>
        <rdfs:comment xml:lang="de">Substanz, die die Stabilität einer Lösung erhöht</rdfs:comment>
        <rdfs:label xml:lang="de">Stabilisator</rdfs:label>
        <rdfs:label xml:lang="en">Stabilizer</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StabilizerC1 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StabilizerC1">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Stabilizer"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Stabilizer C1</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StabilizerC2 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StabilizerC2">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Stabilizer"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Stabilizer C2</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StandardDeviation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StandardDeviation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN ISO 3534-2:2014-10, DIN EN ISO/IEC 17025:2018-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Standard Deviation</rdfs:label>
        <rdfs:label xml:lang="de">Standardabweichung</rdfs:label>
        <skos:definition xml:lang="de">Die Standardabweichung ist ein Maß für die Streuung von Messwerten um ihren Mittelwert und entspricht der positiven Quadratwurzel der Varianz. Sie dient zur quantitativen Angabe der Präzision bzw. Wiederhol- und Vergleichbarkeit von Messergebnissen, z. B. bei der Bewertung von Prozess- und Prüfdaten in der Galvanotechnik. Je nach Auswertung wird zwischen der Standardabweichung einer Grundgesamtheit und der (mit Freiheitsgradkorrektur berechneten) Stichprobenstandardabweichung unterschieden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StandardDeviationThicknessCr -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StandardDeviationThicknessCr">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StandardDeviation"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessCr"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN ISO 5725-1:1997-05; DIN ISO 3534-1:2009-10; DIN EN ISO 2178:2016-12; DIN EN ISO 3882:2003-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Standard Deviation Thickness Cr</rdfs:label>
        <rdfs:label xml:lang="de">Standardabweichung Chromschichtdicke</rdfs:label>
        <skos:definition xml:lang="de">Die Standardabweichung der Chromschichtdicke ist ein statistisches Streuungsmaß, das die Variabilität der gemessenen Dicke einer Chromschicht um ihren Mittelwert für eine Stichprobe von Messwerten beschreibt. Sie dient zur quantitativen Bewertung der Gleichmäßigkeit bzw. Prozessstabilität der Chromabscheidung und zur Angabe der Messwertstreuung bei Schichtdickenprüfungen. Sie ist von der Messunsicherheit zu unterscheiden, die die Unsicherheit des Messergebnisses beschreibt und nicht die Streuung der Schichtdicke selbst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StandardDeviationThicknessNi -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StandardDeviationThicknessNi">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StandardDeviation"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessNi"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN ISO 3534-1:2014-03; DIN EN ISO 2177:2019-06; DIN EN ISO 2064:2020-02; DIN EN ISO 2178:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Standard Deviation Thickness Ni</rdfs:label>
        <rdfs:label xml:lang="de">Standardabweichung Nickelschichtdicke</rdfs:label>
        <skos:definition xml:lang="de">Die Standardabweichung der Nickelschichtdicke ist eine statistische Kenngröße, die die Streuung einzelner Messwerte der Dicke einer Nickelabscheidung um ihren Mittelwert beschreibt. Sie dient zur quantitativen Beurteilung der Gleichmäßigkeit bzw. Reproduzierbarkeit der Nickelschichtdicke auf einem Bauteil oder innerhalb einer Stichprobe. Sie ist von der Messunsicherheit zu unterscheiden, die die Qualität des Messverfahrens beschreibt, während die Standardabweichung die Variabilität der gemessenen Schichtdickenwerte charakterisiert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StarDusting -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StarDusting">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialStructureInfo"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">&lt;plating on plastics&gt; extremely fine form of roughness on the surface of a metallic deposit</rdfs:comment>
        <rdfs:comment xml:lang="de">&lt;Überzug auf Kunststoffen&gt; besonders feine Form von Rauheit auf der Oberfläche eines metallischen Überzugs</rdfs:comment>
        <rdfs:label xml:lang="de">Mikrorauigkeit</rdfs:label>
        <rdfs:label xml:lang="en">Star Dusting</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SteelMaterial -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SteelMaterial">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FerrousMaterial"/>
        <rdfs:label xml:lang="en">SteelMaterial</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Stepsize -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Stepsize">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 1319-1:1995-05; ISO 80000-1:2009-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Schrittweite</rdfs:label>
        <rdfs:label xml:lang="en">Stepsize</rdfs:label>
        <skos:definition xml:lang="de">Die Schrittweite ist die festgelegte Größe eines einzelnen diskreten Inkrements zwischen zwei aufeinanderfolgenden Einstell-, Abtast- oder Messwerten einer Größe. Sie dient dazu, die Auflösung bzw. Granularität von Einstellungen oder Messreihen (z. B. bei der Variation von Stromdichte, Zeit, Temperatur oder Weg/Position in Prüfabläufen) eindeutig zu definieren und reproduzierbar zu machen. Sie ist von der Messunsicherheit zu unterscheiden und beschreibt die Diskretisierung, nicht die Genauigkeit.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StopPotential -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StopPotential">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 17475:2008-12 (Korrosion von Metallen und Legierungen – Elektrochemische Prüfverfahren – Richtlinien für die Anwendung von potentiostatischen und potentiodynamischen Polarisationsmessungen); ASTM G61-86(2018) (Standard Test Method for Conducting Cyclic Potentiodynamic Polarization Measurements for Localized Corrosion Susceptibility of Iron-, Nickel-, or Cobalt-Based Alloys)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Abbruchpotential</rdfs:label>
        <rdfs:label xml:lang="en">Stop Potential</rdfs:label>
        <skos:definition xml:lang="de">Abbruchpotential ist das in einem elektrochemischen Mess- oder Prüfverfahren festgelegte Elektrodenpotential, bei dessen Erreichen die Potentialführung (z. B. ein Potentialsweep) beendet wird. Es dient dazu, den Messbereich zu begrenzen und Probe, Elektrolyt oder Messaufbau vor unerwünschten Zuständen (z. B. starker Gasentwicklung, Durchbruch/Transpassivität, Schädigung der Oberfläche) zu schützen. Es ist ein verfahrensspezifischer Parameter und nicht mit charakteristischen Werkstoffkennwerten wie Korrosionspotential oder Lochfraßpotential gleichzusetzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRelatedQuantity"/>
        <rdfs:label xml:lang="en">StrainRate</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRateInLoadingDirection -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRateInLoadingDirection">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRate"/>
        <rdfs:label xml:lang="en">StrainRateInLoadingDirection</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalQuantity"/>
        <rdfs:label xml:lang="en">StrainRelatedQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StressRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StressRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalQuantity"/>
        <rdfs:label xml:lang="en">StressRelatedQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Strike -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Strike">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Vordecküberzug
Vordeckbad
dünne, fest haftende Schicht des abgeschiedenen Metalls als Grundlage für weitere Überzüge oder eine spezielle Lösung zur Abscheidung dieser dünnen Metallschicht</rdfs:comment>
        <rdfs:comment xml:lang="en">thin adherent layer of metal coating to be followed by other coatings, or a solution to deposit a thin metal coating</rdfs:comment>
        <rdfs:label xml:lang="de">Strike</rdfs:label>
        <rdfs:label xml:lang="en">Strike</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Strontium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Strontium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Strontium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructuralInfo -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructuralInfo">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <rdfs:label xml:lang="en">StructuralInfo</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructuralQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructuralQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:label xml:lang="en">StructuralQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructureDatabase -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructureDatabase">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Software"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 5127:2018-02 (Information und Dokumentation — Grundlagen und Begriffe), ISO 10289:1999 (Methods for corrosion testing of metallic and other inorganic coatings on metallic substrates — Rating of test specimens and manufactured articles subjected to corrosion tests)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Gefüge-Datenbank</rdfs:label>
        <rdfs:label xml:lang="en">Structure database</rdfs:label>
        <skos:definition xml:lang="de">Eine Gefüge-Datenbank ist eine strukturierte Sammlung digital gespeicherter Informationen zu Gefügen (Mikrostrukturen) von Werkstoffen bzw. Schichten, typischerweise einschließlich zugehöriger Metadaten wie Herstell-/Prozessbedingungen, Probenpräparation und Prüf-/Bildgebungsparametern. Hauptzweck ist die systematische Ablage, Vergleichbarkeit und Auswertung von Gefügeinformationen zur Qualitätssicherung, Fehleranalyse und Prozess-/Werkstoffentwicklung. Sie ist von allgemeinen Werkstoffdatenbanken dadurch abgegrenzt, dass der Schwerpunkt auf mikrostrukturellen Merkmalen (z. B. Korngröße, Phasenanteile, Porosität, Riss-/Ausscheidungsmerkmale) und deren dokumentierter Ermittlung liegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Subprocess -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Subprocess">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9000:2015-11; DIN EN ISO 9001:2015-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Subprocess</rdfs:label>
        <rdfs:label xml:lang="de">Subprozess</rdfs:label>
        <skos:definition xml:lang="de">Ein Subprozess ist ein abgegrenzter Teil eines übergeordneten Prozesses, der aus zusammenhängenden Tätigkeiten besteht und definierte Eingaben in definierte Ausgaben überführt. Hauptzweck ist die strukturierte Zerlegung und Steuerung komplexer Prozessabläufe, z. B. zur Planung, Überwachung und Verbesserung von Qualität, Kosten oder Durchlaufzeit. Ein Subprozess ist typischerweise einem Prozess zugeordnet und kann eigene Verantwortlichkeiten, Ressourcen, Schnittstellen und Kennzahlen besitzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SubprocessSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SubprocessSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <rdfs:label xml:lang="en">SubprocessSet</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <rdfs:comment xml:lang="en">a form of matter that has a specific composition and distinct properties</rdfs:comment>
        <rdfs:label xml:lang="en">Substance</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SubstratMaterialCorrection -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SubstratMaterialCorrection">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Substrat Material Correction</rdfs:label>
        <rdfs:label xml:lang="de">Substratmaterialkorrektur</rdfs:label>
        <skos:definition xml:lang="de">Eine Substratmaterialkorrektur ist eine Korrektur (meist als Kalibrier- oder Umrechnungsfaktor umgesetzt) zur Berücksichtigung des Einflusses des Substratmaterials auf ein Mess- oder Prüfergebnis, z. B. bei der Schichtdickenmessung von galvanischen Überzügen. Hauptzweck ist es, systematische Messabweichungen zu reduzieren, die durch unterschiedliche physikalische Eigenschaften des Grundwerkstoffs (z. B. Leitfähigkeit, magnetische Permeabilität, Dichte/Matrixeffekte) gegenüber dem Kalibrierstandard entstehen. Sie ist von der allgemeinen Gerätekalibrierung abzugrenzen, da sie spezifisch die Substratabhängigkeit adressiert und typischerweise nur für definierte Substrat-/Schichtsysteme gültig ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substrate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substrate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringMaterial"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Material,	auf	dem	ein	Überzug	unmittelbar aufgebracht wird</rdfs:comment>
        <rdfs:comment xml:lang="en">material upon which a coating is directly applied</rdfs:comment>
        <rdfs:label xml:lang="de">Substrat</rdfs:label>
        <rdfs:label xml:lang="en">Substrate</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Sulfate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Sulfate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Chemical compound containing sulfate ions</rdfs:comment>
        <rdfs:comment xml:lang="de">Chemische Verbindung, die Sulfat-Ionen enthält</rdfs:comment>
        <rdfs:label xml:lang="de">Sulfat</rdfs:label>
        <rdfs:label xml:lang="en">Sulfate</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Sulfur -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Sulfur">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Sulfur</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Summarising -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Summarising">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CognitiveProcess"/>
        <rdfs:label xml:lang="en">Summarising</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SuperimposedVibration -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SuperimposedVibration">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CastingRelatedSubprocess"/>
        <rdfs:comment>Superimposed vibration during the casting process</rdfs:comment>
        <rdfs:label xml:lang="en">SuperimposedVibration</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Supplier -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Supplier">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Organisation"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Company that supplies products or materials</rdfs:comment>
        <rdfs:comment xml:lang="de">Unternehmen, das Produkte oder Materialien liefert</rdfs:comment>
        <rdfs:label xml:lang="de">Lieferant</rdfs:label>
        <rdfs:label xml:lang="en">Supplier</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SupplierBatch -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SupplierBatch">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SupplierName -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SupplierName">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9001:2015-11; DIN EN ISO 9000:2015-11; DIN EN ISO 10204:2005-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Hersteller Name</rdfs:label>
        <rdfs:label xml:lang="en">Supplier Name</rdfs:label>
        <skos:definition xml:lang="de">Der Lieferantenname ist die textliche Bezeichnung des Lieferanten (Organisation oder Person), der ein Produkt, Material oder eine Dienstleistung bereitstellt. Er dient der eindeutigen Zuordnung von Lieferungen und der Rückverfolgbarkeit in Dokumentation, Kennzeichnung und Qualitätsmanagementprozessen. Der Lieferantenname ist von Lieferantennummer/Identifikator abzugrenzen, die eine codierte, systeminterne eindeutige Kennung darstellen kann.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SupplierNumber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SupplierNumber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Identifier"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Identification number of a supplier</rdfs:comment>
        <rdfs:comment xml:lang="de">Identifikationsnummer eines Lieferanten</rdfs:comment>
        <rdfs:label xml:lang="de">Lieferantennummer</rdfs:label>
        <rdfs:label xml:lang="en">Supplier Number</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceFactor -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceFactor">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Der Oberflächenfaktor, der das Verhältnis von Oberfläche zu Volumen beschreibt.</rdfs:comment>
        <rdfs:comment xml:lang="en">The surface factor, describing the ratio of surface area to volume.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2020-06; DIN EN ISO 2177:2019-06; DIN EN ISO 2080:2022-03</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 25178-2:2012-09; ISO 21920-2:2021-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Oberflächenfaktor</rdfs:label>
        <rdfs:label xml:lang="en">Surface Factor</rdfs:label>
        <skos:definition xml:lang="de">Der Oberflächenfaktor ist ein dimensionsloser Faktor, der das Verhältnis der tatsächlich wirksamen (realen) Oberfläche eines Werkstücks zur geometrisch berechneten Oberfläche beschreibt. Er dient dazu, bei der Auslegung und Steuerung galvanischer Prozesse (z. B. Stromdichte, Strombedarf, Abscheiderate) die durch Rauheit, Porosität oder komplexe Geometrie vergrößerte wirksame Oberfläche zu berücksichtigen. Der Oberflächenfaktor ist von rein geometrischen Formfaktoren abzugrenzen, da er die mikroskopische Oberflächenvergrößerung mit einbezieht.</skos:definition>
        <skos:definition xml:lang="de">Der Oberflächenfaktor ist ein dimensionsloser Faktor, der die Abweichung der real wirksamen Oberfläche eines Werkstücks von seiner geometrisch idealisierten Oberfläche beschreibt (typisch als Verhältnis A_real/A_geo). Er dient dazu, flächenbezogene Prozessgrößen (z. B. Stromdichte, Stoffumsatz, Schichtdickenbildung) auf die tatsächlich wirksame Oberfläche zu beziehen und damit Prozessführung und Vergleichbarkeit zu verbessern. In der galvanotechnischen Praxis wird er häufig über Rauheit/Topographie angenähert und ist vom rein geometrischen Formfaktor abzugrenzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceFinishing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceFinishing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Preparation"/>
        <rdfs:comment>The process of finishing the surface of some kind of object (e.g. polishing, grinding...)</rdfs:comment>
        <rdfs:label xml:lang="en">SurfaceFinishing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceMicrography -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceMicrography">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTesting"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; DIN EN ISO 15749:2002-03; DIN EN ISO 10289:2000-06; DIN EN ISO 8785:1999-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Oberflächenmikrografie</rdfs:label>
        <rdfs:label xml:lang="en">Surface Micrography</rdfs:label>
        <skos:definition xml:lang="de">Oberflächenmikrografie ist die mikroskopische Bildaufnahme und dokumentierte Darstellung einer Oberfläche (z. B. eines galvanischen Überzugs) zur Beurteilung ihrer Mikrostruktur und Topografie. Hauptzweck ist die reproduzierbare Erfassung und Auswertung oberflächenbezogener Merkmale wie Poren, Risse, Nodulen, Rauheits-/Strukturmerkmale oder Defekte als Grundlage für Qualitätsprüfung und Fehleranalyse. Sie ist von der Querschliff‑Mikrografie abzugrenzen, die primär den Schichtaufbau und die Grenzflächen im Schnitt zeigt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfacePropertyDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfacePropertyDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <dc:creator>Christoph Schweizer</dc:creator>
        <rdfs:comment xml:lang="en">subclass of DataSet containing surface properties about an engineering object</rdfs:comment>
        <rdfs:label xml:lang="en">Surface Property DataSet </rdfs:label>
        <foaf:name xml:lang="en">Christoph Schweizer</foaf:name>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceRoughness -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceRoughness">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4287:2010-07, DIN EN ISO 4288:1998-04, DIN EN ISO 21920-1:2022-12, DIN EN ISO 21920-2:2022-12, DIN EN ISO 21920-3:2022-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Oberflächenrauheit</rdfs:label>
        <rdfs:label xml:lang="en">Surface Roughness</rdfs:label>
        <skos:definition xml:lang="de">Oberflächenrauheit ist die Gesamtheit der feineren Unebenheiten einer realen Oberfläche, die durch Abweichungen des Rauheitsprofils von einer idealen Form innerhalb einer festgelegten Bewertungs- bzw. Messstrecke beschrieben wird. Hauptzweck ist die quantitative Charakterisierung der Oberflächenbeschaffenheit mittels genormter Rauheitskenngrößen (z. B. Ra, Rz) zur Spezifikation, Prüfung und Vergleichbarkeit von Oberflächen, auch im Kontext von Beschichtungsprozessen. Sie ist von Welligkeit und Formabweichungen durch unterschiedliche Wellenlängenbereiche und entsprechende Filterung/Trennung im Profil abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceRoughnessTester -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceRoughnessTester">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3274:1998-04; DIN EN ISO 4287:2010-07; DIN EN ISO 4288:1998-04; DIN EN ISO 25178-6:2010-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Oberflächenrauheitsmessgerät</rdfs:label>
        <rdfs:label xml:lang="en">Surface Roughness Tester</rdfs:label>
        <skos:definition xml:lang="de">Ein Oberflächenrauheitsmessgerät ist ein Messgerät zur Erfassung und Auswertung der Oberflächenbeschaffenheit, insbesondere der Rauheit, anhand eines gemessenen Profils oder einer flächenhaften Topographie. Hauptzweck ist die normgerechte Bestimmung von Rauheitskenngrößen (z. B. Ra, Rz) zur Spezifikation und Qualitätsprüfung von Oberflächen. Je nach Messprinzip wird zwischen taktilen Profilverfahren (Tastschnitt) und optischen Verfahren unterschieden, wobei die Auswertebedingungen (Filter, Tastspitzengeometrie, Messbedingungen) normativ festgelegt sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceTension -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceTension">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Force that holds the surface of a liquid together</rdfs:comment>
        <rdfs:comment xml:lang="de">Kraft, die die Oberfläche einer Flüssigkeit zusammenhält</rdfs:comment>
        <rdfs:label xml:lang="de">Oberflächenspannung</rdfs:label>
        <rdfs:label xml:lang="en">Surface Tension</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceTensionMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceTensionMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of the surface tension of a liquid</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung der Oberflächenspannung einer Flüssigkeit</rdfs:comment>
        <rdfs:label xml:lang="de">Oberflächenspannungsmessung</rdfs:label>
        <rdfs:label xml:lang="en">Surface Tension Measurement</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceTopographyMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceTopographyMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTesting"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of surface structure and features</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung der Oberflächenstruktur und -merkmale</rdfs:comment>
        <rdfs:label xml:lang="de">Oberflächentopographiemessung</rdfs:label>
        <rdfs:label xml:lang="en">Surface Topography Measurement</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Suspension -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Suspension">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalSolution"/>
        <rdfs:comment>Suspension used for example during grinding or polishing of metallographic specimens (e.g. diamond suspension)</rdfs:comment>
        <rdfs:label xml:lang="en">Suspension</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#System -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#System">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndependentContinuant"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">A system of equipment and devices for coating or processing.</rdfs:comment>
        <rdfs:comment xml:lang="de">Ein System von Ausstattungen und Geräten für die Beschichtung oder Verarbeitung.</rdfs:comment>
        <rdfs:label xml:lang="de">Anlage</rdfs:label>
        <rdfs:label xml:lang="en">System</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TaberAbraserTest -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TaberAbraserTest">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Test to determine the abrasion resistance of materials</rdfs:comment>
        <rdfs:comment xml:lang="de">Test zur Bestimmung der Abriebfestigkeit von Materialien</rdfs:comment>
        <rdfs:label xml:lang="en">Taber Abraser Test</rdfs:label>
        <rdfs:label xml:lang="de">Taber-Abraser-Test</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TaberAbraserWheel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TaberAbraserWheel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7784-2:2016-07; ASTM D4060-19; ASTM D1044-19</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Taber Abraser Wheel</rdfs:label>
        <rdfs:label xml:lang="de">Taber-Schleifscheibe</rdfs:label>
        <skos:definition xml:lang="de">Eine Taber-Schleifscheibe ist ein standardisiertes, austauschbares Abradier-Rad (Schleifscheibenpaar) für den Taber-Abriebprüfer, das mit definierter Zusammensetzung und Geometrie auf eine rotierende Probe wirkt. Ihr Hauptzweck ist die reproduzierbare Erzeugung eines definierten Abriebs zur Bewertung der Abriebfestigkeit von Beschichtungen (z. B. galvanische Überzüge) unter festgelegten Prüfbedingungen. Sie ist von allgemeinen Schleifscheiben dadurch abzugrenzen, dass sie als Prüfkörper für ein genormtes Abriebprüfverfahren spezifiziert ist (z. B. Radtypen wie CS-10, H-18).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TaberAbrasionTestingMaschine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TaberAbrasionTestingMaschine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>ASTM D4060-19, *Standard Test Method for Abrasion Resistance of Organic Coatings by the Taber Abraser*; ISO 7784-2:2016, *Paints and varnishes — Determination of resistance to abrasion — Part 2: Rotating abrasive rubber wheels method*</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Taber Abrasion Testing Maschine</rdfs:label>
        <rdfs:label xml:lang="de">Taber-Abriebanlage</rdfs:label>
        <skos:definition xml:lang="de">Eine Taber-Abriebanlage ist ein Prüfgerät zur Bestimmung der Abriebfestigkeit von Beschichtungen, bei dem eine Probe unter definierter Belastung durch rotierende Reibräder (abrasive wheels) beansprucht wird. Hauptzweck ist die vergleichende Bewertung des Verschleiß- bzw. Abriebverhaltens von galvanischen und anderen Beschichtungen unter reproduzierbaren Prüfbedingungen. Charakteristisch sind festgelegte Reibradtypen, Auflasten und Auswertekennwerte (z. B. Masseverlust oder Abriebindex) gemäß der jeweiligen Prüfnorm.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TaberWearIndex -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TaberWearIndex">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Resistance of a material to wear using a Taber Abraser test</rdfs:comment>
        <rdfs:comment xml:lang="de">Widerstand eines Materials gegen Abrieb unter Verwendung eines Taber-Abrasertests</rdfs:comment>
        <rdfs:label xml:lang="de">Taber Wear Index</rdfs:label>
        <rdfs:label xml:lang="en">Taber Wear Index</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Table -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Table">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoDimensionalFieldData"/>
        <rdfs:comment>Any kind of table</rdfs:comment>
        <rdfs:label xml:lang="en">Table</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TactileSurfaceRoughnessMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TactileSurfaceRoughnessMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceTopographyMeasurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 21920-1:2022-12; DIN EN ISO 21920-2:2022-12; DIN EN ISO 21920-3:2022-12; DIN EN ISO 3274:1998-04; DIN EN ISO 16610-21:2013-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Tactile Surface Roughness Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Taktile Oberflächenrauigkeitsmessung</rdfs:label>
        <skos:definition xml:lang="de">Eine taktile Oberflächenrauigkeitsmessung ist die Ermittlung von Rauheitskenngrößen einer Oberfläche durch mechanisches Abtasten mit einer Tastspitze, wobei ein Profil der Oberfläche entlang einer Messstrecke aufgezeichnet wird. Hauptzweck ist die normgerechte quantitative Bewertung der Oberflächenbeschaffenheit (z. B. Ra, Rz) zur Spezifikation, Prüfung und Prozessüberwachung. Sie ist von optischen (berührungslosen) Verfahren abzugrenzen und unterliegt u. a. Festlegungen zu Filterung, Messbedingungen und Tastspitzengeometrie.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tantalum -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tantalum">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Tantalum</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Technetium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Technetium">
