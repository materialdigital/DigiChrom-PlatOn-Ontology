    </owl:DatatypeProperty>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasStringLiteral -->

    <owl:DatatypeProperty rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasStringLiteral">
        <rdfs:subPropertyOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasValue"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasURILiteral -->

    <owl:DatatypeProperty rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasURILiteral">
        <rdfs:subPropertyOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasValue"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">hasURILiteral</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasUnitSymbol -->

    <owl:DatatypeProperty rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasUnitSymbol">
        <rdfs:subPropertyOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasStringLiteral"/>
        <rdfs:domain rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:creator xml:lang="en">christoph Schweizer</dc:creator>
        <rdfs:comment xml:lang="en">ubclass of hasUnitSymbol and assigns a unit symbol for the temperature which is assigned to some quantity</rdfs:comment>
