    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MountingOfTestPieceInTestingMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MountingOfTestPieceInTestingMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachinePreparation"/>
        <rdfs:comment>The process of mounting some kind of test piece in a testing machine</rdfs:comment>
        <rdfs:label xml:lang="en">MountingOfTestPieceInTestingMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MountingPress -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MountingPress">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2020-02, DIN EN ISO 9220:2020-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Einbettpresse</rdfs:label>
        <rdfs:label xml:lang="en">Mounting press</rdfs:label>
        <skos:definition xml:lang="de">Eine Einbettpresse ist ein Gerät zur Herstellung eingebetteter Probenkörper, indem eine Probe in ein Einbettmittel (typisch Duroplast/Thermoplast beim Warmeinbetten) unter definiertem Druck und meist erhöhter Temperatur verpresst wird. Hauptzweck ist die reproduzierbare Probenhandhabung für nachfolgende Präparationsschritte (Schleifen/Polieren) und die mikroskopische Untersuchung, z. B. zur Schichtdicken- oder Gefügebeurteilung galvanischer Überzüge. Abzugrenzen ist sie von Kalteinbettverfahren, bei denen das Einbettmittel ohne Pressen aushärtet und eine Presse nicht zwingend erforderlich ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MovementType -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MovementType">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 15730:2001-12 (Metallische und andere anorganische Überzüge — Elektrolytische Abscheidung von Nickel, Kupfer, Chrom und Kombinationen davon — Leitfaden für die Spezifikation und Prüfung); DIN EN ISO 10289:2000-12 (Metallische und andere anorganische Überzüge — Bewertung der Korrosionsprüfungsergebnisse von Überzügen auf metallischen Werkstoffen); DIN EN ISO 2081:2018-09 (Metallische und andere anorganische Überzüge — Galvanische Zinküberzüge mit zusätzlicher Behandlung auf Eisen oder Stahl)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Bewegungsart</rdfs:label>
        <rdfs:label xml:lang="en">Movement Type</rdfs:label>
        <skos:definition xml:lang="de">Eine Bewegungsart ist die festgelegte Art der Bewegung eines Werkstücks, Werkzeugs oder Mediums (z. B. linear, rotierend, oszillierend) während eines galvanotechnischen Prozess- oder Prüfschritts. Sie dient dazu, definierte Prozessbedingungen wie Stofftransport, Benetzung, Schichtgleichmäßigkeit oder reproduzierbare Prüfeinwirkungen sicherzustellen. Die Bewegungsart ist von der Bewegungsgröße (z. B. Geschwindigkeit, Hub, Frequenz) abzugrenzen, die die Intensität der Bewegung beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Identifier"/>
        <rdfs:label xml:lang="en">Name</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Nanoindentation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Nanoindentation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Method for measuring hardness at the nanoscale</rdfs:comment>
        <rdfs:comment xml:lang="de">Verfahren zur Messung der Härte auf nanoskaliger Ebene</rdfs:comment>
        <rdfs:label xml:lang="en">Nanoindentation</rdfs:label>
        <rdfs:label xml:lang="de">Nanoindentierung </rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Nanoindenter -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Nanoindenter">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 14577-1:2015-11, DIN EN ISO 14577-2:2015-11, DIN EN ISO 14577-3:2015-11, DIN EN ISO 14577-4:2016-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Nanoindenter</rdfs:label>
        <rdfs:label xml:lang="en">Nanoindenter</rdfs:label>
        <skos:definition xml:lang="de">Ein Nanoindenter ist ein Prüfgerät zur instrumentierten Eindringprüfung, das mit sehr kleinen Prüfkörpern und Kräften das Eindringen in eine Oberfläche misst und dabei Kraft- und Eindringtiefe kontinuierlich aufzeichnet. Hauptzweck ist die Bestimmung mechanischer Kennwerte (z. B. Eindringhärte und Eindringmodul) insbesondere dünner Schichten und oberflächennaher Bereiche, wie sie in der Galvanotechnik häufig auftreten. Charakteristisch ist die hohe Auflösung im Kraft- und Wegmesssystem sowie die Auswertung nach dem Verfahren der instrumentierten Eindringprüfung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


