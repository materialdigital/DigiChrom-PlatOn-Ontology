        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Role"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">Disposition</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Documenting -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Documenting">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CognitiveProcess"/>
        <rdfs:label xml:lang="en">Documenting</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Drag-In -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Drag-In">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">eingeschleppte Lösung
Flüssigkeit, die mit den zu behandelnden Gegen- ständen in eine Lösung eingeschleppt wird</rdfs:comment>
        <rdfs:comment xml:lang="en">liquid carried into a solution by the objects introduced therein</rdfs:comment>
        <rdfs:label xml:lang="en">Drag-In</rdfs:label>
        <rdfs:label xml:lang="de">Einschleppen</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Drag-Out -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Drag-Out">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">ausgeschleppte Lösung. Flüssigkeit, die mit den zu behandelnden Gegenständen aus einer Lösung ausgeschleppt wird.</rdfs:comment>
        <rdfs:comment xml:lang="en">liquid carried out of a solution by the objects removed therefrom</rdfs:comment>
        <rdfs:label xml:lang="de">Ausschleppen</rdfs:label>
        <rdfs:label xml:lang="en">Drag-Out</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DrilledHole -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DrilledHole">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProductRelatedSite"/>
        <rdfs:comment>A drilled hole in a technological product.</rdfs:comment>
        <rdfs:label xml:lang="en">DrilledHole</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Drying -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Drying">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Verfahren, um Wasser und/oder Lösungsmittel vom Überzug zu entfernen, entweder bei Raumtempe- ratur oder durch Erwärmen</rdfs:comment>
        <rdfs:comment xml:lang="en">process eliminating either water or solvent, or both, from the coating, either at room temperature or by heating</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4042:2020-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Drying</rdfs:label>
        <rdfs:label xml:lang="de">Trocknung</rdfs:label>
        <skos:definition xml:lang="de">Trocknung ist ein Prozessschritt nach dem Spülen oder nach der Beschichtung, bei dem Wasser bzw. flüchtige Medien von der Oberfläche eines Werkstücks entfernt werden, z. B. durch Warmluft, Ofen, Vakuum oder Zentrifugieren. Hauptzweck ist es, Wasserflecken, Korrosionsansatz und Beeinträchtigungen nachfolgender Prozessschritte (z. B. Passivieren, Lackieren, Verpacken) zu vermeiden. Je nach Verfahren und Werkstoff kann Trocknung mit definierten Bedingungen (Temperatur/Zeit) als Teil der Prozessführung festgelegt sein.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DryingDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DryingDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 11134:1996-12; VDI 2083 Blatt 1:2005-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Drying Device</rdfs:label>
        <rdfs:label xml:lang="de">Trocknungsgerät</rdfs:label>
        <skos:definition xml:lang="de">Ein Trocknungsgerät ist eine technische Einrichtung, die Werkstücke oder Schichten nach Vorbehandlungs-, Beschichtungs- oder Spülprozessen durch Wärmeeintrag und/oder Luftführung von anhaftender Feuchtigkeit befreit. Hauptzweck ist das definierte und reproduzierbare Trocknen zur Vermeidung von Flecken, Korrosion oder Beeinträchtigungen nachfolgender Prozessschritte (z. B. Passivieren, Lackieren, Verpacken). Je nach Ausführung erfolgt die Trocknung z. B. konvektiv (Warmluft), durch Strahlung (IR) oder unter vermindertem Druck (Vakuum).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ductility -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ductility">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Fähigkeit eines Überzugs oder eines Materials, sich plastisch zu verformen, ohne zu brechen</rdfs:comment>
        <rdfs:comment xml:lang="en">ability of a coating or a material to deform plastically without fracture</rdfs:comment>
        <rdfs:label xml:lang="en">Ductility</rdfs:label>
        <rdfs:label xml:lang="de">Duktilität</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DullFinish -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DullFinish">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialStructureInfo"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Veredlung , die im Wesentlichen weder diffusen Glanz noch Spiegelglanz aufweist</rdfs:comment>
        <rdfs:comment xml:lang="en">finish  essentially lacking both diffuse and specular reflectance</rdfs:comment>
        <rdfs:label xml:lang="en">Dull Finish</rdfs:label>
        <rdfs:label xml:lang="de">Mattbeschichtung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DutyCycle -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DutyCycle">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 60050-551 (IEC 60050-551):2016-05, International Electrotechnical Vocabulary (IEV) – Part 551: Power electronics (Begriffe zu periodischen Signalen/Einschaltdauer, duty cycle); ASM Handbook, Volume 5: Surface Engineering, ASM International, 1994 (Abschnitte zu pulse plating und duty cycle)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Duty Cycle</rdfs:label>
        <rdfs:label xml:lang="de">Einschaltdauer</rdfs:label>
        <skos:definition xml:lang="de">Das Einschaltdauer-Verhältnis ist das Verhältnis der Einschaltzeit eines periodischen Strom- oder Spannungssignals zur Periodendauer (bzw. zur Summe aus Ein- und Ausschaltzeit) und wird häufig als dimensionslose Größe oder in Prozent angegeben. In der Galvanotechnik dient es zur Charakterisierung von Puls-/Impulsstromprozessen und beeinflusst u. a. mittlere Stromdichte, Abscheiderate und Schichteigenschaften. Es ist abzugrenzen vom Tastverhältnis als Verhältnis Einzeit zu Auszeit (Ton/Toff), das je nach Quelle alternativ verwendet wird.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Dysprosium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Dysprosium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Dysprosium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EBSDDetector -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EBSDDetector">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroscopeEquipment"/>
        <rdfs:comment>An EBSD (electron backscatter diffraction) detector for the SEM</rdfs:comment>
        <rdfs:label xml:lang="en">EBSDDetector</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElasticConstant -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElasticConstant">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalQuantity"/>
        <rdfs:label xml:lang="en">ElasticConstant</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricCharge -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricCharge">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">ElectricCharge</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricCurrent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricCurrent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseQuantityKind"/>
        <rdfs:label xml:lang="en">ElectricCurrent</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricCurrentErodingWire -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricCurrentErodingWire">
