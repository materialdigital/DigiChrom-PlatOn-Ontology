    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroscopeEquipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <rdfs:comment>Microscope related equipment as microscopes and accessories</rdfs:comment>
        <rdfs:label xml:lang="en">MicroscopeEquipment</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Microscopy -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Microscopy">
