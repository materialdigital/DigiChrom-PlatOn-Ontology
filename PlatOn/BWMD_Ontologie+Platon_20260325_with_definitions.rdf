        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:comment>Part of an object, which can be identified, even though there is no break in physical continuity (e.g. nose in the face).</rdfs:comment>
        <rdfs:label xml:lang="en">FiatObjectPart</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FiatObjectPartName -->

