        <dc:creator xml:lang="en">Christoph Schweizer</dc:creator>
        <rdfs:comment xml:lang="en">subclass of hasDoubleValue and assigns a temperature to some quantity (e.g. Rp02 measured at a certain temperature)</rdfs:comment>
        <rdfs:label xml:lang="en">applies For Temperature Value</rdfs:label>
    </owl:DatatypeProperty>
    


