    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NodularStructure -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NodularStructure">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9587:2007-03; DIN EN ISO 1463:2021-08; DIN EN ISO 2178:2016-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Knötchenstruktur</rdfs:label>
        <rdfs:label xml:lang="en">Nodular structure</rdfs:label>
        <skos:definition xml:lang="de">Eine Knötchenstruktur ist eine lokale, knoten- bzw. noppenartige Erhebung in oder auf einem galvanisch abgeschiedenen Überzug, die als Oberflächenunregelmäßigkeit/Schichtfehler auftritt. Sie dient in der Qualitätsbewertung als Merkmal für eine unerwünschte Rauheits- und Dickeninhomogenität, die Funktionseigenschaften (z. B. Korrosionsschutz, Reibung, optisches Erscheinungsbild) beeinträchtigen kann. Abzugrenzen ist sie von porenartigen Fehlstellen (Vertiefungen) sowie von welligen Makroprofilen, da Knötchen punktförmig erhabene Strukturen darstellen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


