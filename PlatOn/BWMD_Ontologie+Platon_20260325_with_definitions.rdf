    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasionCycles -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasionCycles">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 5470-1:2017-02; DIN EN ISO 7784-2:2016-07; DIN EN ISO 9352:2012-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Abrasion Cycles</rdfs:label>
        <rdfs:label xml:lang="de">Abriebzyklen</rdfs:label>
        <skos:definition xml:lang="de">Abriebzyklen sind die Anzahl wiederholter, normativ festgelegter Abriebbewegungen (z. B. Hin- und Herbewegungen oder Umdrehungen) in einer Abriebprüfung. Sie dienen als Maß für die Beanspruchungsdauer bzw. -intensität, bis ein definiertes Abbruchkriterium (z. B. Durchscheuern, Masseverlust, Schichtdurchbruch) erreicht ist. Die genaue Definition eines „Zyklus“ (Bewegungsablauf, Weg, Frequenz, Last) ist jeweils in der angewendeten Prüfnorm festgelegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasionResistanceMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasionResistanceMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7784-2:2016-06; ASTM D4060-19 (Reapproved 2024)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Abrasion resistance measurement</rdfs:label>
        <rdfs:label xml:lang="de">Abriebswiderstandsmessung</rdfs:label>
        <skos:definition xml:lang="de">Eine Abriebswiderstandsmessung ist die Bestimmung des Widerstands einer Oberfläche bzw. Beschichtung gegen Materialabtrag durch definierten mechanischen Abrieb unter festgelegten Prüfbedingungen. Hauptzweck ist die quantitative Bewertung der Verschleißbeständigkeit von Beschichtungen (z. B. galvanischen Überzügen) zur Spezifikations- und Qualitätsprüfung. Die Ergebnisse werden verfahrensabhängig z. B. als Masseverlust, Dickenabtrag oder Abriebindex angegeben und sind nur innerhalb des jeweils normierten Prüfverfahrens vergleichbar.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasionTester -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasionTester">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7784-2:2016-11; DIN EN ISO 5470-1:2017-03; DIN EN ISO 9352:2012-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Abrasion Tester</rdfs:label>
        <rdfs:label xml:lang="de">Abriebstester</rdfs:label>
        <skos:definition xml:lang="de">Ein Abriebstester ist ein Prüfgerät zur Durchführung standardisierter Abriebprüfungen, bei denen die Widerstandsfähigkeit einer Oberfläche oder Beschichtung gegen mechanischen Verschleiß durch Reibkontakt unter definierten Bedingungen ermittelt wird. Hauptzweck ist die vergleichende Bewertung der Abriebfestigkeit (z. B. von galvanischen Überzügen, Lacken oder Kunststoffen) anhand festgelegter Prüfparameter wie Last, Abrasivmittel, Bewegungsart und Prüfzyklen. Je nach Norm sind Bauart und Ergebnisgrößen (z. B. Masseverlust, Durchscheuern, Trübung) festgelegt, wodurch unterschiedliche Abriebstester nicht ohne Bezug auf das jeweilige Verfahren vergleichbar sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasiveWheel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasiveWheel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 12413:2019-10 (Sicherheit von gebundenen Schleifkörpern), DIN EN 13236:2019-06 (Sicherheit von Superabrasive-Produkten), ISO 525:2013 (Bonded abrasive products — General requirements)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Abrasive Wheel</rdfs:label>
        <rdfs:label xml:lang="de">Reibrad</rdfs:label>
        <skos:definition xml:lang="de">Ein Schleifrad ist ein rotierender, gebundener Schleifkörper (Schleifwerkzeug), der aus Schleifkorn und Bindung besteht und zum spanenden Abtragen von Werkstoff durch Schleifen eingesetzt wird. Hauptzweck ist das Erzeugen definierter Oberflächen und Maße durch kontrollierten Materialabtrag, z. B. zur Vor- oder Nachbehandlung von Bauteilen vor galvanischen Beschichtungen. Es ist von Schleifscheiben aus beschichteten Schleifmitteln (z. B. Schleifpapier/-gewebe) abzugrenzen, da das Schleifrad als gebundener Schleifkörper eine eigenständige, formstabile Werkzeuggeometrie besitzt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Acceleration -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Acceleration">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Erhöhung derGeschwindigkeit eines Beschichtungsprozesses durch den Einsatz von chemischen Zusatzstoffen </rdfs:comment>
        <rdfs:comment xml:lang="en">increase of the rate of a coating process by the use of chemical additives</rdfs:comment>
        <rdfs:label xml:lang="en">Acceleration</rdfs:label>
        <rdfs:label xml:lang="de">Beschleunigung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AccelerationVoltage -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AccelerationVoltage">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 22309:2011-12 (Mikrostrahlanalyse — Quantitative Analyse mittels energiedispersiver Röntgenspektrometrie (EDS) für die Elektronenstrahlanregung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Acceleration voltage</rdfs:label>
        <rdfs:label xml:lang="de">Beschleunigungsspannung</rdfs:label>
        <skos:definition xml:lang="de">Die Beschleunigungsspannung ist die elektrische Spannung, mit der geladene Teilchen (insbesondere Elektronen) in einer Elektronenquelle bzw. Elektronenoptik beschleunigt werden. Sie bestimmt maßgeblich die kinetische Energie der Elektronen und damit z. B. Eindringtiefe und Anregungsvolumen bei elektronenstrahlbasierten Analysen von galvanischen Schichten. In der Galvanotechnik tritt sie typischerweise als Mess-/Prüfparameter bei der Schicht- und Werkstoffcharakterisierung (z. B. REM/EDX) auf, nicht als Prozessparameter der Abscheidung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AcquisitionTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AcquisitionTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/IEC 17025:2018-03; DIN EN ISO 9000:2015-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Acquisition time</rdfs:label>
        <rdfs:label xml:lang="de">Erfassungszeit</rdfs:label>
        <skos:definition xml:lang="de">Erfassungszeit ist die Zeitspanne bzw. der Zeitpunktbezug, der angibt, wann oder über welchen Zeitraum Mess-, Prozess- oder Qualitätsdaten in einem galvanotechnischen Prozess erfasst und aufgezeichnet werden. Hauptzweck ist die eindeutige zeitliche Zuordnung von Prozessparametern (z. B. Strom, Spannung, Temperatur, pH-Wert) und Prüfergebnissen zur Sicherstellung von Rückverfolgbarkeit und Vergleichbarkeit. Abzugrenzen ist sie von der Ansprechzeit eines Messgeräts (dynamisches Verhalten) und von der Integrationszeit (zeitliche Mittelung eines Messsignals).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Activation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Activation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2003-11; DIN EN ISO 12686:2011-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Activation</rdfs:label>
        <rdfs:label xml:lang="de">Aktivierung</rdfs:label>
        <skos:definition xml:lang="de">Aktivierung ist ein Vorbehandlungsschritt, bei dem eine Werkstückoberfläche durch chemische oder elektrochemische Behandlung in einen reaktionsfähigen Zustand überführt wird (z. B. durch Entfernen passiver Schichten oder Erzeugen katalytisch aktiver Zentren). Hauptzweck ist die Sicherstellung einer zuverlässigen Initiierung nachfolgender Prozesse wie stromloser Abscheidung, galvanischer Abscheidung oder Konversionsbehandlung durch Verbesserung von Benetzbarkeit, Keimbildung und Haftung. Je nach Substrat und Verfahren umfasst Aktivierung z. B. Beizen/Entoxidieren, Aktivieren von Edelstahl vor dem Beschichten oder Pd/Sn-Aktivierung im Kontext stromloser Metallabscheidung auf Nichtleitern.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ActivationAgent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ActivationAgent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2003-11; DIN EN ISO 9587:2007-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Activation Agent</rdfs:label>
        <rdfs:label xml:lang="de">Aktivierungsmittel</rdfs:label>
        <skos:definition xml:lang="de">Ein Aktivierungsmittel ist ein chemisches Mittel, das eine Werkstückoberfläche unmittelbar vor einem nachfolgenden Prozessschritt (z. B. Beizen, galvanische Abscheidung, stromlose Abscheidung) in einen reaktionsfähigen, „aktiven“ Zustand überführt. Hauptzweck ist das Entfernen bzw. Umwandeln passivierender Schichten (z. B. Oxide) oder das Erzeugen katalytisch aktiver Zentren, um Benetzung, Haftung und Prozesssicherheit der nachfolgenden Beschichtung zu gewährleisten. Aktivierungsmittel sind von Reinigern/Entfettern abzugrenzen, da sie primär die chemische Reaktivität der Oberfläche einstellen und nicht die Entfernung organischer Verunreinigungen zum Ziel haben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ActivationProcess -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ActivationProcess">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Eliminierung eines passiven Oberflächenzustands</rdfs:comment>
        <rdfs:comment xml:lang="en">elimination of a passive surface condition</rdfs:comment>
        <rdfs:label xml:lang="en">Activation Process</rdfs:label>
        <rdfs:label xml:lang="de">Aktivierung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ActuatorEquipment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ActuatorEquipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <rdfs:label xml:lang="en">ActuatorEquipment</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdditionAgent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdditionAgent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Substanz, die üblicherweise in geringen Mengen einer Lösung zugesetzt wird, um die charakteristischen Merkmale der Lösung oder die Eigenschaften des aus der Lösung abgeschiedenen Niederschlags zu verändern</rdfs:comment>
        <rdfs:comment xml:lang="en">substance added to a solution, usually in small amounts, to modify the characteristics of the solution or the properties of the deposit obtained from the solution</rdfs:comment>
        <rdfs:label xml:lang="en">Addition Agent</rdfs:label>
        <rdfs:label xml:lang="de">Zusatzstoff</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Adhesion-BendingTest -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Adhesion-BendingTest">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Test to determine adhesion under bending stress</rdfs:comment>
        <rdfs:comment xml:lang="de">Test zur Bestimmung der Haftung unter Biegebeanspruchung</rdfs:comment>
        <rdfs:label xml:lang="en">Adhesion - Bending Test</rdfs:label>
        <rdfs:label xml:lang="de">Haftung - Biegetest</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Adhesion-ThermalShockTest -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Adhesion-ThermalShockTest">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Test to determine adhesion under thermal shock</rdfs:comment>
        <rdfs:comment xml:lang="de">Test zur Bestimmung der Haftung unter thermischen Schocks</rdfs:comment>
        <rdfs:label xml:lang="en">Adhesion - Thermal Shock Test</rdfs:label>
        <rdfs:label xml:lang="de">Haftung - Thermoschocktest</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdhesionForce -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdhesionForce">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Kraft, die erforderlich ist, um verschiedene Schichten eines Überzugs oder einen Überzug von seinem Substrat  zu trennen, bezogen auf die Fläche der entsprechenden Oberfläche</rdfs:comment>
        <rdfs:comment xml:lang="en">amount of force required to separate different layers of a coating, or a coating from its substrate and the area of the corresponding surface</rdfs:comment>
        <rdfs:label xml:lang="en">Adhesion Force</rdfs:label>
        <rdfs:label xml:lang="de">Haftfestigkeit</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdhesionMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdhesionMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2409:2020-12; DIN EN ISO 4624:2016-08; DIN EN ISO 2819:2017-02; DIN EN ISO 2064:2021-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Adhesion Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Haftfestigkeitsmessung</rdfs:label>
        <skos:definition xml:lang="de">Eine Haftfestigkeitsmessung ist eine Prüfung zur Bestimmung der Haftfestigkeit (Adhäsion) eines aufgebrachten Überzugs gegenüber dem Grundwerkstoff durch ein definiertes mechanisches Beanspruchungs- und Bewertungsverfahren. Hauptzweck ist der Nachweis, dass der Überzug unter festgelegten Prüfbedingungen nicht unzulässig abblättert, sich ablöst oder versagt. Je nach Überzugsart und Anwendung werden unterschiedliche Verfahren (z. B. Gitterschnitt, Abreißprüfung, Biege-/Verformungsprüfung) eingesetzt, die jeweils spezifische Akzeptanzkriterien und Auswertearten vorgeben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdhesionMeasurement2 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdhesionMeasurement2">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2819:2018-02; DIN EN ISO 2409:2020-08; DIN EN ISO 4624:2016-08; DIN EN ISO 9227:2023-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Adhesion Measurement2</rdfs:label>
        <rdfs:label xml:lang="de">Haftfestigkeitsmessung 2</rdfs:label>
        <skos:definition xml:lang="de">Eine Haftfestigkeitsmessung ist eine Prüfung zur Bestimmung der Haftfestigkeit (Adhäsion) eines metallischen oder anorganischen Überzugs gegenüber dem Grundwerkstoff durch definierte mechanische Beanspruchung und anschließende Bewertung von Ablösung/Abplatzung. Hauptzweck ist die Verifizierung, dass der Überzug unter den vorgesehenen Einsatz- und Belastungsbedingungen ausreichend fest am Substrat haftet. „Haftfestigkeitsmessung 2“ ist als Bezeichnung ohne zusätzliche Spezifikation nicht eindeutig und sollte in der Ontologie als Variante eines normativen Haftfestigkeitsprüfverfahrens (z. B. Gitterschnitt, Abreißprüfung, Biege-/Thermoschockprüfung) mit konkret referenzierter Prüfnorm instanziiert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdhesionTest -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AdhesionTest">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Test to determine the adhesion between materials</rdfs:comment>
        <rdfs:comment xml:lang="de">Test zur Bestimmung der Haftung zwischen Materialien</rdfs:comment>
        <rdfs:label xml:lang="en">Adhesion Test</rdfs:label>
        <rdfs:label xml:lang="de">Haftprüfung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AgitationStrength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AgitationStrength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; ISO 15726:2018; Schlesinger, M.; Paunovic, M. (Hrsg.): *Modern Electroplating*, 5th ed., Wiley, 2010.</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Agitation Strength</rdfs:label>
        <rdfs:label xml:lang="de">Rührintensität</rdfs:label>
        <skos:definition xml:lang="de">Rührintensität ist das Maß für die Stärke der Badbewegung (Agitation) in einem galvanischen Elektrolyten, hervorgerufen z. B. durch Rühren, Umwälzen oder Luftbewegung. Ihr Hauptzweck ist die Beeinflussung des Stofftransports an der Kathoden-/Anodenoberfläche (Grenzschichtdicke) und damit die Stabilisierung von Abscheiderate, Schichtgleichmäßigkeit und Prozesssicherheit. Sie ist von der reinen Rührart (z. B. mechanisch, Luft, Pumpenumwälzung) zu unterscheiden und wird praxisnah über strömungs- bzw. umwälzbezogene Kenngrößen beschrieben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AgitationSystem -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AgitationSystem">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <dc:creator xml:lang="en">Elena G. Trelles</dc:creator>
        <rdfs:comment xml:lang="en">Mechanical or air agitation systems to ensure uniform distribution of the plating solution.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 1456:2024-01; DIN EN ISO 2081:2018-09; ISO 15726:2022-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Agitation System</rdfs:label>
        <skos:definition xml:lang="de">Ein Rührsystem ist eine technische Einrichtung zur gezielten Bewegung eines Elektrolyten in einem galvanischen Bad (z. B. durch mechanisches Rühren, Umwälzen oder Strömungserzeugung). Hauptzweck ist die Verbesserung des Stofftransports (z. B. Metallionen, Additive) und der Homogenität von Konzentration und Temperatur, um gleichmäßige Abscheidung und reproduzierbare Schichteigenschaften zu unterstützen. Es ist von reiner Badfiltration abzugrenzen, da Filtration primär Partikel entfernt, während das Rührsystem die Strömungs- und Transportverhältnisse im Bad beeinflusst.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AgitationType -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AgitationType">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>ASM Handbook, Volume 5: Surface Engineering, ASM International, 1994 (Abschnitte zu Electroplating – Agitation/solution movement); Schlesinger, M.; Paunovic, M. (Hrsg.): Modern Electroplating, 5th Edition, John Wiley &amp; Sons, 2010 (Kapitel zu Mass Transport/Agitation in plating baths)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Agitation Type</rdfs:label>
        <rdfs:label xml:lang="de">Rührart</rdfs:label>
        <skos:definition xml:lang="de">Eine Rührart ist die festgelegte Art und Weise, wie ein galvanotechnisches Bad zur Erzeugung von Strömung und Stofftransport bewegt bzw. umgewälzt wird (z. B. mechanisches Rühren, Pumpenumwälzung, Luft-/Gasrühren, Bewegung von Ware oder Gestell). Hauptzweck ist die Beeinflussung von Schichtbildung und Prozessstabilität durch verbesserten Wärme- und Stofftransport sowie homogenere Konzentrations- und Temperaturverteilung im Bad. Die Rührart ist von der Rührintensität (z. B. Strömungsgeschwindigkeit/Volumenstrom) zu unterscheiden und wird als Prozessparameter festgelegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AirDryer -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AirDryer">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8573-1:2010-04; DIN EN ISO 8573-3:2019-03; DIN EN ISO 8573-4:2019-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Air Dryer</rdfs:label>
        <rdfs:label xml:lang="de">Lufttrockner</rdfs:label>
        <skos:definition xml:lang="de">Ein Lufttrockner ist ein Gerät zur Absenkung des Feuchtegehalts von Luft, insbesondere von Druckluft, durch physikalische oder chemische Trocknungsverfahren (z. B. Kälte-, Adsorptions- oder Membrantrocknung). Hauptzweck ist die Bereitstellung trockener Luft zur Vermeidung von Kondensat, Korrosion und prozessbedingten Störungen in Anlagen, z. B. bei pneumatischen Komponenten oder beim Abblasen/Trocknen von Werkstücken. In der Anwendung ist der geforderte Trocknungsgrad häufig über den Drucktaupunkt spezifiziert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AirDrying -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AirDrying">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6270-1:2018-07; DIN EN ISO 1513:2010-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Air Drying</rdfs:label>
        <rdfs:label xml:lang="de">Lufttrocknung</rdfs:label>
        <skos:definition xml:lang="de">Lufttrocknung ist das Trocknen einer Oberfläche oder eines beschichteten/gespülten Werkstücks durch Einwirkung von Umgebungsluft oder einem Luftstrom ohne direkte Wärmezufuhr durch ein separates Heizmedium. Hauptzweck ist das Entfernen von anhaftendem Wasser/Spülflüssigkeit nach Vorbehandlung oder Beschichtung, um Flecken, Korrosion oder Beeinflussung nachfolgender Prüfungen/Prozesse zu vermeiden. Abzugrenzen ist sie von Warmlufttrocknung/Ofentrocknung (gezielte Erwärmung) und Vakuumtrocknung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AirInjectionFlowRate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AirInjectionFlowRate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Durchflussrate der Luftinjektion</rdfs:comment>
        <rdfs:comment xml:lang="en">Flow rate of air injection</rdfs:comment>
        <rdfs:label xml:lang="en">Air Injection Flow Rate</rdfs:label>
        <rdfs:label xml:lang="de">Lufteinblasung Durchflussmenge</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AlkalineCleaning -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AlkalineCleaning">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalCleaning"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Reinigung mithilfe von alkalischen Lösungen</rdfs:comment>
        <rdfs:comment xml:lang="en">cleaning by means of alkaline solutions</rdfs:comment>
        <rdfs:label xml:lang="en">Alkaline Cleaning</rdfs:label>
        <rdfs:label xml:lang="de">alkalische Reinigung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Aluminium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Aluminium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Aluminium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AluminiumAlloy -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AluminiumAlloy">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AluminiumMaterial"/>
        <rdfs:comment>Any kind of aluminium alloy</rdfs:comment>
        <rdfs:label xml:lang="en">AluminiumAlloy</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AluminiumMaterial -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AluminiumMaterial">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonFerrousMaterial"/>
        <rdfs:comment>Any kind of aluminium material (e.g. an alloy or high purity aluminium)</rdfs:comment>
        <rdfs:label xml:lang="en">AluminiumMaterial</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AmbientRelativeHumidity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AmbientRelativeHumidity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 15927-1:2020-03, DIN EN ISO 9223:2012-12, DIN EN ISO 9225:2012-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Ambient Relative Humidity</rdfs:label>
        <rdfs:label xml:lang="de">Relative Luftfeuchtigkeit</rdfs:label>
        <skos:definition xml:lang="de">Die relative Luftfeuchtigkeit ist das Verhältnis des aktuellen Wasserdampf-Partialdrucks (bzw. der aktuellen Wasserdampfmenge) in der Luft zum Sättigungswasserdampf-Partialdruck bei gleicher Temperatur, angegeben in Prozent. Sie dient zur quantitativen Beschreibung des Feuchtezustands der Umgebungsluft und ist eine wesentliche Umgebungsbedingung für Korrosions- und Beschichtungsprozesse (z. B. bei Lagerung, Vorbehandlung und Trocknung). Sie ist temperaturabhängig und daher stets zusammen mit der Lufttemperatur anzugeben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AmbientTemperature -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AmbientTemperature">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-1:2022-09; DIN EN 60721-3-3:2020-06 (IEC 60721-3-3:2019)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Ambient Temperature</rdfs:label>
        <rdfs:label xml:lang="de">Umgebungstemperatur</rdfs:label>
        <skos:definition xml:lang="de">Umgebungstemperatur ist die Temperatur der umgebenden Luft bzw. des umgebenden Mediums am Ort eines Gegenstands oder Prozesses, festgelegt für definierte Umgebungsbedingungen. Sie dient als Bezugsgröße zur Spezifikation, Prüfung und Vergleichbarkeit von Prozess- und Produkteigenschaften (z. B. bei Messungen, Prüfungen oder Lager-/Betriebsbedingungen in der Galvanotechnik). Sie ist von der Objekt-, Bad- oder Werkstücktemperatur abzugrenzen, die sich aufgrund von Prozesswärme oder Wärmeaustausch unterscheiden kann.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ammonium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ammonium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="de">Ammoniak</rdfs:label>
        <rdfs:label xml:lang="en">Ammonium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Amount -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Amount">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:label xml:lang="en">Amount</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AmountOfSubstance -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AmountOfSubstance">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseQuantityKind"/>
        <rdfs:label xml:lang="en">AmountOfSubstance</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyseNumber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyseNumber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/IEC 17025:2018-03; DIN EN ISO 9001:2015-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Analyse Number</rdfs:label>
        <rdfs:label xml:lang="de">Analysennummer</rdfs:label>
        <skos:definition xml:lang="de">Eine Analysennummer ist eine eindeutige Kennzeichnung (Identifikationsnummer) zur Zuordnung einer chemischen/analytischen Untersuchung zu einer konkreten Probe, einem Auftrag oder einem Prüfdatensatz. Sie dient der eindeutigen Identifikation und Rückverfolgbarkeit von Analysenergebnissen in Dokumentation, Prüfbericht und Qualitätssicherung. Sie ist von der Probenahmenummer bzw. Probenkennzeichnung abzugrenzen, kann aber in Labor- und QS-Systemen mit diesen verknüpft sein.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Analysing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Analysing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CognitiveProcess"/>
        <rdfs:label xml:lang="en">Analysing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalysisID -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalysisID">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="de">Analysen ID</rdfs:label>
        <rdfs:label xml:lang="en">Analysis ID</rdfs:label>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalysisOfResultingSpectraAndComparisonWithReferenceSpectra -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalysisOfResultingSpectraAndComparisonWithReferenceSpectra">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Spectroscopy"/>
        <rdfs:comment>The process of analysing the resulting spectra from some kind of spectroscopy process and comparing them to reference spectra (e.g. in a LIBS process)</rdfs:comment>
        <rdfs:label xml:lang="en">AnalysisOfResultingSpectraAndComparisonWithReferenceSpectra</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalysisSoftware -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalysisSoftware">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Software"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/IEC 2382:2015-12; DIN EN ISO/IEC 25010:2023-11; DIN EN ISO/IEC 17025:2018-03; DIN EN ISO 15189:2023-12; DIN EN ISO 16175-1:2020-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Analysesoftware</rdfs:label>
        <rdfs:label xml:lang="en">Analysis software</rdfs:label>
        <skos:definition xml:lang="de">Analysesoftware ist Software, die Mess-, Prüf- oder Prozessdaten erfasst, verarbeitet und auswertet, um daraus Ergebnisse, Kennwerte oder Berichte abzuleiten. Hauptzweck ist die rechnergestützte Auswertung und Dokumentation von Analysen (z. B. chemische Analytik von Elektrolyten, Schichtdickenmessung, Prozessüberwachung) einschließlich Nachvollziehbarkeit der Datenverarbeitung. Sie ist von Steuerungssoftware abzugrenzen, die primär der direkten Prozessführung dient, auch wenn beide in einem System kombiniert sein können.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 1319-1:1995-05; DIN EN ISO/IEC 17025:2018-03; DIN EN ISO 3696:1995-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Analysegerät</rdfs:label>
        <rdfs:label xml:lang="en">Analytic Device</rdfs:label>
        <skos:definition xml:lang="de">Ein Analysegerät ist ein Mess- bzw. Prüfgerät zur qualitativen und/oder quantitativen Bestimmung von Stoffen, Stoffkonzentrationen oder Stoffeigenschaften in Proben (z. B. Elektrolyten, Spülwässern) im Rahmen der galvanotechnischen Prozessüberwachung. Hauptzweck ist die Bereitstellung verlässlicher Analysedaten zur Badführung, Qualitätssicherung und Einhaltung von Prozess- und Umweltanforderungen. Der Begriff ist als Oberklasse zu verstehen und umfasst unterschiedliche Messprinzipien (z. B. elektrochemisch, photometrisch, spektrometrisch) sowie Labor- und Inline/Atline-Systeme.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Analytic Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Analytische Messung</rdfs:label>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticMeasurement1 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticMeasurement1">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/IEC 17025:2018-03; DIN EN ISO 18113-1:2011-12; DIN 1319-1:1995-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Analytic Measurement1</rdfs:label>
        <rdfs:label xml:lang="de">Analytische Messung 1</rdfs:label>
        <skos:definition xml:lang="de">Eine analytische Messung ist eine Messung zur quantitativen oder qualitativen Bestimmung der Zusammensetzung bzw. des Gehalts eines Analyten in einer Probe mittels eines festgelegten Messverfahrens. Hauptzweck ist die Gewinnung metrologisch bewertbarer Ergebnisse (z. B. mit definierter Messunsicherheit) zur Prozessüberwachung, Badführung oder Qualitätsprüfung in der Galvanotechnik. Sie ist von rein indikativem Prüfen dadurch abgegrenzt, dass Messgröße, Verfahren, Kalibrierung und Auswertung so festgelegt sind, dass ein nachvollziehbares Messergebnis entsteht.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticMeasurement2 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticMeasurement2">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Analytic Measurement2</rdfs:label>
        <rdfs:label xml:lang="de">Analytische Messung 2</rdfs:label>
        <skos:definition xml:lang="de">Eine analytische Messung ist die Durchführung einer Messung zur qualitativen oder quantitativen Bestimmung der Zusammensetzung bzw. Konzentration von Stoffen in einer Probe (z. B. Elektrolyt, Spülwasser, Schichtmaterial). Hauptzweck ist die Überwachung und Steuerung von Prozessbädern und -bedingungen in der Galvanotechnik durch verlässliche Analysenergebnisse. Die Bezeichnung „Analytische Messung 2“ ist als Klassenname ohne zusätzliche Spezifikation (z. B. Messgröße, Verfahren, Probe, Normmethode) nicht eindeutig und sollte für eine Ontologie durch eine präzisere Benennung ersetzt oder mit Attributen ergänzt werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticMeasurement3 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticMeasurement3">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Analytic Measurement3</rdfs:label>
        <rdfs:label xml:lang="de">Analytische Messung 3</rdfs:label>
        <skos:definition xml:lang="de">Eine analytische Messung ist eine Messung zur quantitativen oder qualitativen Bestimmung einer chemischen oder physikalisch-chemischen Größe (z. B. Stoffmengenkonzentration, Massenkonzentration, pH-Wert) in einer Probe, typischerweise im Rahmen der Prozess- oder Badüberwachung. Hauptzweck ist die Bereitstellung rückführbarer, dokumentierter Messergebnisse zur Steuerung und Sicherung der Prozessbedingungen in galvanotechnischen Elektrolyten und Spülwässern. Die Angabe „3“ ist ohne zusätzliche Kontextinformation keine normativ definierte Klassifizierung und sollte in einer Ontologie nur als interne Stufe/Variante modelliert werden, sofern sie betrieblich festgelegt ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticalBalance -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnalyticalBalance">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 45501:2015-12, Metrologische Aspekte von nichtselbsttätigen Waagen; OIML R 76-1:2006, Non-automatic weighing instruments – Part 1: Metrological and technical requirements – Tests (anerkannte metrologische Referenz)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Analysenwaage</rdfs:label>
        <rdfs:label xml:lang="en">Analytical Balance</rdfs:label>
        <skos:definition xml:lang="de">Eine Analysenwaage ist eine hochauflösende, nichtselbsttätige Laborwaage zur Bestimmung der Masse kleiner Proben mit sehr geringer Ablese- bzw. Teilungsgröße. Hauptzweck ist das präzise Einwiegen für analytische Arbeiten, z. B. zur Herstellung von Elektrolytansätzen, Referenzlösungen oder zur gravimetrischen Bestimmung von Stoffmengen. Typisch sind konstruktive Maßnahmen zur Minimierung von Wägefehlern (z. B. Windschutz, Nivellierung) und die metrologische Einordnung über die Fehlergrenzen für nichtselbsttätige Waagen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Angle -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Angle">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">Angle</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Annealing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Annealing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTreatment"/>
        <rdfs:label xml:lang="en">Annealing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Anode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Anode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">Electrode where the anodic reaction predominates</rdfs:comment>
        <rdfs:comment xml:lang="de">Elektrode, an der die anodische Reaktion überwiegt</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; DIN EN ISO 2080:2022-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Anode</rdfs:label>
        <rdfs:label xml:lang="en">Anode</rdfs:label>
        <rdfs:label>supplementary anode employed during electrodeposition to achieve a desired thickness distribution of the electrodeposit
</rdfs:label>
        <skos:definition xml:lang="de">Eine Anode ist eine Elektrode, an der in einem elektrochemischen System eine Oxidationsreaktion abläuft und an die der konventionelle Strom in der Elektrolyse eintritt. In galvanotechnischen Prozessen dient sie dazu, den Stromkreis über den Elektrolyten zu schließen und je nach Anodenart entweder Metallionen durch Auflösung bereitzustellen (lösliche Anode) oder als weitgehend inert bleibende Gegenelektrode zu wirken (unlösliche/inert Anode). Die Anode ist damit funktional von der Kathode abzugrenzen, an der die Reduktion und die Abscheidung stattfinden.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeArea -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeArea">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Fläche der Anoden, die im Prozess verwendet wird.</rdfs:comment>
        <rdfs:comment xml:lang="en">The surface area of the anodes used in the process.</rdfs:comment>
        <rdfs:label xml:lang="en">Anode Area</rdfs:label>
        <rdfs:label xml:lang="de">Anodenfläche</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeArrangement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeArrangement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InformationContentEntity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Anordnung der Anoden im System.</rdfs:comment>
        <rdfs:comment xml:lang="en">The arrangement of the anodes in the system.</rdfs:comment>
        <rdfs:label xml:lang="en">Anode Arrangement</rdfs:label>
        <rdfs:label xml:lang="de">Anodenanordnung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeCoating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeCoating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coating"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Beschichtung der Anoden, die deren Lebensdauer und Leistung beeinflusst.</rdfs:comment>
        <rdfs:comment xml:lang="en">The coating of the anodes that affects their lifespan and performance.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; ISO 15254:2017 (Cathodic protection of buried or immersed metallic structures — External current systems)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Anode Coating</rdfs:label>
        <rdfs:label xml:lang="de">Anodenbeschichtung</rdfs:label>
        <skos:definition xml:lang="de">Eine Anodenbeschichtung ist eine auf einem Anodensubstrat aufgebrachte Schicht (z. B. katalytisch aktive Oxid- oder Edelmetallbeschichtung), die die elektrochemischen Eigenschaften der Anode gezielt einstellt. Hauptzweck ist die Bereitstellung einer definierten, langlebigen Anodenoberfläche zur Steuerung von Überspannung, Selektivität und Korrosionsbeständigkeit in elektrolytischen Prozessen. Sie ist von dekorativen/korrosionsschützenden Beschichtungen auf Werkstücken abzugrenzen, da sie funktional für die Anodenreaktion ausgelegt ist.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeCoatingThickness -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeCoatingThickness">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Dicke der Beschichtung auf den Anoden.</rdfs:comment>
        <rdfs:comment xml:lang="en">The thickness of the coating on the anodes.</rdfs:comment>
        <rdfs:label xml:lang="en">Anode Coating Thickness</rdfs:label>
        <rdfs:label xml:lang="de">Anodenbeschichtungsdicke</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeCondition -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeCondition">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-07; DIN EN ISO 17475:2008-10; DIN EN ISO 17476:2017-12</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-07; DIN EN ISO 17475:2010-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Anode Condition</rdfs:label>
        <rdfs:label xml:lang="de">Anodenzustand</rdfs:label>
        <skos:definition xml:lang="de">Anodenzustand bezeichnet den elektrochemischen Zustand einer Anode bzw. einer Elektrode im anodischen Betrieb, charakterisiert durch ihr Potential/Stromdichte-Verhalten und die dabei ablaufenden anodischen Reaktionen (z. B. Metallauflösung oder Sauerstoffentwicklung). Hauptzweck der Beschreibung des Anodenzustands ist die Beurteilung und Steuerung der Prozessstabilität (z. B. Aktiv/Passiv-Verhalten, Polarisation) und damit der Abscheidungs- bzw. Elektrolysebedingungen. Der Anodenzustand ist von der reinen Anodenbauart (lösliche/unlösliche Anode) zu unterscheiden und umfasst insbesondere Oberflächenzustand, Passivierung und Polarisation unter Betriebsbedingungen.</skos:definition>
        <skos:definition xml:lang="de">Anodenzustand bezeichnet den elektrochemischen Zustand einer Anode in einem Elektrolyten, beschrieben durch ihr Anodenverhalten (z. B. aktiv, passiv oder transpassiv) in Abhängigkeit von Potential, Stromdichte und Elektrolytbedingungen. Hauptzweck der Angabe ist die Charakterisierung, ob die Anode sich auflöst bzw. eine Oxidschicht bildet und damit die Anodenreaktion sowie die Prozessstabilität (z. B. Metallionennachlieferung, Sauerstoffentwicklung) bestimmt. Der Anodenzustand ist von der Anodenart (lösliche/unlösliche Anode) zu unterscheiden, da er ein Betriebs- bzw. Reaktionszustand unter gegebenen Bedingungen ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Anode Data Set</rdfs:label>
        <rdfs:label xml:lang="de">Anoden-Datensatz</rdfs:label>
        <skos:definition xml:lang="de">Ein Anoden-Datensatz ist eine strukturierte Zusammenstellung von Informationen zu einer Anode bzw. einem Anodentyp, die für die Planung, Durchführung und Überwachung galvanischer Prozesse verwendet wird. Hauptzweck ist die eindeutige Identifikation und dokumentierte Beschreibung anodenbezogener Merkmale (z. B. Material/Legierung, Abmessungen, Zustand/Verbrauch, Einsatzbedingungen) zur Sicherstellung reproduzierbarer Prozessführung und Rückverfolgbarkeit. Er ist von der „Anode“ als physischem Betriebsmittel zu unterscheiden und beschreibt ausschließlich die zugehörigen Daten/Metadaten.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeDimensions -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeDimensions">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quality"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Abmessungen der Anoden.</rdfs:comment>
        <rdfs:comment xml:lang="en">The dimensions of the anodes.</rdfs:comment>
        <rdfs:label xml:lang="en">Anode Dimensions</rdfs:label>
        <rdfs:label xml:lang="de">Anodenmaße</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeLimitingCurrentDensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeLimitingCurrentDensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:comment xml:lang="en">&lt;electroplating, anodic&gt; maximum current density at which the anode behaves without excessive polarization</rdfs:comment>
        <rdfs:comment xml:lang="de">&lt;galvanische Metallabscheidung, Anode&gt; maximale Stromdichte, bei der die Anode keine übermäßige Polarisation zeigt</rdfs:comment>
        <rdfs:label xml:lang="en">Anode Limiting Current Density</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeType -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodeType">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-12 (Korrosion von Metallen und Legierungen — Grundbegriffe und Definitionen); ISO 2080:2022 (Metallic and other inorganic coatings — Surface treatment, metallic and other inorganic coatings — Vocabulary)</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-12; ISO 2080:2018 (Metallic and other inorganic coatings — Surface treatment, metallic and other inorganic coatings — Vocabulary)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Anode Type</rdfs:label>
        <rdfs:label xml:lang="de">Anodentyp</rdfs:label>
        <skos:definition xml:lang="de">Ein Anodentyp ist eine Klassifikationsangabe, die eine Anode in elektrochemischen Verfahren (z. B. Galvanisieren) nach ihrem Wirkprinzip und/oder Werkstoffverhalten einordnet. Hauptzweck ist die eindeutige Festlegung des Anodenverhaltens im Prozess, insbesondere ob die Anode als Materialquelle dient (lösliche Anode) oder im Wesentlichen formstabil bleibt (unlösliche/inert wirkende Anode). Die Einteilung beeinflusst u. a. Elektrolytführung, Metallionenbilanz und Nebenreaktionen (z. B. Sauerstoffentwicklung).</skos:definition>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Anoden Typ“ bezeichnet die kategoriale Einordnung einer Anode in der Galvanotechnik nach festgelegten Merkmalen wie Löslichkeit im Elektrolyten (lösliche vs. unlösliche/inert), Werkstoff (z. B. Nickel, Kupfer, platinierte Titananode) oder Bauform (z. B. Platte, Korb, Stab). Zweck der Angabe des Anoden Typs ist die eindeutige Festlegung der elektrochemischen Funktion und des Materialeintrags bzw. der Stromübertragung im jeweiligen Abscheideprozess. Je nach Typ beeinflusst die Anode u. a. Elektrolytchemie, Metallionennachlieferung, Nebenreaktionen und Prozessführung.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodesSupplier -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodesSupplier">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Supplier"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Der Lieferant der Anoden.</rdfs:comment>
        <rdfs:comment xml:lang="en">The supplier of the anodes.</rdfs:comment>
        <rdfs:label xml:lang="de">Anoden Lieferant</rdfs:label>
        <rdfs:label xml:lang="en">Anodes Supplier</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodicCleaning -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodicCleaning">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalCleaning"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">electrolytic cleaning in which the work piece to be cleaned is the anode of the cell</rdfs:comment>
        <rdfs:comment xml:lang="de">elektrolytische Reinigung, wobei das zu reinigende Werkstück die Anode der Zelle ist</rdfs:comment>
        <rdfs:label xml:lang="en">Anodic Cleaning</rdfs:label>
        <rdfs:label xml:lang="de">anodische Reinigung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodicTafelSlope -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AnodicTafelSlope">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Slope of the Tafel curve in the anodic region</rdfs:comment>
        <rdfs:comment xml:lang="de">Steigung der Tafelkurve im anodischen Bereich</rdfs:comment>
        <rdfs:label xml:lang="de">Anod. Tafel-Steigung</rdfs:label>
        <rdfs:label xml:lang="en">Anodic Tafel Slope</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Antimony -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Antimony">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Antimony</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Aperture -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Aperture">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>Lowenheim, F.A.: *Modern Electroplating*, 5th ed., Wiley, 2010; Schlesinger, M.; Paunovic, M. (Hrsg.): *Modern Electroplating*, 5th ed., Wiley, 2010 (Kapitel zur Stromverteilung/Abschirmung); Dini, J.W.: *Electrodeposition: The Materials Science of Coatings and Substrates*, Noyes Publications, 1993</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Aperture</rdfs:label>
        <rdfs:label xml:lang="de">Blende</rdfs:label>
        <skos:definition xml:lang="de">Eine Blende ist ein elektrisch leitfähiges oder nichtleitfähiges Bauteil, das im Elektrolyten zwischen Anode und Werkstück (Kathode) oder in deren Nähe angeordnet wird, um den Stromlinienverlauf und damit die lokale Stromdichte gezielt zu beeinflussen. Hauptzweck ist die Abschirmung bzw. Begrenzung des Stromzutritts an bestimmten Werkstückbereichen, um Schichtdickenverteilung, Kantenaufbau und Abscheidegleichmäßigkeit zu steuern. Sie ist von einer Maske dadurch abzugrenzen, dass sie primär die Feld-/Stromverteilung im Bad beeinflusst und nicht zwingend direkt als Abdeckung auf dem Werkstück aufliegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Area -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Area">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">Area</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AreaDetector -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AreaDetector">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingEquipment"/>
        <rdfs:comment>An area detector, e.g. used in a computer tomograph</rdfs:comment>
        <rdfs:label xml:lang="en">AreaDetector</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Argon -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Argon">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Argon</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Arsenic -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Arsenic">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Arsenic</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArticleNumber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArticleNumber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9000:2015-11; DIN EN ISO 9001:2015-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Article Number</rdfs:label>
        <skos:definition xml:lang="de">Eine Artikelnummer ist eine vom Unternehmen vergebene eindeutige alphanumerische Kennung zur Identifikation eines Artikels/Produkts in Systemen wie ERP, Fertigungs- und Prüfunterlagen. Hauptzweck ist die eindeutige Zuordnung von Spezifikationen, Prozessen, Prüfmerkmalen und Dokumentation (z. B. für Rückverfolgbarkeit) über den gesamten Produktlebenszyklus. Sie ist von normierten Identifikatoren (z. B. GTIN) abzugrenzen, da Struktur und Vergaberegeln unternehmensspezifisch sein können.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAging -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAging">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTreatment"/>
        <rdfs:label xml:lang="en">ArtificialAging</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingDuration -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingDuration">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeRelatedQuantity"/>
        <rdfs:comment>The duration of the artificial aging process</rdfs:comment>
        <rdfs:label xml:lang="en">ArtificialAgingDuration</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingDurationAsSupposed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingDurationAsSupposed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingDuration"/>
        <rdfs:comment>The duration of the artificial aging process as supposed.</rdfs:comment>
        <rdfs:label xml:lang="en">ArtificialAgingDurationAsSupposed</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingTemperature -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingTemperature">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureRelatedQuantity"/>
        <rdfs:comment>The temperature controlled during artificial aging</rdfs:comment>
        <rdfs:label xml:lang="en">ArtificialAgingTemperature</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingTemperatureAsSupposed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingTemperatureAsSupposed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingTemperature"/>
        <rdfs:comment>The artificial aging temperature as supposed</rdfs:comment>
        <rdfs:label xml:lang="en">ArtificialAgingTemperatureAsSupposed</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Astatine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Astatine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Astatine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Atom -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Atom">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MatterObject"/>
        <rdfs:label xml:lang="en">Atom</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AttackLevel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AttackLevel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8407:2021-12; DIN EN ISO 9226:2012-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Angriffsgrad</rdfs:label>
        <rdfs:label xml:lang="en">Attack Level</rdfs:label>
        <skos:definition xml:lang="de">Der Angriffsgrad ist ein Maß für das Ausmaß, in dem ein Medium (z. B. Beize, Ätz- oder Reinigungsmedium) einen Werkstoff oder eine Oberfläche chemisch angreift. Er dient zur quantitativen oder qualitativen Beurteilung der Beiz- bzw. Ätzwirkung und zur Prozessführung, z. B. zur Vermeidung von Überbeizen, Maßänderungen oder unerwünschter Oberflächenrauheit. Der Angriffsgrad kann je nach Verfahren über Kenngrößen wie Massenverlust, Abtragsrate oder Veränderung der Oberflächenbeschaffenheit beschrieben werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AuxiliaryAnode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AuxiliaryAnode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Anode"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">supplementary anode employed during electrodeposition to achieve a desired thickness distribution of the electrodeposit</rdfs:comment>
        <rdfs:comment xml:lang="de">zusätzliche Anode, die bei der galvanischen Metallabscheidung verwendet wird, um eine gewünschte Schichtdickenverteilung des galvanisch erzeugten Überzugs zu erreichen</rdfs:comment>
        <rdfs:label xml:lang="en">Auxiliary Anode</rdfs:label>
        <rdfs:label xml:lang="de">Hilfsanode</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AuxiliaryCathode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AuxiliaryCathode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cathode"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Kathode, die so angebracht ist, dass sie einen Teil des Stroms von Teilen der Werkstücke aufnimmt, die sonst einer zu hohen Stromdichte ausgesetzt wären</rdfs:comment>
        <rdfs:comment xml:lang="en">cathode placed so as to divert to itself some portion of the current from portions of the work pieces which otherwise receive a too high
current density</rdfs:comment>
        <rdfs:label xml:lang="en">Auxiliary Cathode</rdfs:label>
        <rdfs:label xml:lang="de">Hilfskathode</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AverageGrainSize -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AverageGrainSize">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrainSize"/>
        <rdfs:label xml:lang="en">AverageGrainSize</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AverageHardnessBrinell -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AverageHardnessBrinell">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HardnessBrinell"/>
        <rdfs:comment>An average value of several Brinell hardness measurements</rdfs:comment>
        <rdfs:label xml:lang="en">AverageHardnessBrinell</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AverageHardnessVickers -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AverageHardnessVickers">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HardnessVickers"/>
        <rdfs:comment>The average value of a series of hardness measurements according to the Vickers indentation process</rdfs:comment>
        <rdfs:label xml:lang="en">AverageHardnessVickers</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Bar -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Bar">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProduct"/>
        <rdfs:label xml:lang="en">Bar</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Barium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Barium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Barium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseElementOfComposition -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseElementOfComposition">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalComposition"/>
        <rdfs:comment xml:lang="en">A &quot;base element of the chemical composition of a metallic material&quot; refers to the primary metal or alloying element that constitutes the majority of the material&apos;s structure. This base element determines the fundamental properties, such as strength, conductivity, and corrosion resistance, of the metallic material. For example, in steel, iron is the base element, while in aluminum alloys, aluminum serves as the base element. Other elements may be added to enhance specific characteristics, but the base element remains the principal component.</rdfs:comment>
        <rdfs:label xml:lang="en">BaseElementOfComposition</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseQuantityKind -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseQuantityKind">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">BaseQuantityKind</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseUnit -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseUnit">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Unit"/>
        <rdfs:label xml:lang="en">BaseUnit</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseWheel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseWheel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>VDI 2083 Blatt 9:2018-03 (Reinraumtechnik – Reinraumgerechte Konstruktion von Maschinen und Anlagen; Begriffe/Anforderungen an bewegte Komponenten), ASM Handbook, Volume 5: Surface Engineering (1994, Abschnitt zu Rack/Fixture Design in Electroplating)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Base Wheel</rdfs:label>
        <rdfs:label xml:lang="de">Trägerrad</rdfs:label>
        <skos:definition xml:lang="de">Ein Trägerrad ist ein radförmiges Bauteil an einem Warenträger/Gestell, das das Verfahren bzw. Transportieren des bestückten Gestells entlang einer Führung oder in einer Anlage ermöglicht. Hauptzweck ist die lasttragende, reibungsarme Führung/Bewegung des Warenträgers während Prozessschritten (z. B. Ein-/Austauchen, Verfahrbewegungen) ohne die Werkstücke zu beeinträchtigen. Es ist von Antriebsrädern zu unterscheiden, da es typischerweise keine Antriebsfunktion übernimmt, sondern primär trägt und führt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BasicMaterial -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BasicMaterial">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringMaterial"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Material, auf dem Überzüge abgeschieden werden</rdfs:comment>
        <rdfs:comment xml:lang="en">material upon which coatings are deposited</rdfs:comment>
        <rdfs:label xml:lang="en">Basic Material</rdfs:label>
        <rdfs:label xml:lang="de">Grundwerkstoff</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Batch -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Batch">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringMaterial"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Batch or delivery of materials</rdfs:comment>
        <rdfs:comment xml:lang="de">Charge oder Lieferung von Materialien</rdfs:comment>
        <rdfs:label xml:lang="en">Batch</rdfs:label>
        <rdfs:label xml:lang="de">Charge/Lieferung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BatchNumber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BatchNumber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9000:2015-11; DIN EN ISO 9001:2015-11; DIN EN ISO 10204:2005-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Batch Number</rdfs:label>
        <skos:definition xml:lang="de">Eine Chargennummer ist eine eindeutige Kennzeichnung (alphanumerischer Code), mit der eine Charge/Los von Erzeugnissen oder Prozessdurchläufen identifiziert wird. Sie dient der Rückverfolgbarkeit, Zuordnung von Prüf- und Prozessdaten sowie der Steuerung von Korrektur- und Reklamationsmaßnahmen in galvanotechnischen Fertigungs- und Prüfprozessen. Sie ist von Seriennummern abzugrenzen, die typischerweise einzelne Teile eindeutig kennzeichnen, während die Chargennummer eine Gruppe bzw. einen gemeinsamen Herstell-/Behandlungsabschnitt referenziert.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BeamCurrent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BeamCurrent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 2064:2021-03; ISO 8044:2020 (Corrosion of metals and alloys — Basic terms and definitions)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Beam current</rdfs:label>
        <rdfs:label xml:lang="de">Strahlstrom</rdfs:label>
        <skos:definition xml:lang="de">Strahlstrom ist der elektrische Strom, der in einem Strahlverfahren (z. B. Strahlgalvanisieren/Brush Plating) über den lokal begrenzten Elektrolytfilm zwischen Werkzeug/Anode und Werkstück/Kathode fließt. Er dient dazu, die elektrochemische Abscheidung im bestrahlten Bereich zu ermöglichen und die lokale Abscheiderate in Kombination mit der wirksamen Fläche (Stromdichte) zu bestimmen. Abzugrenzen ist der Strahlstrom (Gesamtstrom) von der Strahlstromdichte als auf die wirksame Kontakt-/Strahlfläche bezogene Größe.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Berylium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Berylium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Berylium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Bismuth -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Bismuth">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Bismuth</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BlisterFormation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BlisterFormation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4628-2:2016-12, Beschichtungsstoffe – Beurteilung von Beschichtungsschäden – Bewertung der Menge und Größe von Schäden und der Intensität gleichmäßiger Veränderungen im Aussehen – Teil 2: Bewertung des Blasenbildungsgrades; DIN EN ISO 2081:2018-09, Metallische und andere anorganische Überzüge – Galvanische Zinküberzüge auf Eisen oder Stahl mit zusätzlicher Behandlung; DIN EN ISO 2064:2020-01, Metallische und andere anorganische Überzüge – Begriffe und Definitionen zur Messung der Schichtdicke und zur Schichtdickenangabe</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Blasenbildung</rdfs:label>
        <rdfs:label xml:lang="en">Blister Formation</rdfs:label>
        <skos:definition xml:lang="de">Blasenbildung ist ein Beschichtungsfehler, bei dem sich blasenförmige Erhebungen bzw. Hohlräume in oder unter einer metallischen Überzugs- oder Konversionsschicht ausbilden, typischerweise durch lokale Ablösung vom Grundwerkstoff oder durch eingeschlossene Medien (z. B. Gase, Feuchtigkeit, Prozessrückstände). Hauptzweck der Begriffsnutzung ist die einheitliche Benennung und Bewertung dieses Fehlertyps bei der Qualitätsprüfung von galvanischen Überzügen. Blasenbildung ist von Poren (offene Durchtrittsstellen) und von Abplatzungen/Abblättern (flächiger Schichtverlust) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BlucrB -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BlucrB">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Specific chemical compound or product</rdfs:comment>
        <rdfs:comment xml:lang="de">Spezifische chemische Verbindung oder Produkt</rdfs:comment>
        <rdfs:label xml:lang="de">BluCr B</rdfs:label>
        <rdfs:label xml:lang="en">Blucr B</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BlucrC1 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BlucrC1">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Specific chemical compound or product</rdfs:comment>
        <rdfs:comment xml:lang="de">Spezifische chemische Verbindung oder Produkt</rdfs:comment>
        <rdfs:label xml:lang="de">BluCr C1</rdfs:label>
        <rdfs:label xml:lang="en">Blucr C1</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BlucrC2 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BlucrC2">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Specific chemical compound or product</rdfs:comment>
        <rdfs:comment xml:lang="de">Spezifische chemische Verbindung oder Produkt</rdfs:comment>
        <rdfs:label xml:lang="de">BluCr C2</rdfs:label>
        <rdfs:label xml:lang="en">Blucr C2</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Boron -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Boron">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Boron</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BoronCarbideInLayerDistribution -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BoronCarbideInLayerDistribution">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 15726:2018-07, Metallische und andere anorganische Überzüge — Elektrolytisch abgeschiedene Verbundüberzüge; DIN EN ISO 1463:2020-08, Metallische und Oxidschichten — Messung der Schichtdicke — Mikroskopisches Verfahren (Querschliffverfahren)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Boron Carbide In Layer Distribution</rdfs:label>
        <rdfs:label xml:lang="de">Verteilung Borcarbid in der Schicht</rdfs:label>
        <skos:definition xml:lang="de">Die „Verteilung Borcarbid in der Schicht“ beschreibt die räumliche Anordnung und Häufigkeit von Borcarbid-(B4C)-Partikeln innerhalb einer galvanisch abgeschiedenen Verbundschicht über die Schichtdicke und/oder in der Schichtebene. Zweck ist die Beurteilung, ob die Partikel gleichmäßig und prozessgerecht eingebettet sind, da die Partikelverteilung die funktionellen Eigenschaften (z. B. Verschleißverhalten) maßgeblich beeinflusst. Sie wird typischerweise an Querschliffen mittels mikroskopischer Verfahren bewertet und von der reinen Schichtdickenmessung bzw. der Gesamt-Partikelgehaltsangabe abgegrenzt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BrightElectroplatingRange -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BrightElectroplatingRange">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Stromdichtebereich, in dem unter gegebenen oder festgelegten Betriebsbedingungen mit einer Lösung für die galvanische Metallabscheidung glänzende Überzüge abgeschieden werden</rdfs:comment>
        <rdfs:comment xml:lang="en">range of current densities within which an electroplating solution produces a bright deposit under a given or specified set of operating conditions</rdfs:comment>
        <rdfs:label xml:lang="en">Bright Electroplating Range</rdfs:label>
        <rdfs:label xml:lang="de">Glanzbereich</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BrightThrowingPower -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BrightThrowingPower">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Maß für die Fähigkeit einer Lösung für die galvanische Metallabscheidung oder für festgelegte galvanische Abscheidungsbedingungen, auf einer unregelmäßig geformten Kathode einen galvanischen Überzug mit gleichmäßigem Glanz abzuscheiden</rdfs:comment>
        <rdfs:comment xml:lang="en">measure of the ability of an electroplating solution or a specified set of electroplating conditions to deposit uniformly bright electroplate upon an irregularly shaped cathode</rdfs:comment>
        <rdfs:label xml:lang="en">Bright Throwing Power</rdfs:label>
        <rdfs:label xml:lang="de">Glanztiefenstreuung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BrightenerAdditive -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BrightenerAdditive">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
