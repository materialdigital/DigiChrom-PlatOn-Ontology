        <rdfs:comment xml:lang="en">electrodeposited chromium coating with an intentional microscopical porosity </rdfs:comment>
        <rdfs:comment xml:lang="de">galvanisch abgeschiedener Chromüberzug mit einer absichtlich erzeugten, mikroskopisch feinen Porosität </rdfs:comment>
        <rdfs:label xml:lang="en">Microporous Chromium</rdfs:label>
        <rdfs:label xml:lang="de">mikroporiges Chrom</rdfs:label>
    </owl:Class>
    


