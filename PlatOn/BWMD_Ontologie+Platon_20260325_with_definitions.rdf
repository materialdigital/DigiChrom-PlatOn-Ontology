    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SlidingWearMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SlidingWearMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 20808:2016-12; ASTM G99-17 (Reapproved 2022)</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 20808:2016-12; DIN EN ISO 7148-2:2012-12; DIN EN ISO 8044:2020-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Gleitverschleißmessung</rdfs:label>
        <rdfs:label xml:lang="en">Sliding wear measurement</rdfs:label>
        <skos:definition xml:lang="de">Die Messung des Gleitverschleißes ist die normgerechte Bestimmung des Materialabtrags bzw. der Verschleißrate, der bei relativer Gleitbewegung zwischen zwei Kontaktpartnern unter definierten Prüfbedingungen entsteht. Hauptzweck ist die quantitative Bewertung und Vergleichbarkeit der Verschleißbeständigkeit von Werkstoffen und Beschichtungen (z. B. galvanische Überzüge) anhand festgelegter Kenngrößen wie Massenverlust, Volumenverlust oder Verschleißkoeffizient. Sie ist von der Messung des Reibwerts abzugrenzen, kann aber im selben Versuch (z. B. Pin-on-Disc) gemeinsam erfasst werden.</skos:definition>
        <skos:definition xml:lang="de">Gleitverschleißmessung ist die quantitative Bestimmung des Materialabtrags bzw. der Verschleißrate infolge relativer Gleitbewegung zwischen zwei Kontaktpartnern unter definierten Prüfbedingungen. Hauptzweck ist die vergleichende Bewertung der Verschleißbeständigkeit von Werkstoffen und Beschichtungen (z. B. galvanische Überzüge) anhand messbarer Kenngrößen wie Massenverlust, Verschleißvolumen oder Verschleißrate. Sie ist von reinen Reibungsmessungen abzugrenzen, da neben der Reibkraft explizit der Substanzverlust bzw. die Verschleißspur geometrisch oder gravimetrisch erfasst wird.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SlidingWearMeasurementLinear -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SlidingWearMeasurementLinear">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SlidingWearMeasurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7148-2:2012-06, Tribologie — Verschleißprüfung — Teil 2: Prüfung mit reziproker Bewegung; ASTM G133-05(2016), Standard Test Method for Linearly Reciprocating Ball-on-Flat Sliding Wear; DIN EN ISO 20808:2016-12, Metallische und andere anorganische Überzüge — Behandlung und Nachbehandlung zur Verringerung der Wasserstoffversprödung (als Kontextnorm für galvanische Überzüge, nicht als Verschleißprüfnorm)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Linear sliding wear measurement</rdfs:label>
        <rdfs:label xml:lang="de">Lineare Gleitverschleißmessung</rdfs:label>
        <skos:definition xml:lang="de">Eine lineare Gleitverschleißmessung ist eine Verschleißprüfung, bei der ein Prüfkörper unter definierter Normalkraft auf einer Probenoberfläche mit linearer, meist reziproker Gleitbewegung geführt wird und der resultierende Materialabtrag bzw. Verschleiß ermittelt wird. Hauptzweck ist die quantitative Bestimmung und der Vergleich des Verschleißverhaltens von Beschichtungen und Grundwerkstoffen unter definierten tribologischen Bedingungen (z. B. Last, Hub, Frequenz, Gegenkörper, Umgebung). Die Verschleißbewertung erfolgt typischerweise über Massenverlust, Verschleißvolumen/Profilometrie oder Verschleißrate und ist von rotatorischen Gleitverschleißprüfungen (z. B. Pin-on-Disc) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SlidingWearMeasurementRotational -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SlidingWearMeasurementRotational">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SlidingWearMeasurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 1071-13:2010-12, ASTM G99-17</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Rotational sliding wear measurement</rdfs:label>
        <rdfs:label xml:lang="de">Rotierende Gleitverschleißmessung</rdfs:label>
        <skos:definition xml:lang="de">Eine rotierende Gleitverschleißmessung ist eine tribologische Prüfung, bei der ein Prüfkörper unter definierter Normalkraft mit Relativbewegung auf einer rotierenden Gegenkörperoberfläche gleitet und dabei der Verschleiß ermittelt wird. Hauptzweck ist die quantitative Bestimmung und der Vergleich des Verschleißverhaltens (z. B. Verschleißvolumen/-rate) von Werkstoffen oder Beschichtungen unter festgelegten Gleitbedingungen. Typisch ist die Auswertung über Massen-/Volumenverlust oder Profilometrie der Verschleißspur; die Methode ist von rein oszillierenden (reziprokierenden) Gleitverschleißprüfungen abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SoakCleaning -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SoakCleaning">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalCleaning"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Reinigung durch Eintauchen
Reinigung durch Eintauchen ohne Anwendung von Strom, üblicherweise in einer heißen alkalischen Lösung, die oberflächenaktive Mittel enthält</rdfs:comment>
        <rdfs:comment xml:lang="en">cleaning by immersion without the use of electric current, usually in a hot alkaline solution containing surfactants</rdfs:comment>
        <rdfs:label xml:lang="en">Soak Cleaning </rdfs:label>
        <rdfs:label xml:lang="de">Tauchreinigung</rdfs:label>
    </owl:Class>
    


