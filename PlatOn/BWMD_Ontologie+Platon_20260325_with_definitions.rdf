    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhValueAfterCooling -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhValueAfterCooling">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHValue"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">pH value after cooling</rdfs:comment>
        <rdfs:comment xml:lang="de">pH-Wert nach dem Abkühlen</rdfs:comment>
        <rdfs:label xml:lang="en">Ph Value After Cooling</rdfs:label>
        <rdfs:label xml:lang="de">pH-Wert nach Abkühlung </rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhValueEndActual -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhValueEndActual">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHValue"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Actual pH value at the end of a process</rdfs:comment>
        <rdfs:comment xml:lang="de">Tatsächlicher pH-Wert am Ende eines Prozesses</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 10523:2012-04, Wasserbeschaffenheit — Bestimmung des pH-Werts; DIN 38404-5:2009-07, Deutsche Einheitsverfahren zur Wasser-, Abwasser- und Schlammuntersuchung — Physikalische und physikalisch-chemische Kenngrößen (Gruppe C) — Teil 5: Bestimmung des pH-Werts (C 5)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Ph Value End Actual</rdfs:label>
        <rdfs:label xml:lang="de">pH-Wert Ende IST</rdfs:label>
        <skos:definition xml:lang="de">Der „Endwert pH aktuell“ ist der zum aktuellen Zeitpunkt erfasste pH-Messwert am Ende eines definierten Prozessabschnitts oder Messintervalls (z. B. nach Dosierung, Regelvorgang oder Badbehandlung). Er dient der Überwachung und Dokumentation des Säure-/Basen-Zustands einer Prozesslösung (z. B. Elektrolyt, Spülwasser) zur Sicherstellung stabiler Prozessbedingungen und reproduzierbarer Beschichtungsergebnisse. Der Begriff ist von Sollwerten und Mittelwerten abzugrenzen, da er den zuletzt gemessenen End-/Abschlusswert eines betrachteten Abschnitts beschreibt.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhValueStartActual -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhValueStartActual">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHValue"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Actual pH value at the start of a process</rdfs:comment>
        <rdfs:comment xml:lang="de">Tatsächlicher pH-Wert zu Beginn eines Prozesses</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 10523:2012-04, Wasserbeschaffenheit – Bestimmung des pH-Werts; DIN 19268:2005-06, Wasserbeschaffenheit – Bestimmung des pH-Werts – Elektrometrisches Verfahren (mit Glaselektrode)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Ph Value Start Actual</rdfs:label>
        <rdfs:label xml:lang="de">pH-Wert Start IST</rdfs:label>
        <skos:definition xml:lang="de">„Startwert pH aktuell“ ist der zu Beginn eines definierten Prozess- oder Prüfabschnitts gemessene und dokumentierte pH-Wert einer Lösung (z. B. eines galvanotechnischen Elektrolyten oder Spülwassers). Er dient als Ausgangsgröße zur Prozessüberwachung und zur Beurteilung von Änderungen des Säure-/Basenstatus im Verlauf (z. B. durch Nachdosierung, Verschleppung oder Reaktionsprodukte). Der Begriff ist von Sollwerten/Regelwerten abzugrenzen, da er den tatsächlich gemessenen Initialwert (Istwert) beschreibt.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhValueTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhValueTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHValue"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Intended pH value for a solution</rdfs:comment>
        <rdfs:comment xml:lang="de">Vorgesehener pH-Wert für eine Lösung</rdfs:comment>
        <rdfs:label xml:lang="en">Ph Value Target</rdfs:label>
        <rdfs:label xml:lang="de">pH-Wert Soll</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Phosphorus -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Phosphorus">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Phosphorus</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Photomicrograph -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Photomicrograph">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Subprocess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; DIN EN ISO 17639:2022-12; DIN EN ISO 9042:2020-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Lichtmikroskopisches Bild (Verschleißspur)</rdfs:label>
        <rdfs:label xml:lang="en">Photomicrograph (Wear Track)</rdfs:label>
        <skos:definition xml:lang="de">Ein lichtmikroskopisches Bild ist eine mit einem Lichtmikroskop erzeugte bildliche Darstellung einer Probeoberfläche oder eines Schliffgefüges bei definierter Vergrößerung und Beleuchtung. Hauptzweck ist die visuelle Beurteilung und Dokumentation von Mikrostrukturmerkmalen (z. B. Schichtaufbau, Poren, Risse, Korngrenzen) im Rahmen der Prüfung galvanischer Überzüge und Grundwerkstoffe. Es ist von elektronenmikroskopischen Bildern abzugrenzen, die andere Abbildungsprinzipien und typischerweise höhere Auflösungen nutzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhysicalQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhysicalQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:label xml:lang="en">PhysicalQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhysicsModel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhysicsModel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GenericallyDependentContinuant"/>
        <rdfs:label xml:lang="en">PhysicsModel</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Pickling -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Pickling">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Process of removing oxides and contaminants from surfaces</rdfs:comment>
        <rdfs:comment xml:lang="de">Verfahren zur Entfernung von Oxiden und Verunreinigungen von Oberflächen</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2017-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Beize</rdfs:label>
        <rdfs:label xml:lang="en">Pickling</rdfs:label>
        <skos:definition xml:lang="de">Beizen ist eine chemische Oberflächenbehandlung, bei der metallische Werkstücke in einer Beizlösung behandelt werden, um Oxide, Zunder, Rost oder andere anhaftende Reaktions- und Verunreinigungsschichten abzutragen. Hauptzweck ist die Herstellung einer metallisch sauberen, reaktionsfähigen Oberfläche als Voraussetzung für nachfolgende Prozesse wie galvanische Beschichtungen, Konversionsschichten oder Lackierungen. Beizen ist von Entfetten/Alkalischreinigen abzugrenzen, da es primär anorganische Deckschichten durch chemischen Angriff entfernt und dabei auch Grundmetall in begrenztem Umfang abtragen kann.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PicklingAgent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PicklingAgent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08, DIN EN ISO 2081:2018-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Beizmittel</rdfs:label>
        <rdfs:label xml:lang="en">Pickling Agent</rdfs:label>
        <skos:definition xml:lang="de">Ein Beizmittel ist ein chemisches Mittel (meist eine saure oder alkalische Lösung), das beim Beizen eingesetzt wird, um Oxidschichten, Zunder, Anlauffarben oder andere anorganische Verunreinigungen von metallischen Oberflächen zu entfernen. Hauptzweck ist die Herstellung einer metallisch sauberen, reaktionsfähigen Oberfläche als Voraussetzung für nachfolgende Prozesse wie galvanische Beschichtungen, Konversionsschichten oder das Lackieren. Beizmittel sind von Entfettungsmitteln abzugrenzen, die primär organische Verunreinigungen (Öle/Fette) entfernen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PicklingSupplier -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PicklingSupplier">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Supplier"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Lieferant des Beizmittels</rdfs:comment>
        <rdfs:comment xml:lang="en">Supplier of the pickling agent</rdfs:comment>
        <rdfs:label xml:lang="de">Beize Lieferant</rdfs:label>
        <rdfs:label xml:lang="en">Pickling Supplier</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PicklingTemperature -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PicklingTemperature">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Temperatur, bei der das Beizverfahren durchgeführt wird</rdfs:comment>
        <rdfs:comment xml:lang="en">Temperature at which the pickling process is performed</rdfs:comment>
        <rdfs:label xml:lang="de">Beize Temperatur</rdfs:label>
        <rdfs:label xml:lang="en">Pickling Temperature</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PicklingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PicklingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Dauer des Beizverfahrens</rdfs:comment>
        <rdfs:comment xml:lang="en">Duration of the pickling process</rdfs:comment>
        <rdfs:label xml:lang="de">Beize Zeit</rdfs:label>
        <rdfs:label xml:lang="en">Pickling Time</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PinOnDiskMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PinOnDiskMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7148-2:2012-06 (Gleitlager — Prüfung von Werkstoffen für Gleitlager — Teil 2: Prüfverfahren für Werkstoffe für Gleitlager unter Gleitverschleißbedingungen); ASTM G99-17 (Standard Test Method for Wear Testing with a Pin-on-Disk Apparatus)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Pin On Disk Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Pin-on-Disk Messung</rdfs:label>
        <skos:definition xml:lang="de">Eine Pin-on-Disk Messung ist ein tribologisches Prüfverfahren, bei dem ein Stift (Pin) mit definierter Normalkraft gegen eine rotierende Scheibe (Disk) gedrückt wird, um Reib- und Verschleißverhalten eines Werkstoffs oder einer Beschichtung unter Gleitbeanspruchung zu bestimmen. Hauptzweck ist die Ermittlung von Kenngrößen wie Reibungskoeffizient sowie Verschleißrate bzw. Verschleißvolumen unter festgelegten Prüfbedingungen (z. B. Last, Geschwindigkeit, Umgebung, Gegenkörper). Das Verfahren ist von anderen Gleitverschleißprüfungen (z. B. Kugel-auf-Scheibe) durch die Geometrie des Gegenkörpers und die definierte Kontaktkonfiguration abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PistonDiameter -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PistonDiameter">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 5598:2020-02 (Fluidtechnik – Vokabular)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Kolbendurchmesser</rdfs:label>
        <rdfs:label xml:lang="en">Piston Diameter</rdfs:label>
        <skos:definition xml:lang="de">Der Kolbendurchmesser ist das Nennmaß des Außendurchmessers eines Kolbens, üblicherweise bezogen auf den zylindrischen Kolbenabschnitt. Er dient als grundlegende Konstruktions- und Berechnungsgröße zur Bestimmung von wirksamer Fläche, Volumenstrom/Hubvolumen sowie Kräften bzw. Drücken in kolbenbasierten Aggregaten (z. B. Pumpen, Dosier- oder Antriebseinheiten). Der Kolbendurchmesser ist von Bohrungsdurchmesser/Zylinderdurchmesser und ggf. Dichtungsdurchmessern abzugrenzen, sofern diese separat spezifiziert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatedObject -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatedObject">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProduct"/>
        <dc:creator xml:lang="en">Elena G. Trelles (Fraunhofer IWM)</dc:creator>
        <rdfs:comment xml:lang="en">object after plating</rdfs:comment>
        <rdfs:label xml:lang="en">Plated Object</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Plating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Plating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturing"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Fertigen durch Aufbringen einer fest haftenden Schicht aus formlosem Stoff auf ein Werkstück, wobei der unmittelbar vor dem Beschichten herrschende Zustand des Beschichtungsstoffs maßgebend ist</rdfs:comment>
        <rdfs:comment xml:lang="en">Manufactured by applying a firmly adhering layer of amorphous material to a workpiece, whereby the condition of the coating material immediately before coating is decisive</rdfs:comment>
        <rdfs:label xml:lang="de">Beschichten</rdfs:label>
        <rdfs:label xml:lang="en">Plating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingArea -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingArea">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingChromium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingChromium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1456:2023-02, Metallische und andere anorganische Überzüge — Nickel-, Nickel-plus-Chrom-, Kupfer-plus-Nickel- und Kupfer-plus-Nickel-plus-Chrom-Überzüge; DIN EN ISO 6158:2018-03, Metallische Überzüge — Elektrolytisch abgeschiedene Chromüberzüge für technische Zwecke (Hartchrom) — Anforderungen und Prüfverfahren; DIN EN ISO 2080:2022-05, Metallische und andere anorganische Überzüge — Oberflächenbehandlung, metallische und andere anorganische Überzüge — Wörterverzeichnis und Einteilung</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Chrombeschichtung</rdfs:label>
        <rdfs:label xml:lang="en">Plating chromium</rdfs:label>
        <skos:definition xml:lang="de">Eine Chrombeschichtung ist ein Prozess bei dem ein metallischer Überzug aus Chrom auf ein Grundmaterial aufgebracht wird, typischerweise durch galvanische Abscheidung aus Chrom(VI)- oder Chrom(III)-Elektrolyten. Hauptzweck ist die Erzeugung definierter Oberflächeneigenschaften wie Korrosionsschutz (insbesondere im System mit Nickel), Verschleiß- und Reibungsverhalten sowie dekoratives Erscheinungsbild. Je nach Anwendungsfall wird zwischen dekorativen Chromüberzügen (meist dünn, auf Nickel) und Hartchromüberzügen (funktionell, meist dicker) unterschieden.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingID -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingID">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4042:2019-12; DIN EN ISO 10683:2018-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Beschichtungsnummer</rdfs:label>
        <rdfs:label xml:lang="en">Plating ID</rdfs:label>
        <skos:definition xml:lang="de">Eine Beschichtungsnummer ist eine normativ festgelegte alphanumerische Kennzeichnung, die ein Beschichtungs- bzw. Überzugssystem eindeutig beschreibt (z. B. Art des Überzugs, Schichtfolge und ggf. Schichtdickenklasse). Hauptzweck ist die eindeutige Spezifikation und Kommunikation der geforderten Beschichtung in Zeichnungen, Bestellungen und Prüfunterlagen. Sie dient der Vermeidung von Interpretationsspielräumen gegenüber Freitextangaben und ist von internen Artikel- oder Prozessnummern abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingNickel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingNickel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1456:2023-02; DIN EN ISO 4527:2023-02; DIN EN ISO 2081:2018-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Nickel Beschichtung</rdfs:label>
        <rdfs:label xml:lang="en">Nickel plating</rdfs:label>
        <skos:definition xml:lang="de">Eine Nickel Beschichtung ist ein metallischer Überzug aus Nickel, der auf ein Grundmaterial aufgebracht wird, typischerweise durch elektrolytisches oder chemisches (stromloses) Abscheiden. Hauptzweck ist der Korrosionsschutz und/oder die Erzeugung definierter funktioneller Eigenschaften (z. B. Verschleißschutz, Lötbarkeit, elektrische Eigenschaften) sowie dekorativer Oberflächen. Je nach Verfahren und Schichtsystem kann die Beschichtung als eigenständiger Nickelüberzug oder als Bestandteil von Mehrschichtüberzügen (z. B. Nickel/Chrom) spezifiziert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingObjects -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingObjects">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingPreNickel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingPreNickel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 1456:2009-12; DIN EN ISO 4526:2007-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Nickel Vorbeschichtung</rdfs:label>
        <rdfs:label xml:lang="en">Pre-Nickel plating</rdfs:label>
        <skos:definition xml:lang="de">Eine Nickel Vorbeschichtung ist eine zuerst aufgebrachte Nickelschicht, die als Unter- bzw. Zwischenschicht in einem mehrlagigen metallischen Überzugssystem dient. Ihr Hauptzweck ist die Verbesserung der Haftfestigkeit und/oder der Korrosionsschutz- und Funktionseigenschaften der nachfolgenden Schichten (z. B. Chrom, Edelmetalle) durch geeignete Schichtbildung und Oberflächenkonditionierung. Sie ist von einer Nickel-Endbeschichtung dadurch abgegrenzt, dass sie nicht die äußerste Funktions- oder Sichtschicht des Systems bildet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTank -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTank">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <dc:creator xml:lang="en">Elena G. Trelles</dc:creator>
        <rdfs:comment xml:lang="en">A tank to hold the chrome plating solution, often made of materials resistant to corrosion.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN 17059:2018-03 (Oberflächenbehandlung – Anlagen für die Oberflächenbehandlung – Sicherheitsanforderungen); DIN EN 12573-1:2000-12 (Thermoplastische ortsfeste Tanks – Teil 1: Allgemeines)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Plating Tank</rdfs:label>
        <skos:definition xml:lang="de">Ein Beschichtungstank ist ein Prozessbehälter, der eine Beschichtungslösung (z. B. Elektrolyt, chemische Abscheidelösung oder Vorbehandlungsmedium) aufnimmt, in der Werkstücke zur Erzeugung einer Schicht behandelt werden. Hauptzweck ist das sichere Bereitstellen und Führen des Beschichtungsbades unter definierten Betriebsbedingungen (z. B. Temperatur, Umwälzung, Abdeckung/Absaugung) für reproduzierbare Beschichtungsergebnisse. Abzugrenzen ist er von Spül- oder Neutralisationstanks, die nicht primär der Schichtbildung dienen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator xml:lang="en">Elena G. Trelles</dc:creator>
        <rdfs:comment xml:lang="en">uration for which the substrate is immersed in the plating solution, often ranging from 30 minutes to several hours.</rdfs:comment>
        <rdfs:label xml:lang="de">Beschichtungszeit</rdfs:label>
        <rdfs:label xml:lang="en">Plating Time</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTimeActual -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTimeActual">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2021-03; DIN EN ISO 2177:2020-12; DIN EN ISO 2081:2018-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Beschichtungszeit aktuell</rdfs:label>
        <rdfs:label xml:lang="en">Plating Time Actual</rdfs:label>
        <skos:definition xml:lang="de">Die „Beschichtungszeit aktuell“ ist der zum aktuellen Zeitpunkt im laufenden Beschichtungsprozess bereits verstrichene Zeitraum, in dem die Abscheidung/Schichtbildung auf dem Werkstück stattfindet. Sie dient der Prozessführung und -überwachung, insbesondere zur Abschätzung bzw. Regelung der resultierenden Schichtdicke in Abhängigkeit von Stromdichte, Abscheiderate und Wirkungsgrad. Abzugrenzen ist sie von der Soll‑Beschichtungszeit (vorgegebener Zielwert) und der gesamten/abgeschlossenen Beschichtungszeit (Endwert nach Prozessende).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTimeTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTimeTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2020-03; DIN EN ISO 2081:2018-09; DIN EN ISO 2177:2020-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Plating Time Target</rdfs:label>
        <rdfs:label xml:lang="de">Zielwert Beschichtungszeit</rdfs:label>
        <skos:definition xml:lang="de">Der Zielwert der Beschichtungszeit ist der vorgegebene Sollwert für die Dauer eines Beschichtungsvorgangs (z. B. elektrolytische Abscheidung) innerhalb einer Prozessspezifikation oder eines Prüf-/Fertigungsplans. Er dient der reproduzierbaren Einstellung der Schichtbildung und wird in der Regel in Verbindung mit weiteren Prozessparametern (z. B. Stromdichte, Temperatur, Elektrolytzusammensetzung) festgelegt, um die geforderte Schichtdicke bzw. den Schichtauftrag zu erreichen. Abzugrenzen ist er von der tatsächlich erreichten (Ist‑)Beschichtungszeit, die als Mess-/Protokollwert erfasst wird.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTool -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingTool">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Platinum -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Platinum">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Platinum</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Polarity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Polarity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; DIN EN ISO 2080:2022-05; DIN EN ISO 4618:2015-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Polarity</rdfs:label>
        <rdfs:label xml:lang="de">Polarität</rdfs:label>
        <skos:definition xml:lang="de">Polarität ist die Zuordnung eines elektrischen Potentials mit positivem oder negativem Vorzeichen zu einer Elektrode, einem Anschluss oder einem elektrischen Feld in einem elektrochemischen System. In der Galvanotechnik bestimmt die Polarität insbesondere, welches Werkstück als Kathode (negativ) und welche Gegenelektrode als Anode (positiv) betrieben wird und damit die Richtung der elektrochemischen Reaktionen (z. B. Metallabscheidung an der Kathode). Bei Verfahren wie der anodischen Oxidation oder Elektropolieren ist die wirksame Polarität gegenüber der galvanischen Abscheidung umgekehrt, da das Werkstück anodisch betrieben wird.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Polishing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Polishing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MetallographicPreparation"/>
        <rdfs:isDefinedBy>DIN EN ISO 4287:2010-07; DIN EN ISO 1463:2021-08; DIN EN ISO 8407:2021-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Polishing</rdfs:label>
        <skos:definition xml:lang="de">Polieren ist ein mechanisches (ggf. auch chemo‑mechanisches) Feinbearbeitungsverfahren, bei dem eine Oberfläche durch Abtrag sehr kleiner Materialmengen geglättet und auf einen definierten Oberflächenzustand gebracht wird. Hauptzweck ist die Verringerung der Rauheit bzw. das Erzeugen einer reproduzierbaren Oberfläche als Funktions- oder Vorbehandlungszustand, z. B. vor galvanischen Beschichtungen oder für die Gefügebeurteilung. Polieren ist von Schleifen durch den feineren Abtrag und die typischerweise höhere erreichbare Oberflächengüte abzugrenzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingEquipment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingEquipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MetallographicEquipment"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalWorkshopEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4287:2010-07; DIN EN ISO 6507-1:2018-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Poliermaschine</rdfs:label>
        <rdfs:label xml:lang="en">Polishing machine</rdfs:label>
        <skos:definition xml:lang="de">Eine Poliermaschine ist eine Maschine, die Werkstücke oder Proben mittels rotierender oder oszillierender Polierwerkzeuge und geeigneter Poliermittel mechanisch poliert. Ihr Hauptzweck ist das Erzeugen einer definierten Oberflächenbeschaffenheit bzw. das Herstellen einer poliergerechten Oberfläche als Vor- oder Nachbehandlung, z. B. zur Vorbereitung galvanischer Beschichtungen oder zur metallographischen Untersuchung. Je nach Ausführung kann sie manuell oder automatisiert betrieben werden und umfasst typischerweise Antrieb, Werkzeugaufnahme (z. B. Polierscheibe) sowie Einrichtungen zur Dosierung von Poliermitteln.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingPad -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingPad">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2080:2022-08 (Oberflächenbehandlung, metallische und andere anorganische Überzüge — Wörterbuch); DIN EN ISO 1302:2002-07 (Angabe der Oberflächenbeschaffenheit in technischen Zeichnungen — Oberflächenangaben, Regeln und Verfahren)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Polierpad</rdfs:label>
        <rdfs:label xml:lang="en">Polishing Pad</rdfs:label>
        <skos:definition xml:lang="de">Ein Polierpad ist ein meist scheiben- oder kissenförmiges, nachgiebiges Polierwerkzeug bzw. Werkzeugträger (z. B. aus Schaumstoff, Vlies oder Filz), das auf einem Polierteller/Träger montiert wird und beim Polieren mit oder ohne Poliermittel eingesetzt wird. Hauptzweck ist das definierte Einbringen von mechanischer Energie und die gleichmäßige Verteilung von Poliermittel zur Glättung und Erzeugung eines gewünschten Oberflächenzustands vor nachfolgenden galvanischen Prozessen. Abzugrenzen ist es von dem Poliermittel (Abrasiv/Polierpaste) und von starren Schleifwerkzeugen; das Pad wirkt primär über seine Nachgiebigkeit, Struktur und Porosität auf Abtrag und Oberflächenbild.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingSuspensionGrainSize -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingSuspensionGrainSize">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN ISO 13320:2020-06 (Particle size analysis — Laser diffraction methods); ISO 4610:2016 (Plastics — Determination of the particle size distribution of pigments and extenders)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Korngröße der Poliersuspension</rdfs:label>
        <rdfs:label xml:lang="en">Polishing suspension grain size</rdfs:label>
        <skos:definition xml:lang="de">Die Korngröße der Poliersuspension ist die charakteristische Größe (z. B. mittlerer Partikeldurchmesser oder Korngrößenverteilung) der in einer Poliersuspension dispergierten abrasiven Partikel. Sie dient der Festlegung und Kontrolle der Abtrags- und Oberflächenbildungswirkung beim Polieren, da sie maßgeblich Materialabtrag, erreichbare Rauheit und Defektbildung beeinflusst. Je nach Norm/Prüfverfahren wird sie als Verteilung (z. B. d10/d50/d90) und mit einem definierten Messprinzip (z. B. Laserbeugung) angegeben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PolishingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4288:1998-04; DIN EN ISO 6507-1:2018-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Polierzeit</rdfs:label>
        <rdfs:label xml:lang="en">Polishing time</rdfs:label>
        <skos:definition xml:lang="de">Polierzeit ist die festgelegte Zeitdauer, während der ein Werkstück oder eine Probe in einem definierten Polierprozess (z. B. mit bestimmtem Poliermittel, Druck und Relativbewegung) bearbeitet wird. Sie dient der reproduzierbaren Einstellung von Oberflächenzustand bzw. Rauheit/Glanz oder der definierten Materialabtragsmenge, z. B. zur Oberflächenvorbereitung vor dem Beschichten oder zur metallographischen Schliffpräparation. Die Polierzeit ist von der gesamten Prozesszeit zu unterscheiden und ist nur zusammen mit den zugehörigen Prozessparametern eindeutig spezifiziert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Polonium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Polonium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Polonium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Pore -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Pore">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialDefect"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Hohlraum in der Struktur eines Überzugs</rdfs:comment>
        <rdfs:comment xml:lang="en">void in the structure of a coating</rdfs:comment>
        <rdfs:label xml:lang="de">Pore</rdfs:label>
        <rdfs:label xml:lang="en">Pore</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Porosity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Porosity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">&lt;anodic oxidation coating&gt; ratio of the volume of the pores in a given thickness of anodic oxidation coating to the total volume of the coating in that thickness</rdfs:comment>
        <rdfs:comment xml:lang="de">&lt;anodischer Oxidüberzug&gt; Verhältnis des Volumens der Poren  in einer gegebenen Dicke eines anodischen Oxidüberzugs zum Gesamtvolumen des Überzugs in dieser Dicke</rdfs:comment>
        <rdfs:label xml:lang="en">Porosity</rdfs:label>
        <rdfs:label xml:lang="de">Porosität</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PostProcessing -->

