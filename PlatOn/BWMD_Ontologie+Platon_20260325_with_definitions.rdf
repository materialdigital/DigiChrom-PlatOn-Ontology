    </owl:DatatypeProperty>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasValue -->

    <owl:DatatypeProperty rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#hasValue"/>
    


