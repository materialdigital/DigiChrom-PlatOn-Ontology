        <rdfs:label xml:lang="en">Temperature</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureActual -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureActual">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Actual temperature during a process</rdfs:comment>
        <rdfs:comment xml:lang="de">Tatsächliche Temperatur während eines Prozesses</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN 60584-1:2014-07; DIN EN 60751:2009-05; DIN EN IEC 61326-1:2021-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Temperatur IST</rdfs:label>
        <rdfs:label xml:lang="en">Temperature Actual</rdfs:label>
        <skos:definition xml:lang="de">„Temperatur aktuell“ ist der zum betrachteten Zeitpunkt gemessene Istwert der Temperatur eines Mediums oder Prozessbereichs (z. B. Elektrolytbad, Spülbad, Werkstückoberfläche) in einem galvanotechnischen Prozess. Hauptzweck ist die Überwachung und Regelung der Prozessbedingungen, da die Temperatur die Abscheiderate, Schichtbildung und Badchemie maßgeblich beeinflusst. Der Begriff ist als Prozess-/Messwertbezeichnung zu verstehen und von Solltemperatur bzw. Temperaturmittelwert über einen Zeitraum abzugrenzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureAverage -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureAverage">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 1319-1:1995-01, DIN 1319-3:1996-05, DIN EN ISO 80000-1:2022-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Temperatur Mittelwert</rdfs:label>
        <rdfs:label xml:lang="en">Temperature average</rdfs:label>
        <skos:definition xml:lang="de">Der Temperatur Mittelwert ist der nach einer festgelegten Vorschrift (z. B. arithmetisches Mittel) aus mehreren Temperaturmesswerten berechnete Mittelwert. Er dient dazu, einen repräsentativen Temperaturwert für einen definierten Zeitraum, Messort oder Prozesszustand (z. B. Badtemperatur in der Galvanik) anzugeben und Messwertschwankungen zu glätten. Die Berechnungsvorschrift (Mittelungsart, Zeitbezug, Anzahl der Messwerte) muss angegeben werden, da sie den Zahlenwert bestimmt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureControl -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureControl">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Regelung der Temperatur im System oder Prozess.</rdfs:comment>
        <rdfs:comment xml:lang="en">The control of temperature in the system or process.</rdfs:comment>
        <rdfs:label xml:lang="en">Temperature Control</rdfs:label>
        <rdfs:label xml:lang="de">Temperierung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureControlDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureControlDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Das Gerät, das zur Temperaturregelung im System verwendet wird.</rdfs:comment>
        <rdfs:comment xml:lang="en">The device used for temperature control in the system.</rdfs:comment>
        <rdfs:label xml:lang="en">Temperature Control Device</rdfs:label>
        <rdfs:label xml:lang="de">Temperierungsgerät</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureControlManufacturer -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureControlManufacturer">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Supplier"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Der Hersteller des Geräts zur Temperaturregelung.</rdfs:comment>
        <rdfs:comment xml:lang="en">The manufacturer of the temperature control device.</rdfs:comment>
        <rdfs:label xml:lang="en">Temperature Control Manufacturer</rdfs:label>
        <rdfs:label xml:lang="de">Temperierungshersteller</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN IEC 60584-1:2014-07; DIN EN ISO/IEC 17025:2018-03; ISO 80000-5:2019-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Temperatur-Datensatz</rdfs:label>
        <rdfs:label xml:lang="en">Temperature Data Set</rdfs:label>
        <skos:definition xml:lang="de">Ein Temperatur-Datensatz ist eine strukturierte Zusammenstellung aufgezeichneter Temperatur-Messwerte, die einem Messobjekt/-prozess zugeordnet sind und typischerweise Zeitbezug sowie Messbedingungen/Metadaten enthalten. Hauptzweck ist die dokumentierte Überwachung, Rückverfolgbarkeit und Auswertung von Temperaturverläufen (z. B. in galvanotechnischen Bädern, Spülstufen oder Trocknungs-/Wärmebehandlungsprozessen) zur Prozessführung und Qualitätssicherung. Abzugrenzen ist er von einem einzelnen Temperaturmesswert; der Datensatz umfasst i. d. R. mehrere Messwerte und zugehörige Kontextinformationen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMax -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMax">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2021-06; DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Maximale Temperatur</rdfs:label>
        <rdfs:label xml:lang="en">Temperature Maximum</rdfs:label>
        <skos:definition xml:lang="de">Die maximale Temperatur ist der festgelegte höchste zulässige Temperaturwert, der für einen Prozess, ein Bad, ein Werkstück oder ein Produkt unter definierten Bedingungen nicht überschritten werden darf. Hauptzweck ist die Sicherstellung von Prozessstabilität, Qualität und Sicherheit, z. B. zur Vermeidung von Schädigungen (Zersetzung von Elektrolyten, Gefüge-/Eigenschaftsänderungen, Beschichtungsfehler) oder unzulässigen Abweichungen. Sie ist als Grenzwert von Soll-/Betriebstemperatur abzugrenzen und bezieht sich stets auf eine konkret benannte Messstelle bzw. ein definiertes Bezugssystem.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMeasuredByThermocouple -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMeasuredByThermocouple">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CastingQuantity"/>
        <rdfs:label xml:lang="en">TemperatureMeasuredByThermocouple</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Messung der Temperatur im System.</rdfs:comment>
        <rdfs:comment xml:lang="en">The measurement of temperature in the system.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN 60584-1 (VDE 0350-60584-1):2014-07; DIN EN 60751 (VDE 0350-60751):2009-05; DIN EN IEC 60751 (VDE 0350-60751):2023-06; DIN EN 1434-1:2022-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Temperature Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Temperaturmessung</rdfs:label>
        <skos:definition xml:lang="de">Temperaturmessung ist das Bestimmen der Temperatur eines Mediums, Bauteils oder Prozesses mittels geeigneter Messverfahren und Temperaturfühler (z. B. Widerstandsthermometer oder Thermoelemente). Hauptzweck ist die Überwachung und Regelung prozessrelevanter Temperaturen, um definierte Prozessbedingungen (z. B. in galvanischen Bädern) sicherzustellen. Je nach Messaufgabe sind Messunsicherheit, Einbau-/Ankopplungsbedingungen und dynamisches Verhalten des Sensors zu berücksichtigen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMeasurementDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMeasurementDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN IEC 60584-1:2014-07; DIN EN 60751:2009-05; DIN EN ISO/IEC Guide 99:2010-12 (VIM)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Temperature measurement device</rdfs:label>
        <rdfs:label xml:lang="de">Temperaturmessung</rdfs:label>
        <skos:definition xml:lang="de">Temperaturmessung ist die Bestimmung der Temperatur eines Mediums, Körpers oder Prozesses durch Messung mit einem geeigneten Messgerät und zugehörigem Messverfahren. Hauptzweck ist die Erfassung und Überwachung der Temperatur als Messgröße zur Prozessführung, Qualitätssicherung oder Prüfung (z. B. von Elektrolyten, Spülbädern oder Werkstücken). Sie umfasst die Festlegung von Messgröße, Messmethode, Messmittel und Messbedingungen einschließlich Messunsicherheit.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMedium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureMedium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2021-06; DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2017-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Mediumtemperatur</rdfs:label>
        <rdfs:label xml:lang="en">Temperature Medium</rdfs:label>
        <skos:definition xml:lang="de">Mediumtemperatur ist die Temperatur des verwendeten Mediums (z. B. Elektrolyt/Bad, Spülwasser oder Prozesslösung) zum Zeitpunkt der Anwendung bzw. Messung. Sie dient als wesentliche Prozesskenngröße zur Festlegung und Überwachung von Verfahrensbedingungen, da sie Reaktionskinetik, Leitfähigkeit und Abscheide-/Behandlungsergebnis beeinflusst. Abzugrenzen ist sie von der Werkstücktemperatur und der Umgebungstemperatur, die davon abweichen können.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:label xml:lang="en">TemperatureRelatedQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Intended temperature for a process</rdfs:comment>
        <rdfs:comment xml:lang="de">Vorgesehene Temperatur für einen Prozess</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 9000:2015-11; DIN IEC 60050-351:2014-09 (International Electrotechnical Vocabulary – Automatische Regelung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Temperatur SOLL</rdfs:label>
        <rdfs:label xml:lang="en">Temperature Target</rdfs:label>
        <skos:definition xml:lang="de">Der Zielwert Temperatur ist der festgelegte Temperaturwert, auf den ein Prozess (z. B. ein galvanisches Bad oder ein Spül-/Trocknungsschritt) ausgerichtet und geregelt werden soll. Er dient als Referenzgröße für Regelung, Überwachung und Dokumentation der Prozessführung, um reproduzierbare Prozessbedingungen und damit konstante Schichteigenschaften zu erreichen. Vom Grenzwert ist er abzugrenzen, da Grenzwerte zulässige Abweichungsbereiche definieren, während der Zielwert den angestrebten Sollzustand beschreibt.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemporalDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemporalDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <rdfs:label xml:lang="en">TemporalDataSet</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemporalRegion -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemporalRegion">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Occurrent"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">TemporalRegion</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TensileTest -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TensileTest">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalExperiment"/>
        <rdfs:comment>A uniaxial tensile test</rdfs:comment>
        <rdfs:label xml:lang="en">TensileTest</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TensileTestSpecimen -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TensileTestSpecimen">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Specimen"/>
        <rdfs:label xml:lang="en">TensileTestSpecimen</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TensileTestingMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TensileTestingMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectromechanicalTestingMachine"/>
        <rdfs:label xml:lang="en">TensileTestingMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Terbium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Terbium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Terbium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestDuration -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestDuration">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9227:2023-09; DIN EN ISO 16701:2020-02; DIN EN ISO 10289:2000-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Test Duration</rdfs:label>
        <rdfs:label xml:lang="de">Testdauer</rdfs:label>
        <skos:definition xml:lang="de">Die Testdauer ist die festgelegte Zeitspanne, über die eine Prüfung durchgeführt wird bzw. ein Prüfkörper definierten Prüfbedingungen ausgesetzt ist. Ihr Hauptzweck ist die Sicherstellung der Vergleichbarkeit und Reproduzierbarkeit von Prüfergebnissen, indem die zeitliche Beanspruchung eindeutig vorgegeben wird. Je nach Prüfart kann sie als Gesamtdauer oder als Summe definierter Prüfzyklen (z. B. in zyklischen Korrosionsprüfungen) festgelegt sein.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestExecution -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestExecution">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessExecution"/>
        <rdfs:comment>The process of executing any kind of test</rdfs:comment>
        <rdfs:label xml:lang="en">TestExecution</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestFabric -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestFabric">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 105-X12:2016-10 (Textilien – Farbechtheitsprüfungen – Teil X12: Farbechtheit gegen Reiben)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Prüfgewebe</rdfs:label>
        <rdfs:label xml:lang="en">Test Fabric</rdfs:label>
        <skos:definition xml:lang="de">Ein Prüfgewebe ist ein definiertes Gewebe (Textil), das als standardisiertes Prüfmittel in Wisch- oder Abriebprüfungen eingesetzt wird. Hauptzweck ist die reproduzierbare Beanspruchung einer Oberfläche bzw. eines Überzugs, um z. B. Abriebfestigkeit, Abfärben/Übertrag oder Reinigungsbeständigkeit zu beurteilen. Es ist von „Prüfpapier“ oder „Prüfvlies“ abzugrenzen, da Materialart und Oberflächenstruktur des Mediums das Prüfergebnis beeinflussen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestForce -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestForce">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6507-1:2018-07; DIN EN ISO 6506-1:2015-02; DIN EN ISO 4516:2002-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Prüfkraft</rdfs:label>
        <rdfs:label xml:lang="en">Test Force</rdfs:label>
        <skos:definition xml:lang="de">Die Prüfkraft ist die bei einer Prüfung auf ein Prüfobjekt aufgebrachte Kraft, die als definierte Belastungsgröße für die Durchführung und Auswertung der Prüfung festgelegt ist. Ihr Hauptzweck ist die reproduzierbare Erzeugung einer normgerechten Beanspruchung (z. B. beim Härteprüfen oder bei Schichtdickenmessungen mit Eindringkörper/Anpresskraft), um vergleichbare Prüfergebnisse zu erhalten. Sie ist von der resultierenden Kontaktkraft im Messsystem abzugrenzen, sofern diese durch Gerätekinematik oder Reibung beeinflusst wird.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestFrequency -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestFrequency">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9001:2015-11; DIN EN ISO/IEC 17025:2018-03; DIN EN ISO 2178:2016-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Prüffrequenz</rdfs:label>
        <rdfs:label xml:lang="en">Test Frequency</rdfs:label>
        <skos:definition xml:lang="de">Die Prüffrequenz ist die festgelegte Häufigkeit, mit der eine bestimmte Prüfung, Messung oder Überwachung durchgeführt wird (z. B. pro Zeitintervall, pro Los oder pro Stückzahl). Sie dient dazu, die fortlaufende Einhaltung vorgegebener Anforderungen an Prozesse oder Produkte (z. B. Schichtdicke, Haftfestigkeit, Korrosionsverhalten) nachzuweisen und Abweichungen rechtzeitig zu erkennen. Die Prüffrequenz ist abhängig von Risiko, Prozessstabilität und Qualitätsanforderungen und wird typischerweise in Prüfplänen oder Spezifikationen festgelegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestSpecification -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestSpecification">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InformationContentEntity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">A detailed description or document outlining the requirements and procedures for tests.</rdfs:comment>
        <rdfs:comment xml:lang="de">Eine detaillierte Beschreibung oder ein Dokument, das die Anforderungen und Verfahren für Tests festlegt.</rdfs:comment>
        <rdfs:label xml:lang="de">Prüfvorschrift</rdfs:label>
        <rdfs:label xml:lang="en">Test Specification</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestVelocityBackward -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestVelocityBackward">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="de">Prüfgeschwindigkeit rückwärts</rdfs:label>
        <rdfs:label xml:lang="en">Test Velocity Backward</rdfs:label>
        <skos:definition xml:lang="de">Die Prüfgeschwindigkeit rückwärts ist die Geschwindigkeit, mit der ein Prüfgerät bzw. dessen Prüfeinrichtung während der Rückwärtsbewegung (Rückhub/Rücklauf) im Prüfablauf verfährt. Sie dient der Festlegung reproduzierbarer Prüfbedingungen, insbesondere wenn Vorwärts- und Rückwärtsbewegung unterschiedliche Geschwindigkeiten haben oder der Rücklauf Teil der Mess-/Belastungssequenz ist. Abzugrenzen ist sie von der (Vorwärts‑)Prüfgeschwindigkeit im Belastungs- oder Messhub sowie von reinen Rücklaufbewegungen ohne Prüf-/Messfunktion.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestVelocityUpward -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestVelocityUpward">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-12; DIN EN ISO 2360:2017-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Prüfgeschwindigkeit aufwärts</rdfs:label>
        <rdfs:label xml:lang="en">Test Velocity Upward</rdfs:label>
        <skos:definition xml:lang="de">Die Prüfgeschwindigkeit aufwärts ist die Geschwindigkeit, mit der ein Prüfkopf/eine Sonde während einer Messung in aufwärts gerichteter Bewegungsrichtung über eine Prüffläche geführt wird. Sie dient der Festlegung reproduzierbarer Messbedingungen, da die Messwertbildung bei bestimmten Verfahren von der Relativbewegung und deren Richtung/Tempo beeinflusst werden kann. Sie ist von der allgemeinen Prüfgeschwindigkeit zu unterscheiden, indem sie explizit die Bewegungsrichtung „aufwärts“ als Randbedingung festlegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestingMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestingMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ActuatorEquipment"/>
        <rdfs:label xml:lang="en">TestingMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestingTemperature -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestingTemperature">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3270:2018-07; DIN EN ISO 9227:2023-09; DIN EN ISO 2812-1:2017-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Prüftemperatur</rdfs:label>
        <rdfs:label xml:lang="en">Testing Temperature</rdfs:label>
        <skos:definition xml:lang="de">Prüftemperatur ist die festgelegte Temperatur, bei der eine Prüfung durchgeführt wird und unter der die Prüfkörper/Proben während der Prüfung gehalten werden. Sie dient dazu, die Prüfbedingungen zu standardisieren und die Vergleichbarkeit sowie Reproduzierbarkeit von Prüfergebnissen sicherzustellen. Je nach Prüfverfahren kann sie als Sollwert mit zulässiger Toleranz und ggf. mit Konditionierungs-/Ausgleichszeit vor Prüfstart spezifiziert sein.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TestingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9227:2022-02; DIN EN ISO 2178:2016-12; DIN EN ISO 2360:2017-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Prüfzeit</rdfs:label>
        <rdfs:label xml:lang="en">Testing Time</rdfs:label>
        <skos:definition xml:lang="de">Prüfzeit ist die festgelegte Zeitdauer, über die eine Prüfung oder ein Prüfschritt durchgeführt wird bzw. während der ein Prüfkörper definierten Prüfbedingungen ausgesetzt ist. Sie dient der Sicherstellung vergleichbarer und reproduzierbarer Prüfergebnisse, indem die zeitliche Einwirkung (z. B. Belastung, Exposition, Messdauer) eindeutig vorgegeben wird. Je nach Prüfverfahren kann die Prüfzeit als Gesamtdauer der Prüfung oder als Dauer einzelner Prüfabschnitte (z. B. Einwirkzeit) spezifiziert sein.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Texture -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Texture">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quality"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Merkmal des Erscheinungsbildes, der Struktur und anderer Eigenschaften der Oberfläche eines Produkts</rdfs:comment>
        <rdfs:comment xml:lang="en">characteristic of the appearance, structure or other properties of the surface of a product</rdfs:comment>
        <rdfs:label xml:lang="de">Textur</rdfs:label>
        <rdfs:label xml:lang="en">Texture</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Thallium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Thallium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Thallium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermalShockMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermalShockMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2819:2017-02, DIN EN ISO 4624:2016-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Thermal Schock Messung</rdfs:label>
        <rdfs:label xml:lang="en">Thermal shock measurement</rdfs:label>
        <skos:definition xml:lang="de">Eine Thermal Schock Messung ist eine Prüfung, bei der ein beschichtetes/überzogenes Prüfkörper-System definierten, schnellen Temperaturwechseln (z. B. Wechsel zwischen zwei Temperaturbädern oder Klimastufen) ausgesetzt wird. Zweck ist die Bewertung der Haftfestigkeit und Riss-/Abplatzbeständigkeit von galvanischen oder anderen metallischen Überzügen unter thermisch induzierten Spannungen. Die Beurteilung erfolgt typischerweise über visuelle Inspektion und/oder Haftfestigkeitsbewertung nach der Beanspruchung gemäß festgelegten Akzeptanzkriterien.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermoCamera -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermoCamera">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CameraEquipment"/>
        <rdfs:comment>Camera to measure the surface temperature of objects</rdfs:comment>
        <rdfs:label xml:lang="en">ThermoCamera</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermocoupleWire -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermocoupleWire">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Consumable"/>
        <rdfs:comment>A thermocouple is an electrical device consisting of two dissimilar electrical conductors forming an electrical junction. A thermocouple produces a temperature-dependent voltage as a result of the thermoelectric effect, and this voltage can be interpreted to measure temperature. Thermocouples are a widely used type of temperature sensor.</rdfs:comment>
        <rdfs:label xml:lang="en">ThermocoupleWire</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermocoupleWireTypeK -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermocoupleWireTypeK">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermocoupleWire"/>
        <rdfs:comment>Thermocouple of type K</rdfs:comment>
        <rdfs:label xml:lang="en">ThermocoupleWireTypeK</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermophysicalPropertyDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThermophysicalPropertyDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <dc:creator>Christoph Schweizer</dc:creator>
        <rdfs:comment xml:lang="en">subclass of MaterialDataSet containing mechanical properties</rdfs:comment>
        <rdfs:label xml:lang="en">Thermophysical Property DataSet</rdfs:label>
        <foaf:name xml:lang="en">Christoph Schweizer</foaf:name>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessCr -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessCr">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3882:2020-11; DIN EN ISO 2177:2019-06; DIN EN ISO 3497:2000-02; DIN EN ISO 2064:2020-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Chromschichtdicke</rdfs:label>
        <rdfs:label xml:lang="en">Thickness Cr</rdfs:label>
        <skos:definition xml:lang="de">Chromschichtdicke ist die Dicke des aufgebrachten Chromüberzugs auf einem Grundwerkstoff, angegeben als Längenmaß (z. B. in µm). Sie dient zur Spezifikation und Prüfung der funktionalen und/oder dekorativen Eigenschaften des Chromüberzugs (z. B. Verschleiß- und Korrosionsverhalten) sowie zur Einhaltung von Zeichnungs- und Normanforderungen. Die Ermittlung erfolgt nach genormten Schichtdicken-Messverfahren, wobei zwischen lokaler und mittlerer Schichtdicke unterschieden werden kann.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessMeasurementXRF -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessMeasurementXRF">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3497:2000-03, Metallische Überzüge – Messung der Schichtdicke – Röntgenfluoreszenzverfahren; DIN EN ISO 2064:2020-01, Metallische und andere anorganische Überzüge – Begriffe und Definitionen betreffend die Messung der Schichtdicke und die Prüfung der Haftfestigkeit; DIN EN ISO 3613:2021-02, Metallische und andere anorganische Überzüge – Chromat-Umwandlungsüberzüge auf Zink, Aluminium und Cadmium – Prüfverfahren (enthält u. a. Schichtdickenbestimmung per RFA als zulässiges Verfahren, je nach Überzugssystem).</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Schichtdickenmessung (RFA)</rdfs:label>
        <rdfs:label xml:lang="en">Thickness Measurement XRF</rdfs:label>
        <skos:definition xml:lang="de">Schichtdickenmessung (RFA) ist die Bestimmung der Dicke von Beschichtungen mittels Röntgenfluoreszenzanalyse, bei der die durch Primärstrahlung angeregte charakteristische Fluoreszenzstrahlung der Schicht(en) ausgewertet wird. Hauptzweck ist die zerstörungsfreie, materialselektive Ermittlung von Schichtdicken (und häufig auch Zusammensetzungen) insbesondere bei metallischen Überzügen und Mehrschichtsystemen. Die Methode ist ein indirektes Messverfahren, dessen Ergebnis von Kalibrierung/Referenzstandards sowie von Werkstoff- und Geometrieeinflüssen (z. B. Dichte, Legierungsanteile, Schichtaufbau) abhängt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessNi -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessNi">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2020-03; DIN EN ISO 2177:2020-06; DIN EN ISO 2360:2017-12; DIN EN ISO 1456:2020-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Nickelschichtdicke</rdfs:label>
        <rdfs:label xml:lang="en">Thickness Ni</rdfs:label>
        <skos:definition xml:lang="de">Die Nickelschichtdicke ist die Dicke eines aufgebrachten Nickelüberzugs auf einem Grundwerkstoff, angegeben als senkrechter Abstand zwischen der Oberfläche des Überzugs und der Grenzfläche zum Grundwerkstoff (bzw. zur darunterliegenden Schicht). Hauptzweck ist die Festlegung und Prüfung der funktionalen und korrosionsschutzrelevanten Ausführung von Nickelüberzügen durch eine mess- und spezifikationsfähige Kenngröße. Je nach Schichtsystem kann sie als lokale Schichtdicke oder als mittlere Schichtdicke über eine definierte Fläche/Anzahl von Messstellen spezifiziert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThreeDimensionalFieldData -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThreeDimensionalFieldData">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FieldData"/>
        <rdfs:comment>Any kind of three dimensional field data</rdfs:comment>
        <rdfs:label xml:lang="en">ThreeDimensionalFieldData</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThreeDimensionalSpatialRegion -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThreeDimensionalSpatialRegion">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpatialRegion"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoDimensionalSpatialRegion"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ZeroDimensionalSpatialRegion"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">ThreeDimensionalSpatialRegion</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThreeDimensionalXRayComputerTomography -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThreeDimensionalXRayComputerTomography">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTesting"/>
        <rdfs:comment>Three dimensional x-ray computer tomography</rdfs:comment>
        <rdfs:label xml:lang="en">ThreeDimensionalXRayComputerTomography</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Thulium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Thulium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Thulium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Time -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Time">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseQuantityKind"/>
        <rdfs:label xml:lang="en">Time</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimePerStep -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimePerStep">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4042:2018-12; DIN EN ISO 9587:2007-02; DIN EN ISO 9588:2007-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Time per step</rdfs:label>
        <rdfs:label xml:lang="de">Zeit pro Schritt</rdfs:label>
        <skos:definition xml:lang="de">Die Zeit pro Schritt ist die festgelegte Dauer, während der ein einzelner definierter Prozess- oder Prüfschritt (z. B. Beizen, Spülen, Aktivieren, Abscheiden, Passivieren, Trocknen) ausgeführt wird. Sie dient der reproduzierbaren Einstellung und Dokumentation von Prozessbedingungen, um Schichteigenschaften und Prozesssicherheit vergleichbar zu machen. Abzugrenzen ist sie von der Gesamtprozesszeit, die die Summe aller Schrittzeiten einschließlich Transport- und Wartezeiten umfasst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:label xml:lang="en">TimeRelatedQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeToCastingAfterMoldPositioning -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeToCastingAfterMoldPositioning">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeRelatedQuantity"/>
        <rdfs:comment>Time duration until the start of the casting process since the mold has been positioned</rdfs:comment>
        <rdfs:label xml:lang="en">TimeToCastingAfterMoldPositioning</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeToFloodingOfMoldChamber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeToFloodingOfMoldChamber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <rdfs:comment>Time duration until the mold chamber is flooded</rdfs:comment>
        <rdfs:label xml:lang="en">TimeToFloodingOfMoldChamber</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeToInductionSwitchOff -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeToInductionSwitchOff">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <rdfs:comment>Time duration during a casting process until the induction heating system is switched off since the start of the casting process</rdfs:comment>
        <rdfs:label xml:lang="en">TimeToInductionSwitchOff</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tin -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tin">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Tin</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tissue -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tissue">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8502-3:2017-07, DIN EN ISO 8502-4:2017-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Fusselfreies Tuch</rdfs:label>
        <rdfs:label xml:lang="en">Tissue</rdfs:label>
        <skos:definition xml:lang="de">Ein fusselfreies Tuch ist ein Wisch- bzw. Reinigungstuch, das so ausgelegt ist, dass es beim Gebrauch keine oder nur vernachlässigbar wenige Fasern/Partikel (Flusen) freisetzt. Hauptzweck ist die kontaminationsarme Reinigung bzw. das Abwischen von Oberflächen, z. B. vor Beschichtungs- oder Vorbehandlungsprozessen, um Partikelverschleppung und daraus resultierende Oberflächenfehler zu vermeiden. Es ist von gewöhnlichen Textiltüchern abzugrenzen, bei denen Faserabrieb die Sauberkeit und Prozesssicherheit beeinträchtigen kann.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Titanium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Titanium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Titanium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TransmissionElectronMicroscope -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TransmissionElectronMicroscope">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroscopeEquipment"/>
        <rdfs:comment>Transmission electron microscope</rdfs:comment>
        <rdfs:label xml:lang="en">TransmissionElectronMicroscope</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturing"/>
        <rdfs:label xml:lang="en">Treating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TreatmentTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TreatmentTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4042:2019-12; DIN EN ISO 4527:2017-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Behandlungszeit</rdfs:label>
        <rdfs:label xml:lang="en">Treatment Time</rdfs:label>
        <skos:definition xml:lang="de">Behandlungszeit ist die Zeitdauer, während der ein Werkstück einem definierten Behandlungsschritt in einem Prozessbad oder unter festgelegten Prozessbedingungen ausgesetzt ist. Sie dient der gezielten Einstellung des Behandlungsergebnisses (z. B. Schichtdicke, Umwandlungsgrad, Reinigungs- oder Aktivierungswirkung) in Kombination mit weiteren Prozessparametern wie Stromdichte, Temperatur und Badzusammensetzung. Je nach Verfahren kann sie als Verweilzeit/Immersionszeit oder als effektive Zeit unter Strom (bei elektrolytischen Schritten) spezifiziert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TriboTouchHandAbrasionSimulator -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TriboTouchHandAbrasionSimulator">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Tribo Touch Hand Abrasion Simulator</rdfs:label>
        <rdfs:label xml:lang="de">TriboTouch Handsimulator</rdfs:label>
        <skos:definition xml:lang="de">Ein „TriboTouch Handsimulator“ ist ein technisches Prüf- bzw. Messsystem zur Simulation und/oder instrumentierten Erfassung von handähnlichen Kontakt- und Reibvorgängen zwischen einer Oberfläche und einem Prüfkörper. Hauptzweck ist die reproduzierbare Bewertung tribologischer und haptischer Eigenschaften (z. B. Reibung, Gleitverhalten) von beschichteten oder unbehandelten Oberflächen unter definierten Bedingungen. Als Ontologieklasse ist der Begriff von normativ definierten Prüfverfahren (z. B. Reibungsprüfung) abzugrenzen, da er keine genormte Methode, sondern eine gerätespezifische Ausprägung darstellt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TribologicalMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TribologicalMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of friction and wear between surfaces</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung der Reibung und des Verschleißes zwischen Oberflächen</rdfs:comment>
        <rdfs:label xml:lang="en">Tribological Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Tribologische Messung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TribologicalMeasurementTriboTouch -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TribologicalMeasurementTriboTouch">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7148-2:2012-12; DIN EN ISO 20808:2016-06; ASTM G99-17 (2017)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Tribological Measurement Tribo Touch</rdfs:label>
        <rdfs:label xml:lang="de">Tribologische Messung (TriboTouch)</rdfs:label>
        <skos:definition xml:lang="de">Eine tribologische Messung ist die experimentelle Bestimmung von Kenngrößen des tribologischen Systems (z. B. Reibungskoeffizient, Verschleiß) unter definierten Kontakt-, Bewegungs- und Umgebungsbedingungen. Hauptzweck ist die quantitative Bewertung und der Vergleich von Oberflächen, Beschichtungen oder Schmierzuständen hinsichtlich Reibungs- und Verschleißverhalten. „TriboTouch“ bezeichnet dabei typischerweise eine spezifische Messmethode bzw. ein Messgerät/Verfahren zur tribologischen Charakterisierung und ist als Marken-/Systemname von der normativen Verfahrensbeschreibung zu trennen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tribometer -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tribometer">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 20808:2016-12, ASTM G99-17 (Reapproved 2022)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Tribometer</rdfs:label>
        <rdfs:label xml:lang="en">Tribometer</rdfs:label>
        <skos:definition xml:lang="de">Ein Tribometer ist ein Prüfgerät zur experimentellen Bestimmung tribologischer Kenngrößen wie Reibungskoeffizient und Verschleiß unter definierten Kontakt-, Bewegungs- und Umgebungsbedingungen. Hauptzweck ist die vergleichende Bewertung von Werkstoffen, Beschichtungen und Schmierstoffen hinsichtlich ihres Reibungs- und Verschleißverhaltens. Je nach Norm und Anwendung ist das Tribometer an ein spezifisches Prüfprinzip gebunden (z. B. Pin-on-Disc), wodurch Ergebnisse nur innerhalb vergleichbarer Prüfbedingungen direkt gegenüberstellbar sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TrueStrain -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TrueStrain">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRelatedQuantity"/>
        <rdfs:label xml:lang="en">TrueStrain</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TrueStress -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TrueStress">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StressRelatedQuantity"/>
        <rdfs:label xml:lang="en">TrueStress</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tungsten -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Tungsten">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Tungsten</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Turning -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Turning">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachiningWithGeometricallyDeterminedEdge"/>
        <rdfs:label xml:lang="en">Turning</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TurningMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TurningMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalWorkshopEquipment"/>
        <rdfs:comment>A turning machine to perform a turning process</rdfs:comment>
        <rdfs:label xml:lang="en">TurningMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TurningTool -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TurningTool">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Consumable"/>
        <rdfs:comment>The tool used to machine the object within a turning process</rdfs:comment>
        <rdfs:label xml:lang="en">TurningTool</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TurningToolRadius -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TurningToolRadius">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConsumableRelatedQuantity"/>
        <rdfs:comment>The radius at the edge of a turning tool</rdfs:comment>
        <rdfs:label xml:lang="en">TurningToolRadius</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TurntableSpeed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TurntableSpeed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 60050-351:2014-06 (Internationales Elektrotechnisches Wörterbuch – Teil 351: Leittechnik)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Drehtellergeschwindigkeit</rdfs:label>
        <rdfs:label xml:lang="en">Turntable Speed</rdfs:label>
        <skos:definition xml:lang="de">Die Drehtellergeschwindigkeit ist die Rotationsgeschwindigkeit (Drehzahl) eines Drehtellers, z. B. in einer galvanotechnischen Anlage zur Bewegung von Werkstückträgern oder Schüttgut. Sie dient der definierten Relativbewegung zwischen Werkstück und Elektrolyt zur Beeinflussung von Stofftransport, Schichtdickenverteilung und Prozessstabilität. Üblich ist die Angabe als Drehzahl in min⁻¹ (rpm) oder als Winkelgeschwindigkeit in rad·s⁻¹.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoDimensionalContinuantFiatBoundary -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoDimensionalContinuantFiatBoundary">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ContinuantFiatBoundary"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">TwoDimensionalContinuantFiatBoundary</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoDimensionalFieldData -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoDimensionalFieldData">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FieldData"/>
        <rdfs:comment>Any kind of two dimensional field data, e.g. an Excel sheet, a table...</rdfs:comment>
        <rdfs:label xml:lang="en">TwoDimensionalFieldData</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoDimensionalSpatialRegion -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoDimensionalSpatialRegion">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpatialRegion"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">TwoDimensionalSpatialRegion</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoThetaEnd -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoThetaEnd">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 21432:2020-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Two Theta End Value</rdfs:label>
        <rdfs:label xml:lang="de">Zwei Theta Endwert</rdfs:label>
        <skos:definition xml:lang="de">Der Zwei-Theta-Endwert ist der obere Grenzwert des Beugungswinkels 2θ, bis zu dem eine Röntgenbeugungsmessung (XRD) in einem Scan erfasst wird. Er dient der Festlegung des Messbereichs und bestimmt zusammen mit dem Startwert und der Schrittweite/Scanrate, welche Beugungsreflexe im Diffraktogramm erfasst werden. Der Begriff ist ein Scan-Parameter (Messbedingung) und keine Materialkennzahl.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoThetaStart -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoThetaStart">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Two Theta Start Value</rdfs:label>
        <rdfs:label xml:lang="de">Zwei Theta Startwert</rdfs:label>
        <skos:definition xml:lang="de">Der Zwei-Theta-Startwert ist der Anfangswert des Beugungswinkels 2θ in einem Röntgendiffraktometrie‑Messprogramm, ab dem ein Diffraktogramm aufgezeichnet wird. Er dient dazu, den unteren Rand des untersuchten Winkelbereichs festzulegen und damit die erfassten Gitterebenen-/Phaseninformationen (z. B. zur Schichtcharakterisierung galvanischer Überzüge) zu bestimmen. Er ist von galvanotechnischen Startwerten wie Stromdichte‑ oder Potentialrampe abzugrenzen, da er ein Messparameter der XRD‑Analytik ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfAbrasiveWheel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfAbrasiveWheel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 12413:2019-06 (Sicherheit von Schleifkörpern mit Bindung – Schleifkörper für das Schleifen), ISO 525:2013 (Bonded abrasive products — General requirements)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Typ Schleifscheibe</rdfs:label>
        <rdfs:label xml:lang="en">Type Of Abrasive Wheel</rdfs:label>
        <skos:definition xml:lang="de">Der Typ der Schleifscheibe ist die normativ festgelegte Form- bzw. Bauform-Klassifikation einer Schleifscheibe (z. B. gerade Scheibe, Topfscheibe, Schalen-/Tellerscheibe), die über eine Typ-/Formnummer oder -bezeichnung angegeben wird. Er dient der eindeutigen Spezifikation und Auswahl der Schleifscheibe hinsichtlich Geometrie und Einsatz im Schleifprozess sowie der standardisierten Kommunikation in Bestellung, Kennzeichnung und Dokumentation. Der Typ ist von der Spezifikation der Schleifscheibe (z. B. Schleifmittel, Körnung, Bindung, Härte) zu unterscheiden, die separat klassifiziert wird.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfCutOffWheel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfCutOffWheel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 12413:2019-12 (Sicherheit von gebundenen Schleifkörpern), DIN EN ISO 525:2013-06 (Gebundene Schleifmittel – Allgemeine Anforderungen)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Typ der Trennscheibe</rdfs:label>
        <rdfs:label xml:lang="en">Type of cut off wheel</rdfs:label>
        <skos:definition xml:lang="de">Der Typ der Trennscheibe ist eine Klassifikationsangabe, die eine Trennscheibe (gebundene Schleifscheibe zum Trennen) anhand ihrer Bauform und/oder Ausführung eindeutig beschreibt (z. B. flach/gerade oder mit vertieftem Zentrum). Hauptzweck ist die eindeutige Festlegung der passenden Trennscheibe für den vorgesehenen Trennprozess und die sichere, normkonforme Auswahl in Beschaffung und Anwendung. Die Typangabe wird in der Praxis mit weiteren Kenngrößen (z. B. Abmessungen, zulässige Umfangsgeschwindigkeit, Spezifikation des Schleifmittels) kombiniert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfCuttingLubricant -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfCuttingLubricant">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 51385:2018-06; DIN EN ISO 6743-7:2004-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Schneidschmiermittel-Typ</rdfs:label>
        <rdfs:label xml:lang="en">Type of Cutting Lubricant</rdfs:label>
        <skos:definition xml:lang="de">Ein Schneidschmiermittel-Typ ist eine Klassifikation von Schneidschmiermitteln (Metallbearbeitungsflüssigkeiten) nach ihrer stofflichen Art und/oder Anwendungsform, z. B. nichtwassermischbare Schneidöle oder wassermischbare Kühlschmierstoffe (Emulsionen/Lösungen). Zweck der Typisierung ist die eindeutige Zuordnung für Auswahl, Anwendung und Prozessführung bei Zerspan- und Umformprozessen sowie für Anforderungen an Prüfung, Handhabung und Instandhaltung. Die Einteilung kann je nach Normkontext zusätzlich durch Leistungs- und Eigenschaftsmerkmale (z. B. EP/AW-Additivierung, Korrosionsschutz, biologische Stabilität) konkretisiert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfDiffractionDetector -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfDiffractionDetector">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 21432:2020-06 (Zerstörungsfreie Prüfung — Normen und Begriffe für die Röntgenbeugungsprüfung zur Messung von Eigenspannungen)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Beugungsdetektor-Typ</rdfs:label>
        <rdfs:label xml:lang="en">Type of diffraction detector</rdfs:label>
        <skos:definition xml:lang="de">Ein Beugungsdetektor-Typ bezeichnet die Bauart bzw. das Funktionsprinzip eines Detektors, der in Beugungsmessverfahren (insbesondere Röntgenbeugung) die Intensität der gebeugten Strahlung als Messsignal erfasst. Hauptzweck ist die geeignete Detektion und Quantifizierung von Beugungsintensitäten zur Phasen-, Struktur- oder Spannungsanalyse von Werkstoffen und Schichten. Die Typisierung grenzt sich über Detektorprinzipien (z. B. punktförmig/scannend vs. positionssensitiv, zählend vs. integrierend) ab und beeinflusst Messgeometrie, Zählstatistik und Messgeschwindigkeit.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfElectrolyte -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfElectrolyte">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2080:2022-11; DIN EN ISO 2064:2020-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Electrolyte Type</rdfs:label>
        <rdfs:label xml:lang="de">Elektrolytart</rdfs:label>
        <skos:definition xml:lang="de">Elektrolytart ist die Klassifikation eines galvanotechnischen Elektrolyten (Bades) nach seiner chemischen und funktionalen Ausprägung, z. B. sauer, alkalisch oder neutral sowie nach Komplexbildner-/Anionensystem (z. B. Cyanid-, Sulfat-, Chlorid-, Sulfamat-, Pyrophosphat-, Methansulfonat-Elektrolyt). Hauptzweck ist die eindeutige Zuordnung von Prozessbädern, weil die Elektrolytart die Abscheidungsbedingungen und die resultierenden Schichteigenschaften maßgeblich beeinflusst. Sie ist von „Elektrolytzusammensetzung“ (konkrete Konzentrationen) abzugrenzen, da sie eine Typisierung und keine vollständige Rezeptur beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfGrindingPaper -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfGrindingPaper">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6344-1:2013-06; DIN EN ISO 6344-2:2013-06; DIN EN ISO 6344-3:2013-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Typ des Schleifpapiers</rdfs:label>
        <rdfs:label xml:lang="en">Type of grinding paper</rdfs:label>
        <skos:definition xml:lang="de">Der Typ des Schleifpapiers ist die normativ beschreibbare Ausprägung eines beschichteten Schleifmittels in Papierform, festgelegt durch Merkmale wie Schleifkornart, Körnung, Bindung/Bestreuung und Trägermaterial. Hauptzweck ist die eindeutige Spezifikation und Vergleichbarkeit des eingesetzten Schleifmittels für definierte Schleif- bzw. Vorbehandlungsprozesse (z. B. zur Oberflächenvorbereitung vor galvanischen Beschichtungen). Er grenzt sich von der reinen „Körnung“ ab, da er zusätzlich Aufbau- und Materialmerkmale des Schleifmittels umfasst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfIndenter -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfIndenter">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6507-1:2018-07, DIN EN ISO 6506-1:2015-02, DIN EN ISO 6508-1:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Typ des Eindringkörpers</rdfs:label>
        <rdfs:label xml:lang="en">Type of indenter</rdfs:label>
        <skos:definition xml:lang="de">Der Typ des Eindringkörpers ist die festgelegte Ausführung des bei einer Härteprüfung verwendeten Eindringkörpers, insbesondere hinsichtlich Geometrie (z. B. Kugel, Kegel, Pyramide) und Werkstoff (z. B. Diamant, Hartmetall). Er dient der eindeutigen Spezifikation des Prüfmittels und ist maßgeblich für die Vergleichbarkeit und Normkonformität von Härtewerten. Der Typ ist untrennbar mit dem jeweiligen Härteprüfverfahren verknüpft (z. B. Vickers, Brinell, Rockwell) und darf nicht zwischen Verfahren oder Normvorgaben beliebig ausgetauscht werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfLubricant -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfLubricant">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6743-1:2016-12; DIN 51502:2017-06; DIN EN ISO 8681:2012-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Schmierstoffart</rdfs:label>
        <rdfs:label xml:lang="en">Type of Lubricant</rdfs:label>
        <skos:definition xml:lang="de">Eine Schmierstoffart ist eine Kategorie zur Einordnung von Schmierstoffen nach ihrer stofflichen Form bzw. ihrem Aufbau (z. B. Öl, Fett, Paste, Festschmierstoff) und/oder nach ihrer Zusammensetzung (z. B. mineralisch, synthetisch, biologisch abbaubar). Hauptzweck ist die eindeutige Spezifikation eines Schmierstoffs für Auswahl, Anwendung und Dokumentation, insbesondere zur Sicherstellung geeigneter Reibungs- und Verschleißbedingungen. Die Schmierstoffart ist von der Schmierstoffklasse nach ISO 6743 (anwendungsbezogene Klassifikation) abzugrenzen, da „Art“ primär die physikalisch-stoffliche Ausprägung beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfPolishingPad -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfPolishingPad">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1302:2002-02; DIN EN ISO 4287:2010-07; DIN EN ISO 21920-1:2021-12; DIN EN ISO 21920-2:2021-12; DIN EN ISO 21920-3:2021-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Polierpadtyp</rdfs:label>
        <rdfs:label xml:lang="en">Polishing Pad Type</rdfs:label>
        <skos:definition xml:lang="de">Ein Polierpadtyp ist eine Klassifikation von Polierpads nach konstruktiven und werkstofflichen Merkmalen (z. B. Material wie Schaum, Filz, Vlies; Härte/Kompressibilität; Porenstruktur; Oberfläche/Profil), die das Polierverhalten bestimmt. Hauptzweck ist die eindeutige Auswahl und Spezifikation des Polierwerkzeugs für definierte Oberflächenanforderungen in der Vor- bzw. Nachbehandlung galvanischer Schichten. Der Polierpadtyp ist von Poliermittel/Polierpaste (Abrasiv/Träger) zu unterscheiden, da er das Werkzeug und nicht das eingesetzte Schleif-/Polierkorn beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfPolishingSuspension -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfPolishingSuspension">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 16232-1:2018-06; ASTM E3-11(2017)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Typ der Poliersuspension</rdfs:label>
        <rdfs:label xml:lang="en">Type of polishing suspension</rdfs:label>
        <skos:definition xml:lang="de">Der Typ der Poliersuspension ist eine Klassifikationsangabe, die eine Poliersuspension anhand ihres wirksamen Poliermittels und/oder ihrer chemischen Zusammensetzung (z. B. oxidische Suspensionen wie Al₂O₃ oder SiO₂, Diamantsuspensionen) beschreibt. Zweck ist die eindeutige Auswahl und Spezifikation des Poliermediums für definierte Oberflächenzustände bzw. für die metallographische Probenvorbereitung und damit verbundene Anforderungen an Rauheit, Abtrag und Gefügebeeinflussung. Der Typ ist von Parametern wie Korngröße/Konzentration zu unterscheiden, die innerhalb eines Typs variieren können.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfResin -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfResin">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2020-02; DIN EN ISO 4516:2002-10; ASTM E3-11(2017)</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 3696:1995-01; DIN EN ISO 9888:2004-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Typ der Einbettmasse</rdfs:label>
        <rdfs:label xml:lang="en">Type of resin</rdfs:label>
        <skos:definition xml:lang="de">Der Typ der Einbettmasse ist die Klassifikation des für das Einbetten einer Probe verwendeten Einbettmaterials nach seinem System bzw. Aushärtungsmechanismus (z. B. warmhärtend/thermisch, kalteinbettend/reaktiv). Hauptzweck ist die eindeutige Spezifikation der Probenpräparation, um Vergleichbarkeit und Reproduzierbarkeit metallographischer Untersuchungen (z. B. an galvanischen Schichten) sicherzustellen. Der Typ grenzt sich von Parametern wie Einbettverfahren, Mischungsverhältnis oder Aushärtebedingungen ab und beschreibt primär die Materialart.</skos:definition>
        <skos:definition xml:lang="de">Ein Harztyp ist die normativ bzw. fachlich beschreibbare Einordnung eines Harzes nach seiner chemischen Funktionalität und Anwendungseigenschaften (z. B. Kationenaustauscherharz, Anionenaustauscherharz; stark/schwach sauer bzw. basisch). Hauptzweck der Angabe des Harztyps ist die eindeutige Spezifikation des geeigneten Ionenaustauscherharzes für Prozesse wie die Entsalzung/Entionisierung von Prozess- und Spülwasser in der Galvanotechnik. Der Harztyp grenzt die Harzfunktion (Ionenaustauschcharakter) von anderen Harzverwendungen (z. B. Bindemittel-/Beschichtungsharze) ab.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfXRayTube -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TypeOfXRayTube">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3497:2000-12, DIN EN ISO 22489:2016-11, IEC 60613:2010-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Röntgenröhrenart</rdfs:label>
        <rdfs:label xml:lang="en">Type of x-ray tube</rdfs:label>
        <skos:definition xml:lang="de">Eine Röntgenröhrenart ist die klassifizierende Bezeichnung für eine bestimmte Bau- und Ausführungsform einer Röntgenröhre, z. B. nach Anoden-/Targetmaterial, Anodenprinzip (fest/rotierend), Fenster-/Filterausführung oder Geometrie. Sie dient dazu, die Eigenschaften der erzeugten Röntgenstrahlung (Spektrum, Intensität, Strahlgeometrie) und damit die Eignung für ein Mess- oder Prüfverfahren (z. B. RFA in der Schichtdickenmessung) eindeutig festzulegen. In der Galvanotechnik ist die Röntgenröhrenart insbesondere relevant für die Vergleichbarkeit und Rückführbarkeit von Röntgenfluoreszenz-Messergebnissen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#URL -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#URL">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Identifier"/>
        <rdfs:label xml:lang="en">URL</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#URLToFolder -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#URLToFolder">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#URL"/>
        <rdfs:comment>The URL to a folder in a file system</rdfs:comment>
        <rdfs:label xml:lang="en">URLToFolder</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#UniformElongation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#UniformElongation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRelatedQuantity"/>
        <rdfs:label xml:lang="en">UniformElongation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Uniformity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Uniformity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Disposition"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">&lt;Aussehen&gt; sichtbare charakteristische Merkmale eines Überzugs über den gesamten Bereich der wesentlichen Fläche (3.2.193) der/des beschichteten Artikel(s) innerhalb einer Charge oder von Charge zu Charge stimmen innerhalb eines Schwankungsbereichs überein, der durch die Art des Überzugs oder der Veredlung gegeben ist</rdfs:comment>
        <rdfs:comment xml:lang="en">&lt;appearance&gt; visual characteristics of a coating being the same over the entire area of the significant surface (3.2.193) of the coated component(s) within a single batch or batch-to-batch, within the degree of variation typical of the type of coating being applied</rdfs:comment>
        <rdfs:label xml:lang="de">Gleichmäßigkeit</rdfs:label>
        <rdfs:label xml:lang="en">Uniformity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Unit -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Unit">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quality"/>
        <rdfs:label xml:lang="en">Unit</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#UnitSymbol -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#UnitSymbol">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quality"/>
        <rdfs:label xml:lang="en">UnitSymbol</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#UnloadingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#UnloadingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2177:2020-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Entlastungszeit</rdfs:label>
        <rdfs:label xml:lang="en">Unloading time</rdfs:label>
        <skos:definition xml:lang="de">Entlastungszeit ist die definierte Zeitspanne zwischen dem Ende einer Belastung/Beanspruchung bzw. eines Mess- oder Abtragsvorgangs und dem Zeitpunkt, zu dem der nächste Schritt (z. B. Ablesen, Auswerten oder erneutes Belasten) erfolgt. Hauptzweck ist es, zeitabhängige Relaxations- oder Stabilisierungseffekte (z. B. Potential-/Signalstabilisierung, Abklingen transienter Effekte) zu berücksichtigen, um reproduzierbare Ergebnisse zu erhalten. In der Galvanotechnik tritt sie insbesondere als festgelegte Wartezeit in Prüf- und Messabläufen auf und ist von der eigentlichen Prozess- oder Abtragszeit abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VacuumCleaner -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VacuumCleaner">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN IEC 60335-2-2:2021-11 (VDE 0700-2-2), Sicherheit elektrischer Geräte für den Hausgebrauch und ähnliche Zwecke – Teil 2-2: Besondere Anforderungen für Staubsauger und Wassersaugreinigungsgeräte; DIN EN 60312-1:2017-07, Staubsauger für den Hausgebrauch – Teil 1: Trockensauger – Verfahren zur Messung der Gebrauchseigenschaften (IEC 60312-1:2015)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Staubsauger</rdfs:label>
        <rdfs:label xml:lang="en">Vacuum Cleaner</rdfs:label>
        <skos:definition xml:lang="de">Ein Staubsauger ist ein elektrisch betriebenes Sauggerät, das mittels Unterdruck Luft und darin enthaltene Partikel über eine Düse aufnimmt und in einem Behälter oder Filter abscheidet. Hauptzweck ist die Entfernung von Staub und Schmutz von Oberflächen durch Absaugung. In industriellen Anwendungen (z. B. in galvanotechnischen Betrieben) kann er zur Reinigung von Arbeitsbereichen eingesetzt werden, ist jedoch von Absauganlagen zur Erfassung von Prozessabluft (z. B. Nebel/Emissionen) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VacuumSuctionForce -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VacuumSuctionForce">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-4:2020-06; DIN EN ISO 80000-1:2022-09; DIN EN ISO 2787:2022-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Vacuum Suction Force</rdfs:label>
        <rdfs:label xml:lang="de">Vakuum-Saugkraft</rdfs:label>
        <skos:definition xml:lang="de">Vakuum-Saugkraft ist die resultierende Kraft, die durch eine Druckdifferenz zwischen Umgebungsdruck und einem niedrigeren Druck (Unterdruck/Vakuum) auf eine wirksame Fläche entsteht. Sie dient dazu, Werkstücke oder Hilfsmittel durch Ansaugen zu halten, zu positionieren oder zu transportieren, z. B. in Handhabungs- und Spannvorrichtungen in galvanotechnischen Prozessketten. Die Größe ergibt sich idealisiert aus \(F = \Delta p \cdot A\) und ist von der wirksamen Dichtfläche sowie Leckage- und Strömungsverhältnissen abhängig.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Vanadium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Vanadium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Vanadium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Velocity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Velocity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">Velocity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Version -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Version">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InformationContentEntity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Version der verwendeten Software.</rdfs:comment>
        <rdfs:comment xml:lang="en">The version of the software used.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO/IEC 17000:2020-05; DIN EN ISO 9000:2015-11; ISO/IEC Directives, Part 2:2021 (Rules for the structure and drafting of International Standards)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Version</rdfs:label>
        <rdfs:label xml:lang="en">Version</rdfs:label>
        <skos:definition xml:lang="de">Eine Version ist eine eindeutig identifizierte Fassung eines Dokuments, einer Spezifikation, einer Software oder eines Datensatzes, die sich durch definierte Änderungen von anderen Fassungen unterscheidet. Hauptzweck ist die nachvollziehbare Kennzeichnung und Rückverfolgbarkeit des gültigen Inhaltsstands (z. B. für Freigaben, Änderungen und Revisionsstände). Im Normenkontext wird dafür häufig der Begriff „Ausgabe“ (Edition) verwendet, während „Version“ eher als allgemeiner Änderungs- bzw. Revisionsstand genutzt wird.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VickersHardness -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VickersHardness">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6507-1:2018-07, DIN EN ISO 6507-2:2018-07, DIN EN ISO 6507-3:2018-07, DIN EN ISO 6507-4:2018-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Vickers Hardness</rdfs:label>
        <rdfs:label xml:lang="de">Vickershärte</rdfs:label>
        <skos:definition xml:lang="de">Die Vickershärte ist ein Härtekennwert, der aus der Eindruckprüfung mit einer diamantierten, vierseitigen Pyramide (Vickers-Eindringkörper) unter definierter Prüfkraft ermittelt wird und als Verhältnis von Prüfkraft zur Eindruckoberfläche angegeben wird (HV). Hauptzweck ist die vergleichbare Charakterisierung der Härte von Werkstoffen und Schichten, einschließlich dünner galvanischer Überzüge, über verschiedene Prüfkraftbereiche (Makro-, Klein- und Mikrohärte). Die Angabe erfolgt normgerecht mit Härtewert und Prüfbedingungen (z. B. HV 0,1), da Prüfkraft und ggf. Haltezeit das Ergebnis beeinflussen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VickersIndentation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VickersIndentation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Indentation"/>
        <rdfs:comment>An indentation process according to Vickers</rdfs:comment>
        <rdfs:label xml:lang="en">VickersIndentation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VisualAppearance -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VisualAppearance">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 10289:2000-12; DIN EN ISO 2081:2018-09; DIN EN ISO 1463:2021-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Erscheinungsbild</rdfs:label>
        <rdfs:label xml:lang="en">Visual Appearance</rdfs:label>
        <skos:definition xml:lang="de">Erscheinungsbild ist die visuell wahrnehmbare Gesamtheit der Merkmale einer Oberfläche bzw. eines galvanischen Überzugs (z. B. Farbe/Farbton, Glanzgrad, Gleichmäßigkeit, sichtbare Fehlstellen). Hauptzweck ist die qualitative Beurteilung und Festlegung von Anforderungen an die optische Beschaffenheit von beschichteten Teilen im Rahmen der Abnahme und Qualitätsprüfung. Es ist von rein messgrößenbasierten Kenngrößen (z. B. Rauheit, Schichtdicke) abzugrenzen, kann aber durch solche Prüfungen ergänzt werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VisualInspection -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VisualInspection">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CognitiveProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Sichtprüfung zur Beurteilung von Oberflächen oder Materialien</rdfs:comment>
        <rdfs:comment xml:lang="en">Visual inspection to assess surfaces or materials</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 16348:2016-12; DIN EN ISO 1463:2021-08</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 16371:2011-09; DIN EN ISO 10289:2000-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Visual Inspection</rdfs:label>
        <rdfs:label xml:lang="de">Visuelle Prüfung</rdfs:label>
        <skos:definition xml:lang="de">Eine Sichtprüfung ist eine Prüfung durch visuelle Beobachtung (ggf. mit optischen Hilfsmitteln) zur Beurteilung des Zustands oder der Beschaffenheit eines Prüfgegenstands ohne zerstörende Eingriffe. Hauptzweck ist das Erkennen und Bewerten äußerlich erkennbarer Merkmale wie Oberflächenfehler, Unregelmäßigkeiten oder Abweichungen von festgelegten Anforderungen. In der Galvanotechnik wird sie typischerweise zur Beurteilung von Überzügen (z. B. Erscheinungsbild, Fehlstellen) unter definierten Betrachtungsbedingungen eingesetzt.</skos:definition>
        <skos:definition xml:lang="de">Visuelle Inspektion ist eine Prüf- bzw. Bewertungsmethode, bei der die Oberfläche eines Werkstücks oder einer Beschichtung durch Beobachtung mit dem Auge (ggf. mit optischen Hilfsmitteln) auf Merkmale wie Fehler, Unregelmäßigkeiten oder Abweichungen beurteilt wird. Hauptzweck ist die Feststellung der Oberflächenbeschaffenheit und des Erscheinungsbildes (z. B. hinsichtlich Defekten, Gleichmäßigkeit, Verfärbungen) als Teil der Qualitätsprüfung. Sie ist in der Regel eine zerstörungsfreie Prüfung und kann durch festgelegte Betrachtungsbedingungen (z. B. Beleuchtung, Betrachtungsabstand) spezifiziert werden.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoidsBetweenPlatingChromiumAndObject -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoidsBetweenPlatingChromiumAndObject">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 2819:2017-02; DIN EN ISO 4628-2:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Hohlräume zw. Chromschicht und Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Voids Between Plating Chromium And Object</rdfs:label>
        <skos:definition xml:lang="de">Hohlräume zwischen Chromschicht und Objekt sind lokal begrenzte, nicht stoffschlüssig verbundene Bereiche an der Grenzfläche zwischen einem galvanisch abgeschiedenen Chromüberzug und dem Grundwerkstoff bzw. einer darunterliegenden Schicht. Sie führen zu verminderter Haftfestigkeit und können als Blasen/Blister oder als beginnende Ablösung des Überzugs in Erscheinung treten. Solche Hohlstellen sind als Beschichtungsfehler zu bewerten und werden im Rahmen der Prüfung von Haftfestigkeit bzw. der visuellen Beurteilung von Überzugsfehlern erfasst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoidsPlatingChromium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoidsPlatingChromium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 2177:2019-06; DIN EN ISO 1463:2021-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Hohlräume in der Chromschicht</rdfs:label>
        <rdfs:label xml:lang="en">Voids Plating Chromium</rdfs:label>
        <skos:definition xml:lang="de">Hohlräume in der Chromschicht sind lokal begrenzte Volumenfehlstellen (Void-/Kavitätenbereiche) innerhalb eines abgeschiedenen Chromüberzugs, in denen kein zusammenhängendes Chrommaterial vorliegt. Sie wirken als Schichtfehler und können die Dichtheit sowie die Schutz- und Funktionseigenschaften (z. B. Korrosions- und Verschleißverhalten) des Chromüberzugs beeinträchtigen. Von Poren ist abzugrenzen, dass Hohlräume nicht zwingend bis zur Oberfläche oder bis zum Substrat durchgängig offen sein müssen, sondern auch als interne Fehlstellen auftreten können.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Voltage -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Voltage">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:isDefinedBy>DIN EN 61140 (VDE 0140-1):2016-10; DIN EN IEC 60050-121 (VDE 0100-121):2019-10; DIN EN IEC 60050-131 (VDE 0100-131):2021-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Voltage</rdfs:label>
        <skos:definition xml:lang="de">Spannung ist die elektrische Potentialdifferenz zwischen zwei Punkten eines elektrischen Feldes bzw. Stromkreises, definiert als Arbeit pro Ladung. In der Galvanotechnik dient sie als treibende Größe zur Einstellung und Überwachung elektrochemischer Prozesse (z. B. Abscheidung, Auflösung) und wird typischerweise zwischen Elektroden bzw. an der Zelle gemessen. Sie ist von der Elektrodenpotenzialdifferenz zu unterscheiden, da die gemessene Zellspannung zusätzlich ohmsche Spannungsabfälle und Überspannungen umfassen kann.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageActual -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageActual">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Voltage"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Actual voltage during a process</rdfs:comment>
        <rdfs:comment xml:lang="de">Tatsächliche Spannung während eines Prozesses</rdfs:comment>
        <rdfs:label xml:lang="de">Spannung IST</rdfs:label>
        <rdfs:label xml:lang="en">Voltage Actual</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageAverage -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageAverage">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 60050-121 (VDE 0100-200):2012-05; DIN EN 60050-131 (VDE 0100-131):2003-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Spannung Mittelwert</rdfs:label>
        <rdfs:label xml:lang="en">Voltage average</rdfs:label>
        <skos:definition xml:lang="de">Der Spannung-Mittelwert ist der arithmetische Mittelwert der momentanen Spannung über ein festgelegtes Zeitintervall. Er dient zur quantitativen Beschreibung des mittleren elektrischen Potentials bzw. der mittleren Anregung eines Prozesses (z. B. bei zeitabhängigen oder gepulsten Spannungsverläufen) und zur Vergleichbarkeit von Prozessparametern. Von Effektivwert (RMS) und Spitzenwert ist er abzugrenzen, da er die zeitliche Mittelung ohne Quadratisierung beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN ISO 3534-1:2013-12 (Statistik — Begriffe und Formelzeichen — Teil 1: Allgemeine statistische Begriffe und Begriffe der Wahrscheinlichkeit), DIN EN ISO 21748:2013-06 (Leitfaden zur Anwendung von Wiederholbarkeit, Reproduzierbarkeit und Richtigkeitsschätzungen bei der Bewertung von Messergebnissen)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Spannungs-Datensatz</rdfs:label>
        <rdfs:label xml:lang="en">Voltage Data Set</rdfs:label>
        <skos:definition xml:lang="de">Ein Spannungs-Datensatz ist eine geordnete Zusammenstellung von Messwerten der elektrischen Spannung (mit zugehörigen Metadaten wie Zeitstempel, Messstelle, Einheit und Messbedingungen), die während eines galvanotechnischen Prozesses erfasst wird. Hauptzweck ist die dokumentierte und auswertbare Beschreibung des Spannungsverlaufs zur Prozessüberwachung, Rückverfolgbarkeit und Qualitätsbewertung (z. B. im Rahmen der Prozessregelung). Er ist von einem Strom-Datensatz abzugrenzen, der analog Stromwerte beschreibt; in der Praxis werden beide häufig gemeinsam als Prozessdaten geführt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageEndActual -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageEndActual">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Voltage"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN IEC 62485-1:2018-10; DIN EN IEC 62485-2:2018-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Endspannung aktuell</rdfs:label>
        <rdfs:label xml:lang="en">Voltage End Actual</rdfs:label>
        <skos:definition xml:lang="de">Endspannung aktuell ist der momentan gemessene Spannungswert am Ende eines definierten elektrischen Pfades bzw. an den Klemmen eines Verbrauchers/Prozesskreises zum aktuellen Zeitpunkt. Sie dient der laufenden Prozessüberwachung und -regelung, z. B. zur Beurteilung des Betriebszustands einer Stromquelle oder eines elektrochemischen Systems unter Last. Der Zusatz „aktuell“ grenzt den Momentanwert von Soll-, Grenz- oder protokollierten Endspannungswerten (z. B. Endspannung als Abschaltkriterium) ab.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageMax -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageMax">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 60050-151 (VDE 0100-200):2010-06; DIN EN IEC 60050-121 (VDE 0100-121):2022-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Maximale Spannung</rdfs:label>
        <rdfs:label xml:lang="en">VoltageMaximum</rdfs:label>
        <skos:definition xml:lang="de">Maximale Spannung ist der größte zulässige oder auftretende Wert der elektrischen Spannung in einem definierten System, Betriebsmittel oder Prozess unter festgelegten Bedingungen. Hauptzweck ist die Festlegung eines Grenzwerts zur sicheren Auslegung und zum Betrieb (z. B. zur Vermeidung von Überschlägen, Isolationsdurchschlag oder unzulässiger Beanspruchung von Komponenten). Der Begriff ist von Momentanwerten bzw. Effektivwerten abzugrenzen und muss stets mit Bezugsart (DC/AC, Spitze/RMS) und Randbedingungen (Dauer, Last, Umgebung) spezifiziert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageStartActual -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageStartActual">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Voltage"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="de">Startspannung aktuell</rdfs:label>
        <rdfs:label xml:lang="en">Voltage Start Actual</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Startspannung aktuell“ bezeichnet die momentan anliegende elektrische Spannung zu Beginn eines galvanotechnischen Prozessschritts (z. B. beim Einschalten des Gleichrichters oder beim Start einer Strom-/Spannungsrampe) zwischen Anode und Kathode. Zweck ist die Beschreibung bzw. Überwachung des initialen elektrischen Antriebs für den Stromfluss und damit für den Beginn der elektrochemischen Abscheidung unter den aktuellen Bad- und Lastbedingungen. Abzugrenzen ist der Begriff von Sollwerten (parametrierte Startspannung) sowie von Startstrom/-stromdichte, die in der Galvanotechnik üblicher als führende Prozessgrößen verwendet werden.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoltageTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Voltage"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9000:2015-11; DIN EN IEC 60050-131:2015-06; DIN EN IEC 60050-151:2019-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Voltage Target</rdfs:label>
        <rdfs:label xml:lang="de">Zielwert der Spannung</rdfs:label>
        <skos:definition xml:lang="de">Der Zielwert der Spannung ist der vorgegebene Sollwert einer elektrischen Spannung, der in einem Prozess oder einer Prüfung erreicht und eingehalten werden soll. Hauptzweck ist die Festlegung einer Referenzgröße für Regelung, Überwachung und Dokumentation der Spannungsführung (z. B. in elektrochemischen/galvanischen Prozessen oder bei Messungen). Er ist vom Istwert (gemessene Spannung) und von Grenzwerten/Toleranzen (zulässige Abweichungen um den Zielwert) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Volume -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Volume">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:isDefinedBy>DIN EN ISO 80000-3:2020-09 (Größen und Einheiten – Teil 3: Raum und Zeit), DIN EN ISO 80000-1:2023-06 (Größen und Einheiten – Teil 1: Allgemeines)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Volume</rdfs:label>
        <skos:definition xml:lang="de">Volumen ist die physikalische Größe, die den von einem Körper oder einer Stoffmenge eingenommenen dreidimensionalen Raum beschreibt. Es dient zur quantitativen Angabe von Rauminhalten, z. B. von Behältern, Elektrolytmengen oder Bauteilgeometrien in galvanotechnischen Prozessen. Das Volumen ist eine abgeleitete SI-Größe mit der kohärenten Einheit Kubikmeter (m³); gebräuchliche dezimale Vielfache sind z. B. Liter (L) als zur Verwendung mit dem SI zugelassene Einheit.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoxelEdgeLength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#VoxelEdgeLength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <rdfs:comment>Edge length of a voxel</rdfs:comment>
        <rdfs:label xml:lang="en">VoxelEdgeLength</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Wavelength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Wavelength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-3:2020-06; DIN EN ISO 80000-7:2020-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Wavelength</rdfs:label>
        <rdfs:label xml:lang="de">Wellenlänge</rdfs:label>
        <skos:definition xml:lang="de">Die Wellenlänge ist die räumliche Periodenlänge einer Welle, d. h. der Abstand zwischen zwei Punkten gleicher Phase (z. B. zwei aufeinanderfolgenden Maxima) in Ausbreitungsrichtung. In der Galvanotechnik wird sie insbesondere zur eindeutigen Spezifikation von Strahlung in optischen/photometrischen bzw. spektrometrischen Mess- und Prüfverfahren (z. B. UV/Vis) verwendet. Sie steht in Beziehung zu Frequenz und Ausbreitungsgeschwindigkeit (λ = v/f; im Vakuum λ = c/f).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WearDepth -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WearDepth">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 20808:2016-12, DIN EN ISO 4287:2010-07, DIN EN ISO 25178-2:2012-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Verschleißtiefe</rdfs:label>
        <rdfs:label xml:lang="en">Wear Depth</rdfs:label>
        <skos:definition xml:lang="de">Verschleißtiefe ist die durch Verschleiß verursachte Tiefenabnahme bzw. die maximale senkrechte Tiefe einer Verschleißspur relativ zur ursprünglichen Oberfläche eines Werkstücks oder einer Schicht. Sie dient der quantitativen Bewertung des Materialabtrags und damit der Verschleißbeständigkeit, z. B. von galvanischen Überzügen, in definierten Prüfverfahren. Abzugrenzen ist sie von Verschleißvolumen und Massenverlust, die denselben Abtrag volumetrisch bzw. gravimetrisch beschreiben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WeightFraction -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WeightFraction">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CompositionRelatedQuantity"/>
        <rdfs:label xml:lang="en">WeightFraction</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WeightMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WeightMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <rdfs:isDefinedBy>DIN EN ISO 80000-4:2020-07; OIML R 76-1:2006 (Non-automatic weighing instruments – Part 1: Metrological and technical requirements – Tests)</rdfs:isDefinedBy>
        <skos:definition xml:lang="de">Gewichtsmessung ist das Bestimmen der Masse eines Prüfkörpers oder Bauteils durch Wiegen mit einer Waage (Wägeeinrichtung) nach festgelegten Messbedingungen. Hauptzweck ist die Ermittlung von Massenänderungen (z. B. durch Abscheidung oder Abtrag), die in der Galvanotechnik u. a. zur Prozess- und Qualitätsüberwachung sowie zur indirekten Bestimmung von Schichtmassen genutzt werden. Abzugrenzen ist „Gewicht“ als Kraftgröße (Gewichtskraft) von der in der Praxis üblicherweise bestimmten Masse.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WeldedConnection -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WeldedConnection">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProductRelatedFiatObjectPart"/>
        <rdfs:label xml:lang="en">WeldedConnection</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WettingAgent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WettingAgent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Substanz, die die Oberflächenspannung einer Flüssigkeit verringert, sodass sich diese auf einer festen Oberfläche leichter ausbreitet</rdfs:comment>
        <rdfs:comment xml:lang="en">substance that reduces the surface tension of a liquid, thereby causing it to spread more readily on a solid surface</rdfs:comment>
        <rdfs:label xml:lang="de">Netzmittel</rdfs:label>
        <rdfs:label xml:lang="en">Wetting Agent</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Whisker -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Whisker">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingDefect"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">&lt;Galvanotechnik&gt; monokristalline, metallische, faserartige Auswachsung, meist nur mikroskopisch, aber manchmal mehrere Zentimeter Länge erreichend</rdfs:comment>
        <rdfs:comment xml:lang="en">&lt;electroplating&gt; single-crystal metallic filamentary growth, often microscopic but sometimes reaching a length of several centimetres</rdfs:comment>
        <rdfs:label xml:lang="de">Whisker</rdfs:label>
        <rdfs:label xml:lang="en">Whisker</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WhiteLightInterferometry -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WhiteLightInterferometry">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Subprocess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 25178-600:2019-09; DIN EN ISO 25178-604:2013-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Weißlichtinterferometrie</rdfs:label>
        <rdfs:label xml:lang="en">White Light Interferometry</rdfs:label>
        <skos:definition xml:lang="de">Weißlichtinterferometrie ist ein optisches Interferometrieverfahren mit breitbandigem (weißem) Licht zur berührungslosen, flächenhaften Erfassung der Topographie einer Oberfläche durch Auswertung der Interferenzsignale. Hauptzweck ist die Bestimmung von Areal-Oberflächenkenngrößen (3D-Rauheit/Topographie) und Stufenhöhen, z. B. zur Qualitätsprüfung galvanischer Schichten. Charakteristisch ist die hohe vertikale Auflösung bei geringer Kohärenzlänge, wodurch Mehrdeutigkeiten gegenüber monochromatischer Interferometrie reduziert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WireEroding -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WireEroding">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Separating"/>
        <rdfs:comment>Wire eroding (cutting) process</rdfs:comment>
        <rdfs:label xml:lang="en">WireEroding</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WorkPiece -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#WorkPiece">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Material, das galvanisch beschichtet oder auf andere Weise veredelt wird</rdfs:comment>
        <rdfs:comment xml:lang="en">material being electroplated or otherwise finished</rdfs:comment>
        <rdfs:label xml:lang="de">Werkstück</rdfs:label>
        <rdfs:label xml:lang="en">Work Piece</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XCoordinate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XCoordinate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CartesianCoordinate"/>
        <rdfs:comment>X coordinate of cartesian coordinate system</rdfs:comment>
        <rdfs:label xml:lang="en">XCoordinate</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XRFDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XRFDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3497:2000-04, Metallische Überzüge – Messung der Schichtdicke – Röntgenfluoreszenzverfahren; DIN EN ISO 11872:2007-10, Oberflächenbeschaffenheit – Bestimmung der Schichtdicke von Mehrschichtsystemen – Röntgenfluoreszenzverfahren; DIN EN ISO 13032:2012-10, Röntgenspektrometrie – Terminologie; DIN EN ISO 18118:2015-12, Oberflächenchemische Analyse – Terminologie (Begriffe zur Röntgenfluoreszenz/XRF im Kontext der Oberflächenanalyse)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">RFA-Gerät</rdfs:label>
        <rdfs:label xml:lang="en">XRFDevice</rdfs:label>
        <skos:definition xml:lang="de">Ein RFA-Gerät ist ein Messgerät zur zerstörungsarmen elementanalytischen Bestimmung von Zusammensetzung und Schichtsystemen mittels Röntgenfluoreszenz (XRF). Hauptzweck ist die quantitative/qualitative Ermittlung von Elementgehalten, z. B. zur Schichtdicken- und Legierungs-/Beschichtungsanalyse in der Galvanotechnik. Je nach Ausführung (energie- oder wellenlängendispersiv) unterscheidet sich die spektrale Detektion, die Methode bleibt jedoch die Röntgenfluoreszenzanalyse.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XRayDiffractionMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XRayDiffractionMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 15305:2008-02, DIN EN ISO 21432:2020-06, ASTM E915-10(2020)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Röntgenbeugungsmessung</rdfs:label>
        <rdfs:label xml:lang="en">X-Ray diffraction measurement</rdfs:label>
        <skos:definition xml:lang="de">Eine Röntgenbeugungsmessung ist eine Messung, bei der die Beugung von Röntgenstrahlung an kristallinen Strukturen erfasst und ausgewertet wird, um strukturelle Kenngrößen eines Werkstoffs zu bestimmen. Hauptzweck ist die zerstörungsarme Bestimmung von Phasen/Zusammensetzung, Gitterparametern, Textur und/oder Eigenspannungen, z. B. in galvanisch abgeschiedenen metallischen Überzügen. Sie ist von Röntgenfluoreszenzmessungen (XRF) abzugrenzen, die primär die elementare Zusammensetzung über charakteristische Fluoreszenzstrahlung bestimmen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XRayDiffractometer -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XRayDiffractometer">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 15305:2008-02, ASTM E915-10(2020), ASTM E2860-12(2020)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Röntgendiffraktometer</rdfs:label>
        <rdfs:label xml:lang="en">XRay diffractometer</rdfs:label>
        <skos:definition xml:lang="de">Ein Röntgendiffraktometer ist ein Messgerät, das mittels Beugung von Röntgenstrahlung an kristallinen Strukturen ein Diffraktogramm (Intensität in Abhängigkeit vom Beugungswinkel) aufnimmt. Hauptzweck ist die Bestimmung kristallographischer Kenngrößen wie Phasenbestand, Gitterparameter, Textur und/oder Eigenspannungen aus den gemessenen Beugungsmaxima. Typische Ausführungen umfassen Winkelmesssysteme (Goniometer) und Detektoren; abzugrenzen ist es von Röntgenfluoreszenzgeräten, die elementanalytisch ohne Beugungsgeometrie arbeiten.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XRayTube -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#XRayTube">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingEquipment"/>
        <rdfs:comment>An x-ray tube, e.g. used in a computer tomograph</rdfs:comment>
        <rdfs:label xml:lang="en">XRayTube</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Xenon -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Xenon">
