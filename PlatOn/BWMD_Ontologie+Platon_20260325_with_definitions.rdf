        <rdfs:comment xml:lang="de">Mikroriss oder Mikropore in einem Überzug</rdfs:comment>
        <rdfs:comment xml:lang="en">microcrack or micropore in coating</rdfs:comment>
        <rdfs:label xml:lang="en">Microdiscontinuity</rdfs:label>
        <rdfs:label xml:lang="de">Mikrodiskontinuität</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroporousChromium -->

