        <rdfs:label xml:lang="en">Concluding</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConductingSalt -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConductingSalt">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Salz, das einer Lösung zugesetzt wird, um ihre elektrische Leitfähigkeit zu erhöhen</rdfs:comment>
        <rdfs:comment xml:lang="en">salt added to a solution to increase its electrical conductivity</rdfs:comment>
        <rdfs:label xml:lang="en">Conducting Salt</rdfs:label>
        <rdfs:label xml:lang="de">Leitsalz</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Conductivity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Conductivity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Ability of a material to conduct electric current</rdfs:comment>
        <rdfs:comment xml:lang="de">Fähigkeit eines Materials, elektrischen Strom zu leiten</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN 80000-6:2022-02 (Größen und Einheiten – Teil 6: Elektromagnetismus); ISO 7888:1985 (Water quality — Determination of electrical conductivity)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Conductivity</rdfs:label>
        <rdfs:label xml:lang="de">Leitfähigkeit</rdfs:label>
        <skos:definition xml:lang="de">Leitfähigkeit ist die physikalische Größe, die angibt, wie gut ein Material oder eine Lösung elektrischen Strom leitet; sie ist der Kehrwert des spezifischen elektrischen Widerstands. Sie dient in der Galvanotechnik u. a. zur Charakterisierung und Überwachung von Elektrolyten und Prozesswässern, da sie mit der Konzentration und Beweglichkeit gelöster Ionen zusammenhängt. In der Praxis wird sie häufig als spezifische Leitfähigkeit in S/m (oder mS/cm) angegeben und ist temperaturabhängig.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConductivityDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConductivityDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 27888:1993-11 (ISO 7888:1985), DIN EN ISO/IEC 17025:2018-03, DIN EN ISO 11843-1:2017-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Conductivity Data Set</rdfs:label>
        <rdfs:label xml:lang="de">Leitfähigkeits-Datensatz</rdfs:label>
        <skos:definition xml:lang="de">Ein Leitfähigkeits-Datensatz ist eine strukturierte Zusammenstellung von Mess- und Metadaten, die eine Leitfähigkeitsmessung (z. B. elektrolytische Leitfähigkeit einer Lösung) eindeutig beschreibt. Hauptzweck ist die nachvollziehbare Dokumentation, Auswertung und Rückverfolgbarkeit der Leitfähigkeitswerte einschließlich der relevanten Messbedingungen (z. B. Temperatur, Messzelle/Zellkonstante, Kalibrierung). Er grenzt sich von einem einzelnen Messwert dadurch ab, dass er zusätzlich Kontextinformationen zur Messung und Datenintegrität (z. B. Zeitstempel, Probenkennung) umfasst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConductivityMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConductivityMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Subprocess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 27888:1993-11 (entspricht ISO 7888:1985), DIN EN ISO 3696:1995-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Conductivity Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Leitfähigkeitsmessung</rdfs:label>
        <skos:definition xml:lang="de">Leitfähigkeitsmessung ist die Bestimmung der elektrischen Leitfähigkeit einer Lösung als Maß für ihre Fähigkeit, elektrischen Strom durch Ionenleitung zu transportieren. Hauptzweck ist die quantitative Beurteilung der Ionen-/Elektrolytkonzentration und damit die Überwachung und Regelung von Prozessbädern und Spülwässern in der Galvanotechnik. Die Messgröße wird normativ als Leitfähigkeit κ beschrieben und ist von der Leitwertmessung (G) zu unterscheiden, da κ geometrieunabhängig ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConductivityMeasurementDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConductivityMeasurementDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 27888:1993-11 (ISO 7888:1985), Wasserbeschaffenheit – Bestimmung der elektrischen Leitfähigkeit; DIN EN 60746-3:2000-12 (IEC 60746-3:1997), Expression of performance of electrochemical analyzers – Part 3: Electrolytic conductivity analyzers</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Conductivity Measurement Device</rdfs:label>
        <rdfs:label xml:lang="de">Leitfähigkeitsmessgerät</rdfs:label>
        <skos:definition xml:lang="de">Ein Leitfähigkeitsmessgerät ist ein Messgerät zur Bestimmung der elektrischen Leitfähigkeit einer Lösung, üblicherweise durch Auswertung des elektrischen Leitwerts einer Leitfähigkeitszelle und Umrechnung auf die Leitfähigkeit. Hauptzweck ist die Überwachung und Regelung der Bad- und Spülwasserqualität in galvanotechnischen Prozessen (z. B. zur Kontrolle von Salzgehalt, Verunreinigungen oder Konzentrationsänderungen). Häufig umfasst es Temperaturmessung/-kompensation und die Anzeige der Leitfähigkeit bezogen auf eine Referenztemperatur.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Consumable -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Consumable">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProduct"/>
        <rdfs:comment>Consumables are products that consumers use recurrently, i.e., items which &quot;get used up&quot; or discarded.</rdfs:comment>
        <rdfs:label xml:lang="en">Consumable</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConsumableName -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConsumableName">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <rdfs:comment>Name of a consumable</rdfs:comment>
        <rdfs:label xml:lang="en">ConsumableName</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConsumableRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConsumableRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructuralQuantity"/>
        <rdfs:comment>A structural quantity related to some kind of consumable</rdfs:comment>
        <rdfs:label xml:lang="en">ConsumableRelatedQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ContactForce -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ContactForce">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN IEC 60512-3-1:2019-04; DIN EN IEC 61810-7:2019-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Contact Force</rdfs:label>
        <rdfs:label xml:lang="de">Kontaktkraft</rdfs:label>
        <skos:definition xml:lang="de">Kontaktkraft ist die mechanische Kraft, mit der zwei Kontaktpartner (z. B. Kontaktfeder und Gegenkontakt) im Kontaktpunkt gegeneinander gedrückt werden. Sie dient dazu, einen stabilen elektrischen Übergang mit geringerem Kontaktwiderstand sicherzustellen und die Empfindlichkeit gegenüber Erschütterungen, Oxidschichten und Fertigungstoleranzen zu reduzieren. In galvanotechnischen Anwendungen ist sie insbesondere relevant, wenn beschichtete Kontaktoberflächen (z. B. Silber-, Zinn- oder Goldschichten) im Betrieb durch Steck- oder Schaltvorgänge beansprucht werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Continuant -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Continuant">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Entity"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Occurrent"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">Continuant</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ContinuantFiatBoundary -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ContinuantFiatBoundary">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImmaterialEntity"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpatialRegion"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">ContinuantFiatBoundary</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ControlMode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ControlMode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN IEC 60050-351:2014-10 (International Electrotechnical Vocabulary – Regelungstechnik), DIN EN 61131-3:2014-10 (Speicherprogrammierbare Steuerungen – Programmiersprachen; Begriffe zu Betriebsarten/Mode in der Automatisierung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Control mode</rdfs:label>
        <rdfs:label xml:lang="de">Regelmodus</rdfs:label>
        <skos:definition xml:lang="de">Ein Regelmodus ist die festgelegte Betriebs- bzw. Arbeitsweise, in der ein Regelkreis oder Regler arbeitet, insbesondere hinsichtlich der Art der Regelung und der internen Funktionsweise (z. B. Zweipunkt-, P-, PI-, PID-Regelung oder Hand-/Automatikbetrieb). Hauptzweck ist die eindeutige Festlegung, nach welchem Regelgesetz und in welchem Betriebszustand eine Regelgröße geführt wird, um das Prozessverhalten (z. B. in galvanotechnischen Anlagen) reproduzierbar einzustellen. Der Begriff ist als Oberbegriff zu verstehen und sollte in Spezifikationen durch die konkrete Regelungsart bzw. Betriebsart präzisiert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ControlSoftware -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ControlSoftware">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Software"/>
        <rdfs:label xml:lang="en">ControlSoftware</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Convection -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Convection">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Bewegung von Flüssigkeit oder Gas zur Wärmeübertragung.</rdfs:comment>
        <rdfs:comment xml:lang="en">The movement of liquid or gas for heat transfer.</rdfs:comment>
        <rdfs:label xml:lang="en">Convection</rdfs:label>
        <rdfs:label xml:lang="de">Konvektion</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConvectionStrength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConvectionStrength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Strength of convection in a liquid</rdfs:comment>
        <rdfs:comment xml:lang="de">Stärke der Konvektion in einer Flüssigkeit</rdfs:comment>
        <rdfs:label xml:lang="en">Convection Strength</rdfs:label>
        <rdfs:label xml:lang="de">Konvektion Stärke</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cooler -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cooler">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <rdfs:label xml:lang="en">Cooler</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cooling -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cooling">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GenerelExperimentRelatedProcess"/>
        <rdfs:comment>The process of cooling any kind of object</rdfs:comment>
        <rdfs:label xml:lang="en">Cooling</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoolingEmulsionWithWaterAndOil -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoolingEmulsionWithWaterAndOil">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalSolution"/>
        <rdfs:comment>Cooling emulsion containing water and oil used for wire eroding</rdfs:comment>
        <rdfs:label xml:lang="en">CoolingEmulsionWithWaterAndOil</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoolingRate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoolingRate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08 (Korrosion von Metallen und Legierungen – Grundbegriffe und Definitionen)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Abkühlgeschwindigkeit</rdfs:label>
        <rdfs:label xml:lang="en">Cooling rate</rdfs:label>
        <skos:definition xml:lang="de">Die Abkühlgeschwindigkeit ist die zeitliche Änderungsrate der Temperatur eines Körpers oder Systems während des Abkühlens, üblicherweise angegeben als Temperaturabnahme pro Zeiteinheit (z. B. K/s). Sie dient zur quantitativen Beschreibung und Vorgabe thermischer Prozessbedingungen, z. B. beim Abkühlen von Werkstücken oder Prozessbädern, und beeinflusst dadurch resultierende Material- und Schichteigenschaften. Je nach Anwendung kann sie als momentane (dT/dt) oder als mittlere Abkühlgeschwindigkeit über ein definiertes Temperaturintervall festgelegt werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoolingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoolingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9588:2007-06; DIN EN ISO 9587:2007-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Abkühlzeit</rdfs:label>
        <rdfs:label xml:lang="en">Cooling time</rdfs:label>
        <skos:definition xml:lang="de">Die Abkühlzeit ist die festgelegte Zeitspanne, die nach einem thermischen Prozess oder einer Temperaturbeanspruchung abzuwarten ist, bis ein Werkstück, eine Probe oder ein Bauteil auf eine definierte Temperatur (z. B. Umgebungstemperatur oder Prüftemperatur) abgekühlt ist. Sie dient der Sicherstellung reproduzierbarer Prozess- oder Prüfergebnisse, indem Temperaturgradienten und temperaturabhängige Eigenschaften vor der Weiterverarbeitung oder Prüfung stabilisiert werden. In galvanotechnischen Prozessketten kann sie insbesondere zwischen Wärmebehandlungen (z. B. Wasserstoffentsprödungsbehandlung) und nachfolgenden Prüfungen oder Handhabungsschritten festgelegt sein.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoolingWaterConnection -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoolingWaterConnection">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <rdfs:label xml:lang="en">CoolingWaterConnection</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coordinates -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coordinates">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 5459:2011-03, DIN EN ISO 1101:2017-09, DIN EN ISO 10360-1:2000-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Coordinates</rdfs:label>
        <rdfs:label xml:lang="de">Koordinaten</rdfs:label>
        <skos:definition xml:lang="de">Koordinaten sind Zahlenwerte, die die Lage eines Punktes in einem festgelegten Koordinatensystem (z. B. kartesisch) eindeutig beschreiben. Sie dienen dazu, Positionen von Merkmalen, Messpunkten oder Bezugselementen eindeutig anzugeben und damit Geometrie, Ausrichtung und Abstände reproduzierbar zu spezifizieren und zu prüfen. In der galvanotechnischen Praxis werden Koordinaten u. a. zur Definition von Messstellen (z. B. Schichtdickenmesspunkte) und zur Dokumentation von Prüfergebnissen relativ zu festgelegten Bezugsgrößen verwendet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Copper -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Copper">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Copper</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionCurrent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionCurrent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Current caused by corrosion</rdfs:comment>
        <rdfs:comment xml:lang="de">Strom, der durch Korrosion verursacht wird</rdfs:comment>
        <rdfs:label xml:lang="en">Corrosion Current</rdfs:label>
        <rdfs:label xml:lang="de">Korrosionsstrom</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionMeasurementElectrochemical -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionMeasurementElectrochemical">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of corrosion using electrochemical methods</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung der Korrosion durch elektrochemische Methoden</rdfs:comment>
        <rdfs:label xml:lang="en">Corrosion Measurement Electrochemical</rdfs:label>
        <rdfs:label xml:lang="de">Korrosionmessung elektrochem. </rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionMeasurementImpedance -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionMeasurementImpedance">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of corrosion using impedance measurement</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung der Korrosion durch Impedanzmessung</rdfs:comment>
        <rdfs:label xml:lang="en">Corrosion Measurement Impedance</rdfs:label>
        <rdfs:label xml:lang="de">Korrosionmessung Impedanz</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionMeasurementNss -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionMeasurementNss">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of corrosion according to NSS standard</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung der Korrosion nach NSS-Standard</rdfs:comment>
        <rdfs:label xml:lang="en">Corrosion Measurement Nss</rdfs:label>
        <rdfs:label xml:lang="de">Korrosionmessung NSS</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionPotential -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionPotential">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Potential of a material for corrosion</rdfs:comment>
        <rdfs:comment xml:lang="de">Potenzial eines Materials zur Korrosion</rdfs:comment>
        <rdfs:label xml:lang="en">Corrosion Potential</rdfs:label>
        <rdfs:label xml:lang="de">Korrosionspotential</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionProducts -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionProducts">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-07, DIN EN ISO 4628-3:2016-07, DIN EN ISO 9227:2023-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Corrosion Products</rdfs:label>
        <rdfs:label xml:lang="de">Korrosionsprodukte</rdfs:label>
        <skos:definition xml:lang="de">Korrosionsprodukte sind feste, flüssige oder gelartige Stoffe, die infolge einer Korrosionsreaktion aus dem Werkstoff und/oder aus Reaktionspartnern der Umgebung entstehen. Ihr Hauptzweck in der technischen Bewertung ist die Beschreibung und Beurteilung des Korrosionszustands (z. B. Art, Ausmaß und Verteilung von Korrosionsangriffen) sowie möglicher Funktionsbeeinträchtigungen von Oberflächen und Schichten. Korrosionsprodukte sind von Korrosionsschutzschichten zu unterscheiden, da sie ungewollte Reaktionsprodukte des Korrosionsprozesses darstellen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionRate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CorrosionRate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Geschwindigkeit, mit der Korrosion auftritt</rdfs:comment>
        <rdfs:comment xml:lang="en">Rate at which corrosion occurs</rdfs:comment>
        <rdfs:label xml:lang="en">Corrosion Rate</rdfs:label>
        <rdfs:label xml:lang="de">Korrosionsrate</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoverCurrentDensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoverCurrentDensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2080</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cover Current Density</rdfs:label>
        <rdfs:label xml:lang="de">Deckstomdichte</rdfs:label>
        <skos:definition xml:lang="de">Eine initial stark erhöhte kathodische Stromdichte (Stromstoß). Sie wird in der Galvanik eingesetzt, um das Bauteil sofort und flächendeckend mit einer ersten dünnen Metallschicht zu überziehen, bevor die Anoden oder das Werkstück passivieren. Dies ist besonders wichtig für komplexe Geometrien mit Bereichen niedriger lokaler Stromdichte.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoverCurrentTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoverCurrentTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Cover Current Time</rdfs:label>
        <rdfs:label xml:lang="de">Deckstromzeit</rdfs:label>
        <skos:definition xml:lang="de">Die exakte Zeitdauer (meist nur wenige Minuten zu Prozessbeginn), in der das Bauteil im Elektrolyten mit der erhöhten Deckstromdichte belastet wird, bevor der Leistungssteller auf die reguläre Arbeitsstromdichte für den restlichen Schichtaufbau absenkt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coverage -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coverage">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 1456:2020-01; ISO 2177:2013-12 (Metallic coatings — Measurement of coating thickness — Coulometric method by anodic dissolution)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Bedeckung</rdfs:label>
        <rdfs:label xml:lang="en">Coverage</rdfs:label>
        <skos:definition xml:lang="de">Bedeckung bezeichnet in der Galvanotechnik den Grad bzw. die Fähigkeit eines elektrolytisch abgeschiedenen Überzugs, auch in Bereichen mit ungünstiger Stromdichte (z. B. Vertiefungen, Kanten, Innenflächen) eine zusammenhängende Schicht auszubilden. Hauptzweck der Angabe/Prüfung der Bedeckung ist die Beurteilung, ob die geforderte Schutz- oder Funktionswirkung des Überzugs über die gesamte Oberfläche erreicht wird. Bedeckung ist von der Schichtdickenverteilung bzw. „Streu-/Throwing Power“ abzugrenzen, da sie primär das Vorhandensein einer geschlossenen Abscheidung in kritischen Bereichen beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Covering -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Covering">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoveringPower -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoveringPower">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Fähigkeit einer Lösung für die elektrolytische Metallabscheidung (3.1.6), unter bestimmten gegebenen Bedingungen eine geschlossene (durchgängige) Metallschicht auf den Oberflächen in den tiefer gelegenen Bereichen oder in Löchern abzuscheiden</rdfs:comment>
        <rdfs:comment xml:lang="en">ability of an electroplating (3.1.6) solution under a specified set of conditions to deposit a closed (continuous) layer of metal on the surfaces of recessed areas or holes</rdfs:comment>
        <rdfs:label xml:lang="en">Covering Power</rdfs:label>
        <rdfs:label xml:lang="de">Deckfähigkeit</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Crack -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Crack">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialDefect"/>
        <rdfs:label xml:lang="en">Crack</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackAngle -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackAngle">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7539-6:2018-03, Metallische Werkstoffe – Prüfung der Spannungsrisskorrosion – Teil 6: Vorbereitung und Verwendung von vorgekerbten Proben; DIN EN ISO 7539-7:2018-03, Metallische Werkstoffe – Prüfung der Spannungsrisskorrosion – Teil 7: Verfahren zur Bestimmung der Rissausbreitungsgeschwindigkeit mittels vorgekerbter Proben; DIN EN ISO 8044:2020-12, Korrosion von Metallen und Legierungen – Grundbegriffe und Definitionen</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crack angle</rdfs:label>
        <rdfs:label xml:lang="de">Risswinkel</rdfs:label>
        <skos:definition xml:lang="de">Der Risswinkel ist der Winkel, den die Ausbreitungsrichtung eines Risses zu einer festgelegten Bezugsrichtung (z. B. Hauptspannungsrichtung, Probenachse oder Oberfläche/Schichtgrenze) bildet. Er dient der quantitativen Beschreibung der Rissorientierung und damit der Beurteilung von Rissmechanismen (z. B. spröder Bruch, Spannungsrisskorrosion) sowie der Vergleichbarkeit von Prüf- und Schadensbefunden. Die Bezugsrichtung und die Messmethode müssen festgelegt werden, da der Risswinkel sonst nicht eindeutig interpretierbar ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackAngleMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackAngleMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Crack angle measurement</rdfs:label>
        <rdfs:label xml:lang="de">Messung des Risswinkels</rdfs:label>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackArea -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackArea">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6520-1:2009-03; DIN EN ISO 15653:2018-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crack Area</rdfs:label>
        <rdfs:label xml:lang="de">Rissfläche</rdfs:label>
        <skos:definition xml:lang="de">Eine Rissfläche ist die durch Rissbildung entstandene Oberfläche eines Werkstoffs oder einer Schicht, die den Verlauf und die Ausbreitung eines Risses sichtbar macht. Sie dient der Beschreibung und Bewertung von Rissmechanismen (z. B. spröder/duktiler Anteil, interkristalliner/transkristalliner Verlauf) und der Ursachenanalyse von Schädigungen, auch an beschichteten Systemen. Von der Bruchfläche ist sie dadurch abzugrenzen, dass sie sich auf die durch einen Riss erzeugte Fläche bezieht und nicht zwingend den vollständigen Querschnittsversagen/Bruch umfasst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackDensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackDensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08, Metallische und Oxidschichten – Messung der Schichtdicke – Mikroskopisches Verfahren; DIN EN ISO 15749:2005-06, Metallische Überzüge – Messung der Schichtdicke – Röntgenfluoreszenzverfahren (Hinweise zur Bewertung von Überzugszuständen im Messfeld); ISO 8044:2020, Corrosion of metals and alloys — Basic terms and definitions (Grundbegriffe zu Riss/Fehlstellen als Kontext)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crack density</rdfs:label>
        <rdfs:label xml:lang="de">Rissdichte</rdfs:label>
        <skos:definition xml:lang="de">Rissdichte ist ein Kenngrößenmaß für die Häufigkeit von Rissen in einer Schicht oder einem Überzug, ausgedrückt als Anzahl der Risse pro definierter Länge oder Fläche bzw. als Risslänge pro Fläche. Sie dient der quantitativen Bewertung des Risszustands (z. B. bei rissigen Hartchrom- oder anderen funktionellen Überzügen) im Rahmen der Qualitäts- und Funktionsbeurteilung. Die Ermittlung erfolgt typischerweise durch mikroskopische Auswertung an definierten Messfeldern und mit festgelegten Zähl-/Bewertungsregeln.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackDensityMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackDensityMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 15724:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crack density measurement</rdfs:label>
        <rdfs:label xml:lang="de">Messung der Rissdichte</rdfs:label>
        <skos:definition>Determination of the crack density on the longitudinal surface using a photomicrograph</skos:definition>
        <skos:definition xml:lang="de">Die Messung der Rissdichte ist ein Prüfverfahren zur quantitativen Bestimmung der Anzahl von Rissen pro definierter Längeneinheit oder Fläche in einer Schicht bzw. einem Überzug. Hauptzweck ist die Beurteilung der Rissausbildung (z. B. bei mikrorissigen Chromschichten) als Funktionsmerkmal, insbesondere im Hinblick auf Korrosionsverhalten und Schichteigenschaften. Die Ermittlung erfolgt typischerweise durch mikroskopische Auswertung nach geeigneter Präparation/Ätzung und festgelegten Zählregeln.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackDepth -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackDepth">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6520-1:2008-12; DIN EN ISO 3059:2012-10; DIN EN ISO 17635:2016-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crack depth</rdfs:label>
        <rdfs:label xml:lang="de">Risstiefe</rdfs:label>
        <skos:definition xml:lang="de">Die Risstiefe ist die senkrecht zur Oberfläche gemessene Ausdehnung eines Risses von der Bauteil- oder Schichtoberfläche bis zur Rissspitze. Hauptzweck der Angabe ist die quantitative Bewertung der Schädigung (z. B. in Beschichtungen oder Grundwerkstoffen) und die Ableitung von Anforderungen an Prüfung, Zulässigkeit oder Resttragfähigkeit. Je nach Prüfverfahren wird die Risstiefe direkt metallographisch oder indirekt über zerstörungsfreie Prüfmethoden als Fehlertiefe bestimmt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackDepthMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackDepthMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 17643:2016-12 (Zerstörungsfreie Prüfung von Schweißverbindungen – Wirbelstromprüfung – Annahmekriterien), DIN EN ISO 3059:2012-10 (Zerstörungsfreie Prüfung – Eindringprüfung und Magnetpulverprüfung – Betrachtungsbedingungen), DIN EN ISO 23278:2015-12 (Zerstörungsfreie Prüfung von Schweißverbindungen – Magnetpulverprüfung – Annahmekriterien)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crack depth measurement</rdfs:label>
        <rdfs:label xml:lang="de">Risstiefenmessung</rdfs:label>
        <skos:definition xml:lang="de">Risstiefenmessung ist die messtechnische Bestimmung der Tiefe eines Risses (oder einer rissartigen Fehlstelle) bezogen auf eine Bauteiloberfläche bzw. eine definierte Bezugsebene. Hauptzweck ist die quantitative Bewertung der Schädigungsgröße zur Beurteilung der Bauteil- und Schichtintegrität sowie zur Ableitung von Annahmekriterien. Die Messung kann je nach Verfahren zerstörungsfrei (z. B. Wirbelstrom) oder zerstörend/metallographisch (z. B. Schliff/Bruchfläche) erfolgen und ist von der reinen Rissdetektion zu unterscheiden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackNumberMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackNumberMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3882:2003-07, Metallische und andere anorganische Überzüge — Übersicht über Verfahren zur Messung der Dicke; DIN EN ISO 1463:2021-03, Metallische und Oxidschichten — Messung der Schichtdicke — Mikroskopisches Verfahren (Querschliffverfahren); ISO 6158:1982, Metallic coatings — Electrodeposited coatings of chromium for engineering purposes</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crack number measurement</rdfs:label>
        <rdfs:label xml:lang="de">Risszählung</rdfs:label>
        <skos:definition xml:lang="de">Risszählung ist ein Prüf- und Auswerteverfahren zur quantitativen Erfassung der Anzahl von Rissen in einer Schicht oder auf einer Oberfläche innerhalb einer definierten Prüf-/Beobachtungsfläche. Hauptzweck ist die Bestimmung der Rissdichte bzw. die vergleichende Bewertung der Rissneigung und Schichtintegrität (z. B. bei rissigen Chromschichten) unter festgelegten Beobachtungsbedingungen. Die Risszählung erfolgt typischerweise mikroskopisch und ist an definierte Vergrößerung, Auswertefläche und Zählregeln gebunden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackStructure -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackStructure">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quality"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Anordnung und Eigenschaften von Rissen</rdfs:comment>
        <rdfs:comment xml:lang="en">Arrangement and characteristics of cracks</rdfs:comment>
        <rdfs:label xml:lang="en">Crack Structure</rdfs:label>
        <rdfs:label xml:lang="de">Rissstruktur</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackStructureMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackStructureMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; DIN EN ISO 9227:2023-09; DIN EN ISO 10289:2000-12; DIN EN ISO 9587:2007-02; DIN EN ISO 9588:2007-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crack Structure Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Rissstrukturmessung</rdfs:label>
        <skos:definition xml:lang="de">Rissstrukturmessung ist die messtechnische Erfassung und Auswertung der Rissausprägung in einer metallischen Schicht, insbesondere hinsichtlich Anzahl/Dichte, Verteilung und ggf. Orientierung der Risse. Hauptzweck ist die Beurteilung der Schichtintegrität und der Schutzwirkung (z. B. Korrosionsbeständigkeit) sowie die Prozessüberwachung bei rissbehafteten Funktionsschichten. Je nach Anforderung erfolgt die Bestimmung z. B. metallographisch/mikroskopisch an Schliffen oder über genormte Korrosionsindikatorprüfungen, die rissbedingte Durchlässigkeiten sichtbar machen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CracksTotalLength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CracksTotalLength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08, DIN EN ISO 10289:2000-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cracks total length</rdfs:label>
        <rdfs:label xml:lang="de">Gesamtlänge der Risse</rdfs:label>
        <skos:definition xml:lang="de">Die Gesamtlänge der Risse ist die Summe der Längen aller innerhalb eines festgelegten Auswertebereichs erfassten Risse in einer Schicht oder einem Überzug. Sie dient als quantitative Kenngröße zur Beurteilung des Rissausmaßes (Rissdichte/Schädigungsgrad) und zur Vergleichbarkeit von Zuständen, Prozessen oder Prüfbedingungen. Die Ermittlung erfolgt typischerweise auf Basis mikroskopischer Bildauswertung oder Oberflächenprüfung unter definierten Vergrößerungs-, Kontrast- und Auswertebedingungen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Crazing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Crazing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Netzwerk feiner Haarlinienrisse in einem Überzug</rdfs:comment>
        <rdfs:comment xml:lang="en">network of fine hairline cracks in a coating</rdfs:comment>
        <rdfs:label xml:lang="en">Crazing</rdfs:label>
        <rdfs:label xml:lang="de">Haarrissbildung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CriticalCurrentDensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CriticalCurrentDensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">&lt;Galvanotechnik&gt; Stromdichte, bei deren Über- oder Unterschreitung andere und manchmal unerwünschte Reaktionen auftreten</rdfs:comment>
        <rdfs:comment xml:lang="en">&lt;electroplating&gt; current density above or below which, different and sometimes undesirable reactions occur</rdfs:comment>
        <rdfs:label xml:lang="en">Critical Current Density</rdfs:label>
        <rdfs:label xml:lang="de">kritische Stromdichte</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionHeight -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionHeight">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 129-1:2019-03; DIN EN ISO 14405-1:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cross Section Height</rdfs:label>
        <rdfs:label xml:lang="de">Querschnittshöhe</rdfs:label>
        <skos:definition xml:lang="de">Querschnittshöhe ist das Höhenmaß eines betrachteten Querschnitts eines Bauteils oder einer Schicht, gemessen in einer festgelegten Richtung (z. B. senkrecht zur Bezugsfläche) innerhalb einer Schnittdarstellung. Sie dient der eindeutigen geometrischen Beschreibung und Prüfung von Querschnittsgeometrien, z. B. zur Bewertung von Schichtaufbauten oder Profilformen in der Galvanotechnik. Die Querschnittshöhe ist von der Schichtdicke zu unterscheiden, wenn sich das Maß auf die gesamte Querschnittsgeometrie (Substrat und/oder Schichtsystem) und nicht ausschließlich auf die Dicke einer einzelnen Schicht bezieht.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionMicrography -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionMicrography">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08, DIN EN ISO 9220:2020-07, DIN EN ISO 6507-1:2018-07, DIN EN ISO 4287:2010-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cross section micrography</rdfs:label>
        <rdfs:label xml:lang="de">Querschliffmikroskopie</rdfs:label>
        <skos:definition xml:lang="de">Querschliffmikroskopie ist die mikroskopische Untersuchung eines präparierten Querschliffs (metallographischer Schliff) durch ein beschichtetes Bauteil oder eine Probe, um den Schichtaufbau im Schnittbild sichtbar zu machen. Hauptzweck ist die Beurteilung und Messung von Schichtdicke(n), Grenzflächen, Gefüge- und Fehlstellenmerkmalen (z. B. Poren, Risse, Delamination) in galvanischen und anderen Überzügen. Sie ist von reinen Oberflächenmikroskopie-Verfahren dadurch abgegrenzt, dass sie die Schicht im Querschnitt (inkl. Substrat und Grenzfläche) bewertet und eine definierte Präparation erfordert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Preparation of cross-sections for analysis</rdfs:comment>
        <rdfs:comment xml:lang="de">Vorbereitung von Querschnitten für die Analyse</rdfs:comment>
        <rdfs:label xml:lang="en">Cross-Section Preparation</rdfs:label>
        <rdfs:label xml:lang="de">Querschliffpräparation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationCutting -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationCutting">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparation"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; DIN EN ISO 1463:2021-08; ASTM E3-11(2017)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crosssection preparation cutting</rdfs:label>
        <rdfs:label xml:lang="de">Trennen der Querschliffpräparation</rdfs:label>
        <skos:definition xml:lang="de">Das Trennen der Querschliffpräparation ist der Arbeitsschritt, bei dem ein beschichtetes Bauteil oder eine Probe durch Sägen/Trennschleifen so abgetrennt wird, dass eine für den Querschliff geeignete Schnittfläche entsteht. Hauptzweck ist die Gewinnung eines repräsentativen Probenabschnitts ohne unzulässige Gefüge- oder Schichtbeeinflussung (z. B. durch Erwärmung, Verzug, Ausbrüche oder Gratbildung), um nachfolgende Einbett-, Schleif- und Polierschritte sowie die Schichtdicken- und Gefügebeurteilung zu ermöglichen. Dabei sind Trennverfahren und -parameter so zu wählen, dass die Randzone (insbesondere die Beschichtung) nicht beschädigt oder verändert wird.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationEmbedding -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationEmbedding">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparation"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; ASTM E3-11(2017) (Standard Guide for Preparation of Metallographic Specimens)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crosssection preparation embedding</rdfs:label>
        <rdfs:label xml:lang="de">Einbetten der Querschliffpräparation</rdfs:label>
        <skos:definition xml:lang="de">Das Einbetten der Querschliffpräparation ist der Probenpräparationsschritt, bei dem ein Probenstück (z. B. ein beschichtetes Bauteil) in ein Einbettmittel (z. B. Kunstharz) eingebracht und ausgehärtet wird, um einen stabilen Probenkörper für den Querschliff zu erhalten. Hauptzweck ist die mechanische Stabilisierung und definierte Handhabung der Probe, damit nachfolgendes Schleifen/Polieren eine auswertbare Querschnittsfläche (z. B. zur Schichtdicken- und Gefügebeurteilung) ermöglicht. Dabei ist auf eine lage- und kantenstabile Einbettung zu achten, um Ausbrüche, Kantenverrundung oder Spaltbildung an der Schicht/Grundwerkstoff-Grenze zu minimieren.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationGrinding -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationGrinding">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparation"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2020-02; ASTM E3-11(2017)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cross section preparation grinding</rdfs:label>
        <rdfs:label xml:lang="de">Schleifen der Querschliffpräparation</rdfs:label>
        <skos:definition xml:lang="de">Das Schleifen der Querschliffpräparation ist ein mechanischer Abtrags- und Planarisierungsschritt bei der Herstellung eines Querschliffs, bei dem die Probenoberfläche mit Schleifmitteln definierter Körnung bearbeitet wird. Hauptzweck ist das Erzeugen einer ebenen, reproduzierbaren Schlifffläche mit kontrollierter Oberflächenbeschaffenheit als Voraussetzung für nachfolgende Polier- und Untersuchungs-/Messschritte (z. B. Schichtdickenmessung). Dabei werden Schleifparameter und Schleifmittelabfolge so gewählt, dass Verformungen, Riefen und Ausbrüche minimiert und die zu beurteilende Schicht-/Substratgrenze nicht verfälscht wird.</skos:definition>
        <skos:definition>Grinding the crosssection to create a suitable surface for microscopic analysis</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationMounting -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationMounting">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparation"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2020-02; DIN EN ISO 9220:2012-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cross section preparation mounting</rdfs:label>
        <rdfs:label xml:lang="de">Einbetten für Querschliffpräparation</rdfs:label>
        <skos:definition xml:lang="de">Einbetten für Querschliffpräparation ist das Einbringen einer Probe (z. B. eines galvanisch beschichteten Bauteils) in ein Einbettmittel (Warm- oder Kalteinbettung), um einen stabilen Probenkörper für die Herstellung eines Querschliffs zu erzeugen. Hauptzweck ist die mechanische Stabilisierung und Kanten-/Schichtstützung, damit Schleifen und Polieren einen repräsentativen Querschnitt ohne Ausbrüche, Verzug oder Schichtablösungen ermöglichen. Dabei werden Einbettmittel und -verfahren so gewählt, dass die Schicht-/Substratgrenze und die Schichtdicke für die anschließende mikroskopische Bewertung zuverlässig darstellbar sind.</skos:definition>
        <skos:definition>Mounting the crosssection in resin for protection during preparation</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationPolishing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparationPolishing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionPreparation"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 16232-1:2018-12 (Begriffe/Grundlagen der Probenvorbereitung im Kontext technischer Sauberkeit, inkl. Polier-/Bearbeitungsschritte); ASTM E3-11(2017), Standard Guide for Preparation of Metallographic Specimens (anerkannte Fachnorm zur metallographischen Schliff- und Polierpräparation)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Crosssection preparation polishing</rdfs:label>
        <rdfs:label xml:lang="de">Polieren der Querschliffpräparation</rdfs:label>
        <skos:definition xml:lang="de">Polieren der Querschliffpräparation ist der Feinbearbeitungsschritt der metallographischen Präparation eines Querschliffs, bei dem die zuvor geschliffene Probenoberfläche mit geeigneten Poliermitteln und -trägern bis zu einer weitgehend riefen- und verformungsfreien Oberfläche geglättet wird. Hauptzweck ist die Erzeugung einer reproduzierbaren, artefaktarmen Oberfläche zur mikroskopischen Beurteilung von Schichtsystemen (z. B. Schichtdicke, Grenzflächen, Poren/Risse) im Querschnitt. Dabei ist das Verfahren so zu wählen, dass Schichten und Substrat nicht verschmiert, ausgerissen oder selektiv abgetragen werden.</skos:definition>
        <skos:definition>Polishing the crosssection to create a suitable surface for microscopic analysis</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionView -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossSectionView">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08, Metallische und Oxidschichten – Messung der Schichtdicke – Mikroskopisches Verfahren; DIN EN ISO 9220:1988-06, Metallische Überzüge – Messung der Schichtdicke – Rasterelektronenmikroskopisches Verfahren; DIN EN ISO 16700:2016-12, Korrosion von Metallen und Legierungen – Korrosion in künstlichen Atmosphären – Beschleunigte Korrosionsprüfungen mit zyklischer Beanspruchung (Begriffe/Probenbewertung im Kontext metallographischer Querschliffe).</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cross Section View</rdfs:label>
        <rdfs:label xml:lang="de">Schliffbild</rdfs:label>
        <skos:definition xml:lang="de">Ein Schliffbild ist die bildliche Darstellung (z. B. Mikro-/Makroaufnahme) eines präparierten Schliffs einer Probe, die durch Schleifen/Polieren und ggf. Ätzen für die Gefüge- oder Schichtbeurteilung vorbereitet wurde. Es dient der Beurteilung von Aufbau, Dicke, Grenzflächen und Fehlstellen von metallischen Werkstoffen und galvanischen Schichten im Querschliff. Typisch ist die Nutzung in der metallographischen Prüfung zur qualitativen und/oder quantitativen Bewertung (z. B. Schichtdickenmessung, Poren-/Rissbeurteilung).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossheadDisplacement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossheadDisplacement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalTestingRelatedQuantity"/>
        <rdfs:comment>Displacement of the crosshead, e.g. in a tensile test</rdfs:comment>
        <rdfs:label xml:lang="en">CrossheadDisplacement</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossheadDisplacementAfterFracture -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossheadDisplacementAfterFracture">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalTestingRelatedQuantity"/>
        <rdfs:comment>The displacement of the machine crosshead after fracture</rdfs:comment>
        <rdfs:label xml:lang="en">CrossheadDisplacementAfterFracture</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossheadSeparationRate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrossheadSeparationRate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalTestingRelatedQuantity"/>
        <rdfs:comment>Displacement of the crossheads per time (e.g. in a tensile test)</rdfs:comment>
        <rdfs:label xml:lang="en">CrossheadSeparationRate</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrystalStructure -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrystalStructure">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialStructureInfo"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Anordnung der Atome in einem Kristall</rdfs:comment>
        <rdfs:comment xml:lang="en">Arrangement of atoms in a crystal</rdfs:comment>
        <rdfs:label xml:lang="en">Crystal Structure</rdfs:label>
        <rdfs:label xml:lang="de">Kristallstruktur</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrystalStructureAnalysis -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrystalStructureAnalysis">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTesting"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Analyse der Anordnung von Atomen in einem Kristall</rdfs:comment>
        <rdfs:comment xml:lang="en">Analysis of the arrangement of atoms in a crystal</rdfs:comment>
        <rdfs:label xml:lang="en">Crystal Structure Analysis</rdfs:label>
        <rdfs:label xml:lang="de">Kristallstrukturanalyse</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentActual -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentActual">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Actual current during a process</rdfs:comment>
        <rdfs:comment xml:lang="de">Tatsächlicher Strom während eines Prozesses</rdfs:comment>
        <rdfs:label xml:lang="en">Current Actual</rdfs:label>
        <rdfs:label xml:lang="de">Strom IST</rdfs:label>
        <skos:definition xml:lang="de">„Strom aktuell“ ist kein normativ definierter Fachbegriff; in der Galvanotechnik wird damit umgangssprachlich meist der momentan anliegende elektrische Strom (Istwert) in einem Stromkreis bzw. Elektrolyseprozess gemeint. Zweck ist die Beschreibung/Überwachung des aktuellen Prozessstroms als momentaner Messwert, z. B. zur Regelung der Abscheidung über Stromdichte. Abzugrenzen ist dies von „Stromstärke/elektrischer Strom“ als physikalischer Größe sowie von zeitlich gemittelten oder integrierten Größen (Mittelstrom, Ladungsmenge).</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentAverage -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentAverage">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 60050-121 (VDE 0100-200):2012-05, International Electrotechnical Vocabulary (IEV) – Part 121: Electromagnetism (Begriffe zu Mittelwert/average value); ISO 80000-6:2022, Quantities and units — Part 6: Electromagnetism (Größen/Einheiten für elektrische Stromstärke und zeitabhängige Größen)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Current average</rdfs:label>
        <rdfs:label xml:lang="de">Strom Mittelwert</rdfs:label>
        <skos:definition xml:lang="de">Der Strom Mittelwert ist der über ein festgelegtes Zeitintervall gebildete Mittelwert der elektrischen Stromstärke (zeitlicher Mittelwert des Stroms). Er dient zur quantitativen Beschreibung der mittleren Strombelastung bzw. der mittleren elektrochemisch wirksamen Stromzufuhr, z. B. bei gepulsten oder zeitlich veränderlichen Stromverläufen. Er ist vom Effektivwert (RMS) abzugrenzen, der sich auf die äquivalente Wärme-/Leistungswirkung bezieht.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 61131-3 (VDE 0113-3):2014-10; DIN EN 62714-1 (VDE 0800-714-1):2019-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Current Data Set</rdfs:label>
        <rdfs:label xml:lang="de">Strom-Datensatz</rdfs:label>
        <skos:definition xml:lang="de">Ein Strom-Datensatz ist ein strukturierter Satz von Mess- und/oder Sollwertdaten, der elektrische Stromgrößen eines galvanotechnischen Prozesses (z. B. Stromstärke, Stromdichte, zeitlicher Verlauf, Grenzwerte) in definierter Form abbildet. Hauptzweck ist die eindeutige Speicherung, Übertragung und Rückverfolgbarkeit von Strominformationen zur Prozessführung, Qualitätssicherung und Dokumentation. Er ist von allgemeinen Prozessdatensätzen dadurch abgegrenzt, dass sein Informationskern strombezogene elektrische Kenngrößen und deren Zuordnung zu Zeit, Anlage/Bad und Werkstück/Charge ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentDensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentDensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Verhältnis des Stroms auf einer Oberfläche der Elektrode zur Fläche dieser Oberfläche</rdfs:comment>
        <rdfs:comment xml:lang="en">ratio of the current on a surface of an electrode to the area of that surface</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; DIN EN ISO 2064:2020-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Current Density</rdfs:label>
        <rdfs:label xml:lang="de">Stromdichte</rdfs:label>
        <skos:definition xml:lang="de">Stromdichte ist die elektrische Stromstärke bezogen auf die wirksame Elektrodenoberfläche, üblicherweise angegeben in A/dm² oder A/m². Sie dient als zentrale Prozessgröße zur Einstellung und Reproduzierbarkeit elektrochemischer Abscheidungsvorgänge, da sie die Abscheiderate und die Schichteigenschaften maßgeblich beeinflusst. In der Galvanotechnik wird häufig zwischen mittlerer (geometrischer) und lokaler Stromdichte unterschieden, da die Stromverteilung über die Oberfläche nicht homogen sein muss.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentEfficiency -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentEfficiency">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Teil des Stroms, der bei Durchführung einer gegebenen Reaktion entsprechend dem Faradayschen Gesetz wirksam ist</rdfs:comment>
        <rdfs:comment xml:lang="en">proportion of the current that is effective in carrying out a given process in accordance with Faraday&apos;s laws of electrolysis</rdfs:comment>
        <rdfs:label xml:lang="en">Current Efficiency</rdfs:label>
        <rdfs:label xml:lang="de">Wirkungsgrad</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentForm -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentForm">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Art des elektrischen Stroms (z.B. Gleichstrom oder Wechselstrom)</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of electric current (e.g., direct current or alternating current)</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN IEC 60050-131:2015-10 (International Electrotechnical Vocabulary – Teil 131: Schaltungstheorie), DIN EN IEC 60050-551:2017-03 (International Electrotechnical Vocabulary – Teil 551: Leistungselektronik)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Current Form</rdfs:label>
        <rdfs:label xml:lang="de">Stromform</rdfs:label>
        <skos:definition xml:lang="de">Stromform ist die zeitliche Gestalt des elektrischen Stroms (Strom-Zeit-Verlauf) bzw. die Art, wie der Strom über die Zeit bereitgestellt wird (z. B. Gleichstrom, Wechselstrom, pulsierender oder gepulster Strom). Sie dient in der Galvanotechnik dazu, den elektrochemischen Abscheideprozess gezielt zu beeinflussen, insbesondere Abscheiderate, Schichtmorphologie und Stromverteilung. Stromform ist von der Stromstärke zu unterscheiden, da sie nicht den Betrag, sondern den zeitlichen Verlauf und die Periodizität/Impulsung beschreibt.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentMax -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentMax">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 60050-151 (VDE 0100-200):2010-06; DIN EN 60204-1 (VDE 0113-1):2019-06; DIN EN 60364-4-43 (VDE 0100-430):2010-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Current Maximum</rdfs:label>
        <rdfs:label xml:lang="de">Maximale Stromstärke</rdfs:label>
        <skos:definition xml:lang="de">Die maximale Stromstärke ist der größte zulässige elektrische Strom (in Ampere), der in einem festgelegten System, Leiter oder Stromkreis unter definierten Bedingungen auftreten darf. Hauptzweck ist die Begrenzung der elektrischen Belastung zur Einhaltung von Sicherheits-, Funktions- und Qualitätsanforderungen (z. B. Vermeidung unzulässiger Erwärmung oder Überlast). In der Galvanotechnik ist sie von der maximalen Stromdichte zu unterscheiden, da Prozessvorgaben häufig über A/dm² statt über den Gesamtstrom spezifiziert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CurrentTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Intended current for a process</rdfs:comment>
        <rdfs:comment xml:lang="de">Vorgesehener Strom für einen Prozess</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 9000:2015-11; DIN EN IEC 60050-351:2014-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Current Target</rdfs:label>
        <rdfs:label xml:lang="de">Strom SOLL</rdfs:label>
        <skos:definition xml:lang="de">Der Zielwert Strom ist ein vorgegebener Sollwert der elektrischen Stromstärke, auf den ein Prozess (z. B. eine galvanische Abscheidung) geregelt oder eingestellt werden soll. Hauptzweck ist die reproduzierbare Führung der elektrochemischen Reaktion über eine definierte Stromvorgabe (häufig als konstanter Strom oder als zeitabhängiges Stromprofil). Er ist vom Istwert Strom (gemessene Stromstärke) und vom Stromdichte-Zielwert (bezogen auf die wirksame Oberfläche) abzugrenzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CutOffWaveLengthLambda_c -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CutOffWaveLengthLambda_c">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 16610-21:2013-06; DIN EN ISO 4288:1998-04; DIN EN ISO 3274:1998-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cut Off Wave Length Lambda_c</rdfs:label>
        <rdfs:label xml:lang="de">Grenzwellenlänge Lambda_c</rdfs:label>
        <skos:definition xml:lang="de">Die Grenzwellenlänge λc ist ein festgelegter Wellenlängenwert eines Profilfilters, der die Trennung zwischen langwelligen Profilanteilen (z. B. Welligkeit) und kurzwelligen Profilanteilen (z. B. Rauheit) definiert. Sie dient dazu, bei der Auswertung von Oberflächenprofilen die relevanten Rauheitskenngrößen reproduzierbar zu bestimmen, indem der Filter die entsprechenden Frequenzanteile zuordnet. λc ist ein Parameter der Filtereinstellung und ist von der Bewertungs-/Messlänge sowie der gewählten Filterart (z. B. Gauß-Filter) abhängig.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CutOffWaveLengthLambda_s -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CutOffWaveLengthLambda_s">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 16610-21:2013-06, DIN EN ISO 3274:1998-04, DIN EN ISO 4288:1998-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cut Off Wave Length Lambda_s</rdfs:label>
        <rdfs:label xml:lang="de">Grenzwellenlänge Lambda_s</rdfs:label>
        <skos:definition xml:lang="de">Die Grenzwellenlänge λs ist die kurzwellige Grenzwellenlänge des S-Filters (Short-wavelength filter) bei der Profilfilterung von Oberflächenmessdaten. Sie dient dazu, sehr kurzwellige Anteile (z. B. Messrauschen oder sehr feine Oberflächenanteile) zu unterdrücken, bevor weitere Filterungen/Parameterberechnungen (z. B. Rauheits- oder Welligkeitsauswertung) erfolgen. λs ist von der Messaufgabe und dem Messverfahren abhängig und ist von der langwelligen Grenzwellenlänge λc (Trennung Rauheit/Welligkeit) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CutOffWheel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CutOffWheel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>EN 12413:2019, Safety requirements for bonded abrasive products; ISO 525:2013, Bonded abrasive products — General requirements; ISO 6103:2019, Coated abrasives — Discs with centre hole — Dimensions and tolerances</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cut off wheel</rdfs:label>
        <rdfs:label xml:lang="de">Trennscheibe</rdfs:label>
        <skos:definition xml:lang="de">Eine Trennscheibe ist eine rotierende, scheibenförmige Trennwerkzeug-Komponente (z. B. kunstharzgebundene Schleif-/Trennscheibe oder diamantbestückte Scheibe), die in handgeführten oder stationären Maschinen zum Trennen von Werkstoffen eingesetzt wird. Hauptzweck ist das spanende Abtrennen von Proben, Bauteilen oder Abschnittstücken, z. B. zur Probenpräparation für Schichtdickenmessung, metallographische Untersuchungen oder zur Entnahme von Prüfkörpern. Abzugrenzen ist sie von Schleifscheiben (primär zum Abtragen/Schleifen) und von Sägeblättern (gezahnte Trennwerkzeuge).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cutting -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cutting">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 8580:2020-05; DIN 8588:2003-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cutting</rdfs:label>
        <rdfs:label xml:lang="de">Schneiden</rdfs:label>
        <skos:definition xml:lang="de">Schneiden ist ein Fertigungsverfahren zum Trennen eines Werkstücks oder Halbzeugs entlang einer vorgegebenen Schnittlinie durch mechanische, thermische oder andere physikalische Einwirkung. Hauptzweck ist die Herstellung definierter Abmessungen und Kanten als Vorbereitung oder Bestandteil einer Prozesskette, z. B. vor dem Beschichten. In der Galvanotechnik ist Schneiden typischerweise ein vor- oder nachgelagerter Arbeitsschritt (z. B. Zuschnitt, Entgraten), nicht der Beschichtungsprozess selbst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CuttingFeeds -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CuttingFeeds">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 8589:2003-09; DIN 6580:2003-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cutting Feed</rdfs:label>
        <rdfs:label xml:lang="de">Schnittvorschub</rdfs:label>
        <skos:definition xml:lang="de">Schnittvorschub ist der beim Schneiden bzw. bei einem zerspanenden/abtragenden Bearbeitungsvorgang wirksame Vorschub, d. h. die definierte Relativbewegung des Werkzeugs gegenüber dem Werkstück in Vorschubrichtung. Er dient dazu, den Materialabtrag pro Zeit bzw. pro Werkzeugumdrehung/-hub festzulegen und damit Prozesskräfte, Oberflächenqualität und Maßhaltigkeit zu beeinflussen. In galvanotechnischen Prozessketten wird der Begriff typischerweise im Kontext von Vor- oder Nachbearbeitungen (z. B. Entgraten, Schleifen, spanende Bearbeitung) verwendet, nicht als Parameter des elektrochemischen Abscheideprozesses selbst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CuttingLength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CuttingLength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2409:2020-12 (Beschichtungsstoffe – Gitterschnittprüfung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cutting Length</rdfs:label>
        <rdfs:label xml:lang="de">Schnittlänge</rdfs:label>
        <skos:definition xml:lang="de">Schnittlänge ist die definierte Länge eines mit einem Schneidwerkzeug erzeugten Schnittes in einer Beschichtung bzw. auf einer Oberfläche, z. B. im Rahmen eines Haftfestigkeitsprüfverfahrens. Sie dient dazu, die Prüffläche und die Beanspruchung beim Schneiden reproduzierbar festzulegen und damit Prüfergebnisse vergleichbar zu machen. Im Gitterschnittverfahren ist die Schnittlänge durch die geforderte Ausdehnung des Schnittgitters (Anzahl der Schnitte und Schnittabstand) praktisch vorgegeben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CuttingMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CuttingMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MetallographicEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 12100:2011-03; DIN EN ISO 14120:2016-05; DIN EN ISO 2064:2020-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cutting machine</rdfs:label>
        <rdfs:label xml:lang="de">Trennmaschine</rdfs:label>
        <skos:definition xml:lang="de">Eine Trennmaschine ist eine Maschine, die Werkstücke oder Proben durch ein Trennverfahren (z. B. Sägen, Schleifen/Trennschleifen) in definierte Teilstücke zerlegt. Hauptzweck ist das reproduzierbare Abtrennen von Material zur Weiterverarbeitung, Probenpräparation oder zur Entnahme von Prüfkörpern, z. B. für Schichtdicken- oder Gefügeuntersuchungen nach galvanischen Beschichtungsprozessen. Abzugrenzen ist sie von Trennvorrichtungen/Handwerkzeugen ohne maschinellen Antrieb sowie von reinen Zerkleinerungsmaschinen (Brechen/Mahlen).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CuttingSpeed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CuttingSpeed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 6580:2003-09, DIN 6581:1993-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cutting Speed</rdfs:label>
        <rdfs:label xml:lang="de">Schnittgeschwindigkeit</rdfs:label>
        <skos:definition xml:lang="de">Die Schnittgeschwindigkeit ist die Geschwindigkeit der Relativbewegung zwischen Schneide und Werkstück in Richtung der Schnittbewegung, angegeben als Weg pro Zeit (typisch m/min). Sie dient als grundlegender Schnittwert zur Festlegung und Vergleichbarkeit von Zerspanungsbedingungen und beeinflusst u. a. Werkzeugstandzeit, Wärmeentwicklung und Oberflächengüte. Sie ist von Vorschub und Schnitttiefe zu unterscheiden und wird bei rotierenden Prozessen häufig aus Werkstück- bzw. Werkzeugdurchmesser und Drehzahl abgeleitet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cycles -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cycles">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 11997-1:2018-08; DIN EN ISO 16701:2020-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cycles</rdfs:label>
        <rdfs:label xml:lang="de">Zyklen</rdfs:label>
        <skos:definition xml:lang="de">Zyklen sind in der Galvanotechnik wiederkehrende, definierte Abfolgen von Prozess- oder Prüfbedingungen, die als Einheit wiederholt werden. Hauptzweck ist die reproduzierbare Beschreibung und Quantifizierung von wiederholten Abläufen (z. B. Wechsel von Bedingungen in Korrosionsprüfungen oder wiederholte Belastungs-/Expositionsfolgen) zur Bewertung von Schicht- und Systemverhalten. Die genaue Bedeutung (Dauer, Reihenfolge, Parameter) ist stets durch die jeweilige Norm/Prüfvorschrift festgelegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CylindricalTensileTestSpecimen -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CylindricalTensileTestSpecimen">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TensileTestSpecimen"/>
        <rdfs:label xml:lang="en">CylindricalTensileTestSpecimen</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DampingTable -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DampingTable">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 60068-2-6:2008-10; DIN EN 60068-2-64:2009-04; ISO 5344:2004-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Damping Table</rdfs:label>
        <rdfs:label xml:lang="de">Schwingungstisch</rdfs:label>
        <skos:definition xml:lang="de">Ein Schwingungstisch ist eine Prüfeinrichtung, die ein Prüfling definierten mechanischen Schwingungen (z. B. sinusförmig oder breitbandig) mit festgelegter Frequenz und Beschleunigung aussetzt. Hauptzweck ist die Durchführung normierter Schwingungsprüfungen zur Beurteilung der mechanischen Beanspruchbarkeit bzw. Funktions- und Integritätsprüfung von Bauteilen/Verbindungen, was auch für galvanisch beschichtete Teile relevant sein kann. Er ist von Rütteltischen für Prozesszwecke abzugrenzen, da er primär als Mess- und Prüfsystem mit geregelter Anregung und spezifizierten Prüfparametern eingesetzt wird.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataAcquisitionSoftware -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataAcquisitionSoftware">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Software"/>
        <rdfs:label xml:lang="en">DataAcquisitionSoftware</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataEvaluation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataEvaluation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataTransformation"/>
        <rdfs:comment>The process of evaluating some kind of data</rdfs:comment>
        <rdfs:label xml:lang="en">DataEvaluation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataExport -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataExport">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataTransformation"/>
        <rdfs:comment>The process of exporting data (e.g. from a output file generated by some simulation software)</rdfs:comment>
        <rdfs:label xml:lang="en">DataExport</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataReduction -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataReduction">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataTransformation"/>
        <rdfs:label xml:lang="en">DataReduction</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InformationContentEntity"/>
        <rdfs:comment>Any kind of data set</rdfs:comment>
        <rdfs:label xml:lang="en">DataSet</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataTransformation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataTransformation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <rdfs:label xml:lang="en">DataTransformation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DateLastPlating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DateLastPlating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9001:2015-11; DIN EN ISO 10289:2020-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Date Last Plating</rdfs:label>
        <rdfs:label xml:lang="de">Datum letzte Beschichtung</rdfs:label>
        <skos:definition xml:lang="de">Das „Datum letzte Beschichtung“ ist ein Datumsattribut, das den Zeitpunkt angibt, an dem ein Bauteil zuletzt einen Beschichtungsprozess (z. B. galvanische Abscheidung) durchlaufen hat. Es dient der Rückverfolgbarkeit, der Zuordnung zu Prozess-/Prüfaufzeichnungen und der Bewertung von Lager-/Verarbeitungszeiten im Rahmen der Qualitätssicherung. Es ist von allgemeinen Datumsangaben wie Herstell- oder Lieferdatum abzugrenzen, da es spezifisch den letzten Beschichtungsvorgang referenziert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DateLastReactivation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DateLastReactivation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Date Last Reactivation</rdfs:label>
        <rdfs:label xml:lang="de">Datum letzte Reaktivierung</rdfs:label>
        <skos:definition xml:lang="de">Das „Datum letzte Reaktivierung“ ist ein Datumswert, der den Zeitpunkt dokumentiert, an dem ein zuvor deaktivierter oder außer Betrieb gesetzter Zustand (z. B. eines Prozesses, Bades, Anlagen-/Messmittels oder Datensatzes) wieder in den aktiven Betriebs- bzw. Nutzungszustand überführt wurde. Hauptzweck ist die Rückverfolgbarkeit und zeitliche Einordnung von Zustandswechseln im Rahmen von Betriebsführung, Qualitätssicherung und Auditierung. Der Begriff ist von „Datum Inbetriebnahme“ (erstmalige Aktivierung) und „Datum letzte Wartung“ (Instandhaltungsereignis ohne zwingende Reaktivierung) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Deburring -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Deburring">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Posttreatement"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Entfernung von scharfen Kanten und Graten mittels mechanischer, chemischer oder elektrochemischer Verfahren</rdfs:comment>
        <rdfs:comment xml:lang="en">removal of sharp edges and burrs by mechanical, chemical or electrochemical means</rdfs:comment>
        <rdfs:label xml:lang="en">Deburring</rdfs:label>
        <rdfs:label xml:lang="de">Entgratung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Decapitation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Decapitation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Posttreatement"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Das Entfernen eines Teils der Struktur, z. B. das Entfernen einer Schicht.</rdfs:comment>
        <rdfs:comment xml:lang="en">The removal of part of a structure, e.g., the removal of a layer.</rdfs:comment>
        <rdfs:label xml:lang="en">Decapitation</rdfs:label>
        <rdfs:label xml:lang="de">Dekapierung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DecapitationSupplier -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DecapitationSupplier">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Supplier"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Der Anbieter der Dekapierungschemikalien oder -dienste.</rdfs:comment>
        <rdfs:comment xml:lang="en">The supplier of decapitation chemicals or services.</rdfs:comment>
        <rdfs:label xml:lang="en">Decapitation Supplier</rdfs:label>
        <rdfs:label xml:lang="de">Dekapierung Lieferant</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DecapitationTemperature -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DecapitationTemperature">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Temperatur, bei der die Dekapierung stattfindet.</rdfs:comment>
        <rdfs:comment xml:lang="en">The temperature at which decapitation occurs.</rdfs:comment>
        <rdfs:label xml:lang="en">Decapitation Temperature</rdfs:label>
        <rdfs:label xml:lang="de">Dekapierung Temperatur</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DecapitationTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DecapitationTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Zeit, die für die Dekapierung benötigt wird.</rdfs:comment>
        <rdfs:comment xml:lang="en">The time required for decapitation.</rdfs:comment>
        <rdfs:label xml:lang="en">Decapitation Time</rdfs:label>
        <rdfs:label xml:lang="de">Dekapierung Zeit </rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DecorativeChromePlating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DecorativeChromePlating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Plating"/>
        <dc:creator xml:lang="en">Elena G. Trelles</dc:creator>
        <rdfs:comment xml:lang="en">is a process that enhances the appearance and corrosion resistance of various substrates. It involves careful control of parameters and the use of specialized equipment and infrastructure to ensure high-quality results. The process outputs decorative chrome-plated items, along with data on thickness and quality for compliance and quality assurance. (ChatGPT)</rdfs:comment>
        <rdfs:label xml:lang="en">Decorative Chrome Plating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Defects -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Defects">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2021-06; DIN EN ISO 2081:2018-09; DIN EN ISO 4520:2016-12; DIN EN ISO 10289:2000-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Defects</rdfs:label>
        <rdfs:label xml:lang="de">Defekte</rdfs:label>
        <skos:definition xml:lang="de">Defekte sind unerwünschte Abweichungen eines galvanischen Überzugs oder der beschichteten Oberfläche von festgelegten Anforderungen (z. B. hinsichtlich Erscheinungsbild, Kontinuität, Haftfestigkeit oder Schutzwirkung). Ihr Zweck in der Qualitätssicherung ist die Klassifizierung und Bewertung von Abweichungen, um Konformität, Funktion und Korrosionsschutz der Beschichtung zu beurteilen. Defekte werden in der Praxis über definierte Prüf- und Abnahmekriterien sowie über spezifische Fehlerbilder (z. B. Poren, Blasen, Abplatzungen, Risse) erfasst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Degreasing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Degreasing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Entfernung von Fett und Öl von einer Oberfläche</rdfs:comment>
        <rdfs:comment xml:lang="en">removal of grease or oil from a surface</rdfs:comment>
        <rdfs:label xml:lang="en">Degreasing</rdfs:label>
        <rdfs:label xml:lang="de">Entfettung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreasingAgent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreasingAgent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2018-07; ISO 9587:2007-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Degreasing Agent</rdfs:label>
        <rdfs:label xml:lang="de">Enfettungsmittel</rdfs:label>
        <skos:definition xml:lang="de">Ein Enfettungsmittel ist ein chemisches Mittel (z. B. wässrig-alkalisch, neutral oder lösemittelbasiert), das zur Entfernung von Fetten, Ölen und vergleichbaren organischen Verunreinigungen von Werkstückoberflächen eingesetzt wird. Hauptzweck ist die Herstellung einer sauberen, benetzbaren Oberfläche als Voraussetzung für nachfolgende Prozesse wie Beizen, Aktivieren, galvanische Abscheidung oder Beschichten. Enfettungsmittel sind von Beizmitteln abzugrenzen, da sie primär organische Kontaminationen entfernen und nicht gezielt metallische Oxide/Deckschichten lösen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreasingAnodic -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreasingAnodic">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2017-02; ASM Handbook, Volume 5: Surface Engineering, ASM International, 1994 (Abschnitte zur elektrolytischen Reinigung/alkalischen Entfettung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Anodic degreasing</rdfs:label>
        <rdfs:label xml:lang="de">Anodisches Entfetten</rdfs:label>
        <skos:definition xml:lang="de">Anodisches Entfetten ist ein elektrolytisches Reinigungsverfahren, bei dem das Werkstück als Anode in einem wässrigen, meist alkalischen Elektrolyten geschaltet wird, um organische Verunreinigungen (z. B. Öle, Fette) von der Oberfläche zu entfernen. Hauptzweck ist die Herstellung einer sauberen, benetzbaren Oberfläche als Voraussetzung für nachfolgende Prozesse wie Beizen, Aktivieren oder galvanische Abscheidung. Charakteristisch ist die Gasentwicklung an der Anode (Sauerstoff), die die Ablösung von Schmutzfilmen unterstützt; gegenüber kathodischem Entfetten ist die Wasserstoffaufnahme in das Werkstück typischerweise geringer, die Oxidationswirkung kann jedoch empfindliche Oberflächen beeinflussen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreasingCathodic -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreasingCathodic">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4520:2007-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Cathodic degreasing</rdfs:label>
        <rdfs:label xml:lang="de">Kathodisches Entfetten</rdfs:label>
        <skos:definition xml:lang="de">Kathodisches Entfetten ist ein elektrolytisches Reinigungsverfahren, bei dem das Werkstück als Kathode geschaltet wird und in einem alkalischen Elektrolyten unter Stromfluss von Fetten, Ölen und anderen organischen Verunreinigungen befreit wird. Hauptzweck ist die Herstellung einer sauberen, benetzbaren Oberfläche als Voraussetzung für nachfolgende Beschichtungs- oder Konversionsschritte (z. B. galvanische Abscheidung). Charakteristisch ist die Reinigungswirkung durch Wasserstoffentwicklung an der Kathode, wodurch Verunreinigungen gelöst und abgehoben werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreasingImmersion -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreasingImmersion">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4520:2007-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Degreasing Immersion</rdfs:label>
        <rdfs:label xml:lang="de">Immersions Entfetten</rdfs:label>
        <skos:definition xml:lang="de">Immersions Entfetten ist ein Verfahren der wässrigen oder lösemittelbasierten Reinigung, bei dem Werkstücke zur Entfernung von Ölen, Fetten und anderen organischen Verunreinigungen in ein Entfettungsbad eingetaucht werden. Hauptzweck ist die Herstellung einer sauberen, benetzbaren Oberfläche als Voraussetzung für nachfolgende Beiz-, Aktivierungs- und Beschichtungsprozesse (z. B. galvanische Abscheidung). Im Unterschied zu Spritz- oder elektrolytischem Entfetten erfolgt die Reinigungswirkung primär durch chemische Badwirkung (ggf. unterstützt durch Temperatur/Bewegung), nicht durch Strahl- oder Stromwirkung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreeOfOrder -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DegreeOfOrder">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-9:2020-09 (Größen und Einheiten – Teil 9: Physikalische Chemie und Molekularphysik)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Degree of order</rdfs:label>
        <rdfs:label xml:lang="de">Ordnungszahl</rdfs:label>
        <skos:definition xml:lang="de">Die Ordnungszahl ist die Kennzahl eines chemischen Elements, die der Anzahl der Protonen im Atomkern entspricht und das Element eindeutig im Periodensystem festlegt. Sie dient zur eindeutigen Identifikation von Elementen und zur Ableitung grundlegender chemischer Eigenschaften, die u. a. für die Auswahl von Elektrolyten, Anoden-/Kathodenmaterialien und Legierungsbestandteilen relevant sind. Sie ist von der Massenzahl zu unterscheiden, die die Summe aus Protonen und Neutronen beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Deionization -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Deionization">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Entfernen von Ionen</rdfs:comment>
        <rdfs:comment xml:lang="en">removal of ions</rdfs:comment>
        <rdfs:label xml:lang="en">Deionization</rdfs:label>
        <rdfs:label xml:lang="de">Entionisierung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Delamination -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Delamination">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4628-8:2012-10; DIN EN ISO 2409:2020-12; DIN EN ISO 6272-1:2012-11</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 4628-8:2013-12; DIN EN ISO 2409:2020-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Delamination</rdfs:label>
        <rdfs:label xml:lang="en">Delamination</rdfs:label>
        <skos:definition xml:lang="de">Delamination ist das Ablösen bzw. die Trennung einer Beschichtung oder eines Schichtsystems von einer angrenzenden Schicht oder vom Grundwerkstoff entlang einer Grenzfläche. Hauptzweck der Begriffsverwendung ist die eindeutige Benennung eines Haftungs- bzw. Schichtverbundversagens als Beschichtungsfehler/Schadensbild. Abzugrenzen ist Delamination von kohäsivem Bruch innerhalb der Beschichtung (Schichtbruch) sowie von Blasenbildung, bei der eine lokale Ablösung mit Hohlraumbildung vorliegt.</skos:definition>
        <skos:definition xml:lang="de">Delamination ist eine Form des Haftungsversagens, bei der sich eine oder mehrere Schichten eines Schichtsystems (z. B. metallische Überzüge oder organische Beschichtungen) flächig voneinander oder vom Grundwerkstoff ablösen. Hauptzweck der Begriffsverwendung ist die eindeutige Benennung und Bewertung eines charakteristischen Schadens-/Fehlerbildes im Rahmen der Qualitätsprüfung von Überzügen. Abzugrenzen ist Delamination von lokaler Blasenbildung (Blistering) und von Rissbildung, da Delamination typischerweise als schichtweises, flächiges Ablösen entlang einer Grenzfläche auftritt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DeltaE00 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DeltaE00">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-6:2016-12 (Farbmetrik — Teil 6: CIEDE2000-Farbabstandsformel)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Delta E00</rdfs:label>
        <rdfs:label xml:lang="de">Farbunterschied ΔE00</rdfs:label>
        <skos:definition xml:lang="de">Der Farbunterschied ΔE00 ist ein nach der CIEDE2000-Formel berechnetes Maß für den wahrgenommenen Unterschied zwischen zwei Farben im CIE-L*a*b*-Farbraum. Er dient der quantitativen Bewertung und Spezifikation von Farbabweichungen, z. B. zur Qualitätskontrolle farbiger galvanischer Überzüge oder dekorativer Oberflächen. ΔE00 berücksichtigt u. a. unterschiedliche Wahrnehmungsempfindlichkeiten für Helligkeit, Buntheit und Farbton und ist gegenüber älteren ΔE-Formeln (z. B. ΔE*ab) besser an die visuelle Wahrnehmung angepasst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DendriteArmSpacing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DendriteArmSpacing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicrostructuralQuantity"/>
        <rdfs:label xml:lang="en">DendriteArmSpacing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Density -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Density">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment>Density: Mass/Volume</rdfs:comment>
        <rdfs:comment xml:lang="en">Mass per unit volume</rdfs:comment>
        <rdfs:comment xml:lang="de">Masse pro Volumeneinheit</rdfs:comment>
        <rdfs:isDefinedBy>DIN 1306:2020-06; DIN EN ISO 80000-4:2020-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Density</rdfs:label>
        <rdfs:label xml:lang="de">Dichte</rdfs:label>
        <skos:definition xml:lang="de">Dichte ist die auf das Volumen bezogene Masse eines Stoffes zu einer festgelegten Temperatur und ggf. einem festgelegten Druck (ρ = m/V). Sie dient in der Galvanotechnik u. a. zur Charakterisierung und Überwachung von Prozessmedien (z. B. Elektrolyten) sowie zur Umrechnung zwischen Massen- und Volumenangaben. Die Dichte ist von Temperatur (und bei Gasen auch von Druck) abhängig und ist von der relativen Dichte zu unterscheiden.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DepthOfCut -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DepthOfCut">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <rdfs:comment>Depth of cut is a process quantity for a turning process characterizing the depth of the machined cut.</rdfs:comment>
        <rdfs:label xml:lang="en">DepthOfCut</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DerivedUnit -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DerivedUnit">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Unit"/>
        <rdfs:label xml:lang="en">DerivedUnit</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Desktop -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Desktop">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ITEquipment"/>
        <rdfs:label xml:lang="en">Desktop</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 12706:2010-02; DIN EN ISO/IEC 80000-1:2023-06; ISO/IEC Guide 99:2007 (VIM)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Destructive Testing Related Quantity</rdfs:label>
        <rdfs:label xml:lang="de">Zerstörender Prüfung zugehörige Größe</rdfs:label>
        <skos:definition xml:lang="de">Eine „zerstörender Prüfung zugehörige Größe“ ist eine Messgröße, die im Rahmen einer zerstörenden Prüfung ermittelt wird, bei der der Prüfling durch die Prüfung unbrauchbar wird oder seine Gebrauchseigenschaften dauerhaft verändert werden. Hauptzweck ist die quantitative Beschreibung von Eigenschaften/Verhaltensweisen (z. B. Festigkeit, Haftfestigkeit, Schichtdicke nach Querschliff), die nur durch Eingriffe wie Trennen, Abtragen oder Überlasten zuverlässig bestimmbar sind. Sie ist von Größen aus zerstörungsfreien Prüfungen abzugrenzen, bei denen der Prüfling bestimmungsgemäß verwendbar bleibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DetectorMode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DetectorMode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>ISO 22493:2020 (Surface chemical analysis — Scanning electron microscopy — Vocabulary); ISO 18115-1:2023 (Surface chemical analysis — Vocabulary — Part 1: General terms and terms used in spectroscopy)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Detector mode</rdfs:label>
        <rdfs:label xml:lang="de">Detektormodus</rdfs:label>
        <skos:definition xml:lang="de">Der Detektormodus ist eine festgelegte Betriebsart eines Mess- oder Analysesystems, bei der definiert ist, welcher Detektor bzw. welches Detektorsignal zur Datenerfassung verwendet wird. Hauptzweck ist die gezielte Auswahl der Signalart (z. B. unterschiedliche Elektronen- oder Röntgensignale) zur Anpassung von Kontrast, Empfindlichkeit oder Informationsgehalt an die jeweilige Prüf- bzw. Analyseaufgabe. In der Galvanotechnik wird der Begriff vor allem im Kontext der Schicht- und Oberflächencharakterisierung (z. B. REM/EDX) genutzt und ist von allgemeinen Messmodi (z. B. Scan-/Abbildungsmodus) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DeviceNumber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DeviceNumber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Identifier"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Kennnummer des Messgeräts.</rdfs:comment>
        <rdfs:comment xml:lang="en">The identification number of the measuring device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device Number</rdfs:label>
        <rdfs:label xml:lang="de">Gerätenummer</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Diameter -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Diameter">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GeneralGeometricQuantity"/>
        <rdfs:label xml:lang="en">Diameter</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DiameterBrinellIndenter -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DiameterBrinellIndenter">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ConsumableRelatedQuantity"/>
        <rdfs:comment>The diameter of a Brinell indenter</rdfs:comment>
        <rdfs:label xml:lang="en">DiameterBrinellIndenter</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DiffractionPhase -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DiffractionPhase">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 21432:2020-06 (Anodizing of aluminium and its alloys — Assessment of the resistance of anodic oxidation coatings to cracking by deformation); Cullity, B. D.; Stock, S. R.: *Elements of X-Ray Diffraction*, 3rd ed., Prentice Hall, 2001.</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Diffraction phase</rdfs:label>
        <rdfs:label xml:lang="de">Phasenbeugung</rdfs:label>
        <skos:definition xml:lang="de">Phasenbeugung bezeichnet die Beugungserscheinung, die entsteht, wenn kohärente Strahlung (typisch Röntgenstrahlung) an kristallinen Phasen eines Werkstoffs oder einer Beschichtung interferiert und dadurch phasenspezifische Beugungsmaxima liefert. Hauptzweck ist die Identifikation und ggf. quantitative Bestimmung von kristallinen Phasen in Schichten und Substraten, z. B. zur Charakterisierung galvanischer Überzüge. Abzugrenzen ist dies von „Phasenverschiebung“ (optische Phase) sowie von rein geometrischer Beugung ohne phasenspezifische Kristallstrukturinformation.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DigitalCamera -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DigitalCamera">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CameraEquipment"/>
        <rdfs:comment>A digital camera used within a process setup</rdfs:comment>
        <rdfs:label xml:lang="en">DigitalCamera</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DigitalMicroscope -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DigitalMicroscope">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9022-1:2016-06; DIN EN ISO 9022-3:2016-06; DIN EN ISO 9022-11:2016-06; DIN EN ISO 14997:2015-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Digital microscope</rdfs:label>
        <rdfs:label xml:lang="de">Digitalmikroskop</rdfs:label>
        <skos:definition xml:lang="de">Ein Digitalmikroskop ist ein Mikroskopiesystem, das die vergrößerte Abbildung eines Objekts mittels elektronischem Bildsensor erfasst und als digitales Bild auf einem Display bzw. in einer Datei bereitstellt. Hauptzweck ist die visuelle Prüfung, Dokumentation und ggf. Messung von Oberflächen- und Schichtmerkmalen (z. B. Defekte, Struktur, Schichtzustand) im Rahmen der Qualitätsprüfung galvanischer Überzüge. Im Unterschied zum klassischen Lichtmikroskop steht die digitale Bildaufnahme/-verarbeitung (Anzeige, Speicherung, Auswertung) im Vordergrund.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Dimension -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Dimension">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 14405-1:2016-12, DIN EN ISO 286-1:2010-11, DIN EN ISO 2178:2016-06</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 80000-1:2022-09, DIN EN ISO 14405-1:2016-12, DIN EN ISO 2064:2020-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Abmessung</rdfs:label>
        <rdfs:label xml:lang="en">Dimension</rdfs:label>
        <skos:definition xml:lang="de">Eine Abmessung ist ein geometrisches Maß eines Werkstücks oder einer Schicht, das eine Größe wie Länge, Breite, Dicke oder Durchmesser quantitativ beschreibt. Hauptzweck ist die eindeutige Festlegung und Prüfung geometrischer Eigenschaften als Grundlage für Spezifikation, Fertigung und Qualitätsprüfung (z. B. auch bei beschichteten Teilen). Abmessungen können als Nennmaße mit zulässigen Abweichungen (Toleranzen) festgelegt werden.</skos:definition>
        <skos:definition xml:lang="de">Eine Dimension ist eine messbare geometrische Größe eines Werkstücks oder Merkmals (z. B. Länge, Durchmesser, Dicke), die durch einen Zahlenwert und eine Einheit angegeben wird. Sie dient der eindeutigen Festlegung und Prüfung von Geometrieanforderungen in der technischen Dokumentation und Qualitätssicherung. Im Kontext galvanischer Überzüge ist die Dimension u. a. relevant, weil Schichtdickenanforderungen und Maßänderungen durch Beschichtung auf definierte geometrische Merkmale bezogen werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DimensionlessRatio -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DimensionlessRatio">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">DimensionlessRatio</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DispersionChromePlating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DispersionChromePlating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Plating"/>
        <rdfs:comment xml:lang="en">is a plating process that provides a uniform coating of chromium particles on various substrates. It involves careful control of parameters and the use of specialized equipment and infrastructure to ensure high-quality results. The process outputs dispersion chrome-plated items, along with data on thickness and quality for compliance and quality assurance.</rdfs:comment>
        <rdfs:label xml:lang="en">Dispersion Chrome Plating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DispersoidInclusionRate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DispersoidInclusionRate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Anteil der dispergierten Einschlüsse in einem Material</rdfs:comment>
        <rdfs:comment xml:lang="en">Proportion of dispersed inclusions in a material</rdfs:comment>
        <rdfs:label xml:lang="en">Dispersoid Inclusion Rate</rdfs:label>
        <rdfs:label xml:lang="de">Einlagerungsanteil der Dispersoide</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Disposition -->

