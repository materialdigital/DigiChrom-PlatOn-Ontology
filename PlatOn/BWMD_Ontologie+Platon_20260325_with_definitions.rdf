    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Etchant -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Etchant">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalSolution"/>
        <rdfs:comment>Etchant, e.g. used to etch metallographic specimens</rdfs:comment>
        <rdfs:label xml:lang="en">Etchant</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Etching -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Etching">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MetallographicPreparation"/>
        <rdfs:comment>Etching of metallographic specimens</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2017-02; DIN EN ISO 9587:2007-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Etching</rdfs:label>
        <skos:definition xml:lang="de">Ätzen ist eine chemische oder elektrochemische Behandlung einer Werkstückoberfläche, bei der Material gezielt abgetragen wird, um die Oberfläche zu reinigen, zu aktivieren oder zu strukturieren. Hauptzweck ist die Erzeugung eines definierten Oberflächenzustands (z. B. Entfernung von Oxiden/Passivschichten, Erhöhung der Benetzbarkeit und Haftfestigkeit) als Vorbereitung nachfolgender Prozesse wie galvanischer Beschichtung oder Konversionsschichten. Je nach Werkstoff und Ziel wird zwischen Beizätzen (stärkerer Abtrag/Entzunderung) und Aktivierätzen (kurzer, oberflächennaher Abtrag) abgegrenzt.</skos:definition>
    </owl:Class>
    


