        <rdfs:label xml:lang="en">Extrapolation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FabricFeed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FabricFeed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4520:2001-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Fabric Feed</rdfs:label>
        <rdfs:label xml:lang="de">Gewebevorschub</rdfs:label>
        <skos:definition xml:lang="de">Gewebevorschub ist die definierte, meist kontinuierliche Bewegung eines Gewebes (Textilsubstrats) durch eine galvanotechnische Prozesslinie, typischerweise über Transport- und Umlenkeinrichtungen durch Vorbehandlung, Elektrolytbad und Nachbehandlung. Hauptzweck ist die Sicherstellung einer reproduzierbaren Verweilzeit und gleichmäßigen Prozessführung, wodurch eine gleichmäßige Abscheidung bzw. Oberflächenbehandlung über die Gewebelänge erreicht wird. Der Gewebevorschub ist funktional analog zum Bandvorschub bei Bandgalvanik, unterscheidet sich jedoch durch die substratspezifische Handhabung (z. B. Dehnung, Benetzung, Kapillarität).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FeedRate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FeedRate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4287:2010-07; DIN 8580:2003-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">FeedRate</rdfs:label>
        <rdfs:label xml:lang="de">Vorschubgeschwindigkeit</rdfs:label>
        <skos:definition xml:lang="de">Die Vorschubgeschwindigkeit ist die Geschwindigkeit, mit der ein Werkstück oder ein Werkzeug während eines Prozesses in Vorschubrichtung relativ zueinander bewegt wird. Ihr Hauptzweck ist die Festlegung der Prozesskinematik und damit die Beeinflussung von Prozesszeit und Ergebnis, z. B. Schichtgleichmäßigkeit bei bewegten Gestellen oder die Oberflächenstruktur bei mechanischer Vorbehandlung. Sie ist von der Schnittgeschwindigkeit bzw. Umfangsgeschwindigkeit abzugrenzen und wird typischerweise in mm/min oder m/min angegeben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FerrousMaterial -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FerrousMaterial">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MetallicMaterial"/>
        <rdfs:label xml:lang="en">FerrousMaterial</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FiatObjectPart -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FiatObjectPart">
