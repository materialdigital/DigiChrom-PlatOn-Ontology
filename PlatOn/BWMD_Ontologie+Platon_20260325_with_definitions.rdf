        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Menge der Flüssigkeit, die pro Zeiteinheit durch das System fließt.</rdfs:comment>
        <rdfs:comment xml:lang="en">The amount of liquid that flows through the system per unit of time.</rdfs:comment>
        <rdfs:label xml:lang="de">Durchflussmenge</rdfs:label>
        <rdfs:label xml:lang="en">Flow Rate</rdfs:label>
    </owl:Class>
    


