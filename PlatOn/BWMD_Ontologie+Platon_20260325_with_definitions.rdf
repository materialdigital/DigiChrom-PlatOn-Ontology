        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Der Hersteller der Pumpe, die im System verwendet wird.</rdfs:comment>
        <rdfs:comment xml:lang="en">The manufacturer of the pump used in the system.</rdfs:comment>
        <rdfs:label xml:lang="en">Pump Manufacturer</rdfs:label>
        <rdfs:label xml:lang="de">Pumpemhersteller</rdfs:label>
    </owl:Class>
    


