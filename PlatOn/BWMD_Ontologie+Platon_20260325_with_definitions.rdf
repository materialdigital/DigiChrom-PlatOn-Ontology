        <rdfs:label xml:lang="en">MaterialNanoStructure</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 1301-1:2010-10; DIN EN ISO 80000-1:2013-08; DIN EN ISO 80000-9:2013-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Material Quantity</rdfs:label>
        <rdfs:label xml:lang="de">Materialmenge</rdfs:label>
        <skos:definition xml:lang="de">Materialmenge bezeichnet die Menge eines Stoffes, die in der Regel als Stoffmenge \(n\) über die Einheit Mol ausgedrückt wird. Sie dient zur quantitativen Beschreibung und Berechnung von Stoffumsätzen, z. B. bei elektrochemischen Abscheidungs- und Auflösungsprozessen (Faradaysche Gesetzmäßigkeiten). In der galvanotechnischen Praxis ist „Materialmenge“ häufig unscharf und kann je nach Kontext auch Masse oder Volumen meinen; normativ eindeutig ist die Stoffmenge.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


