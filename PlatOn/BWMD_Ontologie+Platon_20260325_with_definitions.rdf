    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaximumValue -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaximumValue">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN ISO 3534-2:2014-10, Statistik — Begriffe und Formelzeichen — Teil 2: Angewandte Statistik; DIN EN ISO/IEC Guide 99:2010-12, Internationale Metrologie-Vokabular (VIM) — Grundlegende und allgemeine Begriffe und zugehörige Begriffe (deutsche Fassung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Maximalwert</rdfs:label>
        <rdfs:label xml:lang="en">Maximum Value</rdfs:label>
        <skos:definition xml:lang="de">Ein Maximalwert ist der größte Wert, den eine Messgröße oder ein Merkmal unter festgelegten Bedingungen in einer Menge von Beobachtungen/Ergebnissen annimmt. Er dient zur Spezifikation und Bewertung von oberen Grenzanforderungen (z. B. zulässige Höchstwerte von Schichtdicke, Konzentration oder Stromdichte) in Prüf- und Prozessvorgaben. Der Maximalwert ist ein Extremwert und ist von einem Grenzwert (festgelegter zulässiger Wert) zu unterscheiden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaximumValueThicknessCr -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaximumValueThicknessCr">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaximumValue"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessCr"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-12; DIN EN ISO 3497:2000-12; DIN EN ISO 3882:2003-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Maximalwert Chromschichtdicke</rdfs:label>
        <rdfs:label xml:lang="en">Maximum Value Thickness Cr</rdfs:label>
        <skos:definition xml:lang="de">Der Maximalwert der Chromschichtdicke ist der größte ermittelte Wert der lokalen Schichtdicke einer Chromabscheidung innerhalb eines festgelegten Messbereichs bzw. einer definierten Stichprobe. Er dient der Bewertung der Schichtdickenverteilung und dem Nachweis der Einhaltung von Spezifikationen, insbesondere wenn neben Mindestdicken auch Obergrenzen oder Gleichmäßigkeitsanforderungen festgelegt sind. Der Maximalwert ist von der Nenn- oder Mindestschichtdicke zu unterscheiden und ist nur zusammen mit Messverfahren, Messstellenfestlegung und Auswerte-Regeln eindeutig interpretierbar.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaximumValueThicknessNi -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaximumValueThicknessNi">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaximumValue"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessNi"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-12; DIN EN ISO 2360:2017-08; DIN EN ISO 3882:2003-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Maximalwert Nickelschichtdicke</rdfs:label>
        <rdfs:label xml:lang="en">Maximum Value Thickness Ni</rdfs:label>
        <skos:definition xml:lang="de">Der Maximalwert der Nickelschichtdicke ist der größte ermittelte Wert der Dicke einer aufgebrachten Nickelschicht innerhalb eines definierten Prüfbereichs, bestimmt aus Einzelmessungen nach einem festgelegten Messverfahren. Er dient zur Bewertung der Schichtdickenverteilung und zur Prüfung der Einhaltung von Spezifikationen (z. B. obere Grenzwerte oder Toleranzen) für Nickelüberzüge. Der Maximalwert ist vom Nennwert/Sollwert sowie von statistischen Kenngrößen wie Mittelwert oder Median abzugrenzen und ist abhängig von Messort, Stichprobenplan und Messmethode.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeanValue -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeanValue">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 55350-12:2000-05; DIN ISO 3534-1:2013-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Mean Value</rdfs:label>
        <rdfs:label xml:lang="de">Mittelwert</rdfs:label>
        <skos:definition xml:lang="de">Der Mittelwert ist ein statistischer Kennwert, der als Quotient aus der Summe der beobachteten Werte und der Anzahl der Beobachtungen definiert ist (arithmetischer Mittelwert). Er dient dazu, Messergebnisse oder Prozesskenngrößen (z. B. Schichtdicke, Rauheit, Stromdichte) als repräsentativen zentralen Wert zusammenzufassen und für Bewertung, Vergleich oder Regelung heranzuziehen. In der Messtechnik ist der Mittelwert von Streuungskennwerten (z. B. Standardabweichung) abzugrenzen, da er allein keine Aussage über die Variabilität der Werte liefert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeanValueThicknessCr -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeanValueThicknessCr">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeanValue"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessCr"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-12; DIN EN ISO 3497:2000-10; DIN EN ISO 3882:2003-08; ISO 3543:2015-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Mean Value Thickness Cr</rdfs:label>
        <rdfs:label xml:lang="de">Mittelwert Chromschichtdicke</rdfs:label>
        <skos:definition xml:lang="de">Der Mittelwert der Chromschichtdicke ist der arithmetische Mittelwert der an einem chrombeschichteten Bauteil an definierten Messstellen ermittelten lokalen Schichtdickenwerte. Er dient dazu, die mittlere Schichtdicke einer Chromabscheidung für Spezifikation, Prozessüberwachung und Konformitätsbewertung gegenüber Anforderungen an die Schichtdicke zusammenzufassen. Die Aussagekraft hängt von Messverfahren, Anzahl und Lage der Messstellen sowie der festgelegten Auswerte-/Prüfregel ab.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeanValueThicknessNi -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeanValueThicknessNi">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeanValue"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessNi"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-12; DIN EN ISO 2360:2017-12; DIN EN ISO 1456:2009-06; DIN EN ISO 4526:2007-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Mean Value Thickness Ni</rdfs:label>
        <rdfs:label xml:lang="de">Mittelwert Nickelschichtdicke</rdfs:label>
        <skos:definition xml:lang="de">Der Mittelwert Nickelschichtdicke ist der arithmetische Mittelwert der an einer festgelegten Anzahl von Messstellen ermittelten Dicken eines Nickelüberzugs auf einem Bauteil oder in einem definierten Prüfbereich. Er dient zur quantitativen Beschreibung der durchschnittlichen Überzugsdicke, z. B. zur Prozessüberwachung, zum Vergleich von Beschichtungszuständen oder zur Bewertung gegenüber vorgegebenen Schichtdickenanforderungen. Die Aussagekraft ist an ein definiertes Messverfahren, die Festlegung der Messstellen/Prüffläche und die statistische Auswertung (arithmetisches Mittel) gebunden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/IEC 17000:2020-05; DIN EN ISO/IEC 17025:2018-03; DIN EN IEC 80000-1:2023-06; JCGM 200:2012 (VIM, 3. Auflage)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Messung</rdfs:label>
        <skos:definition xml:lang="de">Messung ist ein Prozess zur experimentellen Bestimmung eines oder mehrerer Größenwerte, die einer Größe zugeordnet werden können. Hauptzweck ist die Gewinnung eines Messergebnisses als Grundlage für Bewertung, Überwachung oder Regelung (z. B. von Prozessparametern in galvanotechnischen Verfahren). Die Messung umfasst dabei festgelegte Messbedingungen und ein Messverfahren und ist von der bloßen Anzeige oder Schätzung ohne definierte Messvorschrift abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementArea -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementArea">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN IEC 60050-300:2001-01 (International Electrotechnical Vocabulary – Electrical and electronic measurements and measuring instruments – Part 311: General terms relating to measurements); JCGM 200:2012 (VIM, 3rd edition) – International vocabulary of metrology – Basic and general concepts and associated terms (deutsche Fassung: DIN VIM:2012)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Measurement Area</rdfs:label>
        <rdfs:label xml:lang="de">Messbereich</rdfs:label>
        <skos:definition xml:lang="de">Der Messbereich ist das Intervall der Werte einer Messgröße, innerhalb dessen ein Messgerät oder ein Messsystem Messungen unter festgelegten Bedingungen mit spezifizierten metrologischen Eigenschaften durchführen kann. Er dient dazu, die zulässigen unteren und oberen Grenzen der Messgröße für die Anwendung und die Bewertung der Messergebnisse festzulegen. Der Messbereich wird durch die Messbereichsgrenzen (untere und obere Grenze) beschrieben und ist von der Messspanne (Differenz der Grenzen) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementDistance -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementDistance">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9022-1:2016-10; DIN EN ISO 11146-1:2021-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Measurement Distance</rdfs:label>
        <rdfs:label xml:lang="de">Messabstand</rdfs:label>
        <skos:definition xml:lang="de">Der Messabstand ist der definierte Abstand zwischen Messmittel (z. B. Sensor/Messkopf) und Messobjekt bzw. der Messstelle, bei dem eine Messung durchgeführt wird. Er dient dazu, Messbedingungen zu standardisieren und die Vergleichbarkeit sowie Rückführbarkeit von Messergebnissen (z. B. bei optischen Messverfahren oder Schichtdickenmessungen) sicherzustellen. Je nach Messverfahren kann der Messabstand als Arbeitsabstand, Messgeometrie oder Abstandsvorgabe in der Prüfanweisung festgelegt sein.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <rdfs:label xml:lang="en">MeasurementEquipment</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementLength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementLength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6892-1:2020-06, DIN EN ISO 7500-1:2018-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Measurement Length</rdfs:label>
        <rdfs:label xml:lang="de">Messlänge</rdfs:label>
        <skos:definition xml:lang="de">Die Messlänge ist der festgelegte Abschnitt einer Probe oder eines Prüfstücks, über den eine Messgröße (z. B. Dehnung oder Längenänderung) erfasst und ausgewertet wird. Hauptzweck ist die eindeutige, reproduzierbare Festlegung des Bezugsbereichs für Messergebnisse, insbesondere bei mechanischen Prüfungen wie dem Zugversuch. Sie ist von der Probenlänge bzw. Einspannlänge abzugrenzen und wird in der Regel vor der Prüfung definiert bzw. markiert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementLocation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementLocation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementRelatedFiatObjectPart"/>
        <rdfs:comment>The location (a point) at which some quantity is measured</rdfs:comment>
        <rdfs:label xml:lang="en">MeasurementLocation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementRange -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementRange">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementRelatedFiatObjectPart"/>
        <rdfs:comment>Measurement range: The area/volume in which the measurement
is performed.</rdfs:comment>
        <rdfs:label xml:lang="en">MeasurementRange</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementRelatedFiatObjectPart -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementRelatedFiatObjectPart">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FiatObjectPart"/>
        <rdfs:comment>Measurement related fiat object part, e.g. measurement range or measurement location</rdfs:comment>
        <rdfs:label xml:lang="en">MeasurementRelatedFiatObjectPart</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 1319-1:1995-05; DIN 1319-3:1996-05; DIN EN ISO/IEC Guide 99 (VIM):2010-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Measurement Time</rdfs:label>
        <rdfs:label xml:lang="de">Messdauer</rdfs:label>
        <skos:definition xml:lang="de">Messdauer ist die Zeitspanne, über die eine Messung durchgeführt wird bzw. während der ein Messsignal erfasst und zur Ergebnisbildung herangezogen wird. Hauptzweck ist die Festlegung des zeitlichen Bezugs der Messwertaufnahme, um Messwerte hinsichtlich Mittelung, Stabilität und Vergleichbarkeit eindeutig zu spezifizieren. Je nach Messverfahren kann die Messdauer als Integrationszeit, Abtast-/Erfassungszeit oder als Dauer eines Messzyklus festgelegt sein.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasuringDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasuringDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Das Messgerät, das zur Bestimmung von Parametern wie Temperatur oder pH verwendet wird.</rdfs:comment>
        <rdfs:comment xml:lang="en">The device used to measure parameters such as temperature or pH.</rdfs:comment>
        <rdfs:label xml:lang="en">Measuring Device</rdfs:label>
        <rdfs:label xml:lang="de">Messgerät</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalExperiment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalExperiment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <rdfs:label xml:lang="en">MechanicalExperiment</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:label xml:lang="en">MechanicalQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalTestingRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalTestingRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:label xml:lang="en">MechanicalTestingRelatedQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalWorkshopEquipment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalWorkshopEquipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <rdfs:comment>Any kind of equipment within a mechanical workshop</rdfs:comment>
        <rdfs:label xml:lang="en">MechanicalWorkshopEquipment</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Medium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Medium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 9227:2023-09; DIN EN ISO 8044:2020-12</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; DIN EN ISO 9227:2023-09; DIN EN ISO 2081:2018-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Medium</rdfs:label>
        <rdfs:label xml:lang="en">Medium</rdfs:label>
        <skos:definition xml:lang="de">Ein Medium ist ein Stoff oder Stoffgemisch (z. B. Flüssigkeit, Gas oder Feststoff), das als umgebende oder eingesetzte Phase in einem Prozess oder einer Prüfung wirkt. In der Galvanotechnik dient ein Medium typischerweise als Elektrolyt/Bad, Spül- oder Behandlungsflüssigkeit bzw. als Prüf- oder Korrosionsmedium zur definierten Einwirkung auf Werkstücke und Schichten. Je nach Kontext ist das Medium durch Zusammensetzung und Zustandsgrößen (z. B. Temperatur, pH-Wert, Leitfähigkeit) festgelegt und von „Werkstoff“ bzw. „Beschichtung“ als zu prüfendem/zu erzeugendem Objekt abzugrenzen.</skos:definition>
        <skos:definition xml:lang="de">Ein Medium ist ein Stoff oder Stoffgemisch (z. B. Flüssigkeit, Gas oder Paste), das als umgebende oder wirksame Phase in einem Prozess, einer Prüfung oder einer Beanspruchungssituation eingesetzt wird. In der Galvanotechnik dient das Medium typischerweise als Träger für chemische/elektrochemische Reaktionen (z. B. Elektrolyt im Bad) oder als definierte Umgebung zur Bewertung von Eigenschaften (z. B. Korrosions- oder Prüfmedium). Der Begriff ist von spezifischeren normativen Begriffen wie „Elektrolyt“, „Bad“ oder „Prüflösung“ abzugrenzen, die das Medium hinsichtlich Funktion und Zusammensetzung genauer festlegen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Melting -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Melting">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CastingRelatedSubprocess"/>
        <rdfs:comment>The act of melting a solid state material within a casting process</rdfs:comment>
        <rdfs:label xml:lang="en">Melting</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Mercury -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Mercury">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Mercury</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Mesh -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Mesh">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 862:2017-03 (Oberflächenaktive Stoffe — Netzvermögen — Bestimmung durch Messung der dynamischen Oberflächenspannung)</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN ISO 3310-1:2017-03; ASTM E11-20 (2020)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Mesh</rdfs:label>
        <rdfs:label xml:lang="de">Mesh (Gittergröße)</rdfs:label>
        <skos:definition xml:lang="de">Ein Netz ist allgemein eine strukturierte Anordnung aus miteinander verbundenen Elementen, die als System zur Verteilung oder zum Austausch von Stoffen, Energie oder Informationen dient. In der Galvanotechnik tritt „Netz“ typischerweise als Bestandteil zusammengesetzter Begriffe auf, z. B. beim Netzmittel zur Verbesserung der Benetzung von Oberflächen durch Elektrolyte. Als eigenständiger Begriff ist „Netz“ ohne Zusatz mehrdeutig und sollte für ontologische Zwecke durch Spezifikation (z. B. „Netzmittel“, „Versorgungsnetz“, „Drahtnetz/Kathodennetz“) präzisiert werden.</skos:definition>
        <skos:definition xml:lang="de">Mesh (Gittergröße) bezeichnet eine Kenngröße für Siebe/Gitter, die üblicherweise die Anzahl der Maschenöffnungen pro Längeneinheit (historisch häufig pro Zoll) bzw. die zugehörige Sieb-/Maschenweite beschreibt. Hauptzweck ist die eindeutige Spezifikation und Vergleichbarkeit von Sieben/Filtern zur Klassierung oder Abtrennung von Partikeln (z. B. bei Pulver-, Schleif- oder Filteranwendungen in Prozessbädern). Die Angabe „mesh“ ist nicht direkt eine Längenangabe; für technische Eindeutigkeit wird in Normen die Maschenweite/Öffnungsweite in mm bevorzugt und über genormte Prüfsiebe abgebildet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MetalDistribution -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MetalDistribution">
