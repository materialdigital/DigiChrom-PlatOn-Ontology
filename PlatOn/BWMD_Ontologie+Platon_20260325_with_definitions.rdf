    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#File -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#File">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificDataFormat"/>
        <rdfs:label xml:lang="en">File</rdfs:label>
