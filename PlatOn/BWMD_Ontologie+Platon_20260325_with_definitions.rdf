        <rdfs:comment>Machine used for an electric discharge process (e.g. wire eroding)</rdfs:comment>
        <rdfs:label xml:lang="en">ElectricDischargeMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricalConductance -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricalConductance">
