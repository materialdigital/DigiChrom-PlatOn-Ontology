        <rdfs:comment xml:lang="en">Capacity of an equivalent circuit</rdfs:comment>
        <rdfs:comment xml:lang="de">Kapazität eines äquivalenten Schaltkreises</rdfs:comment>
        <rdfs:label xml:lang="en">Equivalent Circuit Capacity</rdfs:label>
        <rdfs:label xml:lang="de">Ersatzschaltbild Kapazität</rdfs:label>
    </owl:Class>
    


