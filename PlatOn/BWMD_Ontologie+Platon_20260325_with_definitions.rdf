    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Method -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Method">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/IEC 17025:2018-03; DIN EN ISO 9000:2015-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Method</rdfs:label>
        <rdfs:label xml:lang="de">Methode</rdfs:label>
        <skos:definition xml:lang="de">Eine Methode ist eine festgelegte, dokumentierte Vorgehensweise zur Durchführung einer Prüfung, Messung, Analyse oder eines Verfahrens unter definierten Bedingungen. Ihr Hauptzweck ist die reproduzierbare und vergleichbare Ermittlung von Ergebnissen bzw. die einheitliche Ausführung eines Prozesses. In Normen wird „Methode“ häufig als „Prüfverfahren/Prüfmethode“ konkretisiert und von allgemeinen Arbeitsanweisungen durch den normativ festgelegten Ablauf und die Randbedingungen abgegrenzt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MethodNumber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MethodNumber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4618:2015-03; DIN EN ISO 2064:2021-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Method Number</rdfs:label>
        <rdfs:label xml:lang="de">Methodennummer</rdfs:label>
        <skos:definition xml:lang="de">Eine Methodennummer ist eine eindeutige alphanumerische Kennzeichnung, mit der eine festgelegte Methode (z. B. ein Prüfverfahren oder ein analytisches Bestimmungsverfahren) innerhalb eines Normdokuments oder eines methodischen Regelwerks identifiziert wird. Sie dient der eindeutigen Referenzierung und Zuordnung von Anforderungen, Durchführungsschritten und Auswertungsvorschriften zu genau dieser Methode. Methodennummern sind von Proben- oder Auftragsnummern abzugrenzen, da sie nicht ein konkretes Objekt, sondern die anzuwendende Vorgehensweise identifizieren.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicrocrackedChromium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicrocrackedChromium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Coating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">electrodeposited chromium coating with an intentional microscopical crack pattern</rdfs:comment>
        <rdfs:comment xml:lang="de">galvanisch abgeschiedener Chromüberzug mit einem absichtlich erzeugten, mikroskopisch feinen Rissmuster </rdfs:comment>
        <rdfs:label xml:lang="en">Microcracked Chromium</rdfs:label>
        <rdfs:label xml:lang="de">mikrorissiges Chrom</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Microdiscontinuity -->

