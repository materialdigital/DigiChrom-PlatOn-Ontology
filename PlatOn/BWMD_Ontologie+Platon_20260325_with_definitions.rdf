        <rdfs:label xml:lang="en">TechnicalStrain</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProduct -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProduct">
