        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FurnaceGripSystem -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FurnaceGripSystem">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GripSystem"/>
        <rdfs:label xml:lang="en">FurnaceGripSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Furnance -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Furnance">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 746-1:2020-12, Industrielle Thermoprozessanlagen – Teil 1: Allgemeine Sicherheitsanforderungen; DIN EN ISO 857-1:2013-03, Hartlöten – Vokabular – Teil 1: Begriffe für Verfahren und Ausrüstung (enthält u. a. „Ofenlöten“/Furnace brazing als Ausrüstungs-/Verfahrensbezug)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Furnance</rdfs:label>
        <rdfs:label xml:lang="de">Ofen</rdfs:label>
        <skos:definition xml:lang="de">Ein Ofen ist eine technische Anlage (thermische Ausrüstung), die einen umschlossenen Raum bereitstellt, in dem Werkstücke oder Materialien durch kontrollierte Wärmezufuhr auf eine vorgegebene Temperatur gebracht und ggf. dort gehalten werden. Hauptzweck ist das Erwärmen bzw. Wärmebehandeln (z. B. Trocknen, Aushärten, Anlassen/Spannungsarmglühen) von Bauteilen oder Schichten, auch als Prozessschritt vor oder nach galvanischen/chemischen Beschichtungen. Je nach Ausführung kann der Ofen mit definierter Atmosphäre (z. B. Luft, Schutzgas) betrieben werden; abzugrenzen ist er von offenen Heizquellen ohne umschlossenen Prozessraum.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Gadolinium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Gadolinium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Gadolinium</rdfs:label>
    </owl:Class>
    


