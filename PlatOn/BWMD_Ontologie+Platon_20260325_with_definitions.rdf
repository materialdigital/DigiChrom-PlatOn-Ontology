        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Verhältnis des abgeschiedenen Metalls über einer Kathode</rdfs:comment>
        <rdfs:comment xml:lang="en">ratio of deposited metal over a cathode </rdfs:comment>
        <rdfs:label xml:lang="en">Metal Distribution</rdfs:label>
        <rdfs:label xml:lang="de">Metallverteilung</rdfs:label>
    </owl:Class>
    


