        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructuralQuantity"/>
        <rdfs:label xml:lang="en">MicrostructuralQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicrothrowingPower -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicrothrowingPower">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Fähigkeit eines Elektrolyts, unter gegebenen Abscheidungsbedingungen Metall in Poren oder Kratzern abzuscheiden</rdfs:comment>
        <rdfs:comment xml:lang="en">ability of an electrolyte or a specified set of electroplating  conditions to deposit metal in pores  or scratches</rdfs:comment>
        <rdfs:label xml:lang="en">Microthrowing Power</rdfs:label>
        <rdfs:label xml:lang="de">Mikrostreufähigkeit</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MinimumValue -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MinimumValue">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3534-2:2007-02, DIN EN ISO 80000-1:2023-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Minimalwert</rdfs:label>
        <rdfs:label xml:lang="en">Minimum Value</rdfs:label>
        <skos:definition xml:lang="de">Ein Minimalwert ist der kleinste zulässige oder festgelegte Wert einer spezifizierten Größe innerhalb eines Anforderungs- oder Toleranzbereichs. Er dient dazu, die Einhaltung von Mindestanforderungen (z. B. an Schichtdicke, Haftfestigkeit oder Korrosionsschutzleistung) eindeutig zu definieren und zu prüfen. Der Minimalwert ist vom Messwert (Ergebnis einer Messung) und vom Grenzwertbegriff allgemein abzugrenzen, da er die untere Grenze einer Spezifikation beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MinimumValueThicknessCr -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MinimumValueThicknessCr">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MinimumValue"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessCr"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6158:2018-03; DIN EN ISO 2177:2019-06; DIN EN ISO 3497:2000-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Minimalwert Chromschichtdicke</rdfs:label>
        <rdfs:label xml:lang="en">Minimum Value Thickness Cr</rdfs:label>
        <skos:definition xml:lang="de">Der Minimalwert der Chromschichtdicke ist die kleinste zulässige Schichtdicke eines Chromüberzugs an der/den festgelegten Messstelle(n) bzw. innerhalb der spezifizierten Oberfläche, wie sie in der Schichtdickenspezifikation gefordert wird. Hauptzweck ist die Sicherstellung der geforderten Funktionseigenschaften (z. B. Korrosionsschutz, Verschleißbeständigkeit) durch Einhaltung einer Mindestüberzugsdicke. Der Minimalwert ist von einem Mittelwert über mehrere Messpunkte zu unterscheiden und bezieht sich auf die minimale (örtliche) Dicke gemäß Prüf- und Abnahmeregeln.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MinimumValueThicknessNi -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MinimumValueThicknessNi">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MinimumValue"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThicknessNi"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2020-03; DIN EN ISO 1456:2020-01; DIN EN ISO 4526:2007-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Minimalwert Nickelschichtdicke</rdfs:label>
        <rdfs:label xml:lang="en">Minimum Value Thickness Ni</rdfs:label>
        <skos:definition xml:lang="de">Der Minimalwert der Nickelschichtdicke ist die kleinste zulässige Dicke einer aufgebrachten Nickelschicht an der betrachteten Oberfläche bzw. an festgelegten Messstellen. Er dient dazu, die Funktionsanforderungen der Beschichtung (z. B. Korrosionsschutz, Verschleißschutz oder dekorative Wirkung) sicherzustellen, indem eine Unterdeckung der Schichtdicke ausgeschlossen wird. In Spezifikationen wird der Minimalwert typischerweise als lokale Mindestschichtdicke festgelegt und ist von einem Mittelwert über eine Fläche oder Charge abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Modes -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Modes">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2020-06; DIN EN ISO 2081:2018-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Modes</rdfs:label>
        <rdfs:label xml:lang="de">Modi</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Modi“ ist der Plural von „Modus“ und bezeichnet unterschiedliche Betriebsarten bzw. Arbeitsweisen, in denen ein galvanotechnischer Prozess oder eine Anlage betrieben werden kann (z. B. Strom-/Spannungsregelung, Gleichstrom- oder Pulsbetrieb). Zweck ist die eindeutige Unterscheidung und Festlegung von Prozesszuständen bzw. Regel- und Betriebsarten zur reproduzierbaren Prozessführung. Der Begriff ist kontextabhängig und wird in der Galvanotechnik typischerweise nur in Verbindung mit einem konkret benannten Modus (z. B. „Pulsmodus“) fachlich eindeutig.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ModulatedCurrentElectroplating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ModulatedCurrentElectroplating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Plating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Verfahren zur galvanischen Metallabscheidung, bei dem die kathodische Stromdichte periodisch verändert wird</rdfs:comment>
        <rdfs:comment xml:lang="en">method of electroplating in which the cathode current density is changed periodically</rdfs:comment>
        <rdfs:label xml:lang="de">Metallabscheidung mit moduliertem Strom</rdfs:label>
        <rdfs:label xml:lang="en">Modulated Current Electroplating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MoldTemperatureAsIs -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MoldTemperatureAsIs">
