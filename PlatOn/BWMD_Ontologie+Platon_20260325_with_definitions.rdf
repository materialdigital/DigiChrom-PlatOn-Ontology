        <rdfs:label xml:lang="en">Radium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Radon -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Radon">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Radon</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RampTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RampTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 60050-351 (Leittechnik)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Rampenzeit</rdfs:label>
        <rdfs:label xml:lang="en">Rampt Time</rdfs:label>
        <skos:definition xml:lang="de">Die definierte Dauer der Anfahrphase, in der der Galvanikstrom vom Startwert kontinuierlich auf den finalen Arbeitsstrom hochgeregelt wird. Dies verhindert das „Verbrennen“ von Kanten durch plötzliche Stromspitzen und minimiert innere Spannungen in der aufwachsenden Schicht, um eine optimale Haftfestigkeit auf dem Grundwerkstoff zu gewährleisten.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ratio -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ratio">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">Ratio</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RatioUV -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RatioUV">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>N. Kanani (Hrsg.): *Galvanotechnik – Grundlagen, Verfahren, Praxis*, 3. Auflage, Springer Vieweg, 2014.</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Ratio UV</rdfs:label>
        <skos:definition xml:lang="de">Das Verhältnis UV ist ein dimensionsloser Kennwert, der das Verhältnis zwischen dem Umformgrad (U) eines Elektrolyten/Verfahrens und dessen Verteilungsvermögen (V) beschreibt. Es dient zur vergleichenden Bewertung, wie stark eine Abscheidung zur Nivellierung/Glättung (Umformung) beiträgt im Verhältnis zur Fähigkeit, die Schichtdicke geometriebedingt gleichmäßig zu verteilen. Es ist von rein geometrisch-elektrischen Kenngrößen der Stromverteilung abzugrenzen und wird typischerweise im Kontext der Beurteilung von Glanz-/Nivelliereigenschaften und Schichtdickenverteilung herangezogen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RealizableEntity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RealizableEntity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificallyDependentContinuant"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">RealizableEntity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RedoxPotential -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RedoxPotential">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Maß für die Fähigkeit eines Stoffes, Elektronen zu gewinnen oder abzugeben</rdfs:comment>
        <rdfs:comment xml:lang="en">Measure of a substance&apos;s ability to gain or lose electrons</rdfs:comment>
        <rdfs:label xml:lang="en">Redox Potential</rdfs:label>
        <rdfs:label xml:lang="de">Redoxpotential</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ReductionOfAreaAtFracture -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ReductionOfAreaAtFracture">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenRelatedQuantity"/>
        <rdfs:label xml:lang="en">ReductionOfAreaAtFracture</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ReferenceArea -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ReferenceArea">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Oberflächenbereich, der auf Übereinstimmung mit einer oder mehreren festgelegten Anforderung(en) untersucht wird</rdfs:comment>
        <rdfs:comment xml:lang="en">surface area that is examined for conformance to one or more specified requirements</rdfs:comment>
        <rdfs:label xml:lang="en">Reference Area</rdfs:label>
        <rdfs:label xml:lang="de">Referenzfläche</rdfs:label>
    </owl:Class>
    


