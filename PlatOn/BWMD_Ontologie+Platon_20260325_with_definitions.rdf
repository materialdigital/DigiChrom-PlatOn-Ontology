    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RackElectroplating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RackElectroplating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Plating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Gestellverfahren
Prozess der galvanischen Metallabscheidung, bei dem Metalle elektrolytisch auf Artikel abgeschieden werden, die an Gestellen befestigt sind, die durch die Galvanikanlage befördert werden</rdfs:comment>
        <rdfs:comment xml:lang="en">electroplating process in which electrodeposits are applied to articles fixed on rack plating jigs which are transported through the plating line</rdfs:comment>
        <rdfs:label xml:lang="de">Gestellartikelgalvanisierung</rdfs:label>
        <rdfs:label xml:lang="en">Rack Electroplating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RackPlatingJig -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RackPlatingJig">
