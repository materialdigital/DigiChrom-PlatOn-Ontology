        <rdfs:label xml:lang="en">Entity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProduct"/>
        <rdfs:label xml:lang="en">Equipment</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentID -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentID">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9000:2015-11; DIN EN ISO/IEC 17025:2018-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Equipment ID</rdfs:label>
        <rdfs:label xml:lang="de">Geräte-ID</rdfs:label>
        <skos:definition xml:lang="de">Eine Geräte-ID ist ein eindeutiger Identifikator, der einem Gerät zugeordnet wird, um es innerhalb eines Systems oder einer Organisation eindeutig zu erkennen und von anderen Geräten zu unterscheiden. Hauptzweck ist die nachvollziehbare Zuordnung von Gerätedaten wie Kalibrier-/Prüfstatus, Wartung, Einsatzhistorie und Messergebnissen zu genau diesem Gerät. Die Geräte-ID kann als Nummer, Code oder alphanumerische Kennung umgesetzt sein und ist von Gerätebezeichnung oder Typenbezeichnung abzugrenzen, die nicht zwingend eindeutig sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentName -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentName">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <rdfs:comment>Name of an equipment</rdfs:comment>
        <rdfs:label xml:lang="en">EquipmentName</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StructuralQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/IEC 17025:2018-03; DIN EN ISO 10012:2003-12; DIN EN IEC 60050-300:2009-01 (International Electrotechnical Vocabulary – Quantities and units)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Equipment Related Quantity</rdfs:label>
        <rdfs:label xml:lang="de">Equipment zugehörige Größe</rdfs:label>
        <skos:definition xml:lang="de">Eine „Equipment zugehörige Größe“ ist eine physikalische oder chemische Größe (Messgröße), die einem bestimmten Equipment (z. B. Messmittel, Sensor, Prüfgerät oder Prozessanlage) eindeutig zugeordnet ist und von diesem erfasst, angezeigt, geregelt oder beeinflusst wird. Hauptzweck ist die eindeutige Festlegung, welche Größe das jeweilige Equipment im Rahmen von Prüfung, Überwachung oder Prozessführung bestimmt bzw. steuert, um Vergleichbarkeit und Rückführbarkeit sicherzustellen. Abzugrenzen ist dies von allgemeinen Prozessparametern ohne eindeutige Zuordnung zu einem konkreten Equipment.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSet"/>
        <rdfs:label xml:lang="en">EquipmentSet</rdfs:label>
    </owl:Class>
    


