    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTransferCoefficientRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTransferCoefficientRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PhysicalQuantity"/>
        <rdfs:comment>Specific heat transfer coefficients</rdfs:comment>
        <rdfs:label xml:lang="en">HeatTransferCoefficientRelatedQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTransferCoefficientSolidifiedMetalAndMold -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTransferCoefficientSolidifiedMetalAndMold">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTransferCoefficientRelatedQuantity"/>
        <rdfs:comment>Heat transfer coefficient between solidified metal and atmosphere</rdfs:comment>
        <rdfs:label xml:lang="en">HeatTransferCoefficientSolidifiedMetalAndMold</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTreatment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTreatment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating"/>
        <rdfs:isDefinedBy>DIN EN 10052:2007-06; DIN EN ISO 9587:2007-02; DIN EN ISO 9588:2007-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">HeatTreatment</rdfs:label>
        <skos:definition xml:lang="de">Wärmebehandlung ist ein kontrollierter thermischer Prozess, bei dem ein Werkstoff oder ein beschichtetes Bauteil nach definierten Temperatur-Zeit-Bedingungen erwärmt und abgekühlt wird, um seine Eigenschaften gezielt zu verändern. Hauptzweck ist das Einstellen bzw. Verbessern von Eigenschaften wie Härte, Festigkeit, Duktilität oder Spannungszustand; im galvanotechnischen Kontext wird sie u. a. zur Spannungsarmung, zur Wasserstoffentsprödungsbehandlung (Entgasen) oder zur Beeinflussung von Schichteigenschaften eingesetzt. Sie ist von Trocknung/Einbrennen dadurch abzugrenzen, dass die Zielsetzung primär eine Werkstoff- bzw. Eigenschaftsänderung und nicht nur das Entfernen von Feuchtigkeit oder das Aushärten eines organischen Systems ist.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTreatmentFurnace -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatTreatmentFurnace">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Furnace"/>
        <rdfs:comment>A furnace used for the heat treatment of objects</rdfs:comment>
        <rdfs:label xml:lang="en">HeatTreatmentFurnace</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Heating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Heating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GenerelExperimentRelatedProcess"/>
        <rdfs:comment>The process of heating any kind of object</rdfs:comment>
        <rdfs:label xml:lang="en">Heating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingEquipment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingEquipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <rdfs:label xml:lang="en">HeatingEquipment</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingRate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingRate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN IEC 80000-1:2023-06; DIN EN IEC 80000-5:2023-06; DIN EN 60335-1:2023-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Heating Rate</rdfs:label>
        <rdfs:label xml:lang="de">Heizleistung</rdfs:label>
        <skos:definition xml:lang="de">Heizleistung ist die Leistung, mit der ein Heizsystem thermische Energie pro Zeit an ein Medium oder einen Prozess abgibt bzw. in Wärme umsetzt. Hauptzweck ist die Bereitstellung der erforderlichen Wärmemenge zur Einstellung und Aufrechterhaltung einer vorgegebenen Temperatur, z. B. in galvanotechnischen Bädern. Sie wird als Wirkleistung in Watt angegeben und ist von der zugeführten elektrischen Leistung sowie von Wärmeverlusten und der Wärmeübertragung an das Bad zu unterscheiden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingSystem -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingSystem">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <dc:creator xml:lang="en">Elena G. Trelles</dc:creator>
        <rdfs:comment xml:lang="en">Equipment to maintain the desired temperature of the plating bath.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN 60335-2-96:2015-10; DIN EN 12828:2014-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Heating System</rdfs:label>
        <skos:definition xml:lang="de">Ein Heizsystem ist eine technische Einrichtung bzw. Kombination von Komponenten zur Erzeugung, Regelung und Übertragung von Wärme an ein zu beheizendes Medium oder einen Prozess. Hauptzweck ist das Bereitstellen und Halten einer vorgegebenen Temperatur zur Sicherstellung definierter Prozessbedingungen (z. B. in Behältern, Leitungen oder Anlagenkomponenten). Je nach Ausführung kann die Wärmeerzeugung z. B. elektrisch (Widerstandsheizung) oder über Wärmeträger erfolgen und umfasst typischerweise auch Mess- und Regeleinrichtungen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingTemperature -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingTemperature">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2080:2022-07 (Metallische und andere anorganische Überzüge – Oberflächenbehandlung, metallische und andere anorganische Überzüge – Wörterbuch), DIN EN ISO 2064:2020-03 (Metallische und andere anorganische Überzüge – Begriffe und Definitionen)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Heating temperature</rdfs:label>
        <rdfs:label xml:lang="de">Heiztemperatur</rdfs:label>
        <skos:definition xml:lang="de">Heiztemperatur ist die vorgegebene Temperatur, auf die ein Medium (z. B. Elektrolytbad, Spülwasser) oder ein Werkstück durch Heizen gebracht und während eines Prozessschritts gehalten wird. Hauptzweck ist das Einstellen definierter Prozessbedingungen, insbesondere zur Beeinflussung von Reaktionskinetik, Leitfähigkeit, Abscheiderate und Schichteigenschaften. Sie ist von der Umgebungstemperatur und der Lagertemperatur abzugrenzen und wird in Verfahrensangaben als Sollwert mit zulässiger Toleranz festgelegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 17665-1:2024-01; DIN EN ISO 11140-1:2014-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Heating time</rdfs:label>
        <rdfs:label xml:lang="de">Heizzeit</rdfs:label>
        <skos:definition xml:lang="de">Heizzeit ist die Zeitspanne, in der ein Werkstück oder ein Prozessmedium von einer Ausgangstemperatur auf eine vorgegebene Solltemperatur aufgeheizt wird. Hauptzweck ist das Erreichen definierter thermischer Prozessbedingungen (z. B. für Wärmebehandlung, Trocknung oder Entgasung/Wasserstoffentsprödungsbehandlung) vor Beginn einer Haltezeit bzw. vor dem nächsten Prozessschritt. Die Heizzeit ist von der Haltezeit (Verweildauer auf Solltemperatur) und der Abkühlzeit abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Helium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Helium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Helium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HighPurityAluminiumMaterial -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HighPurityAluminiumMaterial">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AluminiumMaterial"/>
        <rdfs:comment>A high purity aluminium material</rdfs:comment>
        <rdfs:label xml:lang="en">HighPurityAluminiumMaterial</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HighVoltageCurrentConnection -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HighVoltageCurrentConnection">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricalConnection"/>
        <rdfs:label xml:lang="en">HighVoltageCurrentConnection</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#History -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#History">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessProfile"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">History</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HoldTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HoldTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9227:2023-09, DIN EN ISO 2081:2018-09, DIN EN ISO 2177:2019-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Haltezeit</rdfs:label>
        <rdfs:label xml:lang="en">Hold Time</rdfs:label>
        <skos:definition xml:lang="de">Haltezeit ist die festgelegte Zeitdauer, während der ein Prozesszustand oder eine Prüfbedingung (z. B. Temperatur, Stromdichte, Potential, Badzusammensetzung oder Einwirkbedingungen) konstant eingehalten wird. Hauptzweck ist die Sicherstellung reproduzierbarer Prozess- bzw. Prüfergebnisse, indem zeitabhängige Vorgänge (z. B. Schichtbildung, Diffusion, Passivierung, Korrosionsbeanspruchung) unter definierten Bedingungen ablaufen. Haltezeit ist von der Gesamtprozesszeit abzugrenzen, da sie sich auf das Verweilen bei einem definierten Sollzustand bezieht (z. B. nach Erreichen der Solltemperatur).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Holmium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Holmium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Holmium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HotDegreasing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HotDegreasing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Process of cleaning surfaces with hot solvent</rdfs:comment>
        <rdfs:comment xml:lang="de">Verfahren zur Reinigung von Oberflächen mit heißem Lösungsmittel</rdfs:comment>
        <rdfs:label xml:lang="de">Heißentfettung</rdfs:label>
        <rdfs:label xml:lang="en">Hot Degreasing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HotDegreasingSupplier -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HotDegreasingSupplier">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Supplier"/>
