        <rdfs:comment>The duration of the solution annealing process as supposed.</rdfs:comment>
        <rdfs:label xml:lang="en">SolutionAnnealingDurationAsSupposed</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealingTemperature -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealingTemperature">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemperatureRelatedQuantity"/>
        <rdfs:comment>The temperature at which the solution annealing process is performed</rdfs:comment>
