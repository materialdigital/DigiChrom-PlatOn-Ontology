        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Kennnummer der Pumpe im System.</rdfs:comment>
        <rdfs:comment xml:lang="en">The identification number of the pump in the system.</rdfs:comment>
        <rdfs:label xml:lang="en">Pump Number</rdfs:label>
        <rdfs:label xml:lang="de">Pumpennummer</rdfs:label>
    </owl:Class>
    


