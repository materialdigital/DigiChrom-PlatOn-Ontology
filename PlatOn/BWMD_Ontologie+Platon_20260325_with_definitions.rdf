        <rdfs:comment xml:lang="en">Chromium in the +3 oxidation state</rdfs:comment>
        <rdfs:label xml:lang="de">Chrom(III)</rdfs:label>
        <rdfs:label xml:lang="en">Chromium (III)</rdfs:label>
    </owl:Class>
    


