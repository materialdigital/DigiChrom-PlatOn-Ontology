    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GridSize -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GridSize">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Größe des Gitters, das in Anoden oder Elektrolysezellen verwendet wird.</rdfs:comment>
        <rdfs:comment xml:lang="en">The size of the grid used in anodes or electrolytic cells.</rdfs:comment>
        <rdfs:label xml:lang="en">Grid Size</rdfs:label>
        <rdfs:label xml:lang="de">Netzgröße</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Grinding -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Grinding">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MetallographicPreparation"/>
        <rdfs:isDefinedBy>DIN 8589:2003-09; DIN EN ISO 21920-1:2022-05; DIN EN ISO 21920-2:2022-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Grinding</rdfs:label>
        <skos:definition xml:lang="de">Schleifen ist ein spanendes Fertigungsverfahren, bei dem Material durch die Wirkung gebundener Schleifkörner (Schleifmittel) abgetragen wird, um eine Oberfläche zu erzeugen oder zu verändern. Hauptzweck ist das Erreichen definierter Maß-, Form- und Oberflächenkennwerte (z. B. Rauheit) als Vor- oder Nachbehandlung von Werkstücken, auch im Kontext galvanischer Beschichtungen. Im galvanotechnischen Prozessumfeld dient Schleifen typischerweise der Oberflächenvorbereitung (Entfernen von Unebenheiten/Altbeschichtungen) oder dem Finish nach dem Beschichten.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingAndPolishingEquipment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingAndPolishingEquipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MetallographicEquipment"/>
        <rdfs:comment>Grinding equipment (e.g. used for metallographic specimen preparation)</rdfs:comment>
        <rdfs:label xml:lang="en">GrindingEquipment</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalWorkshopEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 16089:2015-09, DIN EN ISO 23125:2015-12, DIN EN ISO 12100:2011-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Grinding machine</rdfs:label>
        <rdfs:label xml:lang="de">Schleifmaschine</rdfs:label>
        <skos:definition xml:lang="de">Eine Schleifmaschine ist eine Werkzeugmaschine, die Werkstücke mit einem rotierenden Schleifwerkzeug (z. B. Schleifscheibe) durch spanende Bearbeitung mit geometrisch unbestimmter Schneide formt und/oder deren Oberfläche bearbeitet. Hauptzweck ist das Erreichen definierter Maße, Formgenauigkeit und Oberflächenbeschaffenheit, häufig als Feinbearbeitung nach vor- oder zwischenliegenden Fertigungsschritten. Je nach Bauart (z. B. Flach-, Rund-, Werkzeugschleifmaschine) unterscheiden sich Kinematik, Spannmittel und Einsatzgebiet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingPaper -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingPaper">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingAndPolishingEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 13743:2009-06 (Sicherheit von Schleifmitteln – Beschichtete Schleifmittel), ISO 6344-1:1998 (Coated abrasives — Grain size analysis — Part 1: Grain size distribution test), ISO 6344-2:1998 (Coated abrasives — Grain size analysis — Part 2: Determination of grain size distribution of macrogrits P12 to P220), ISO 6344-3:1998 (Coated abrasives — Grain size analysis — Part 3: Determination of grain size distribution of microgrits P240 to P2500)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Grinding paper</rdfs:label>
        <rdfs:label xml:lang="de">Schleifpapier</rdfs:label>
        <skos:definition xml:lang="de">Schleifpapier ist ein beschichtetes Schleifmittel, bei dem Schleifkorn mit Bindemittel auf eine flexible Unterlage (typisch Papier) aufgebracht ist. Hauptzweck ist das mechanische Abtragen und Egalisieren von Oberflächen, z. B. zur Vorbehandlung vor galvanischen Beschichtungen (Entgraten, Mattieren, Entfernen von Oxiden/Altbeschichtungsresten). Es ist von Schleifleinen (Textilunterlage) und Schleifvlies (Vliesunterlage) durch die Art der Unterlage abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingPaperGrainSize -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingPaperGrainSize">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6344-1:2013-06; DIN EN ISO 6344-2:2013-06; DIN EN ISO 6344-3:2013-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Grinding paper grain size</rdfs:label>
        <rdfs:label xml:lang="de">Körnung des Schleifpapiers</rdfs:label>
        <skos:definition xml:lang="de">Die Körnung des Schleifpapiers ist die genormte Angabe der Korngröße (Grit) des auf dem Trägermaterial gebundenen Schleifkorns und damit eine Klassifikation des Schleifmittels nach Korngrößenbereich. Sie dient zur Festlegung der Abtragsleistung und der erzielbaren Oberflächenrauheit als Vorbereitungsschritt vor galvanischen Beschichtungen. Üblicherweise wird sie über standardisierte Kennzeichnungen (z. B. FEPA „P“-Körnungen für beschichtete Schleifmittel) angegeben und ist von der Art des Schleifkorns und der Bindung zu unterscheiden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrindingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 32502:2020-06 (Paints and varnishes — Determination of resistance to wear by abrasive particles), DIN EN ISO 19403-2:2017-12 (Paints and varnishes — Wettability — Part 2: Determination of the surface free energy of solid surfaces by measuring the contact angle)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Grinding time</rdfs:label>
        <rdfs:label xml:lang="de">Schleifzeit</rdfs:label>
        <skos:definition xml:lang="de">Schleifzeit ist die Zeitdauer, über die ein Schleifvorgang an einem Werkstück oder einer Oberfläche unter definierten Bedingungen durchgeführt wird. Sie dient als wesentlicher Prozess- oder Prüfparameter zur Einstellung bzw. Vergleichbarkeit des Materialabtrags, der Oberflächenbeschaffenheit und der Vorbereitung von Oberflächen vor nachfolgenden Beschichtungs- oder Prüfprozessen. In der Galvanotechnik ist sie insbesondere bei der mechanischen Vorbehandlung (z. B. vor dem Beschichten) und bei metallographischer Probenpräparation relevant und stets zusammen mit weiteren Parametern (z. B. Anpresskraft, Körnung, Geschwindigkeit, Kühlschmierung) zu spezifizieren.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GripSystem -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GripSystem">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <rdfs:label xml:lang="en">GripSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Hafnium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Hafnium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Hafnium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HardChromePlating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HardChromePlating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Plating"/>
        <dc:creator xml:lang="en">Elena G. Trelles</dc:creator>
        <rdfs:comment xml:lang="en">is a plating process that enhances the wear resistance and durability of various substrates. It involves careful control of parameters and the use of specialized equipment and infrastructure to ensure high-quality results. The process outputs hard chrome-plated items, along with data on thickness and quality for compliance and quality assurance.(ChatGPT)</rdfs:comment>
        <rdfs:label xml:lang="en">Hard Chrome Plating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Hardness -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Hardness">
