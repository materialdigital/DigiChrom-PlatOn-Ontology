    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Electrolyte/ElectrolyticSolution -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Electrolyte/ElectrolyticSolution">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalSolution"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">conducting medium in which the flow of current is accompanied by movement of matter, being most often an aqueous solution of acids, bases or dissolved salts of the metal to be deposited</rdfs:comment>
        <rdfs:comment xml:lang="de">leitendes Medium, in dem der Stromfluss von einer Bewegung von Materie begleitet wird; meist eine wässrige Lösung von Säuren, Basen oder gelösten Salzen des abzuscheidenden Metalls</rdfs:comment>
        <rdfs:label xml:lang="en">Electrolyte / Electrolytic Solution</rdfs:label>
        <rdfs:label xml:lang="de">Elektrolyt</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TankVoltage/CellVoltage -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TankVoltage/CellVoltage">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Gesamtspannung zwischen Anode und Kathode einer Lösung für die galvanische Metall- abscheidung oder einer elektrolytischen Zelle während der Elektrolyse, die der Summe aus dem Gleichgewichtsreaktionspotential, dem Abfall des Strom-Widerstands (IR) und den einzelnen Elektrodenpotentialen entspricht</rdfs:comment>
        <rdfs:comment xml:lang="en">total voltage between the anode and the cathode of an electroplating solution or electrolytic cell during electrolysis, being equal to the sum of the equilibrium reaction potential, the current-resistance (IR) drop, and the individual electrode potentials</rdfs:comment>
        <rdfs:label xml:lang="de">Badspannung</rdfs:label>
        <rdfs:label xml:lang="en">Tank Voltage / Cell Voltage</rdfs:label>
    </owl:Class>
</rdf:RDF>



