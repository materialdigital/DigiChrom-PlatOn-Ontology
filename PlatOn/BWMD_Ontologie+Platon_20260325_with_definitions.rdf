        <rdfs:label xml:lang="en">RegionOfInterest</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Regulation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Regulation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GenericallyDependentContinuant"/>
        <rdfs:label xml:lang="en">Regulation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RelationalQuality -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RelationalQuality">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quality"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">RelationalQuality</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RelativeTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RelativeTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Time in relation to a reference point</rdfs:comment>
        <rdfs:comment xml:lang="de">Zeit im Verhältnis zu einem Referenzzeitpunkt</rdfs:comment>
        <rdfs:isDefinedBy>ISO 80000-3:2019, Quantities and units — Part 3: Space and time</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Relative Time</rdfs:label>
        <rdfs:label xml:lang="de">Relativzeit</rdfs:label>
        <skos:definition xml:lang="de">Relative Zeit ist eine Zeitangabe, die nicht als absoluter Zeitpunkt (Datum/Uhrzeit), sondern als Zeitdifferenz bezogen auf einen festgelegten Referenzzeitpunkt (z. B. Start eines Prozesses oder Beginn einer Messung) angegeben wird. Sie dient dazu, Prozess- oder Messabläufe (z. B. Strom-/Spannungsverläufe, Badparameter, Schichtbildungsphasen) zeitlich eindeutig relativ zum Start zu beschreiben und vergleichbar zu machen. Relative Zeit ist damit von „absoluter Zeit“ (Zeitpunkt) und „Dauer“ (Zeitspanne ohne Referenzbezug) abzugrenenzen, auch wenn sie in der Praxis häufig als „t“ ab Start geführt wird.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Remarks -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Remarks">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InformationContentEntity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Anmerkungen oder Kommentare zu einem Thema</rdfs:comment>
        <rdfs:comment xml:lang="en">Notes or comments on a subject</rdfs:comment>
        <rdfs:label xml:lang="de">Bemerkungen</rdfs:label>
        <rdfs:label xml:lang="en">Remarks</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RemovalOfSpecimenFromTestingMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RemovalOfSpecimenFromTestingMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenPreparation"/>
        <rdfs:comment>The process of removing a specimen from a testing machine</rdfs:comment>
        <rdfs:label xml:lang="en">RemovalOfSpecimenFromTestingMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RemovalOfTestPieceFromTestingMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RemovalOfTestPieceFromTestingMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachinePreparation"/>
        <rdfs:label xml:lang="en">RemovalOfTestPieceFromTestingMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RemovalSpeed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RemovalSpeed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 15730:2001-03 (Metallische und andere anorganische Überzüge — Elektropolieren als Mittel zur Glättung und Passivierung von Edelstahl); ASM Handbook, Volume 5: Surface Engineering, ASM International, 1994 (Abschnitte zu chemical/electrochemical polishing und material removal rate)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Abtragsgeschwindigkeit</rdfs:label>
        <rdfs:label xml:lang="en">Removal Speed</rdfs:label>
        <skos:definition xml:lang="de">Die Abtragsgeschwindigkeit ist die zeitbezogene Rate, mit der Material von einer Werkstückoberfläche durch chemische oder elektrochemische Prozesse abgetragen wird. Hauptzweck ist die quantitative Beschreibung und Prozessführung von Abtragsverfahren (z. B. zur Einstellung von Maß, Rauheit oder zur Oberflächenvorbehandlung) über eine definierte Abtragsmenge pro Zeiteinheit. Sie wird je nach Anwendung als Dickenabtrag pro Zeit (z. B. µm/min) oder als Massenabtrag pro Zeit (z. B. g/min) angegeben und ist von der Abscheiderate (Schichtwachstum) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RemoveObjectFromMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RemoveObjectFromMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachinePreparation"/>
        <rdfs:comment>The process of removing any kind of object from a machine.</rdfs:comment>
        <rdfs:label xml:lang="en">RemoveObjectFromMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ReplenishmentNickel -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ReplenishmentNickel">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4526:2023-03; ISO 1456:2009-06; Schlesinger, M.; Paunovic, M. (Hrsg.): Modern Electroplating, 5th Edition, Wiley, 2010</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Nickel replenishment</rdfs:label>
        <rdfs:label xml:lang="de">Zugabe ins Nickel</rdfs:label>
        <skos:definition xml:lang="de">Eine „Zugabe ins Nickel“ ist das gezielte Einbringen von Chemikalien (Zusätzen/Additiven oder Korrekturchemikalien) in einen Nickelelektrolyten während Herstellung oder Betrieb des Bades. Hauptzweck ist die Einstellung bzw. Stabilisierung der Badzusammensetzung und damit der Abscheidungseigenschaften (z. B. Glanz, Einebnung, Duktilität, innere Spannung, Benetzbarkeit, pH/Leitfähigkeit). Abzugrenzen ist dies von der Zugabe von Nickelmetall zur Anodenbestückung; gemeint ist die Dosierung in den Elektrolyten.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Resin -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Resin">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2020-02, DIN EN ISO 9220:2020-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Einbettmasse / Harz</rdfs:label>
        <rdfs:label xml:lang="en">Resin</rdfs:label>
        <skos:definition xml:lang="de">Eine Einbettmasse (häufig auf Harzbasis) ist ein Material, mit dem Proben für die metallographische Untersuchung formschlüssig eingebettet und mechanisch stabilisiert werden. Hauptzweck ist die sichere Handhabung sowie die definierte Präparation (Schleifen/Polieren) und Querschnittsdarstellung von Schichtsystemen, z. B. galvanischen Überzügen. Harz-basierte Einbettmassen werden je nach Verfahren als Warm- oder Kalteinbettmittel eingesetzt und sind von Verguss-/Dichtmassen durch den primären Zweck der Probenpräparation abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ResinAmount -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ResinAmount">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3696:1995-03; DIN EN 14743:2007-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Harzmenge</rdfs:label>
        <rdfs:label xml:lang="en">Resin Quantity</rdfs:label>
        <skos:definition xml:lang="de">Harzmenge ist die definierte Menge (typisch als Volumen oder Masse) eines Ionenaustauscherharzes, die in einer Ionenaustauscheranlage bzw. -säule eingesetzt wird. Sie dient als Bezugsgröße zur Auslegung und Bewertung der Austauschkapazität, der Beladung/Regeneration sowie der Durchsatz- und Standzeitberechnung bei der Wasseraufbereitung in galvanotechnischen Prozessen. Üblich ist die Angabe als Harzvolumen (z. B. in Litern) bzw. als Bettvolumen, auf das Betriebskenngrößen normiert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Resist -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Resist">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringMaterial"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">&lt;nicht leitende Oberflächen&gt; Material, das auf einem Teil einer Kathode oder eines Gestells aufgebracht ist, um diese Oberflächen- stellen nicht leitend zu machen</rdfs:comment>
        <rdfs:comment xml:lang="en">&lt;non-conductive surface&gt; material applied to a part of a cathode or a plating jig to render the surface non-conductive</rdfs:comment>
        <rdfs:label xml:lang="de">Abdeckmittel</rdfs:label>
        <rdfs:label xml:lang="en">Resist</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Resistance -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Resistance">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">Resistance</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rhenium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rhenium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Rhenium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rhodium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rhodium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Rhodium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RightRingLightIntensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RightRingLightIntensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="de">Rechte Ringbeleuchtungsintensität</rdfs:label>
        <rdfs:label xml:lang="en">Right ring light intensity</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Rechte Ringbeleuchtungsintensität“ bezeichnet sprachlich eine Beleuchtungsstärke bzw. Beleuchtungsintensität, die einem rechtsseitig angeordneten ringförmigen Beleuchter (Ringlicht) zugeordnet wird. Zweck ist die quantitative Beschreibung der Beleuchtung, die von diesem rechten Ringlicht auf eine Mess- oder Beobachtungsfläche wirkt (z. B. in optischen Inspektions- oder Messaufbauten). Der Begriff ist nicht normativ festgelegt; in normkonformer Terminologie wäre typischerweise „Beleuchtungsstärke“ (illuminance) mit eindeutiger Geometrie-/Positionsangabe (z. B. „rechts, Ringlicht“) zu verwenden.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RightRingLightingTechnology -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RightRingLightingTechnology">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="de">Rechte Ringbeleuchtungstechnologie</rdfs:label>
        <rdfs:label xml:lang="en">Right ring lighting technology</rdfs:label>
        <skos:definition xml:lang="de">Eine „Rechte Ringbeleuchtungstechnologie“ bezeichnet eine ringförmig um ein Objektiv oder eine Beobachtungsachse angeordnete Beleuchtungseinheit mit rechteckiger (nicht kreisförmiger) Geometrie. Hauptzweck ist eine gleichmäßige, schattenarme Ausleuchtung zur optischen Inspektion/Überwachung (z. B. von Oberflächen, Schichtfehlern oder Benetzungszuständen) in galvanotechnischen Prozessen. Abzugrenzen ist der Begriff von normativ definierten Beleuchtungsgrößen (z. B. Beleuchtungsstärke) und von „Ringlicht“ als allgemeiner, nicht geometrisch spezifizierter Bauformbezeichnung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RinseWater -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RinseWater">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator xml:lang="en">Elena G. Trelles</dc:creator>
        <rdfs:comment xml:lang="en">Water used for rinsing the substrate before and after plating. (ChatGPT)</rdfs:comment>
        <rdfs:label xml:lang="en">Rinse Water</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rinsing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rinsing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9587:2007-06; DIN EN ISO 9588:2007-06; DIN EN ISO 4527:2023-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Rinsing</rdfs:label>
        <rdfs:label xml:lang="de">Spülen</rdfs:label>
        <skos:definition xml:lang="de">Spülen ist ein Verfahrensschritt, bei dem Werkstücke oder Oberflächen nach einer Vorbehandlung oder Beschichtung mit einem Spülmedium (typisch Wasser) in Kontakt gebracht werden, um anhaftende Prozesslösungen und gelöste Verunreinigungen zu entfernen. Hauptzweck ist die Vermeidung von Verschleppung (Drag-out) in nachfolgende Bäder und die Sicherstellung definierter Oberflächenzustände für die nächste Prozessstufe. Spülen kann als Tauch-, Spritz- oder Kaskadenspülen ausgeführt werden und ist von „Reinigen/Entfetten“ abzugrenzen, das primär die Entfernung von Schmutz- und Fettfilmen bezweckt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RinsingCycles -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RinsingCycles">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Anzahl Spülen Heißentfettung</rdfs:label>
        <rdfs:label xml:lang="en">Rinsing Cycles</rdfs:label>
        <skos:definition xml:lang="de">Spülen Heißentfettung ist ein Spülprozess (typisch mit Wasser), der unmittelbar nach einer Heißentfettung durchgeführt wird, um anhaftende Entfettungsmedien und gelöste Verunreinigungen von der Werkstückoberfläche zu entfernen. Hauptzweck ist die Vermeidung von Verschleppung (Carry-over) in nachfolgende Prozessbäder und die Sicherstellung einer definierten, rückstandsarmen Oberfläche für nachfolgende Beiz-, Aktivierungs- oder Beschichtungsschritte. Je nach Anforderung kann das Spülen als Tauch-, Spritz- oder Kaskadenspülen ausgeführt werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RinsingDuration -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RinsingDuration">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Dauer des Spülvorgangs</rdfs:comment>
        <rdfs:comment xml:lang="en">Duration of the rinsing process</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-06; DIN EN ISO 9587:2007-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Rinsing Duration</rdfs:label>
        <rdfs:label xml:lang="de">Spüldauer</rdfs:label>
        <skos:definition xml:lang="de">Die Spüldauer Heißentfettung ist die festgelegte Zeitspanne, während der ein Werkstück nach einer Heißentfettung in einem oder mehreren Spülschritten mit Spülmedium (typisch Wasser) gespült wird. Ihr Hauptzweck ist das Entfernen von anhaftenden Entfettungsmedien und gelösten Verunreinigungen, um Verschleppung in nachfolgende Prozessbäder zu vermeiden und eine definierte Oberflächenreinheit für die Beschichtung sicherzustellen. Sie ist prozessabhängig festzulegen (z. B. in Abhängigkeit von Badchemie, Temperatur, Geometrie und Spülführung) und von der Einwirkzeit der Heißentfettung abzugrenzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RinsingStations -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RinsingStations">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7599:2018-08, Metallische und andere anorganische Überzüge — Anodisieren von Aluminium und seinen Legierungen — Allgemeine Festlegungen für anodische Oxidüberzüge auf Aluminium; DIN EN ISO 2064:2020-01, Metallische und andere anorganische Überzüge — Begriffe und Definitionen; DIN EN ISO 11130:2010-12, Korrosion von Metallen und Legierungen — Korrosion in künstlichen Atmosphären — Beschleunigte Prüfung unter wechselnden Salzsprüh-/Trocknungsbedingungen (Bezug auf Spülen/Reinigen als Prozessschritt im Probenhandling)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Rinsing Stations</rdfs:label>
        <rdfs:label xml:lang="de">Spülstationen</rdfs:label>
        <skos:definition xml:lang="de">Spülstationen sind Anlagenteile in galvanotechnischen bzw. oberflächentechnischen Prozesslinien, in denen Werkstücke nach einem Behandlungsschritt mit Wasser (oder geeigneten Spülmedien) gespült werden. Ihr Hauptzweck ist das Entfernen bzw. Verdünnen von anhaftenden Prozesschemikalien und das Vermeiden von Verschleppung in nachfolgende Bäder zur Sicherung der Prozess- und Beschichtungsqualität. Spülstationen können als Standspülen, Kaskadenspülen oder Spritzspülen ausgeführt sein und sind typischerweise zwischen Prozessbädern angeordnet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Role -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Role">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RealizableEntity"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">Role</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RotationalSpeed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RotationalSpeed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-3:2020-09</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 80000-3:2020-09 (Größen und Einheiten – Teil 3: Raum und Zeit)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Drehzahl</rdfs:label>
        <rdfs:label xml:lang="en">Rotational speed</rdfs:label>
        <skos:definition xml:lang="de">Die Drehzahl ist die Anzahl der Umdrehungen eines rotierenden Körpers oder einer rotierenden Maschine bezogen auf eine Zeiteinheit, üblicherweise angegeben in min⁻¹ (Umdrehungen pro Minute). Sie dient zur quantitativen Beschreibung und Vorgabe der Rotationsgeschwindigkeit, z. B. von Trommeln, Gestellen oder Rührwerken in galvanotechnischen Anlagen, und beeinflusst damit Prozessführung und Ergebnis (z. B. Durchmischung, Relativbewegung, Abscheidebedingungen). Als Größe ist sie von der Winkelgeschwindigkeit zu unterscheiden, die in rad·s⁻¹ angegeben wird.</skos:definition>
        <skos:definition xml:lang="de">Die Drehzahl ist die Anzahl der Umdrehungen eines rotierenden Körpers oder einer rotierenden Maschine bezogen auf eine Zeiteinheit. Hauptzweck ist die quantitative Beschreibung der Rotationsgeschwindigkeit, z. B. von Rührwerken, Trommeln oder Werkstückaufnahmen in galvanotechnischen Prozessen zur Prozessführung und Reproduzierbarkeit. Übliche Angaben erfolgen als Frequenz (s⁻¹, Hz) oder als Umdrehungen pro Minute (min⁻¹, „rpm“), wobei die SI-konforme Einheit s⁻¹ ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of the roughness of a surface</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung der Rauheit einer Oberfläche</rdfs:comment>
        <rdfs:label xml:lang="de">Rauheitsmessung</rdfs:label>
        <rdfs:label xml:lang="en">Roughness Measurement</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessRa -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessRa">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 21920-2:2022-09, DIN EN ISO 21920-1:2022-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Arithmetischer Mittenrauwert (Ra)</rdfs:label>
        <rdfs:label xml:lang="en">AverageRoughness (Ra)</rdfs:label>
        <skos:definition xml:lang="de">Der arithmetische Mittenrauwert Ra ist ein Kenngrößenwert der Oberflächenrauheit und entspricht dem arithmetischen Mittel der Beträge der Profilabweichungen eines Rauheitsprofils von der Mittellinie innerhalb der Bewertungsstrecke. Er dient zur quantitativen Beschreibung und Spezifikation der Oberflächenbeschaffenheit (z. B. von Grundwerkstoffen oder galvanischen Überzügen) für Funktion, Qualitätssicherung und Vergleichbarkeit. Ra ist eine amplitudenbezogene Rauheitskenngröße und wird in der Regel aus einem gefilterten Profil (R-Profil) nach festgelegten Mess- und Auswertebedingungen bestimmt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessRmax -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessRmax">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4287:2010-07; DIN EN ISO 4288:1998-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Maximale Rautiefe (Rmax)</rdfs:label>
        <rdfs:label xml:lang="en">MaximumRoughnessDepth (Rmax)</rdfs:label>
        <skos:definition xml:lang="de">Die maximale Rautiefe (Rmax) bezeichnet den größten innerhalb einer Einzelmessstrecke ermittelten Abstand zwischen der höchsten Profilspitze und dem tiefsten Profiltal eines Rauheitsprofils. Sie dient zur Charakterisierung der extremen Rauheitsspitzen/-täler einer Oberfläche und wird u. a. zur Beurteilung von Funktions- und Beschichtungsanforderungen (z. B. Haftung, Schichtdickenreserve, Dichtverhalten) herangezogen. In der aktuellen ISO-Terminologie entspricht diese Bedeutung dem Parameter Rz (maximale Höhe des Rauheitsprofils innerhalb einer Einzelmessstrecke) und ist von Rt (Gesamtprofilhöhe über die Bewertungsstrecke) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessRz -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessRz">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4287:2010-07, DIN EN ISO 4288:1998-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">AverageMaximumRoughness(Rz)</rdfs:label>
        <rdfs:label xml:lang="de">Maximale Mittlere Rautiefe (Rz)</rdfs:label>
        <skos:definition xml:lang="de">Die Maximale Mittlere Rautiefe Rz ist ein Rauheitskennwert eines Oberflächenprofils und entspricht der arithmetischen Mittelung der Einzelrautiefen aus mehreren aufeinanderfolgenden Einzelmessstrecken innerhalb der Bewertungsstrecke. Sie dient der quantitativen Beschreibung der Profilhöhen (Spitzen-Tal-Ausprägung) einer Oberfläche und wird zur Spezifikation und Prüfung von Oberflächenzuständen, z. B. vor oder nach galvanischen Beschichtungen, verwendet. Rz ist von der „maximalen Rautiefe“ Rt zu unterscheiden, die die gesamte Spitzen-Tal-Höhe über die Bewertungsstrecke beschreibt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessSa -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessSa">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Average roughness of the surface</rdfs:comment>
        <rdfs:comment xml:lang="de">Durchschnittliche Rauheit der Oberfläche</rdfs:comment>
        <rdfs:label xml:lang="de">Rauheit Sa</rdfs:label>
        <rdfs:label xml:lang="en">Roughness Sa</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessSm -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoughnessSm">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Mean roughness of the surface</rdfs:comment>
        <rdfs:comment xml:lang="de">Mittlere Rauheit der Oberfläche</rdfs:comment>
        <rdfs:label xml:lang="de">Rauheit Sm</rdfs:label>
        <rdfs:label xml:lang="en">Roughness Sm</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoundBlank -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#RoundBlank">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProduct"/>
        <rdfs:comment>A round blank (a cylinder shaped object with height typically smaller than diameter)</rdfs:comment>
        <rdfs:label xml:lang="en">RoundBlank</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rp02 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rp02">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#YieldStress"/>
        <rdfs:label xml:lang="en">Rp02</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rubidium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Rubidium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Rubidium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ruthenium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ruthenium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Ruthenium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SEMCathode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SEMCathode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroscopeEquipment"/>
        <rdfs:comment>A cathode installed within the SEM</rdfs:comment>
        <rdfs:label xml:lang="en">SEMCathode</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SaltSprayTest -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SaltSprayTest">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Test to determine corrosion resistance through salt spray</rdfs:comment>
        <rdfs:comment xml:lang="de">Test zur Bestimmung der Korrosionsbeständigkeit durch Sprühnebel</rdfs:comment>
        <rdfs:label xml:lang="de">NSS-Test</rdfs:label>
        <rdfs:label xml:lang="en">Salt Spray Test</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SaltSprayTestingChamber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SaltSprayTestingChamber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9227:2022-02; DIN EN ISO 10289:1999-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Salt Spray Testing Chamber</rdfs:label>
        <rdfs:label xml:lang="de">Salzsprühkammer</rdfs:label>
        <skos:definition xml:lang="de">Eine Salzsprühkammer ist eine geschlossene Prüfkammer eines Salzsprühprüfgeräts, in der eine definierte Salzlösung als Aerosol (Nebel) unter festgelegten Umgebungsbedingungen erzeugt und auf Prüfkörper eingewirkt wird. Hauptzweck ist die Durchführung genormter Salzsprühprüfungen zur Beurteilung des Korrosionsverhaltens bzw. der Korrosionsbeständigkeit von metallischen Überzügen und Werkstoffen unter beschleunigten Bedingungen. Wesentliche Merkmale sind die geregelte Nebelerzeugung und -verteilung sowie die Einhaltung normierter Parameter (z. B. Temperatur, Salzlösung, pH-Wert, Sammelrate).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Samarium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Samarium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Samarium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SampleHolder -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SampleHolder">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9227:2023-09; DIN EN ISO 16701:2022-12; DIN EN ISO 2812-1:2017-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Probenhalter</rdfs:label>
        <rdfs:label xml:lang="en">Sample Holder</rdfs:label>
        <skos:definition xml:lang="de">Ein Probenhalter ist eine Vorrichtung zum definierten Fixieren und Positionieren von Proben (z. B. beschichtete Prüfkörper) während einer Prüfung oder Exposition. Hauptzweck ist die reproduzierbare Lagerung/Anordnung der Proben, um normgerechte Prüfbedingungen (z. B. Orientierung, Abstand, elektrische Kontaktierung je nach Verfahren) sicherzustellen. Je nach Prüfverfahren kann der Probenhalter Anforderungen an Werkstoffbeständigkeit, Geometrie und ggf. elektrische Isolation bzw. Kontaktierung erfüllen müssen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SandpaperStrips -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SandpaperStrips">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6344-1:2013-06; DIN EN ISO 6344-2:2013-06; DIN EN ISO 6344-3:2013-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Sandpaper Strips</rdfs:label>
        <rdfs:label xml:lang="de">Schleifpapierstreifen</rdfs:label>
        <skos:definition xml:lang="de">Ein Schleifpapierstreifen ist ein streifenförmig zugeschnittenes Schleifmittel auf Unterlage (z. B. Papier) mit aufgebrachtem Schleifkorn. Er dient zum manuellen oder maschinellen Schleifen/Anschleifen von Oberflächen, z. B. zur Vorbehandlung vor galvanischen Beschichtungen (Reinigen, Aufrauen, Entfernen von Oxiden/Altbeschichtungen). Im Unterschied zu Scheiben oder Bändern ist der Streifen ein Zuschnitt/Format und keine eigene Schleifmittelart.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Sawing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Sawing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachiningWithGeometricallyDeterminedEdge"/>
        <rdfs:label xml:lang="en">Sawing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanMode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanMode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 16700:2016-12 (Rasterelektronenmikroskopie — Vokabular)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Scan mode</rdfs:label>
        <rdfs:label xml:lang="de">Scan-Modus</rdfs:label>
        <skos:definition xml:lang="de">Der Scan-Modus ist eine Betriebsart eines abtastenden Mess- oder Bildgebungssystems, bei der ein Messstrahl oder Messpunkt zeilen- bzw. rasterförmig über eine Oberfläche geführt und das Signal ortsaufgelöst erfasst wird. Hauptzweck ist die Erzeugung einer flächenhaften Mess- oder Bildinformation (z. B. Topographie- oder Kontrastbild) aus punktweisen Signalen. In der Galvanotechnik wird der Scan-Modus insbesondere bei der Oberflächen- und Schichtcharakterisierung (z. B. mittels SEM) verwendet und ist von punktuellen Messmodi (Spot-/Punktmodus) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanMovement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanMovement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 25178-600:2019-09; DIN EN ISO 25178-601:2019-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Scan Movement</rdfs:label>
        <rdfs:label xml:lang="de">Scanbewegung</rdfs:label>
        <skos:definition xml:lang="de">Eine Scanbewegung ist eine definierte, meist kontinuierliche Relativbewegung zwischen Mess-/Bearbeitungseinheit und Werkstückoberfläche entlang einer vorgegebenen Bahn zur flächenhaften Erfassung oder Bearbeitung. Hauptzweck ist das systematische Abtasten/Erfassen von Oberflächenmerkmalen (z. B. Topographie) bzw. das reproduzierbare Überstreichen eines Bereichs. In der Galvanotechnik tritt sie typischerweise im Kontext der Oberflächenprüfung (z. B. optische/ taktile Messverfahren) auf und ist von einer reinen Positionierbewegung durch die kontinuierliche Bahnführung zur Datenerfassung abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanType -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanType">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 25178-600:2019-03; DIN EN ISO 3274:1998-04; DIN EN ISO 4287:2010-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Scan type</rdfs:label>
        <rdfs:label xml:lang="de">Scan-Typ</rdfs:label>
        <skos:definition xml:lang="de">Ein Scan-Typ ist die festgelegte Art und Geometrie der Abtastung (Scanstrategie) bei einer messenden oder bildgebenden Erfassung einer Oberfläche, z. B. als Linienscan (Profil) oder Flächenscan (Areal). Hauptzweck ist die eindeutige Spezifikation, wie Messpunkte räumlich erfasst werden, um Messergebnisse (z. B. Rauheits-/Topographieparameter oder Schichtdickenkarten) reproduzierbar zu machen und vergleichbar auszuwerten. Der Scan-Typ ist von Scanparametern wie Scanlänge, Schrittweite/Abtastabstand und Scangeschwindigkeit abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Scandium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Scandium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Scandium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanningElectronMicroscope -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanningElectronMicroscope">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroscopeEquipment"/>
        <rdfs:comment>Scanning electron microscope</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 16700:2016-12; DIN EN ISO 22309:2011-12</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 22493:2020-12; DIN EN ISO 18115-1:2023-06; DIN EN ISO 18115-2:2023-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">ScanningElectronMicroscope</rdfs:label>
        <skos:definition xml:lang="de">Ein Rasterelektronenmikroskop (REM) ist ein Elektronenmikroskop, das eine Probenoberfläche mit einem fokussierten Elektronenstrahl zeilenweise abtastet und aus den detektierten Wechselwirkungssignalen (z. B. Sekundär- und Rückstreuelektronen) ein Bild erzeugt. Hauptzweck ist die hochauflösende Darstellung und Analyse der Oberflächenmorphologie und -topographie sowie – in Kombination mit geeigneten Detektoren – die ortsaufgelöste Material-/Elementinformation. Im Unterschied zur Transmissionselektronenmikroskopie wird primär die Oberfläche bzw. oberflächennahe Zone untersucht und die Bildentstehung beruht auf dem Rasterprinzip.</skos:definition>
        <skos:definition xml:lang="de">Ein Rasterelektronenmikroskop (REM, engl. scanning electron microscope, SEM) ist ein Elektronenmikroskop, das eine Probe mit einem fokussierten Elektronenstrahl zeilenweise (rasterförmig) abtastet und aus den dabei erzeugten Signalen ein Bild der Probenoberfläche erzeugt. Hauptzweck ist die hochauflösende Untersuchung von Oberflächenmorphologie und Mikrostruktur sowie – je nach Detektion – die Gewinnung von material- und topographiebezogenen Kontrastinformationen. In der Galvanotechnik wird es insbesondere zur Beurteilung von Schichtaufbau, Defekten und Bruch-/Querschliffbildern eingesetzt; die Kombination mit energiedispersiver Röntgenspektroskopie (EDS) dient zusätzlich der elementaren Analyse.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanningElectronMicroscopy -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ScanningElectronMicroscopy">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Microscopy"/>
        <rdfs:isDefinedBy>DIN EN ISO 16700:2016-12, DIN EN ISO 22309:2011-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">ScanningElectronMicroscopy</rdfs:label>
        <skos:definition xml:lang="de">Rasterelektronenmikroskopie (REM) ist ein bildgebendes Verfahren der Elektronenmikroskopie, bei dem ein fokussierter Elektronenstrahl zeilenweise über die Probenoberfläche gerastert und aus den entstehenden Signalen (z. B. Sekundär- und Rückstreuelektronen) ein Bild erzeugt wird. Hauptzweck ist die hochauflösende Untersuchung von Oberflächenmorphologie und Mikrostruktur, z. B. zur Bewertung von Schichtoberflächen, Defekten oder Bruchflächen in galvanisch abgeschiedenen Überzügen. In der Praxis wird REM häufig mit energiedispersiver Röntgenspektroskopie (EDS/EDX) zur lokalen chemischen Analyse kombiniert, wobei diese Analytik normativ separat behandelt sein kann.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Scratches -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Scratches">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8785:1999-11, DIN EN ISO 25178-2:2012-09, DIN EN ISO 1302:2002-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Kratzer</rdfs:label>
        <rdfs:label xml:lang="en">Scratches</rdfs:label>
        <skos:definition xml:lang="de">Ein Kratzer ist eine linienförmige Oberflächenbeschädigung bzw. -unregelmäßigkeit, die durch mechanische Einwirkung entsteht und als Rille/Spur in oder auf der Oberfläche erkennbar ist. Hauptzweck der Erfassung ist die Beurteilung der Oberflächenqualität, da Kratzer das Aussehen, die Funktion (z. B. Dichtheit, Reibung) und ggf. die Korrosionsbeständigkeit von beschichteten Bauteilen beeinträchtigen können. In der Abgrenzung zu Rissen ist ein Kratzer typischerweise eine durch äußere Einwirkung verursachte Spur ohne werkstoffbedingte Rissausbreitung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Second -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Second">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseUnit"/>
        <rdfs:label xml:lang="en">Second</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SecondaryDendriteArmSpacing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SecondaryDendriteArmSpacing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DendriteArmSpacing"/>
        <rdfs:label xml:lang="en">SecondaryDendriteArmSpacing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Selenium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Selenium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Selenium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Separating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Separating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturing"/>
        <rdfs:label xml:lang="en">Separating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SeparatingCastPartFromMold -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SeparatingCastPartFromMold">
