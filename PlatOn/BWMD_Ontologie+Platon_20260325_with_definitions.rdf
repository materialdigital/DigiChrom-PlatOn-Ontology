    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GrainStructure">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialStructureRelatedFiatObjectPart"/>
        <rdfs:label xml:lang="en">GrainStructure</rdfs:label>
    </owl:Class>
    


