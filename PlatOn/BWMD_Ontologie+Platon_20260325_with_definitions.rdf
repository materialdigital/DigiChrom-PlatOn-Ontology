        <rdfs:comment xml:lang="de">Lieferant des heißen Entfettungsmittels</rdfs:comment>
        <rdfs:comment xml:lang="en">Supplier of the hot degreasing agent</rdfs:comment>
        <rdfs:label xml:lang="de">Heißentfettung Lieferant</rdfs:label>
        <rdfs:label xml:lang="en">Hot Degreasing Supplier</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HotDegreasingTemperature -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HotDegreasingTemperature">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Temperatur, bei der das heiße Entfettungsverfahren durchgeführt wird</rdfs:comment>
        <rdfs:comment xml:lang="en">Temperature at which the hot degreasing process is performed</rdfs:comment>
        <rdfs:label xml:lang="de">Heißentfettung Temperatur </rdfs:label>
        <rdfs:label xml:lang="en">Hot Degreasing Temperature</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HotDegreasingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HotDegreasingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Dauer des heißen Entfettungsverfahrens</rdfs:comment>
        <rdfs:comment xml:lang="en">Duration of the hot degreasing process</rdfs:comment>
        <rdfs:label xml:lang="de">Heißentfettung Zeit</rdfs:label>
        <rdfs:label xml:lang="en">Hot Degreasing Time</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HullCell -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HullCell">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">trapezförmige Prüfzelle aus nicht leitendem Material, in dem die Elektroden so angeordnet sind, dass kathodische oder anodische Effekte über weite Stromdichtebereiche beobachtet und die Eigenschaften von Elektrolyten verglichen werden können</rdfs:comment>
        <rdfs:comment xml:lang="en">trapezoidal test cell of non-conducting material with electrodes arranged to permit the observation of cathodic or anodic effects over a wide range of current densities and compare the characteristics of electrolytes </rdfs:comment>
        <rdfs:label xml:lang="en">Hull Cell</rdfs:label>
        <rdfs:label xml:lang="de">Hull-Zelle</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Hydrogen -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Hydrogen">
