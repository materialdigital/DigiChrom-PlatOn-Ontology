    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NormalForce -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NormalForce">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-4:2020-07, DIN EN ISO 7148-2:2012-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Normal Force</rdfs:label>
        <rdfs:label xml:lang="de">Normalkraft</rdfs:label>
        <skos:definition xml:lang="de">Die Normalkraft ist die Kraftkomponente, die senkrecht (normal) auf eine Kontaktfläche oder Trennfläche wirkt. Sie dient als maßgebende Bezugsgröße zur Beschreibung von Kontakt- und Reibungszuständen, z. B. zur Bestimmung der Reibkraft über einen Reibungskoeffizienten. In der Tribologie wird sie häufig als äußere Belastung eines Reibkontakts (Normalbelastung) verwendet und ist von tangentialen Kraftanteilen (Reib-/Schubkraft) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Notch -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Notch">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TechnologicalProductRelatedSite"/>
        <rdfs:comment>A notch in a technological product.</rdfs:comment>
        <rdfs:label xml:lang="en">Notch</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Number -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Number">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Amount"/>
        <rdfs:label xml:lang="en">Number</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberDensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberDensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">NumberDensity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberFraction -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberFraction">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Amount"/>
        <rdfs:label xml:lang="en">NumberFraction</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfCalibrations -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfCalibrations">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/IEC 17025:2018-03; DIN EN ISO 9001:2015-11; DIN EN ISO 10012:2003-12; VDI/VDE 2623 Blatt 1:2012-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Anzahl Kalibrierungen</rdfs:label>
        <rdfs:label xml:lang="en">Number Of Calibrations</rdfs:label>
        <skos:definition xml:lang="de">Die Anzahl Kalibrierungen ist eine Zählgröße, die angibt, wie oft ein Messmittel, Prüfmittel oder eine Messeinrichtung kalibriert wurde. Sie dient der Rückverfolgbarkeit und Dokumentation im Rahmen der Messmittelüberwachung sowie der Bewertung der Messzuverlässigkeit über den Lebenszyklus. Sie ist von dem Kalibrierintervall (Zeit/Frist zwischen Kalibrierungen) und dem Kalibrierstatus (gültig/abgelaufen) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfCracks -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfCracks">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Anzahl der Risse in einem Material</rdfs:comment>
        <rdfs:comment xml:lang="en">Number of cracks in a material</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 6158:2018-03 (Metallische Überzüge – Elektrolytisch abgeschiedene Chromüberzüge für technische Zwecke)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Number Of Cracks</rdfs:label>
        <rdfs:label xml:lang="de">Risszahl</rdfs:label>
        <skos:definition xml:lang="de">Anzahl Risse ist die gezählte Menge einzelner Risse in einem definierten Prüf- bzw. Bewertungsbereich einer Oberfläche oder eines Überzugs. Sie dient der quantitativen Beurteilung des Risszustands (Rissbildung/Rissdichte) und damit der Vergleichbarkeit von Überzugsqualitäten oder Prozesszuständen. Die Angabe erfolgt normgerecht bezogen auf eine festgelegte Fläche bzw. Messstrecke und unter definierten Beobachtungsbedingungen (z. B. Vergrößerung, Auswerteverfahren).</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfCycles -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfCycles">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Amount"/>
        <rdfs:label xml:lang="en">NumberOfCycles</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfHeaderLinesInTable -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfHeaderLinesInTable">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FormatDescription"/>
        <rdfs:label xml:lang="en">NumberOfHeaderLinesInTable</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfLines -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfLines">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4287:2010-07, DIN EN ISO 4288:1998-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Anzahl Linien</rdfs:label>
        <rdfs:label xml:lang="en">Number Of Lines</rdfs:label>
        <skos:definition xml:lang="de">Die Anzahl Linien ist eine Zählgröße, die angibt, wie viele Linien (z. B. Profil-, Schnitt- oder Auswertelinien) bei einer Messung oder Auswertung herangezogen werden. Sie dient dazu, den Umfang der Datenerfassung bzw. die statistische Grundlage der Bewertung (z. B. von Rauheitskennwerten) festzulegen und nachvollziehbar zu dokumentieren. Je nach Messverfahren ist sie von der Auswertelänge bzw. der Anzahl der Einzelmessungen abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-12; DIN EN ISO 2360:2017-12; DIN EN ISO 4618:2015-03; DIN EN ISO/IEC 17025:2018-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Anzahl Messungen</rdfs:label>
        <rdfs:label xml:lang="en">Number Of Measurement</rdfs:label>
        <skos:definition xml:lang="de">Die Anzahl Messungen ist die festgelegte oder dokumentierte Zahl der durchgeführten Einzelmessungen (Wiederholungen) innerhalb eines Mess- oder Prüfverfahrens. Sie dient der statistisch belastbaren Ermittlung eines Messergebnisses (z. B. Mittelwert) und der Bewertung der Messunsicherheit bzw. Streuung. Sie ist von der Anzahl Prüflinge/Proben zu unterscheiden, da mehrere Messungen an derselben Probe möglich sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfSurfaceCracks -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberOfSurfaceCracks">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1302:2002-07; DIN EN ISO 23277:2015-12; DIN EN ISO 3452-1:2021-12</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 1302:2002-07; DIN EN ISO 8785:1999-11; DIN EN ISO 10289:2000-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Anzahl an Oberflächenrissen</rdfs:label>
        <rdfs:label xml:lang="en">Number of surface cracks</rdfs:label>
        <skos:definition xml:lang="de">Die Anzahl an Oberflächenrissen ist eine Zählgröße, die angibt, wie viele einzelne Risse an einer definierten Oberfläche bzw. in einem festgelegten Prüfbereich eines Bauteils oder einer Beschichtung festgestellt werden. Hauptzweck ist die quantitative Bewertung der Risshäufigkeit als Qualitäts- bzw. Abnahmekriterium im Rahmen einer festgelegten Prüfmethode (z. B. Sichtprüfung oder Eindringprüfung) und definierter Annahmekriterien. Sie ist von rissbezogenen Längen-/Breitenkennwerten und von flächenbezogenen Dichten (z. B. „Risse pro Fläche“) abzugrenzen, sofern diese separat spezifiziert werden.</skos:definition>
        <skos:definition xml:lang="de">Die Anzahl der Oberflächenrisse ist eine quantitative Kenngröße, die angibt, wie viele als Oberflächenrisse identifizierte Rissanzeigen auf einer definierten Oberfläche bzw. in einem festgelegten Prüfbereich vorhanden sind. Sie dient der Bewertung der Oberflächenintegrität und der Festlegung bzw. Überprüfung von Qualitäts- und Annahmekriterien (z. B. zulässige Rissanzahl pro Fläche oder pro Bauteil) bei galvanisch beschichteten oder metallischen Oberflächen. Die Kenngröße ist nur sinnvoll in Verbindung mit einer festgelegten Prüfmethode, Prüfbedingung und Auswerte-/Zählregel (z. B. visuelle Prüfung, Vergrößerung, Mindestlänge/Öffnungsweite, Abgrenzung zu Poren/Kratzern).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberofMeasurements -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NumberofMeasurements">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Anzahl der durchgeführten Messungen.</rdfs:comment>
        <rdfs:comment xml:lang="en">The number of measurements performed.</rdfs:comment>
        <rdfs:label xml:lang="de">Anzahl Messungen</rdfs:label>
        <rdfs:label xml:lang="en">Number of Measurements</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Object -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Object">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialEntity"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">Object</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAbrasionMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAbrasionMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7784-2:2016-07; DIN EN ISO 4649:2017-02; ASTM G65-16(2021)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Abrieb gemessen</rdfs:label>
        <rdfs:label xml:lang="en">Object Abrasion Measured</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Abrieb gemessen“ bezeichnet den im Rahmen einer genormten Abriebprüfung ermittelten Abrieb eines beschichteten oder unbeschichteten Werkstoffs als Messwert (z. B. Massenverlust, Volumenverlust oder Schichtdickenabtrag). Zweck ist die quantitative Bewertung der Abrieb- bzw. Verschleißbeständigkeit einer Oberfläche unter definierten Prüfbedingungen. Der Messwert ist stets an das verwendete Prüfverfahren, die Prüfkörper/Schleifmittel, die Belastung und die Auswertegröße gebunden und daher nur bei Angabe der Prüfbedingungen vergleichbar.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAbrasionResistanceMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAbrasionResistanceMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7784-2:2016-12; DIN EN ISO 5470-1:2017-01; DIN EN ISO 11998:2007-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Abriebfestigkeit gemessen</rdfs:label>
        <rdfs:label xml:lang="en">Object Abrasion Resistance Measured</rdfs:label>
        <skos:definition xml:lang="de">Abriebfestigkeit gemessen ist ein ermittelter Messwert bzw. ein Prüfergebnis, das die Widerstandsfähigkeit einer Oberfläche oder Beschichtung gegen Abnutzung durch Reib- bzw. Abrasivbeanspruchung unter festgelegten Prüfbedingungen beschreibt. Hauptzweck ist die quantitative Bewertung und Vergleichbarkeit der Verschleißbeständigkeit von galvanischen Überzügen/Schichtsystemen anhand eines definierten Prüfverfahrens und einer festgelegten Kenngröße (z. B. Masseverlust, Volumenverlust, Durchscheuerzyklen). Die Aussage ist nur zusammen mit dem angewendeten Normprüfverfahren, den Prüfparametern und der Auswertegröße eindeutig.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectActivated -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectActivated">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-03; DIN EN ISO 9587:2007-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Aktiviertes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Activated</rdfs:label>
        <skos:definition xml:lang="de">Ein aktiviertes Objekt ist ein Werkstück, dessen Oberfläche durch einen Aktivierungsschritt in einen reaktionsfähigen, haftfähigen Zustand überführt wurde (z. B. durch Entfernen passivierender Schichten oder durch Erzeugen einer chemisch aktiven Oberfläche). Hauptzweck ist die Sicherstellung einer zuverlässigen nachfolgenden Beschichtung/Abscheidung (z. B. galvanische Metallabscheidung) durch verbesserte Benetzbarkeit und Haftung. Die Aktivierung ist von der Reinigung/Entfettung abzugrenzen, da sie gezielt die Oberflächenreaktivität bzw. Passivschichtfreiheit für den Prozessstart herstellt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAdhesionMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAdhesionMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2819:2018-12; DIN EN ISO 2409:2020-08; DIN EN ISO 4624:2016-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Haftfestigkeit gemessen</rdfs:label>
        <rdfs:label xml:lang="en">Object Adhesion Measured</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Haftfestigkeit gemessen“ bezeichnet den im Rahmen einer genormten Prüfung ermittelten Wert bzw. das Ergebnis zur Haftfestigkeit einer Beschichtung auf einem Substrat. Hauptzweck ist die dokumentierte, vergleichbare Bewertung der Verbundfestigkeit (Adhäsion) zwischen Schicht und Grundwerkstoff nach festgelegtem Prüfverfahren und definierten Randbedingungen. Der Messwert ist stets an das verwendete Verfahren (z. B. Abreißprüfung, Gitterschnitt) und die zugehörigen Prüfparameter gebunden und daher ohne diese Angaben nicht eindeutig interpretierbar.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAdhesionMeasured2 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAdhesionMeasured2">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="de">Haftfestigkeit gemessen 2</rdfs:label>
        <rdfs:label xml:lang="en">Object Adhesion Measured2</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Haftfestigkeit gemessen 2“ bezeichnet einen zweiten erfassten Messwert zur Haftfestigkeit einer Beschichtung auf einem Substrat innerhalb einer Prüfserie. Zweck ist die Dokumentation einer Wiederholungs- oder Vergleichsmessung zur Beurteilung der Reproduzierbarkeit bzw. Streuung der Haftfestigkeit. Der Begriff ist von der normativen Kenngröße „Haftfestigkeit/Haftung“ zu trennen, deren Messverfahren und Ergebnisdarstellung in den jeweiligen Prüfnormen festgelegt sind.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAggregate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAggregate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialEntity"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">ObjectAggregate</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAggregateName -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAggregateName">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <rdfs:comment>Name of a specific object aggregate</rdfs:comment>
        <rdfs:label xml:lang="en">ObjectAggregateName</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectChemicalResistanceMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectChemicalResistanceMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2812-1:2018-12; DIN EN ISO 2812-2:2018-12; DIN EN ISO 2812-3:2018-12; DIN EN ISO 2812-4:2018-12; DIN EN ISO 4628-1:2016-07; DIN EN ISO 4628-2:2016-07; DIN EN ISO 4628-3:2016-07; DIN EN ISO 4628-4:2016-07; DIN EN ISO 4628-5:2016-07; DIN EN ISO 2409:2020-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Chemikalienbeständigkeit gemessen</rdfs:label>
        <rdfs:label xml:lang="en">Object Chemical Resistance Measured</rdfs:label>
        <skos:definition xml:lang="de">Chemikalienbeständigkeit gemessen ist ein dokumentiertes Prüfergebnis, das die Widerstandsfähigkeit eines beschichteten oder unbeschichteten Werkstücks gegenüber definierten Chemikalien unter festgelegten Einwirkbedingungen (z. B. Konzentration, Temperatur, Zeit) quantitativ oder qualitativ beschreibt. Hauptzweck ist die objektive Bewertung und Vergleichbarkeit der Beständigkeit (z. B. anhand von Massenänderung, Sichtbefund, Haftfestigkeitsänderung oder Korrosions-/Schädigungsgrad) zur Spezifikation und Qualitätsprüfung von Oberflächen. Die Aussage ist nur im Kontext des angewendeten Prüfverfahrens und der Prüfbedingungen gültig und darf nicht ohne diese Randbedingungen verallgemeinert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectChromiumPlated -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectChromiumPlated">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1456:2023-02; DIN EN ISO 6158:2018-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Chromium Plated</rdfs:label>
        <rdfs:label xml:lang="de">Verchromtes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein verchromtes Objekt ist ein Werkstück oder Bauteil, dessen Oberfläche durch einen galvanisch abgeschiedenen Chromüberzug (Chrombeschichtung) bedeckt ist. Hauptzweck ist die Bereitstellung definierter Oberflächeneigenschaften wie Korrosionsschutz (typisch in Kombination mit Nickel), dekoratives Aussehen oder erhöhte Verschleißbeständigkeit. Je nach Ausführung wird zwischen dekorativem Chrom (dünne Chromschicht auf Nickel) und Hartchrom (funktioneller, dicker Chromüberzug) unterschieden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCleaned -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCleaned">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingObjects"/>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2017-02; DIN EN ISO 9587:2007-02</rdfs:isDefinedBy>
        <skos:definition xml:lang="de">Ein gereinigtes Objekt ist ein Werkstück, dessen Oberfläche durch geeignete Reinigungsverfahren von prozessrelevanten Verunreinigungen (z. B. Öle, Fette, Partikel, Bearbeitungsrückstände) befreit wurde. Zweck ist es, eine definierte Oberflächenreinheit als Voraussetzung für nachfolgende Prozessschritte wie Beizen, Aktivieren oder galvanisches Abscheiden sicherzustellen und Haftungs- bzw. Qualitätsprobleme zu vermeiden. Der Begriff beschreibt einen Prozesszustand des Werkstücks und ist von „aktiviertem“ oder „gebeiztem“ Objekt abzugrenzen, bei denen zusätzlich chemische Oberflächenumwandlungen vorliegen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectColorMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectColorMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-4:2020-03; DIN EN ISO/CIE 11664-2:2022-03; DIN EN ISO 7724-1:2022-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Farbe gemessen</rdfs:label>
        <rdfs:label xml:lang="en">Object Color Measured</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Farbe gemessen“ bezeichnet das Ergebnis einer Farbmessung, d. h. die durch ein genormtes Messverfahren ermittelten farbmetrischen Werte eines Prüfkörpers bzw. einer Oberfläche (z. B. L\*a\*b\*-Koordinaten oder Tristimuluswerte). Hauptzweck ist die objektive, reproduzierbare Beschreibung und Vergleichbarkeit von Oberflächenfarben (z. B. galvanisch erzeugter Schichten) unabhängig von subjektiver visueller Beurteilung. Voraussetzung für Vergleichbarkeit ist die eindeutige Angabe von Messbedingungen wie Normlichtart/Beobachter, Messgeometrie und Auswerteverfahren.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectColoumetryMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectColoumetryMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 127:1998-06 (Wasserbeschaffenheit — Bestimmung von Chrom(VI) — Photometrisches Verfahren); DIN 38405-24:2011-10 (Deutsche Einheitsverfahren zur Wasser-, Abwasser- und Schlammuntersuchung — Anionen (Gruppe D) — Teil 24: Bestimmung von Chlorid — Coulometrische Titration)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Coulometrisch gemessen</rdfs:label>
        <rdfs:label xml:lang="en">Object Coloumetry Measured</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Coulometrisch gemessen“ bezeichnet einen Messwert, der mittels Coulometrie bestimmt wurde, also durch Erfassung der elektrischen Ladungsmenge (Coulomb), die bei einer elektrochemischen Reaktion umgesetzt wird. Hauptzweck ist die quantitative Bestimmung einer Stoffmenge bzw. eines Gehalts über das Faradaysche Gesetz aus dem integrierten Strom-Zeit-Verlauf. In der Galvanotechnik wird dies u. a. zur analytischen Bestimmung von Inhaltsstoffen in Prozesslösungen verwendet und ist vom potentiometrischen oder photometrischen Messprinzip abzugrenzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrackDensityMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrackDensityMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 21207:2015-12; ASTM E1122-13(2021)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object crack density measured</rdfs:label>
        <rdfs:label xml:lang="de">Objekt mit gemessener Rissdichte</rdfs:label>
        <skos:definition xml:lang="de">Ein „Objekt mit gemessener Rissdichte“ ist ein Prüfkörper oder Bauteil, für das die Rissdichte eines Überzugs oder Werkstoffbereichs nach einem festgelegten Prüf- und Auswerteverfahren quantitativ bestimmt und dokumentiert wurde. Zweck ist die objektive Bewertung des Risszustands (z. B. zur Qualitätsüberwachung, Prozessfreigabe oder zum Vergleich von Beschichtungszuständen) anhand einer definierten Kenngröße pro Bezugsfläche bzw. Bezugsstrecke. Die Klasse umfasst das Objekt zusammen mit dem zugehörigen Messergebnis und den Randbedingungen der Messung (Prüfverfahren, Vergrößerung/Auswertefläche, Akzeptanzkriterien), um Vergleichbarkeit sicherzustellen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrackNumberMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrackNumberMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 15721:2011-12, Metallische und andere anorganische Überzüge — Verfahren zur Messung der Rissdichte von Chromüberzügen (Crack density of chromium coatings)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Crack Number Measured</rdfs:label>
        <rdfs:label xml:lang="de">Rissanzahl gemessen</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Rissanzahl gemessen“ ist ein Messwert, der die bei einer Prüfung ermittelte Anzahl von Rissen in einem definierten Auswertebereich einer Oberfläche bzw. eines Überzugs angibt. Hauptzweck ist die quantitative Charakterisierung der Rissigkeit (z. B. zur Qualitätsüberwachung und zum Vergleich von Überzügen/Prozessbedingungen). Üblich ist die Angabe bezogen auf eine Messstrecke oder Fläche (z. B. als Risse pro Millimeter oder pro Quadratmillimeter) und die Ermittlung mittels mikroskopischer Auswertung nach festgelegten Prüfbedingungen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionEtchedViewed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionEtchedViewed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08, DIN EN ISO 9220:2020-11, DIN EN ISO 17639:2022-12, ASTM E3-11(2017), ASTM E407-07(2015)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Geätztes Schliffbild betrachtet</rdfs:label>
        <rdfs:label xml:lang="en">Object Cross Section Etched Viewed</rdfs:label>
        <skos:definition xml:lang="de">Ein „geätztes Schliffbild“ ist die nach dem metallographischen Präparieren und anschließenden Ätzen erzeugte Probenoberfläche, deren Mikrostruktur (z. B. Gefüge, Schichtaufbau, Korngrenzen) sichtbar gemacht wird. „Betrachtet“ bezeichnet die visuelle bzw. mikroskopische Auswertung dieses geätzten Schliffbildes zur Beurteilung von Werkstoff- oder Schichteigenschaften (z. B. Schichtdicke, Poren/Risse, Grenzflächen). Abzugrenzen ist dies von ungeätzten Schliffen (Kontrast primär durch Politur/Topographie) sowie von rein makroskopischen Oberflächenprüfungen ohne metallographischen Querschliff.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionMicrographed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionMicrographed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2020-08; DIN EN ISO 9220:2020-07; DIN EN ISO 3613:2021-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object cross section micrographed</rdfs:label>
        <rdfs:label xml:lang="de">Objekt mit Querschliffmikroaufnahme</rdfs:label>
        <skos:definition xml:lang="de">Ein Objekt mit Querschliffmikroaufnahme ist ein Prüfobjekt bzw. Datensatz, der eine mikroskopische Aufnahme eines präparierten Querschliffs eines beschichteten Werkstücks enthält. Hauptzweck ist die dokumentierte Beurteilung von Schichtaufbau und Schichtdicke sowie ggf. von Grenzflächen, Poren, Rissen oder Haftungsmerkmalen im Querschnitt. Es ist von reinen Oberflächenaufnahmen abzugrenzen, da die Information aus der Schnittfläche (Querschliff) stammt und typischerweise eine metallographische Präparation voraussetzt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationCut -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationCut">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; DIN EN ISO 9220:2020-11; ASTM E3-11(2017)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Getrenntes Objekt (Querschliffpräparation)</rdfs:label>
        <rdfs:label xml:lang="en">Object cross section preparation cut</rdfs:label>
        <skos:definition xml:lang="de">Ein getrenntes Objekt ist ein aus einem Bauteil oder einer Probe durch Trennen (z. B. Sägen, Trennschleifen) entnommenes Probenstück, das für die Querschliffpräparation weiterverarbeitet wird. Hauptzweck ist die Gewinnung eines handhabbaren, repräsentativen Probenkörpers zur nachfolgenden Einbettung, Schleif- und Polierpräparation sowie mikroskopischen Bewertung von Schichtsystemen und Grenzflächen. Es ist vom „eingebetteten Objekt“ (nach dem Einbetten) und vom „Querschliff“ (fertig präparierte Schlifffläche/Präparat) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationEmbedded -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationEmbedded">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08, DIN EN ISO 9220:2020-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Eingebettetes Objekt (Querschliffpräparation)</rdfs:label>
        <rdfs:label xml:lang="en">Object cross section preparation embedded</rdfs:label>
        <skos:definition xml:lang="de">Ein eingebettetes Objekt ist eine für die Querschliffuntersuchung vorgesehene Probe bzw. ein Probenabschnitt, der in ein Einbettmittel (z. B. Kunstharz) eingebracht und ausgehärtet wurde, sodass ein handhabbarer Probenkörper entsteht. Hauptzweck ist die mechanische Stabilisierung, Kanten- und Schichtstützung sowie die definierte Ausrichtung der Probe für nachfolgendes Schleifen, Polieren und mikroskopische Bewertung von Schichten und Grenzflächen. Abzugrenzen ist es vom „Einbettmittel“ (Matrix) und vom „Querschliff“ als Ergebnis der Präparation (freigelegte Schnittfläche).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationGrinded -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationGrinded">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; DIN EN ISO 9220:2020-07; DIN EN ISO 16700:2016-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Geschliffenes Objekt (Querschliffpräparation)</rdfs:label>
        <rdfs:label xml:lang="en">Object cross section preparation grinded</rdfs:label>
        <skos:definition xml:lang="de">Ein geschliffenes Objekt (im Kontext der Querschliffpräparation) ist eine eingebettete oder fixierte Probe, deren Schnittfläche durch Schleifen (und ggf. nachfolgendes Polieren) plan und definiert oberflächenvorbereitet wurde, um den Querschnitt eines beschichteten Bauteils untersuchen zu können. Hauptzweck ist die reproduzierbare Herstellung einer auswertbaren Querschliffoberfläche für mikroskopische Prüfungen, z. B. zur Schichtdickenmessung und zur Beurteilung von Schichtaufbau, Grenzflächen und Fehlstellen. Abzugrenzen ist es vom „polierten Objekt“ (zusätzlicher Polierschritt) sowie vom „geätzten Schliff“ (zusätzliche Ätzung zur Gefügekontrastierung).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationMounted -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationMounted">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 20567-1:2017-02; ASTM E3-11(2017)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Eingebettetes Objekt für Querschliffpräparation</rdfs:label>
        <rdfs:label xml:lang="en">Object cross section preparation mounted</rdfs:label>
        <skos:definition xml:lang="de">Ein eingebettetes Objekt für Querschliffpräparation ist eine Probe bzw. ein Probenkörper, der zur Querschliffherstellung in ein Einbettmittel (z. B. warm- oder kalteinbettender Kunststoff) eingebracht und formstabil fixiert wurde. Zweck ist die mechanische Stabilisierung, definierte Ausrichtung und Kanten-/Schichtschutz der Probe, um einen repräsentativen Querschnitt durch Beschichtungen und Grundwerkstoff schleifen, polieren und anschließend mikroskopisch auswerten zu können. Es ist vom „Einbettmittel“ (Material) und vom „Querschliff“ (Ergebnis/Schliffpräparat) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationPolished -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionPreparationPolished">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; ASTM B487-20 (Reapproved 2024); DIN EN ISO 4287:2010-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object cross section preparation polished</rdfs:label>
        <rdfs:label xml:lang="de">Poliertes Objekt (Querschliffpräparation)</rdfs:label>
        <skos:definition xml:lang="de">Ein poliertes Objekt (Querschliffpräparation) ist eine in einem definierten Querschnitt freigelegte und bis zur erforderlichen Oberflächengüte geschliffene und polierte Probe, die die Mikrostruktur und Schichtfolge (z. B. galvanische Überzüge) unverfälscht abbilden soll. Hauptzweck ist die reproduzierbare mikroskopische Beurteilung und Messung, insbesondere der Schichtdicke und der Schichtqualität im Querschnitt. Wesentlich ist, dass die Präparation (Einbetten, Schleifen, Polieren) keine relevanten Präparationsartefakte erzeugt, die die Bewertung beeinflussen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionViewed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCrossSectionViewed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08, Metallische und anorganische Überzüge — Messung der Schichtdicke — Mikroskopisches Verfahren; DIN EN ISO 9220:2020-11, Metallische Überzüge — Messung der Schichtdicke — Rasterelektronenmikroskopisches Verfahren; DIN EN ISO 3613:2021-06, Metallische und andere anorganische Überzüge — Chromat-Umwandlungsüberzüge auf Zink, Cadmium, Aluminium und deren Legierungen — Prüfverfahren (Querschliff/Schichtbeurteilung im Kontext der Prüfung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Cross Section Viewed</rdfs:label>
        <rdfs:label xml:lang="de">Schliffbild erstellt</rdfs:label>
        <skos:definition xml:lang="de">Ein „Schliffbild“ ist die bildliche Darstellung einer präparierten Schliffprobe (Querschliff/Anschliff), die nach Einbetten, Schleifen/Polieren und ggf. Ätzen mikroskopisch aufgenommen wird. Der Hauptzweck ist die Beurteilung von Schichtaufbau, Schichtdicke, Gefüge, Grenzflächen und möglichen Fehlern (z. B. Poren, Risse) an galvanischen Überzügen. „Schliffbild erstellt“ bezeichnet, dass diese Präparation und die zugehörige mikroskopische Dokumentation abgeschlossen und ein auswertbares Bild vorliegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCut -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCut">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-12, DIN EN ISO 2360:2017-12, DIN EN ISO 3497:2000-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Getrenntes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object cut</rdfs:label>
        <skos:definition xml:lang="de">Ein getrenntes Objekt ist ein von einem Bauteil oder Grundwerkstoff abgetrennter Teil (Probe/Prüfstück), der als eigenständiges Objekt für Prüf- oder Messzwecke behandelt wird. Hauptzweck ist die Durchführung von Prüfungen (z. B. Schichtdickenmessung) unter definierten Bedingungen, wenn Messungen am eingebauten oder vollständigen Bauteil nicht möglich oder nicht zulässig sind. Abzugrenzen ist es von Messungen am „ungetrennten“ Originalbauteil, bei denen Geometrie, Randbedingungen und Schichtzustand unverändert bleiben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCutted1 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCutted1">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Object Cutted1</rdfs:label>
        <rdfs:label xml:lang="de">Objekt geschnitten 1</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Objekt geschnitten 1“ bezeichnet typischerweise ein Werkstück/Prüfobjekt, das durch Schneiden bzw. Trennen so präpariert wurde, dass eine Schnittfläche oder ein Querschnitt zur Beurteilung zugänglich ist. Hauptzweck ist die Untersuchung von Schichtaufbau, Schichtdicke, Haftung oder Gefüge an der Schnittfläche, z. B. im Rahmen metallographischer oder schichttechnischer Prüfungen. Die Ziffer „1“ ist dabei üblicherweise eine Identifikations- oder Variantenkennzeichnung und kein normativ festgelegtes Merkmal.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCutted2 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCutted2">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Object Cutted2</rdfs:label>
        <rdfs:label xml:lang="de">Objekt geschnitten 2</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Objekt geschnitten 2“ bezeichnet typischerweise ein Werkstück/Probenobjekt, das für die Untersuchung im Querschliff (Schnittpräparation) geschnitten wurde, wobei „2“ eine laufende Kennnummer des Schnitts/der Probe ist. Hauptzweck ist die eindeutige Zuordnung eines spezifischen Schnittpräparats zu Messungen oder Befunddokumentationen (z. B. Schichtdickenmessung, Gefüge-/Schichtaufbauanalyse). Der Begriff ist kein normativ definierter Terminus, sondern eine Benennungskonvention im Prüf- und Laborumfeld.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCutted3 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCutted3">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Object Cutted3</rdfs:label>
        <rdfs:label xml:lang="de">Objekt geschnitten 3</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Objekt geschnitten 3“ bezeichnet typischerweise ein Objekt bzw. eine Probe in geschnittener Darstellung oder als Schnittpräparat mit der Kennnummer 3. Hauptzweck ist die eindeutige Identifikation einer bestimmten Schnittansicht/Querschliff-Probe für die Bewertung von Schichtaufbau, Schichtdicke oder Gefüge im Rahmen der galvanotechnischen Prüfung. Der Begriff ist ohne Kontext (Zeichnung, Prüfplan, Probenliste) nicht eindeutig normativ interpretierbar und sollte in Ontologien als projektspezifische Kennzeichnung modelliert werden.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCutted4 -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectCutted4">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Object Cutted4</rdfs:label>
        <rdfs:label xml:lang="de">Objekt geschnitten 4</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Objekt geschnitten 4“ bezeichnet typischerweise eine spezifische, intern nummerierte Probe bzw. ein Präparat nach einem Schneid-/Trennvorgang (z. B. Querschnitt/Schliff) zur weiteren Prüfung. Hauptzweck ist die eindeutige Identifikation eines bestimmten geschnittenen Objekts innerhalb einer Prüfserie (z. B. für metallographische Auswertung oder Schichtdickenbestimmung am Querschliff). Der Begriff ist keine normativ festgelegte Bezeichnung, sondern eine dokumentations-/laborinterne Benennung.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectDegreased -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectDegreased">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4520:2007-11; DIN EN ISO 9587:2007-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Entfettetes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Degreased</rdfs:label>
        <skos:definition xml:lang="de">Ein entfettetes Objekt ist ein Werkstück, dessen Oberfläche durch einen Entfettungsprozess von Fetten, Ölen und vergleichbaren organischen Verunreinigungen befreit wurde. Hauptzweck ist die Sicherstellung einer definierten Oberflächenreinheit als Voraussetzung für nachfolgende Prozessschritte wie Beizen, Aktivieren oder galvanische Abscheidung, um Haftfestigkeit und Schichtqualität zu gewährleisten. Der Begriff beschreibt einen Oberflächenzustand (Ergebnis der Vorbehandlung) und nicht das Entfettungsverfahren selbst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectDegreasedAnodic -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectDegreasedAnodic">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4527:2023-06; ASTM B322-11(2021)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Anodisch entfettetes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Degreased Anodic</rdfs:label>
        <skos:definition xml:lang="de">Ein anodisch entfettetes Objekt ist ein Werkstück, das in einem elektrolytischen Entfettungsbad als Anode geschaltet und dadurch von Fetten/Ölen und anderen organischen Verunreinigungen befreit wurde. Hauptzweck ist die definierte Oberflächenvorbereitung zur Verbesserung der Benetzbarkeit und Haftfestigkeit nachfolgender galvanischer oder chemischer Beschichtungen. Charakteristisch ist die anodische Gasentwicklung an der Werkstückoberfläche, die die Reinigungswirkung unterstützt und sich vom kathodischen Entfetten durch Polung und Nebenreaktionen unterscheidet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectDegreasedCathodic -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectDegreasedCathodic">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2018-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Kathodisch entfettetes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Degreased Cathodic</rdfs:label>
        <skos:definition xml:lang="de">Ein kathodisch entfettetes Objekt ist ein Werkstück, das in einem elektrolytischen Entfettungsbad als Kathode geschaltet und dadurch von Fetten, Ölen und anderen organischen Verunreinigungen befreit wurde. Hauptzweck ist die Herstellung einer sauberen, aktivierten Oberfläche als Voraussetzung für nachfolgende Beschichtungsprozesse (z. B. galvanische Abscheidung) mit guter Haftfestigkeit. Abzugrenzen ist es vom anodischen Entfetten (Werkstück als Anode) sowie von rein chemischen Entfettungsverfahren ohne Strom.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectDried -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectDried">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9227:2022-09; DIN EN ISO 10289:2020-01; DIN EN ISO 2081:2018-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Getrocknetes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Dried</rdfs:label>
        <skos:definition xml:lang="de">Ein getrocknetes Objekt ist ein Werkstück/Prüfkörper, dessen Oberfläche nach einer nasschemischen Behandlung (z. B. Spülen, Passivieren, Beschichten) durch geeignete Maßnahmen so entwässert wurde, dass anhaftende Flüssigkeiten entfernt sind und ein definierter trockener Zustand vorliegt. Hauptzweck ist die Sicherstellung reproduzierbarer Prozessfolgen und Prüfergebnisse (z. B. vor Messungen, Korrosionsprüfungen oder Verpackung) sowie die Vermeidung von Fleckenbildung, Korrosion oder Beeinflussung nachfolgender Schichten. Der Begriff beschreibt einen Zustand (Ergebnis des Trocknungsprozesses) und ist von „Trocknung“ als Verfahren/Prozessschritt abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectEmbedded -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectEmbedded">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08, Metallische und Oxidschichten – Messung der Schichtdicke – Mikroskopisches Verfahren; DIN EN ISO 9220:1988-06, Metallische Überzüge – Messung der Schichtdicke – Rasterelektronenmikroskopisches Verfahren; DIN EN ISO 4516:2002-10, Metallische und andere anorganische Überzüge – Vickers- und Knoop-Mikrohärteprüfungen (Querschliffpräparation im Kontext der Prüfung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Eingebettetes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Embedded</rdfs:label>
        <skos:definition xml:lang="de">Ein eingebettetes Objekt ist ein Prüfkörper oder Probenstück, das zur Untersuchung in ein Einbettmittel (z. B. Harz) vollständig oder teilweise eingebracht und darin fixiert wurde. Hauptzweck ist die lage- und formstabile Handhabung sowie die definierte Präparation (Schleifen/Polieren) zur Beurteilung von Schichtsystemen, Grenzflächen und Gefügemerkmalen. Es ist vom „Einbettmittel“ (Matrixmaterial) und vom „Einbetten“ (Prozess) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectEnergyDispersiveXRayMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectEnergyDispersiveXRayMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>ISO 22309:2011, *Microbeam analysis — Quantitative analysis using energy-dispersive spectrometry (EDS) for elements with atomic number 11 or higher*; ISO 15632:2021, *Microbeam analysis — Selected instrumental performance parameters for the specification and checking of energy-dispersive X-ray spectrometers for use in electron probe microanalysis*</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object energy dispersive xray measured</rdfs:label>
        <rdfs:label xml:lang="de">Objekt mit gemessener energiedispersiver Röntgenspektroskopie</rdfs:label>
        <skos:definition xml:lang="de">Ein „Objekt mit gemessener energiedispersiver Röntgenspektroskopie“ ist ein Probenkörper/Prüfobjekt, für den ein EDX/EDS-Spektrum mittels energiedispersiver Röntgenspektroskopie aufgenommen und als Messdaten zugeordnet wurde. Hauptzweck ist die qualitative und/oder quantitative Bestimmung der elementaren Zusammensetzung (z. B. von Schichten, Überzügen oder Korrosionsprodukten) am Objekt bzw. in einem definierten Messbereich. Abzugrenzen ist dies von Objekten, für die lediglich eine EDX-Messung geplant oder simuliert wurde, ohne dass ein tatsächlich erfasstes Spektrum als Messergebnis vorliegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectEtched -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectEtched">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4527:2023-06; DIN EN ISO 2080:2022-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Geätztes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Etched</rdfs:label>
        <skos:definition xml:lang="de">Ein geätztes Objekt ist ein Werkstück oder Probekörper, dessen Oberfläche durch Ätzen mittels geeigneter chemischer oder elektrochemischer Verfahren gezielt angegriffen und dabei Material abgetragen bzw. die Oberflächenmorphologie verändert wurde. Hauptzweck ist die Oberflächenvorbereitung (z. B. Aktivierung, Reinigung, Erzeugung definierter Rauheit) oder das Freilegen/Erzeugen von Strukturen als Voraussetzung für nachfolgende Beschichtungs- oder Prüfprozesse. Abzugrenzen ist es von rein mechanisch aufgerauten oder nur entfetteten Objekten, da beim Ätzen ein chemisch/elektrochemisch verursachter Materialabtrag stattfindet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectGlossMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectGlossMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2813:2015-02, DIN 67530:1982-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Glanz gemessen</rdfs:label>
        <rdfs:label xml:lang="en">Object Gloss Measured</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Glanz gemessen“ bezeichnet den durch ein genormtes Glanzmessverfahren ermittelten Glanzgrad einer Oberfläche als Messwert, üblicherweise angegeben in Glanzeinheiten (GU) bei festgelegter Geometrie (z. B. 20°, 60° oder 85°). Hauptzweck ist die objektive, vergleichbare Bewertung des spiegelnden Reflexionsanteils von galvanisch erzeugten oder nachbehandelten Oberflächen zur Qualitätsprüfung und Spezifikationserfüllung. Der Messwert ist nur bei Angabe der Messgeometrie, Kalibrierung und Messbedingungen normkonform interpretierbar.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectGrinded -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectGrinded">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1302:2002-12; DIN EN ISO 21920-1:2022-10; DIN EN ISO 21920-2:2022-10; DIN EN ISO 21920-3:2022-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Geschliffenes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Grinded</rdfs:label>
        <skos:definition xml:lang="de">Ein geschliffenes Objekt ist ein Werkstück, dessen Oberfläche durch das Fertigungsverfahren Schleifen gezielt bearbeitet wurde, um eine definierte Oberflächenbeschaffenheit zu erzeugen. Hauptzweck ist die Einstellung von Rauheit/Welligkeit sowie ggf. Maß- und Formgenauigkeit als Grundlage für nachfolgende Prozesse (z. B. galvanische Beschichtungen) oder für die Funktion der Oberfläche. Abzugrenzen ist es von polierten oder gestrahlten Objekten, da die Oberflächenstruktur und die zugehörigen Kenngrößen aus dem spezifischen Abtragsprozess „Schleifen“ resultieren.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectHeatTreated -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectHeatTreated">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4885:2019-12, Wärmebehandlung von Eisenwerkstoffen – Begriffe; DIN EN 10052:1993-03, Vokabular der Wärmebehandlung von Eisenwerkstoffen; DIN EN ISO 2081:2018-09, Metallische und andere anorganische Überzüge – Galvanische Zinküberzüge auf Eisen oder Stahl mit zusätzlicher Behandlung (Hinweise zu Wärmebehandlung/Entsprödung im Prozesskontext)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Heat Treated</rdfs:label>
        <rdfs:label xml:lang="de">Wärmebehandeltes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein wärmebehandeltes Objekt ist ein Werkstück/Teil, dessen Werkstoffeigenschaften durch einen definierten Wärmebehandlungsprozess (z. B. Glühen, Härten, Anlassen) gezielt verändert wurden. Hauptzweck ist die Einstellung von Eigenschaften wie Härte, Festigkeit, Zähigkeit oder Gefügezustand als Voraussetzung oder Einflussgröße für nachfolgende Prozesse (z. B. galvanische Beschichtung) und die spätere Bauteilfunktion. Abzugrenzen ist es von lediglich erwärmten Teilen ohne spezifizierten Wärmebehandlungszweck bzw. ohne festgelegte Prozessparameter.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Identifier"/>
        <rdfs:label xml:lang="en">ObjectID</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_BetzChrom -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_BetzChrom">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID"/>
        <rdfs:label xml:lang="en">ObjectID_BetzChrom</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_FraunhoferIPA -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_FraunhoferIPA">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID"/>
        <rdfs:label xml:lang="en">ObjectID_FraunhoferIPA</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_HSAalen -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_HSAalen">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID"/>
        <rdfs:label xml:lang="en">ObjectID_HSAalen</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_TUIllmenau -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_TUIllmenau">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID"/>
        <rdfs:label xml:lang="en">ObjectID_TUIllmenau</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_hansgrohe -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID_hansgrohe">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectID"/>
        <rdfs:label xml:lang="en">ObjectID_hansgrohe</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectImageRecorded -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectImageRecorded">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 11145:2018-03 (Optik und Photonik — Laser und laserbezogene Ausrüstung — Vokabular und Symbole); DIN EN ISO 21073:2019-06 (Optik und Photonik — Spektrale Bänder)</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>ISO 12233:2017, Photography — Electronic still picture imaging — Resolution and spatial frequency responses; ISO 15739:2017, Photography — Electronic still-picture imaging — Noise measurements; (Fachliteratur) W. Nitsche, M. Nitsche, Galvanotechnik, 3. Auflage, Springer Vieweg, 2019.</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Bild aufgenommenes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Image Recorded</rdfs:label>
        <skos:definition xml:lang="de">Ein bild aufgenommenes Objekt ist der physische Gegenstand oder Bereich (z. B. Werkstück, Probenfläche oder Merkmal), der bei der Bildaufnahme durch ein optisches System erfasst und im Bild abgebildet wird. Hauptzweck ist die eindeutige Benennung des realen Referenzobjekts, auf das sich bildbasierte Auswertung, Messung oder Dokumentation (z. B. Oberflächenprüfung, Schichtfehlerdetektion) beziehen. Es ist vom „Bildobjekt“ (digitales Objekt/ROI im Bild) und vom „Objektfeld“ (räumlicher Bereich, der abgebildet wird) abzugrenzen.</skos:definition>
        <skos:definition xml:lang="de">Ein fotografiertes Objekt ist der physische Gegenstand oder Bereich, der bei einer fotografischen Aufnahme als Motiv erfasst und auf einem Bild wiedergegeben wird. Hauptzweck ist die eindeutige Referenz des abgebildeten Prüflings/Details, z. B. zur Dokumentation von Oberflächenzuständen, Fehlern oder Schichtmerkmalen in der galvanotechnischen Qualitätssicherung. Abzugrenzen ist es vom „Bild“ bzw. „Foto“ als Ergebnis der Aufnahme und von der „Probe/Prüfkörper“‑Bezeichnung in Prüf- und Produktnormen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectInstrumentedIndentationMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectInstrumentedIndentationMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 14577-1:2015-11, DIN EN ISO 14577-2:2015-11, DIN EN ISO 14577-3:2015-11, DIN EN ISO 14577-4:2016-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object instrumented indentation measured</rdfs:label>
        <rdfs:label xml:lang="de">Objekt mit instrumentierter Eindringprüfung</rdfs:label>
        <skos:definition xml:lang="de">Ein „Objekt mit instrumentierter Eindringprüfung“ ist ein Prüfobjekt (z. B. Bauteil, Probe oder beschichteter Probekörper), an dem eine instrumentierte Eindringprüfung durchgeführt wird, bei der Kraft und Eindringtiefe während des Eindringvorgangs kontinuierlich gemessen und aufgezeichnet werden. Hauptzweck ist die Ermittlung mechanischer Kenngrößen (z. B. Härte und ggf. weitere aus dem Kraft-Eindringtiefe-Verlauf abgeleitete Parameter) auch für dünne Schichten bzw. oberflächennahe Bereiche. Abzugrenzen ist es von Objekten, die ausschließlich mit konventionellen Härteprüfverfahren (ohne kontinuierliche Messkurve) geprüft werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectInstrumentedIndented -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectInstrumentedIndented">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 14577-1:2015-11; DIN EN ISO 14577-2:2015-11; DIN EN ISO 14577-3:2015-11; DIN EN ISO 14577-4:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Instrumentiert eingedrückt</rdfs:label>
        <rdfs:label xml:lang="en">Object Instrumented Indented</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Instrumentiert eingedrückt“ bezeichnet einen Zustand bzw. eine Prüfsituation, bei der ein Eindringkörper unter kontinuierlicher Messung von Kraft und Eindringtiefe in eine Oberfläche eingedrückt wird. Hauptzweck ist die Ermittlung mechanischer Kennwerte (z. B. Eindringhärte und Eindringmodul) aus der Kraft–Eindringtiefe-Kurve. Der Ausdruck ist sprachlich eher eine Ableitung/Umformung; normativ gebräuchlich ist die Bezeichnung des Verfahrens als instrumentierte Eindringprüfung.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectLayerThicknessMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectLayerThicknessMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2017-03; DIN EN ISO 2178:2016-09; DIN EN ISO 2360:2017-03; DIN EN ISO 3497:2000-08</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2020-03; DIN EN ISO 2178:2016-12; DIN EN ISO 2360:2017-05; DIN EN ISO 3497:2000-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object layer thickness measured</rdfs:label>
        <rdfs:label xml:lang="de">Objekt mit gemessener Schichtdicke</rdfs:label>
        <skos:definition xml:lang="de">Ein Objekt mit gemessener Schichtdicke ist ein Bauteil oder Prüfkörper, an dem die Dicke einer aufgebrachten Schicht mittels eines festgelegten Messverfahrens bestimmt und als Messwert dokumentiert wurde. Hauptzweck ist der Nachweis bzw. die Verifikation der Schichtdicke als Qualitäts- und Konformitätsmerkmal gegenüber einer Spezifikation. Abzugrenzen ist es von Referenznormalen/Kalibrierstandards, die primär zur Kalibrierung des Messsystems dienen, nicht zur Bewertung der Schichtdicke des Objekts selbst.</skos:definition>
        <skos:definition xml:lang="de">Schichtdicke gemessen ist der durch ein festgelegtes Messverfahren ermittelte Zahlenwert der Dicke einer aufgebrachten Schicht (z. B. metallischer Überzug) an einer definierten Messstelle bzw. über eine definierte Messfläche. Hauptzweck ist die objektive Verifikation der Schichtdicke zur Erfüllung von Spezifikationen, Qualitätsanforderungen und Konformitätsnachweisen. Sie ist vom Sollwert/Nennwert der Schichtdicke zu unterscheiden und hängt vom angewendeten Messprinzip, der Kalibrierung und der Messstrategie (Messpunkte, Mittelwertbildung) ab.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectLens -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectLens">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroscopeAccessory"/>
        <rdfs:comment>Object lens of a light microscope</rdfs:comment>
        <rdfs:label xml:lang="en">ObjectLens</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectLightMicroscoped -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectLightMicroscoped">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; DIN EN ISO 17639:2022-12; DIN EN ISO 9042:2020-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object light microscoped</rdfs:label>
        <rdfs:label xml:lang="de">Objekt lichtmikroskopisch untersucht</rdfs:label>
        <skos:definition xml:lang="de">Ein „Objekt lichtmikroskopisch untersucht“ ist ein Prüfobjekt (z. B. beschichtetes Bauteil oder Schliffprobe), das mittels Lichtmikroskopie visuell und bildgebend ausgewertet wurde. Hauptzweck ist die Beurteilung von Mikrostruktur- und Oberflächen-/Schichtmerkmalen (z. B. Schichtaufbau, Defekte, Poren, Risse) und/oder die Messung von Schichtdicken an Querschliffen. Die Aussage ist verfahrensbezogen und beschreibt den Untersuchungsstatus, nicht das Ergebnis oder eine Qualitätsklasse.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectNickelPlated -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectNickelPlated">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2004-11; DIN EN ISO 1456:2009-12</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-02; DIN EN ISO 4528:2023-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Nickel Plated</rdfs:label>
        <rdfs:label xml:lang="de">Vernickeltes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein vernickeltes Objekt ist ein Werkstück, dessen Oberfläche mit einem Nickelüberzug versehen ist (z. B. durch elektrolytisches oder chemisches Vernickeln). Zweck des Nickelüberzugs ist je nach Spezifikation insbesondere Korrosionsschutz, Verschleißschutz und/oder die Bereitstellung definierter funktioneller bzw. dekorativer Oberflächeneigenschaften. Der Begriff beschreibt das beschichtete Substrat (Objekt) und ist von der Prozessbezeichnung „Vernickeln“ sowie von Mehrschichtsystemen (z. B. Nickel/Chrom) abzugrenzen.</skos:definition>
        <skos:definition xml:lang="de">Ein vernickeltes Objekt ist ein Werkstück, dessen Oberfläche mit einem Nickelüberzug versehen wurde (z. B. durch elektrolytisches oder chemisches Vernickeln). Hauptzweck ist der Schutz des Grundwerkstoffs und/oder die Bereitstellung definierter Oberflächeneigenschaften (z. B. Korrosionsbeständigkeit, Verschleißverhalten, Löt-/Kontaktierbarkeit oder dekoratives Aussehen). Abzugrenzen ist es von Objekten mit Nickel als Grundwerkstoff sowie von Mehrschichtsystemen, bei denen Nickel nur eine von mehreren Schichten darstellt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectOpticalSurfaceRoughnessMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectOpticalSurfaceRoughnessMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 25178-1:2016-12; DIN EN ISO 25178-600:2019-09; DIN EN ISO 21920-1:2022-07; DIN EN ISO 21920-2:2022-07; DIN EN ISO 21920-3:2022-07</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 25178-6:2010-12; DIN EN ISO 25178-604:2013-05; DIN EN ISO 25178-2:2012-09; DIN EN ISO 21920-1:2022-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Optical Surface Measured</rdfs:label>
        <rdfs:label xml:lang="en">Object optical surface roughness measured</rdfs:label>
        <rdfs:label xml:lang="de">Objekt mit gemessener optischer Oberflächenrauheit</rdfs:label>
        <rdfs:label xml:lang="de">Optisch Oberflächenrauigkeits gemessenes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein optisch oberflächenrauigkeits gemessenes Objekt ist ein Prüf- oder Werkstück, dessen Oberflächenrauheit mit einem optischen (berührungslosen) Messverfahren erfasst und als Oberflächenkenngrößen dokumentiert wurde. Hauptzweck ist die quantitative Beurteilung der Oberflächenbeschaffenheit (z. B. zur Prozessüberwachung, Spezifikationsprüfung oder Funktionsbewertung von galvanischen Schichten). Abzugrenzen ist es von taktil gemessenen Objekten, bei denen die Rauheit mit Tastschnitt- oder Tastsystemen bestimmt wird.</skos:definition>
        <skos:definition xml:lang="de">Ein „Objekt mit gemessener optischer Oberflächenrauheit“ ist ein Werkstück/Prüfkörper, dessen Oberflächenrauheit mittels optischer, berührungsloser Topographie-Messung erfasst und als Rauheitskenngrößen beschrieben wurde. Hauptzweck ist die quantitative Charakterisierung der Oberflächenbeschaffenheit zur Spezifikation, Qualitätsprüfung und Vergleichbarkeit von Oberflächen unabhängig von taktilen Messverfahren. Besonderheit ist, dass die Messung auf optisch erfassten Flächendaten basiert und die Auswertung nach genormten Rauheitskenngrößen (profil- oder flächenbezogen) erfolgt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPickled -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPickled">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4527:2022-06; DIN EN ISO 2081:2018-09; DIN EN ISO 1463:2021-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Geätztes Objekt</rdfs:label>
        <rdfs:label xml:lang="en">Object Pickled</rdfs:label>
        <skos:definition xml:lang="de">Ein geätztes Objekt ist ein Werkstück oder Probekörper, dessen Oberfläche durch Ätzen gezielt chemisch oder elektrochemisch abgetragen und dadurch in ihrer Topographie bzw. Oberflächenbeschaffenheit verändert wurde. Hauptzweck ist die Reinigung, Aktivierung oder definierte Rauheits- bzw. Strukturierungserzeugung als Vorbehandlung für nachfolgende Beschichtungsprozesse (z. B. galvanische Abscheidung) oder zur Sichtbarmachung von Gefügestrukturen. Abzugrenzen ist es von mechanisch aufgerauten Objekten (z. B. gestrahlt), da der Materialabtrag beim Ätzen überwiegend durch chemische Reaktion erfolgt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPinOnDisk -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPinOnDisk">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>ASTM G99-17, *Standard Test Method for Wear Testing with a Pin-on-Disk Apparatus* (Reapproved 2022)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Pin On Disk</rdfs:label>
        <rdfs:label xml:lang="de">Pin-on-Disk Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein Pin-on-Disk Objekt ist ein Prüfkörper (Pin oder Scheibe), der in einem Pin-on-Disk‑Reib- und Verschleißversuch als Kontaktpartner eingesetzt wird. Hauptzweck ist die definierte Erzeugung eines Gleitkontakts zur Bestimmung von Reibungskoeffizient und/oder Verschleißverhalten von Werkstoffen bzw. Beschichtungen unter festgelegten Prüfbedingungen. Das Objekt ist damit Teil des Tribosystems und wird in der Norm über Geometrie, Werkstoff, Oberflächenzustand und Prüfparameter spezifiziert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPolished -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPolished">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4287:2010-07; DIN EN ISO 4288:1998-04; DIN EN ISO 1463:2021-08</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Polished</rdfs:label>
        <rdfs:label xml:lang="de">Poliertes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein poliertes Objekt ist ein Werkstück oder eine Probe, dessen Oberfläche durch Polieren (mechanisch und/oder chemisch-mechanisch) gezielt geglättet und von Bearbeitungsspuren befreit wurde. Hauptzweck ist die Erzeugung einer definierten, reproduzierbaren Oberflächenbeschaffenheit, z. B. als Vorzustand für galvanische Beschichtungen oder für die mikroskopische/messtechnische Beurteilung. Abzugrenzen ist es von geschliffenen oder gestrahlten Objekten, bei denen eine andere Oberflächenstruktur bzw. Rauheitscharakteristik erzeugt wird.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPreNickelPlated -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPreNickelPlated">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1456:2023-02; DIN EN ISO 4527:2023-02; DIN EN ISO 2081:2018-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Pre Nickel Plated</rdfs:label>
        <rdfs:label xml:lang="de">Vorvernickeltes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein vorvernickeltes Objekt ist ein Werkstück, dessen Oberfläche bereits vor einem nachfolgenden Beschichtungsprozess mit einer Nickelschicht (als Vor- bzw. Unterschicht) versehen wurde. Hauptzweck der Vorvernickelung ist es, die Haftung und/oder Korrosionsbeständigkeit eines nachfolgenden Schichtsystems zu verbessern bzw. eine definierte Unterlage für weitere metallische Überzüge bereitzustellen. Abzugrenzen ist dies von einer Endvernickelung, bei der die Nickelschicht die funktionale/abschließende Nutzschicht darstellt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPreparated -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPreparated">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="en">Object Preparated</rdfs:label>
        <rdfs:label xml:lang="de">Vorbereitetes Objekt</rdfs:label>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPrepared -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPrepared">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-02; DIN EN ISO 9587:2008-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Prepared</rdfs:label>
        <rdfs:label xml:lang="de">Vorbereitetes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein vorbereitetes Objekt ist ein Werkstück/Teil, dessen Oberfläche durch festgelegte Vorbehandlungs- und Reinigungsprozesse (z. B. Entfetten, Beizen, Aktivieren, Spülen) in einen definierten Zustand für nachfolgende galvanische oder chemische Beschichtungsprozesse überführt wurde. Hauptzweck ist das Sicherstellen der erforderlichen Oberflächenreinheit und -aktivität, um eine ausreichende Haftfestigkeit und gleichmäßige Schichtbildung der nachfolgenden Abscheidung zu ermöglichen. Abzugrenzen ist es vom unbehandelten Objekt sowie vom beschichteten Objekt, bei dem bereits eine Schicht aufgebracht wurde.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPrepareted -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectPrepareted">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingObjects"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRaw -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRaw">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PlatingObjects"/>
        <rdfs:isDefinedBy>DIN EN ISO 2080:2022-07 (Metallische und andere anorganische Überzüge – Oberflächenbehandlung, metallische und andere anorganische Überzüge – Wörterbuch); DIN EN ISO 2064:2020-06 (Metallische und andere anorganische Überzüge – Begriffe und Definitionen)</rdfs:isDefinedBy>
        <skos:definition xml:lang="de">Ein Rohobjekt ist ein noch nicht beschichtetes bzw. noch nicht oberflächenbehandeltes Werkstück, das als Ausgangsteil in einen galvanotechnischen Prozess eingeht. Hauptzweck ist die Bereitstellung des Substrats/Grundwerkstoffs, auf dem durch Vorbehandlung und Abscheidung eine definierte metallische Überzugs- oder Schichtfunktion erzeugt wird. Es ist vom „beschichteten Werkstück“ bzw. „Überzug“ abzugrenzen, da es den Zustand vor der Schichtbildung beschreibt.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRoomTemperatureAged -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRoomTemperatureAged">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6892-1:2020-06; DIN EN ISO 15614-1:2017-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Gealtert bei Raumtemperatur</rdfs:label>
        <rdfs:label xml:lang="en">Object Room Temperature Aged</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Gealtert bei Raumtemperatur“ bezeichnet den Zustand eines Werkstoffs oder einer Beschichtung nach einer definierten Lager-/Wartezeit unter Umgebungsbedingungen ohne gezielte Wärmezufuhr. Zweck ist die Erfassung bzw. Nutzung zeitabhängiger Änderungen von Eigenschaften (z. B. Aushärtung, Relaxation, Stabilisierung) vor der Prüfung oder Anwendung. Abzugrenzen ist dies von künstlicher Alterung/Warmauslagerung, bei der die Alterung gezielt bei erhöhter Temperatur erfolgt.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSaltSprayTested -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSaltSprayTested">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9227:2023-10, DIN EN ISO 10289:2000-12, DIN EN ISO 2081:2018-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object salt spray tested</rdfs:label>
        <rdfs:label xml:lang="de">Salzsprühgetestetes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein salzsprühgetestetes Objekt ist ein Prüfkörper/Prüfstück (z. B. ein beschichtetes Bauteil), das einer genormten Salzsprühprüfung unter festgelegten Bedingungen ausgesetzt wurde. Zweck ist die Beurteilung des Korrosionsverhaltens bzw. der Korrosionsschutzwirkung von metallischen Werkstoffen und Überzügen anhand definierter Expositions- und Bewertungsregeln. Abzugrenzen ist der Begriff von der „Salzsprühprüfung“ (Verfahren) und vom „Prüfbericht“ (Dokumentation der Ergebnisse).</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectScanningElectronMicroscoped -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectScanningElectronMicroscoped">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 16700:2016-12 (Mikrostrahlanalyse — Rasterelektronenmikroskopie — Leitfaden für die Messung der Bildauflösung); DIN EN ISO 22493:2020-02 (Mikrostrahlanalyse — Rasterelektronenmikroskopie — Terminologie)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object scanning electron microscoped</rdfs:label>
        <rdfs:label xml:lang="de">Objekt rasterelektronenmikroskopisch untersucht</rdfs:label>
        <skos:definition xml:lang="de">Ein „Objekt rasterelektronenmikroskopisch untersucht“ ist ein Prüfobjekt (z. B. beschichtetes Bauteil oder Schliff), dessen Oberfläche bzw. Mikrostruktur mittels Rasterelektronenmikroskopie (REM/SEM) analysiert wurde. Zweck ist die hochauflösende Charakterisierung von Topographie, Morphologie und ggf. Gefüge-/Schichtmerkmalen (z. B. Defekte, Poren, Risse) als Bestandteil der Qualitäts- oder Schadensanalyse galvanischer Schichten. Je nach Prüfziel kann die Untersuchung mit geeigneter Probenvorbereitung (z. B. Querschliff) und optionaler Mikroanalyse (z. B. EDS) kombiniert werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Object"/>
        <rdfs:label xml:lang="en">ObjectSet</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSlidingWearMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSlidingWearMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 20808:2016-12; DIN EN ISO 7148-2:2012-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object sliding wear measured</rdfs:label>
        <rdfs:label xml:lang="de">Objekt mit gemessenem Gleitverschleiß</rdfs:label>
        <skos:definition xml:lang="de">Ein „Objekt mit gemessenem Gleitverschleiß“ ist ein Prüfkörper, Bauteil oder beschichtetes Werkstück, für das der Verschleiß infolge Gleitbeanspruchung in einem definierten Prüfverfahren quantitativ ermittelt und dokumentiert wurde. Hauptzweck ist die vergleichende Bewertung der Verschleißbeständigkeit (z. B. von galvanischen Überzügen) anhand festgelegter Prüfbedingungen und Auswertegrößen wie Verschleißvolumen oder Masseverlust. Abzugrenzen ist dies von Abrasivverschleißprüfungen mit freien Partikeln, da beim Gleitverschleiß der Verschleiß durch Relativbewegung zweier Kontaktpartner unter Last entsteht.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSupplier -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSupplier">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSurfaceMicrographed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSurfaceMicrographed">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 25178-2:2012-09; DIN EN ISO 4287:2010-07; DIN EN ISO 1463:2021-08; DIN EN ISO 9220:1988-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Surface Micrographed</rdfs:label>
        <rdfs:label xml:lang="de">Objekt Oberflächen Mikrographiert</rdfs:label>
        <skos:definition xml:lang="de">Ein „Objekt oberflächen mikrographiert“ ist ein Werkstück/Objekt, dessen Oberfläche mittels Mikroskopie bildlich erfasst und dokumentiert wurde (Mikrographie), um die Mikrogeometrie bzw. Mikrostruktur der Oberfläche darzustellen. Hauptzweck ist die qualitative und/oder quantitative Beurteilung von Oberflächenmerkmalen (z. B. Topographie, Defekte, Schicht-/Gefügemerkmale) als Grundlage für Prozesskontrolle und Qualitätsnachweis in der Oberflächentechnik/Galvanotechnik. Abzugrenzen ist dies von rein taktilen/optischen Rauheitskennwertmessungen ohne bildgebende Dokumentation.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSurfaceRoughnessMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSurfaceRoughnessMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 21920-1:2022-08; DIN EN ISO 21920-2:2022-08; DIN EN ISO 21920-3:2022-08; DIN EN ISO 25178-2:2022-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Oberflächenrauheit gemessen</rdfs:label>
        <rdfs:label xml:lang="en">Object Surface Roughness Measured</rdfs:label>
        <skos:definition xml:lang="de">Oberflächenrauheit gemessen ist ein Messwert bzw. ein Satz von Messwerten, der die Rauheit einer Oberfläche aus einer normgerecht erfassten Profil- oder Flächenmessung (z. B. taktil oder optisch) als Rauheitskenngröße(n) beschreibt. Hauptzweck ist die objektive, vergleichbare Spezifikation und Prüfung des Oberflächenzustands (z. B. zur Funktions- und Qualitätsbewertung von beschichteten oder zu beschichtenden Teilen). Die Aussage ist nur eindeutig, wenn Messverfahren, Filterung/Auswertung, Messstrecke bzw. Messfläche und der verwendete Rauheitsparameter (z. B. Ra, Rz, Sa) nach Norm festgelegt sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectTactileSurfaceRoughnessMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectTactileSurfaceRoughnessMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3274:1998-04; DIN EN ISO 4287:2010-07; DIN EN ISO 4288:1998-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Tactile Surface Roughness Measured</rdfs:label>
        <rdfs:label xml:lang="de">Taktile Oberflächenrauigkeits gemessenes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein „taktile Oberflächenrauigkeits gemessenes Objekt“ ist das physische Werkstück bzw. die Oberfläche, an der die Oberflächenrauheit mit einem Tastschnittgerät (Profilometer) durch Abtasten mit einer Tastspitze erfasst wird. Zweck ist die Bereitstellung der Messoberfläche, auf der das Rauheitsprofil aufgenommen und daraus Rauheitskenngrößen nach festgelegten Messbedingungen (z. B. Filterung, Auswertelänge) bestimmt werden. Abzugrenzen ist es vom Rauheitsnormal (Kalibrier-/Referenzkörper) sowie vom Messgerät und den daraus abgeleiteten Messwerten.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectThermalShockMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectThermalShockMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4628-8:2013-12; DIN EN ISO 2819:2017-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object thermal shock measured</rdfs:label>
        <rdfs:label xml:lang="de">Thermalschock gemessenes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein „Thermalschock gemessenes Objekt“ ist das Prüfobjekt (z. B. beschichtetes Bauteil oder Probekörper), an dem im Rahmen einer Thermalschockprüfung Messungen bzw. Bewertungen durchgeführt werden. Hauptzweck ist die Erfassung der Auswirkungen schneller Temperaturwechsel auf das Objekt, insbesondere hinsichtlich Schädigungen wie Rissbildung, Abplatzungen oder Haftfestigkeitsverlust von Schichten. Abzugrenzen ist es von der Prüfeinrichtung bzw. den Messmitteln; gemeint ist das zu prüfende/zu bewertende Objekt selbst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectThicknessMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectThicknessMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2021-08; DIN EN ISO 2178:2016-11; DIN EN ISO 3497:2000-06; DIN EN ISO 3882:2003-09</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Thickness Measured</rdfs:label>
        <rdfs:label xml:lang="de">Schichtdicke gemessen</rdfs:label>
        <skos:definition xml:lang="de">Schichtdicke gemessen ist der durch ein festgelegtes Messverfahren ermittelte Zahlenwert der Dicke einer aufgebrachten Schicht an einer definierten Messstelle. Hauptzweck ist die quantitative Verifikation der Schichtdicke zur Beurteilung der Konformität mit Spezifikationen und zur Qualitätssicherung. Die Aussage ist stets an Messmethode, Messbedingungen und Messort gebunden und ist von Soll-/Nennschichtdicke zu unterscheiden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectTribologicalMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectTribologicalMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 7148-2:2012-10; DIN EN ISO 20808:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Tribological Measured</rdfs:label>
        <rdfs:label xml:lang="de">Tribologisch gemessen</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Tribologisch gemessen“ bezeichnet, dass ein Kennwert oder eine Eigenschaft (z. B. Reibungskoeffizient, Verschleißrate, Verschleißvolumen) durch eine tribologische Prüfung unter definierten Kontakt-, Bewegungs- und Umgebungsbedingungen bestimmt wurde. Hauptzweck ist die vergleichbare, prüfstandsbasierte Bewertung des Reibungs- und Verschleißverhaltens von Werkstoffen, Schichten oder Oberflächen. Die Aussage ist ohne Angabe des konkreten Prüfverfahrens und der Prüfparameter (z. B. nach ISO 7148-2 oder ISO 20808) nicht eindeutig interpretierbar.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectType -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectType">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN IEC 61360-1:2018-07; DIN EN IEC 62656-1:2014-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object type</rdfs:label>
        <rdfs:label xml:lang="de">Objekt-Typ</rdfs:label>
        <skos:definition xml:lang="de">Ein Objekt-Typ ist eine festgelegte Klasse/Kategorie von Objekten, die durch gemeinsame Merkmale und zulässige Eigenschaften beschrieben wird. Er dient dazu, Objekte in Datenmodellen, Spezifikationen oder Prüf-/Dokumentationssystemen eindeutig zu klassifizieren und dadurch Anforderungen, Merkmale und Beziehungen konsistent zuzuordnen. In der Galvanotechnik kann dies z. B. zur Typisierung von Bauteilen, Prüfkörpern, Schichten oder Prozessobjekten in digitalen Beschreibungen genutzt werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectVisualInspected -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectVisualInspected">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 17637:2017-05; DIN EN ISO 9712:2022-05; DIN EN ISO 2064:2020-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Visual Inspected</rdfs:label>
        <rdfs:label xml:lang="de">Sichtgeprüftes Objekt</rdfs:label>
        <skos:definition xml:lang="de">Ein sichtgeprüftes Objekt ist ein Prüfobjekt, an dem eine visuelle Prüfung (Sichtprüfung) durchgeführt wurde, um den Zustand bzw. die Ausführung anhand des äußeren Erscheinungsbildes zu beurteilen. Hauptzweck ist das Erkennen oberflächlicher Merkmale oder Abweichungen (z. B. Fehlstellen, Verfärbungen, Beschädigungen) ohne oder mit einfachen optischen Hilfsmitteln. Der Begriff beschreibt den Prüfstatus (durchgeführte Sichtprüfung) und ist von „zerstörender Prüfung“ sowie von Prüfungen mit Messmitteln (z. B. Schichtdickenmessung) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectWeight -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectWeight">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2020-01; DIN EN ISO 2080:2022-02; DIN EN ISO 8044:2020-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object Weight</rdfs:label>
        <rdfs:label xml:lang="de">Objektgewicht</rdfs:label>
        <skos:definition xml:lang="de">Objektgewicht ist die Masse eines zu beschichtenden Werkstücks/Objekts, üblicherweise angegeben in Kilogramm. Es dient in der Galvanotechnik als Eingangsgröße für die Auslegung und Steuerung von Transport-, Gestell- und Trommelprozessen sowie für die Abschätzung von Badbelastung und Durchsatz. Abzugrenzen ist es von Schichtmasse bzw. Flächenmasse der abgeschiedenen Schicht, die sich auf den Überzug und nicht auf das gesamte Objekt bezieht.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectWeightedAfterChromePlating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectWeightedAfterChromePlating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="de">Gewogen nach Verchromung</rdfs:label>
        <rdfs:label xml:lang="en">Object Weighted After Chrome Plating</rdfs:label>
        <skos:definition>tbd</skos:definition>
        <skos:definition xml:lang="de">„Gewogen nach Verchromung“ bezeichnet die Ermittlung und Dokumentation der Masse eines Werkstücks nach Abschluss eines Verchromungsprozesses (Chromabscheidung). Hauptzweck ist die Massenbilanzierung bzw. die indirekte Ermittlung des Massezuwachses durch die abgeschiedene Chromschicht im Vergleich zu einer Wägung vor der Beschichtung. Die Angabe beschreibt einen Messzeitpunkt/Prüfschritt und ist von normativ definierten Schichtdickenprüfverfahren (z. B. coulometrisch, mikroskopisch) abzugrenzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectXRayDiffractionMeasured -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectXRayDiffractionMeasured">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 13925-1:2003-07; DIN EN 15305:2008-09; ISO 21432:2019-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Object xray diffraction measured</rdfs:label>
        <rdfs:label xml:lang="de">Objekt mit gemessener Röntgendiffraktion</rdfs:label>
        <skos:definition xml:lang="de">Ein „Objekt mit gemessener Röntgendiffraktion“ ist ein Prüfobjekt bzw. eine Probe, für die ein Röntgendiffraktions-/Röntgenbeugungs-Messdatensatz (Diffraktogramm) nach einem XRD-Verfahren aufgenommen wurde. Hauptzweck ist die Ableitung von kristallographischen Informationen (z. B. Phasenidentifikation, Gitterparameter, Textur oder Eigenspannungen) aus den gemessenen Beugungsdaten. Abzugrenzen ist es von einem „Objekt mit Röntgenfluoreszenz-Messung“ (XRF), bei dem elementare Zusammensetzung statt Beugungsinformation ermittelt wird.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Occurrent -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Occurrent">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Entity"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">Occurrent</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OffTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OffTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 1456:2009-10; DIN EN ISO 4527:2004-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Off Time</rdfs:label>
        <skos:definition xml:lang="de">Die Pausendauer ist die festgelegte Zeitspanne, in der ein Werkstück oder Prüfkörper zwischen zwei definierten Prozessschritten ohne weitere Behandlung verbleibt. Sie dient der reproduzierbaren Prozessführung, z. B. zur Begrenzung von Oberflächenreaktionen (Oxidation, Austrocknung, Repassivierung) und zur Sicherstellung vergleichbarer Beschichtungsergebnisse. Die Pausendauer ist von der eigentlichen Behandlungszeit eines Prozessschritts (z. B. Beizzeit, Aktivierzeit, Abscheidezeit) abzugrenzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OnTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OnTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 60034-1 (VDE 0530-1):2010-10; IEC 60034-1:2010</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">On Time</rdfs:label>
        <skos:definition xml:lang="de">Die Einschaltdauer ist der Anteil der Zeit, in der ein Gerät oder eine elektrische Größe innerhalb eines festgelegten Zeitintervalls eingeschaltet bzw. wirksam ist, angegeben meist als Verhältnis oder in Prozent. Hauptzweck ist die eindeutige Festlegung der zeitlichen Belastung (z. B. bei periodischem Betrieb) zur Auslegung, Prüfung und Vergleichbarkeit von Stromquellen/Anlagen, wie sie auch in der Galvanotechnik eingesetzt werden. In der Pulsstromanwendung entspricht sie dem Tastgrad (Duty Cycle) als Verhältnis von Impulsdauer zur Periodendauer.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OneDimensionalContinuantFiatBoundary -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OneDimensionalContinuantFiatBoundary">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ContinuantFiatBoundary"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TwoDimensionalContinuantFiatBoundary"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ZeroDimensionalContinuantFiatBoundary"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">OneDimensionalContinuantFiatBoundary</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OneDimensionalFieldData -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OneDimensionalFieldData">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FieldData"/>
        <rdfs:comment>Any kind of one dimensional field data</rdfs:comment>
        <rdfs:label xml:lang="en">OneDimensionalFieldData</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OneDimensionalSpatialRegion -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OneDimensionalSpatialRegion">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpatialRegion"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ThreeDimensionalSpatialRegion"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">OneDimensionalSpatialRegion</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OneDimensionalTemporalRegion -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OneDimensionalTemporalRegion">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemporalRegion"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ZeroDimensionalTemporalRegion"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">OneDimensionalTemporalRegion</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OpticalDisplacementAsIs -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OpticalDisplacementAsIs">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ExtensometerDisplacement"/>
        <rdfs:comment>An optically measured displacement as is e.g. by using digital image correlation</rdfs:comment>
        <rdfs:label xml:lang="en">OpticalDisplacementAsIs</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OpticalStrainMeasurementSystem -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OpticalStrainMeasurementSystem">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <rdfs:comment>Any kind of optical strain measurement system (e.g. Aramis)</rdfs:comment>
        <rdfs:label xml:lang="en">OpticalStrainMeasurementSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OpticalSurfaceRoughnessMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OpticalSurfaceRoughnessMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SurfaceTopographyMeasurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 25178-6:2010-12; DIN EN ISO 25178-604:2013-04; DIN EN ISO 25178-2:2012-09; DIN EN ISO 4287:2010-07; DIN EN ISO 4288:1998-04</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 25178-6:2010-12; DIN EN ISO 25178-604:2013-05; DIN EN ISO 25178-607:2014-10; DIN EN ISO 4287:2010-07; DIN EN ISO 4288:1998-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Optical Surface Roughness Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Optische Oberflächenrauigkeitsmessung</rdfs:label>
        <skos:definition xml:lang="de">Die Messung der optischen Oberflächenrauheit ist die Ermittlung von Rauheitskenngrößen einer Oberfläche mit berührungslosen, lichtbasierten Messverfahren (z. B. konfokale Mikroskopie, Interferometrie oder Fokusvariation) auf Basis eines optisch erfassten Höhenprofils bzw. einer 3D-Flächenmessung. Zweck ist die quantitative Charakterisierung der Oberflächenbeschaffenheit über genormte Rauheitsparameter zur Spezifikation, Prozessüberwachung und Qualitätsprüfung von galvanischen Schichten. Besonderheit ist die berührungslose Messung, deren Ergebnis von optischen Eigenschaften der Oberfläche (Reflexion, Transparenz, Streuung) und der gewählten Auswertefilterung/Abtastbedingungen abhängen kann.</skos:definition>
        <skos:definition xml:lang="de">Optische Oberflächenrauigkeitsmessung ist die berührungslose Erfassung der Oberflächentopographie mittels optischer Messprinzipien (z. B. Interferometrie, konfokale Mikroskopie), um daraus Rauheitskenngrößen abzuleiten. Hauptzweck ist die quantitative Beurteilung der Oberflächenbeschaffenheit (Profil- und/oder Flächenkenngrößen) ohne mechanischen Tasterkontakt, z. B. zur Prozess- und Qualitätskontrolle galvanischer Schichten. Besonderheit ist die Zuordnung zu Profil- (ISO 4287/4288) bzw. Flächenkenngrößen (ISO 25178) bei optischer Topographiemessung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OrderID -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OrderID">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Identifier"/>
        <rdfs:comment>Order ID belonging to a process</rdfs:comment>
        <rdfs:label xml:lang="en">OrderID</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OrderNumber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OrderNumber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Organisation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Organisation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndependentContinuant"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Structure and arrangement of resources and activities in a company</rdfs:comment>
        <rdfs:comment xml:lang="de">Struktur und Anordnung von Ressourcen und Aktivitäten in einem Unternehmen</rdfs:comment>
        <rdfs:label xml:lang="en">Organisation</rdfs:label>
        <rdfs:label xml:lang="de">Projektpartner</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OriginalCrossSectionalAreaOfTheParallelLength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OriginalCrossSectionalAreaOfTheParallelLength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenCrossSectionArea"/>
        <rdfs:comment>Original cross-sectional area of the parallel length (e.g. according to DIN ISO 6892-1:2017-02)</rdfs:comment>
        <rdfs:label xml:lang="en">OriginalCrossSectionalAreaOfTheParallelLength</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OriginalGaugeLength -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#OriginalGaugeLength">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GaugeLength"/>
        <rdfs:comment>Original gauge length of the test piece</rdfs:comment>
        <rdfs:label xml:lang="en">OriginalGaugeLength</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Osmium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Osmium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Osmium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Oxygen -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Oxygen">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Oxygen</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 10523:2012-04, Wasserbeschaffenheit — Bestimmung des pH-Werts; DIN EN ISO/IEC 17025:2018-03, Allgemeine Anforderungen an die Kompetenz von Prüf- und Kalibrierlaboratorien</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">pH Data Set</rdfs:label>
        <rdfs:label xml:lang="de">pH-Datensatz</rdfs:label>
        <skos:definition xml:lang="de">Ein pH-Datensatz ist eine strukturierte Zusammenstellung von Mess- und Metadaten zur Bestimmung und Dokumentation des pH-Werts einer Lösung (z. B. Elektrolyt/Bad) zu einem definierten Zeitpunkt oder Zeitraum. Hauptzweck ist die nachvollziehbare Prozessüberwachung und Qualitätssicherung durch reproduzierbare Erfassung von pH-Messwert, Messbedingungen und Rückführbarkeit (z. B. Kalibrierung). Typische Inhalte sind pH-Wert, Temperatur, Datum/Uhrzeit, Messverfahren/Messgerät, Kalibrierstatus und verwendete Pufferlösungen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHElectrode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHElectrode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 10523:2012-04, Wasserbeschaffenheit – Bestimmung des pH-Werts; DIN 19263:2011-01, pH-Messung – Begriffe; DIN EN 60746-2:2003-11 (IEC 60746-2:2002), Expression of performance of electrochemical analyzers – Part 2: pH value (Hinweis: Norm ggf. durch neuere Ausgabe ersetzt)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">ph electrode</rdfs:label>
        <rdfs:label xml:lang="de">ph-Elektrode</rdfs:label>
        <skos:definition xml:lang="de">Eine pH-Elektrode ist eine elektrochemische Elektrode (meist Glaselektrode), die zusammen mit einer Bezugselektrode eine potentialabhängige Messung der Wasserstoffionenaktivität einer Lösung ermöglicht und daraus den pH-Wert bestimmt. Hauptzweck ist die Bestimmung und Überwachung des pH-Werts von wässrigen Lösungen, z. B. in Prozessbädern der Galvanotechnik zur Badführung. Häufig ist sie als Kombinationselektrode ausgeführt, bei der Mess- und Bezugselektrode in einem Gehäuse integriert sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Messung des pH-Werts im System oder Prozess.</rdfs:comment>
        <rdfs:comment xml:lang="en">The measurement of pH value in the system or process.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 10523:2012-04; DIN 19268:2005-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">pH Measurement</rdfs:label>
        <rdfs:label xml:lang="de">pH Messung</rdfs:label>
        <skos:definition xml:lang="de">pH-Messung ist die Bestimmung des pH-Werts einer wässrigen Lösung als Maß für deren Wasserstoffionenaktivität, üblicherweise durch potentiometrische Messung mit Glaselektrode und Bezugselektrode. Hauptzweck ist die Überwachung und Regelung der Wasserstoffionenaktivität in Prozesslösungen (z. B. Elektrolyten und Spülwässern), um Prozessstabilität und reproduzierbare Schichteigenschaften sicherzustellen. Die Messung erfordert definierte Kalibrierung mit Pufferlösungen sowie festgelegte Bedingungen für Temperatur und Messkette, da diese den Messwert beeinflussen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 10523:2012-04; DIN EN 61131-3 (VDE 0113-3):2014-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">PHTarget</rdfs:label>
        <rdfs:label xml:lang="de">Zielwert pH</rdfs:label>
        <skos:definition xml:lang="de">Der Zielwert pH ist der vorgegebene Sollwert der pH-Größe, auf den ein Prozess (z. B. ein galvanotechnisches Bad oder eine Vorbehandlungs-/Spülstufe) eingestellt bzw. geregelt werden soll. Hauptzweck ist die Sicherstellung definierter Prozessbedingungen, um Reaktionsführung, Abscheideverhalten und Badstabilität innerhalb spezifizierter Grenzen zu halten. Der Zielwert pH ist vom Istwert (gemessener pH) und von zulässigen Toleranz- bzw. Regelgrenzen zu unterscheiden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHValue -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHValue">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator xml:lang="en">elena G. Trelles</dc:creator>
        <rdfs:comment xml:lang="en">is a measure of the acidity or alkalinity of a solution, expressed on a logarithmic scale ranging from 0 to 14. A pH value of 7 is considered neutral, indicating a balance between acidity and alkalinity. Values below 7 indicate acidic solutions (higher concentration of hydrogen ions, H⁺), while values above 7 indicate alkaline (or basic) solutions (lower concentration of hydrogen ions). The pH scale is commonly used in chemistry, biology, and environmental science to assess the chemical properties of solutions.</rdfs:comment>
        <rdfs:label xml:lang="en">PH Value</rdfs:label>
        <rdfs:label xml:lang="de">PH-Wert</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHValueAverage -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PHValueAverage">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 19268:2020-04; DIN ISO 5725-1:2017-12; DIN EN ISO 10523:2012-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">PH value average</rdfs:label>
        <rdfs:label xml:lang="de">pH Mittelwert</rdfs:label>
        <skos:definition xml:lang="de">Der pH Mittelwert ist der aus mehreren pH-Messwerten gebildete Mittelwert zur repräsentativen Angabe des pH-Zustands einer Lösung über eine definierte Messreihe. Er dient der statistischen Zusammenfassung und Vergleichbarkeit von pH-Messungen, z. B. zur Prozessüberwachung oder Dokumentation. Bei der Mittelwertbildung ist zu beachten, dass pH eine logarithmische Größe ist; je nach Zweck kann daher die Mittelung der zugehörigen Wasserstoffionenaktivität (und anschließende Rückrechnung) fachlich geeigneter sein als das arithmetische Mittel der pH-Zahlenwerte.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Palladium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Palladium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Palladium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleArea -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleArea">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2021-08; DIN EN ISO 4519:2009-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Particle area</rdfs:label>
        <rdfs:label xml:lang="de">Partikelfläche</rdfs:label>
        <skos:definition xml:lang="de">Partikelfläche ist die Oberfläche eines einzelnen Partikels (z. B. Feststoffpartikel), die als Grenzfläche zwischen Partikel und umgebendem Medium (Elektrolyt/Matrix) wirkt. In der Galvanotechnik ist sie maßgeblich für Benetzung, Adsorption und Anlagerung/Einbau von Partikeln bei der Herstellung galvanischer Verbundschichten. Abzugrenzen ist sie von der Bauteiloberfläche (Substratoberfläche) und der resultierenden Schichtoberfläche.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleConcentrationTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleConcentrationTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Intended concentration of particles in a solution</rdfs:comment>
        <rdfs:comment xml:lang="de">Vorgesehene Konzentration von Partikeln in einer Lösung</rdfs:comment>
        <rdfs:label xml:lang="en">Particle Concentration Target</rdfs:label>
        <rdfs:label xml:lang="de">Partikelkonzentration Soll</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleNumber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleNumber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 16232:2018-12; ISO 4406:2021; ISO 11171:2016</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Particle number</rdfs:label>
        <rdfs:label xml:lang="de">Partikelanzahl</rdfs:label>
        <skos:definition xml:lang="de">Partikelanzahl ist die Anzahl diskreter Partikel, die in einem definierten Probenvolumen, auf einer definierten Fläche oder in einem definierten Medium (z. B. Flüssigkeit, Gas) erfasst wird. Hauptzweck ist die quantitative Bewertung der Partikelbelastung zur Überwachung von Sauberkeit, Filtration oder Prozessmedienqualität, was in galvanotechnischen Prozessen z. B. für Badreinheit und Oberflächenreinheit relevant ist. Üblicherweise wird sie als Zählwert oder als Konzentration (z. B. Partikel pro mL) angegeben und ist von der Partikelgröße/-klassen abhängig.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleShape -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleShape">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quality"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Form der Partikel in einer Probe</rdfs:comment>
        <rdfs:comment xml:lang="en">Shape of particles in a sample</rdfs:comment>
        <rdfs:label xml:lang="en">Particle Shape</rdfs:label>
        <rdfs:label xml:lang="de">Partikelform</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleSize -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ParticleSize">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Größe der Partikel in einer Probe</rdfs:comment>
        <rdfs:comment xml:lang="en">Size of particles in a sample</rdfs:comment>
        <rdfs:label xml:lang="en">Particle Size</rdfs:label>
        <rdfs:label xml:lang="de">Partikelgröße</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Particles -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Particles">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EngineeringObject"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Kleinste Einheit eines Stoffes</rdfs:comment>
        <rdfs:comment xml:lang="en">Smallest unit of a substance</rdfs:comment>
        <rdfs:label xml:lang="en">Particles</rdfs:label>
        <rdfs:label xml:lang="de">Partikel</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Peeling -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Peeling">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">detachment or partial detachment of a coating from the basis material or undercoating</rdfs:comment>
        <rdfs:comment xml:lang="de">vollständiges oder teilweises Ablösen eines Überzugs vom Grundwerkstoff oder von einem Zwischenüberzug</rdfs:comment>
        <rdfs:label xml:lang="de">Abblättern</rdfs:label>
        <rdfs:label xml:lang="en">Peeling</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PenetrationModulus -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PenetrationModulus">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Maß für die Fähigkeit eines Materials, in ein anderes Material einzudringen</rdfs:comment>
        <rdfs:comment xml:lang="en">Measure of a material&apos;s ability to penetrate another material</rdfs:comment>
        <rdfs:label xml:lang="de">Eindringmodul</rdfs:label>
        <rdfs:label xml:lang="en">Penetration Modulus</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PercentageElongationAfterFracture -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PercentageElongationAfterFracture">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRelatedQuantity"/>
        <rdfs:comment>permanent elongation of the gauge length after fracture, (Lu − Lo), expressed as a percentage of the original gauge length</rdfs:comment>
        <rdfs:label xml:lang="en">PercentageElongationAfterFracture</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PercentagePlasticExtensionAtMaximumForce -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PercentagePlasticExtensionAtMaximumForce">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#StrainRelatedQuantity"/>
        <rdfs:comment>Percentage plastic extension at maximum force.</rdfs:comment>
        <rdfs:label xml:lang="en">PercentagePlasticExtensionAtMaximumForce</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PeriodicReverseElectrolyticCleaning -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PeriodicReverseElectrolyticCleaning">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalCleaning"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Verfahren der elektrolytischen Reinigung, bei dem der Strom in der Reinigungslösung periodisch umgepolt wird, und wobei die Zyklen nicht länger als mehrere Sekunden oder wenige Minuten sind</rdfs:comment>
        <rdfs:comment xml:lang="en">method of electrolytic cleaning in which the current in the cleaning solution is reversed periodically, the cycles being no longer than several seconds or a few minutes</rdfs:comment>
        <rdfs:label xml:lang="en">Periodic Reverse Electrolytic Cleaning</rdfs:label>
        <rdfs:label xml:lang="de">elektrolytische Reinigung mit Umpolung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PeriodicReverseElectroplating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PeriodicReverseElectroplating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Plating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">PR electroplating
method of electroplating in which the current is reversed periodically, the individual reverse cycles being no longer than several secondsperiodic reverse electroplating</rdfs:comment>
        <rdfs:comment xml:lang="de">PR-Verfahren, en: periodic reverse electroplating
Verfahren der galvanischen Metallabscheidung, bei dem der Strom periodisch umgepolt wird, und wobei die einzelnen Umpolungszyklen üblicherweise nicht länger als mehrere Sekunden
sind</rdfs:comment>
        <rdfs:label xml:lang="en">Periodic Reverse Electroplating</rdfs:label>
        <rdfs:label xml:lang="de">Umpolverfahren</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PermanentMold -->

