        <rdfs:label xml:lang="en">Solution</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Annealing"/>
        <rdfs:comment>Solution annealing is used to homogenize the material. The temperature is sufficiently high to deliberately dissolve certain phases (e.g. gamma&apos; in superalloys)</rdfs:comment>
        <rdfs:label xml:lang="en">SolutionAnnealing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealingDuration -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealingDuration">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeRelatedQuantity"/>
        <rdfs:comment>The duration of the solution annealing process, i.e. of the time spent at the solution annealing temperature</rdfs:comment>
        <rdfs:label xml:lang="en">SolutionAnnealingDuration</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealingDurationAsSupposed -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolutionAnnealingDurationAsSupposed">
