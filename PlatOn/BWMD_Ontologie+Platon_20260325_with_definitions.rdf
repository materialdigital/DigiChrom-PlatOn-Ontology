        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Der Prozess des Entfernens von Verunreinigungen aus einer Flüssigkeit.</rdfs:comment>
        <rdfs:comment xml:lang="en">The process of removing impurities from a liquid.</rdfs:comment>
        <rdfs:label xml:lang="en">Filtration</rdfs:label>
        <rdfs:label xml:lang="de">Filtrierung</rdfs:label>
    </owl:Class>
    


