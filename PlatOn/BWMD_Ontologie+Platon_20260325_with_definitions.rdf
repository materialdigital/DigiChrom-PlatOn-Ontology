    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolidAngle -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SolidAngle">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-1:2022-09, DIN EN ISO 80000-3:2020-09, IEC 80000-1:2009-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Raumwinkel</rdfs:label>
        <rdfs:label xml:lang="en">solid angle</rdfs:label>
        <skos:definition xml:lang="de">Ein Raumwinkel ist das Maß für die Ausdehnung eines räumlichen Bereichs, der von einem Punkt aus gesehen wird, und wird als Verhältnis der von diesem Bereich auf einer Kugel um den Punkt ausgeschnittenen Fläche zum Quadrat des Kugelradius definiert. Hauptzweck ist die quantitative Beschreibung der räumlichen Abstrahl- oder Empfangsrichtung und -verteilung, z. B. in der Radiometrie/Photometrie oder bei geometrischen Betrachtungen. Die SI-Einheit ist das Steradiant (sr), wobei der Raumwinkel eine abgeleitete Größe mit der Dimension 1 ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Solution -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Solution">
