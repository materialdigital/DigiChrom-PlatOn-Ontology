    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageAnalysis -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageAnalysis">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Software"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 15708-2:2017-05, DIN EN ISO 15708-3:2017-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Bildanalyse</rdfs:label>
        <rdfs:label xml:lang="en">Image Analysis</rdfs:label>
        <skos:definition xml:lang="de">Bildanalyse ist die (meist rechnergestützte) Auswertung digitaler Bilder zur Gewinnung quantitativer oder qualitativer Merkmale aus dem Bildinhalt. Hauptzweck ist die objektive Beurteilung und Messung von Eigenschaften wie Struktur, Defekten, Flächenanteilen oder geometrischen Größen, z. B. an Oberflächen oder Schliffen. Sie ist von der reinen Bildaufnahme (Bildgebung) abzugrenzen, da sie die algorithmische Interpretation und Messwertableitung umfasst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageAnlysis -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageAnlysis">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Subprocess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 15708-2:2017-05; ASTM E1268-16(2021); ASTM E1382-97(2022)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Bildanalyse</rdfs:label>
        <rdfs:label xml:lang="en">Image Anlysis</rdfs:label>
        <skos:definition xml:lang="de">Bildanalyse ist die systematische Auswertung digitaler oder analoger Bilder mittels visueller oder rechnergestützter Verfahren zur Gewinnung quantitativer oder qualitativer Merkmale. Hauptzweck ist die objektive Beurteilung und Messung von Eigenschaften (z. B. Geometrie, Defekte, Strukturen) aus Bilddaten, etwa zur Qualitätsprüfung oder Prozessüberwachung. In der Galvanotechnik wird Bildanalyse typischerweise zur Auswertung von Mikrostrukturen, Schichtquerschnitten und Oberflächenmerkmalen eingesetzt und ist von der reinen Bildaufnahme (Mikroskopie/Imaging) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageArea -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageArea">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 25178-6:2010-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Bildfläche</rdfs:label>
        <rdfs:label xml:lang="en">Image area</rdfs:label>
        <skos:definition xml:lang="de">Die Bildfläche ist die zweidimensionale Fläche des aufgenommenen bzw. ausgewerteten Bildausschnitts in einem optischen oder mikroskopischen Mess- und Auswerteverfahren. Sie dient dazu, Merkmale einer Oberfläche (z. B. Poren, Risse, Partikel, Bedeckungsgrad) flächenbezogen zu erfassen und als Kenngrößen pro Fläche zu quantifizieren. Abzugrenzen ist sie von der realen Bauteiloberfläche; die Bildfläche ist eine messsystem- und vergrößerungsabhängige Projektions-/Auswertefläche.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageGeneration -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageGeneration">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataTransformation"/>
        <rdfs:comment>An image generation process, e.g. during tomography</rdfs:comment>
        <rdfs:label xml:lang="en">ImageGeneration</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageMode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageMode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 12639:2013-05 (Graphic technology — Prepress digital data exchange — Tag image file format for image technology (TIFF/IT)); DIN EN ISO 22028-1:2016-07 (Photography and graphic technology — Extended colour encodings for digital image storage, manipulation and interchange — Part 1: Architecture and requirements)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Bildmodus</rdfs:label>
        <rdfs:label xml:lang="en">Image mode</rdfs:label>
        <skos:definition xml:lang="de">Ein Bildmodus ist eine festgelegte Betriebsart zur Darstellung, Erfassung oder Verarbeitung eines Bildes, die u. a. Parameter wie Farbraum, Farbtiefe oder Graustufen-/Farbwiedergabe bestimmt. Hauptzweck ist die eindeutige Festlegung der Bildrepräsentation, um eine konsistente Verarbeitung, Übertragung oder Ausgabe (z. B. Anzeige, Druck, Archivierung) zu ermöglichen. In der Galvanotechnik kann der Begriff kontextabhängig bei der digitalen Dokumentation/Inspektion (z. B. Mikroskopie, Oberflächenprüfung) auftreten, ist dort aber nicht als eigenständiger normativer Prozessbegriff etabliert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageRecording -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImageRecording">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Subprocess"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08; DIN EN ISO 9220:2012-11; DIN EN ISO 2128:2010-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Bildaufnahme</rdfs:label>
        <rdfs:label xml:lang="en">Image Recording</rdfs:label>
        <skos:definition xml:lang="de">Eine Bildaufnahme ist die Erfassung und Speicherung eines visuellen Abbilds eines Objekts oder einer Oberfläche mittels optischer oder elektronischer Bildgebung (z. B. Kamera, Mikroskop). Sie dient in der Galvanotechnik insbesondere der Dokumentation und Auswertung von Oberflächenzustand, Schichtmerkmalen und Fehlerbildern im Rahmen von Prüfung, Qualitätssicherung und Reklamationsanalyse. Je nach Verfahren kann die Bildaufnahme als Makroaufnahme, Mikroaufnahme oder digitale Aufnahme mit definierter Vergrößerung und Auflösung erfolgen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImmaterialEntity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImmaterialEntity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndependentContinuant"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialEntity"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">ImmaterialEntity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImportCAMDataAndMountMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ImportCAMDataAndMountMachine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachinePreparation"/>
        <rdfs:comment>The process of importing CAM data and mounting a machine</rdfs:comment>
        <rdfs:label xml:lang="en">ImportCAMDataAndMountMachine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Inclusion -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Inclusion">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialStructureRelatedObject"/>
        <rdfs:label xml:lang="en">Inclusion</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Indentation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Indentation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MechanicalExperiment"/>
        <rdfs:label xml:lang="en">Indentation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndentationDurationBrinell -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndentationDurationBrinell">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TimeRelatedQuantity"/>
        <rdfs:comment>Duration of the application of the indentation force during Brinell testing</rdfs:comment>
        <rdfs:label xml:lang="en">IndentationDurationBrinell</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndentationForceBrinell -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndentationForceBrinell">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ForceRelatedQuantity"/>
        <rdfs:comment>Applied indentation force within the Brinell indentation process</rdfs:comment>
        <rdfs:label xml:lang="en">IndentationForceBrinell</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndentationModul -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndentationModul">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 14577-1:2015-11, DIN EN ISO 14577-4:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Eindringmodul</rdfs:label>
        <rdfs:label xml:lang="en">Indentation Modul</rdfs:label>
        <skos:definition xml:lang="de">Das Eindringmodul ist ein aus instrumentierten Eindringprüfungen abgeleiteter Elastizitätskennwert, der die elastische Verformungsantwort des geprüften Werkstoffs im Kontakt unter dem Eindringkörper beschreibt. Es dient der Bestimmung bzw. Charakterisierung der elastischen Eigenschaften (z. B. von Schichten/Überzügen) aus der Entlastungskurve unter definierten Prüfbedingungen. Es ist vom Elastizitätsmodul zu unterscheiden, da es als „reduzierter“/effektiver Modul den Einfluss von Prüfkörper und Probe im Kontakt berücksichtigt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndentationTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndentationTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8296:2013-06 (Kunststoffe – Folien und Bahnen – Bestimmung der Benetzungsspannung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Eindringzeit</rdfs:label>
        <rdfs:label xml:lang="en">Indentation Time</rdfs:label>
        <skos:definition xml:lang="de">Eindringzeit ist die Zeitspanne vom Beginn des Kontakts eines Prüfkörpers/Prüfmediums mit einer Oberfläche bis zum Erreichen eines definierten Eindring- oder Benetzungszustands. Sie dient zur quantitativen Beurteilung der Benetzbarkeit bzw. der Wirksamkeit von Netzmitteln/Prozesslösungen auf Oberflächen, z. B. zur Prozessüberwachung in der Vorbehandlung vor galvanischen Abscheidungen. Die genaue Definition (Start-/Endkriterium) ist an die jeweilige Prüfmethode gebunden und muss in der Spezifikation eindeutig festgelegt werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Indenter -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Indenter">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6507-1:2018-07; DIN EN ISO 6506-1:2014-12; DIN EN ISO 6508-1:2016-12; DIN EN ISO 4545-1:2020-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Eindringkörper</rdfs:label>
        <rdfs:label xml:lang="en">Indenter</rdfs:label>
        <skos:definition xml:lang="de">Ein Eindringkörper ist ein genormter Körper definierter Geometrie und Werkstoffeigenschaften, der bei der Härteprüfung unter festgelegter Prüfkraft in die Oberfläche eines Werkstoffs eingedrückt wird. Sein Hauptzweck ist die Erzeugung eines reproduzierbaren Eindrucks, aus dessen Tiefe, Größe oder Form der Härtewert nach dem jeweiligen Prüfverfahren bestimmt wird. Je nach Verfahren (z. B. Vickers, Brinell, Rockwell, Knoop) sind Form (z. B. Diamantpyramide, Kugel, Diamantkegel) und Anforderungen an Maß- und Oberflächenqualität normativ festgelegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndependentContinuant -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndependentContinuant">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Continuant"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificallyDependentContinuant"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">IndependentContinuant</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Indium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Indium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Indium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InductionHeatingSystem -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InductionHeatingSystem">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#HeatingEquipment"/>
        <rdfs:label xml:lang="en">InductionHeatingSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InertGasAtmosphere -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InertGasAtmosphere">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectAggregate"/>
        <rdfs:comment>An inert gas atmosphere in some kind of chamber, which is used within a process</rdfs:comment>
        <rdfs:label xml:lang="en">InertGasAtmosphere</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InformationContentEntity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InformationContentEntity">
