    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InputFileGeneration -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InputFileGeneration">
