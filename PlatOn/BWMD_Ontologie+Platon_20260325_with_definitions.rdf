        <rdfs:comment>An ingot is often used as raw material for a casting process</rdfs:comment>
        <rdfs:label xml:lang="en">Ingot</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Inhibitor -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Inhibitor">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ActuatorEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">in geringen Konzentrationen zugefügte Substanz, die zur Reduzierung der Geschwindigkeit einer chemischen oder elektrochemischen Reaktion, z. B. bei der Korrosion oder beim Beizen, dient</rdfs:comment>
        <rdfs:comment xml:lang="en">substance, added in small concentrations, that reduces the rate of a chemical or electrochemical reaction, for example in corrosion or pickling</rdfs:comment>
        <rdfs:label xml:lang="de">Inhibitor</rdfs:label>
        <rdfs:label xml:lang="en">Inhibitor</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InitialWeight -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InitialWeight">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectRelatedQuantity"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InlensEnergySelectedBackscatterDetector -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InlensEnergySelectedBackscatterDetector">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroscopeEquipment"/>
        <rdfs:comment>An inlens selected backscatter detector for the SEM</rdfs:comment>
