        <rdfs:comment>Electric current applied during a wire eroding process</rdfs:comment>
        <rdfs:label xml:lang="en">ElectricCurrentErodingWire</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricDischargeMachine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ElectricDischargeMachine">
