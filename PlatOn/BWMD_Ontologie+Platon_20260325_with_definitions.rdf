    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Power -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Power">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">Power</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PowerSource -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PowerSource">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Stromquelle, die für den Prozess verwendet wird.</rdfs:comment>
        <rdfs:comment xml:lang="en">The power source used for the process.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN 60050-151 (VDE 0100-200):2010-06, International Electrotechnical Vocabulary (IEV) – Teil 151: Elektrische und magnetische Geräte; DIN EN 60050-131 (VDE 0100-131):2010-06, International Electrotechnical Vocabulary (IEV) – Teil 131: Schaltungstheorie; ISO 2064:2023, Metallic and other inorganic coatings — Definitions and conventions concerning the measurement of thickness (Begriffsverwendung im Kontext elektrolytischer Abscheidung)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Power Source</rdfs:label>
        <rdfs:label xml:lang="de">Stromquelle</rdfs:label>
        <skos:definition xml:lang="de">Eine Stromquelle ist eine elektrische Quelle bzw. ein Betriebsmittel, das an seinen Klemmen elektrische Energie bereitstellt und dabei eine elektrische Größe (Strom oder Spannung) gemäß vorgegebenen Kennwerten liefert. In der Galvanotechnik dient sie dazu, den Prozessstrom für elektrochemische Abscheidung oder anodische Prozesse bereitzustellen und zu regeln, typischerweise als Gleichstromquelle. Abzugrenzen ist sie von der idealisierten Stromquelle als Schaltungselement; praktisch werden Stromquellen als Stromversorgungen/Gleichrichter mit definierter Regelart (z. B. Konstantstrom/Konstantspannung) realisiert.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PowerSourceManufacturer -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PowerSourceManufacturer">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Supplier"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Der Hersteller der Stromquelle.</rdfs:comment>
        <rdfs:comment xml:lang="en">The manufacturer of the power source.</rdfs:comment>
        <rdfs:label xml:lang="en">Power Source Manufacturer</rdfs:label>
        <rdfs:label xml:lang="de">Stromquelle Hersteller</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PowerSourceNumber -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PowerSourceNumber">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Identifier"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Die Kennnummer der Stromquelle im System.</rdfs:comment>
        <rdfs:comment xml:lang="en">The identification number of the power source in the system.</rdfs:comment>
        <rdfs:label xml:lang="en">Power Source Number</rdfs:label>
        <rdfs:label xml:lang="de">Stromquelle Nummer</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PowerXRayTube -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PowerXRayTube">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <rdfs:comment>Power of x-ray tube (e.g. in a computer tomograph)</rdfs:comment>
        <rdfs:label xml:lang="en">PowerXRayTube</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Prasedoymium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Prasedoymium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Prasedoymium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PreProcessing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PreProcessing">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Simulation"/>
        <rdfs:label xml:lang="en">PreProcessing</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Precipitate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Precipitate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MaterialStructureRelatedObject"/>
        <rdfs:label xml:lang="en">Precipitate</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PrecipitateRadius -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PrecipitateRadius">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicrostructuralQuantity"/>
        <rdfs:label xml:lang="en">PrecipitateRadius</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Preparation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Preparation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <rdfs:label xml:lang="en">Preparation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PreparationSubstrate -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PreparationSubstrate">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-02; DIN EN ISO 4526:2007-10; DIN EN ISO 9587:2007-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Preparation Substrate</rdfs:label>
        <rdfs:label xml:lang="de">Substratvorbereitung</rdfs:label>
        <skos:definition xml:lang="de">Substratvorbereitung ist die Gesamtheit der vor einer Beschichtung durchgeführten Prozessschritte, mit denen die Oberfläche eines Grundwerkstoffs in einen definierten, beschichtungsfähigen Zustand überführt wird. Hauptzweck ist das Entfernen von Verunreinigungen und das Einstellen eines geeigneten Oberflächenzustands (z. B. chemische Aktivität/Rauheit), um Haftfestigkeit und Funktionsfähigkeit der nachfolgenden galvanischen oder chemischen Abscheidung sicherzustellen. Sie umfasst typischerweise mechanische, chemische und elektrochemische Vorbehandlungen und ist von der eigentlichen Abscheidung (Beschichtungsprozess) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PreprocessingSoftware -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PreprocessingSoftware">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SimulationSoftware"/>
        <rdfs:comment>Software used for preprocessing</rdfs:comment>
        <rdfs:label xml:lang="en">PreprocessingSoftware</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PressFormDiameter -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PressFormDiameter">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN ISO 286-1:2010-11; DIN ISO 286-2:2010-11; DIN EN ISO 1101:2017-09; DIN EN ISO 14405-1:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Pressform Diameter</rdfs:label>
        <rdfs:label xml:lang="de">Pressformdurchmesser</rdfs:label>
        <skos:definition xml:lang="de">Der Pressformdurchmesser ist der definierte Durchmesser der Pressform (Matrize/Kalibrieröffnung), der die Geometrie eines durch Pressen hergestellten Formteils vorgibt. Er dient als maßgebendes Werkzeugmaß zur Festlegung und Prüfung des resultierenden Bauteildurchmessers (z. B. vor bzw. nach nachfolgenden Prozessschritten wie Sintern oder Beschichten). Abzugrenzen ist er vom Ist-Durchmesser des Werkstücks, der durch Rückfederung, Verdichtung, Sinter-/Wärmebehandlung und ggf. Schichtdicken beeinflusst werden kann.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Pressure -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Pressure">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">Pressure</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PrimaryCurrentDistribution -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PrimaryCurrentDistribution">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Disposition"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">auf der Oberfläche einer Elektrode ohne Polarisa- tion ausschließlich aus geometrischen Erwägungen erwartete Stromverteilung</rdfs:comment>
        <rdfs:comment xml:lang="en">distribution of current over the surface of an electrode that is expected from geometrical considerations alone, in the absence of polarization</rdfs:comment>
        <rdfs:label xml:lang="en">Primary Current Distribution</rdfs:label>
        <rdfs:label xml:lang="de">primäre Stromverteilung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PrimaryShaping -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PrimaryShaping">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturing"/>
        <rdfs:label xml:lang="en">PrimaryShaping</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PrimaryShapingFromLiquidState -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PrimaryShapingFromLiquidState">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PrimaryShaping"/>
        <rdfs:label xml:lang="en">PrimaryShapingFromLiquidState</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Procedure -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Procedure">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Regulation"/>
        <rdfs:label xml:lang="en">Procedure</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcedureName -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcedureName">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <rdfs:comment>Name of a procedure (e.g. norm, standard, internal procedure)</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 2081:2018-09; DIN EN ISO 4042:2018-12; DIN EN ISO 4527:2023-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">ProcedureName</rdfs:label>
        <skos:definition xml:lang="de">Ein Verfahrensname ist die eindeutige Benennung eines angewendeten technischen Verfahrens (z. B. eines galvanischen oder chemischen Beschichtungsprozesses) in Dokumenten, Spezifikationen oder Datensätzen. Er dient der eindeutigen Identifikation und Rückverfolgbarkeit des eingesetzten Prozesses, insbesondere zur Zuordnung von Anforderungen, Parametern und Ergebnissen. Der Verfahrensname ist eine Bezeichnung (Metadatum) und nicht mit der Verfahrensbeschreibung oder den Prozessparametern gleichzusetzen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Occurrent"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemporalRegion"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">Process</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessBoundary -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessBoundary">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Occurrent"/>
        <owl:disjointWith rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#TemporalRegion"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">ProcessBoundary</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessDataSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessDataSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <rdfs:comment>Any kind of data set, that is the output of a process (e.g. raw data, analysed data, files, quantities...)</rdfs:comment>
        <rdfs:label xml:lang="en">ProcessDataSet</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessEvaluation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessEvaluation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CognitiveProcess"/>
        <rdfs:label xml:lang="en">ProcessEvaluation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessExecution -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessExecution">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GenerelExperimentRelatedProcess"/>
        <rdfs:comment>The process of executing any kind of process</rdfs:comment>
        <rdfs:label xml:lang="en">ProcessExecution</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessID -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessID">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Identifier"/>
        <rdfs:label xml:lang="en">ProcessID</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessParameterSet -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessParameterSet">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataSet"/>
        <rdfs:comment>A set of parameters, that is used to control a process. Those are usually quantities of type &quot;as supposed&quot;.</rdfs:comment>
        <rdfs:label xml:lang="en">ProcessParameterSet</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessProfile -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessProfile">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Process"/>
        <rdfs:comment>Class defined by the Basic Formal Ontology (BFO)</rdfs:comment>
        <rdfs:label xml:lang="en">ProcessProfile</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Quantity"/>
        <rdfs:label xml:lang="en">ProcessQuantity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessSetup -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessSetup">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ObjectSet"/>
        <rdfs:label xml:lang="en">ProcessSetup</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessTemperature -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessTemperature">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2021-08; DIN EN ISO 2081:2018-09; DIN EN ISO 4527:2023-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Process Temperature</rdfs:label>
        <rdfs:label xml:lang="de">Prozesstemperatur</rdfs:label>
        <skos:definition xml:lang="de">Prozesstemperatur ist die Temperatur, bei der ein definierter technischer Prozess unter festgelegten Bedingungen durchgeführt wird. Sie dient der Sicherstellung reproduzierbarer Prozessführung und beeinflusst maßgeblich Prozesskinetik, Stofftransport und damit Eigenschaften und Qualität des erzeugten Überzugs. In der Galvanotechnik bezieht sie sich typischerweise auf die Temperatur des Elektrolyten/Prozessbads bzw. des Werkstücks während der Abscheidung und ist als Sollwert mit zulässigen Toleranzen zu spezifizieren und zu überwachen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProducerName -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProducerName">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <rdfs:comment>Name of the producer of any kind of product</rdfs:comment>
        <rdfs:label xml:lang="en">ProducerName</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProductCode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProductCode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1043-1:2016-12; DIN EN ISO 1043-2:2012-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Product Code</rdfs:label>
        <rdfs:label xml:lang="de">Produktcode</rdfs:label>
        <skos:definition xml:lang="de">Ein Produktcode ist eine alphanumerische Kennzeichnung zur eindeutigen Identifikation eines Produkts oder Produkttyps innerhalb eines festgelegten Kodiersystems. Hauptzweck ist die standardisierte Zuordnung von Produktinformationen (z. B. Spezifikation, Ausführung, Variante) für Kommunikation, Dokumentation, Rückverfolgbarkeit und Datenverarbeitung. Der Produktcode ist von Prozess- oder Chargencodes abzugrenzen, die primär Herstellungs- bzw. Fertigungslose identifizieren.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProductName -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProductName">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 1043-1:2016-12; DIN EN ISO 15223-1:2021-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Product Name</rdfs:label>
        <rdfs:label xml:lang="de">Produktname</rdfs:label>
        <skos:definition xml:lang="de">Ein Produktname ist die vom Hersteller oder Inverkehrbringer vergebene Bezeichnung zur eindeutigen Identifikation eines Produkts in Kommunikation und Dokumentation. Er dient der Zuordnung von Produktinformationen (z. B. Spezifikation, Sicherheitsdatenblatt, technische Merkblätter) und der Rückverfolgbarkeit in Lieferkette und Anwendung. Der Produktname ist von normativen Stoff-/Gemischbezeichnungen oder chemischen Identifikatoren (z. B. CAS-/EG-Nummer) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Profile -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Profile">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 4287:2010-07; DIN EN ISO 16610-21:2013-06; DIN EN ISO 21920-2:2022-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Profil</rdfs:label>
        <rdfs:label xml:lang="en">Profile</rdfs:label>
        <skos:definition xml:lang="de">Ein Profil ist die Darstellung oder geometrische Form eines Querschnitts bzw. einer Kontur eines Werkstücks oder einer Oberfläche entlang einer definierten Linie. Hauptzweck ist die eindeutige geometrische Beschreibung zur Spezifikation, Prüfung und Bewertung, z. B. von Bauteilgeometrien oder von Oberflächenprofilen (Rauheitsprofil) nach festgelegten Mess- und Filterregeln. Im galvanotechnischen Kontext ist „Profil“ häufig relevant zur Beschreibung von Oberflächenprofilen vor/nach Beschichtung sowie zur Abgrenzung von Formabweichungen und Rauheitskenngrößen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Promethium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Promethium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Promethium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PulsePlating -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PulsePlating">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Plating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Abscheidung mit Impulsstrom
Verfahren zur galvanischen Metallabscheidung, bei dem der Strom oft unterbrochen oder periodisch herab- oder heraufgesetzt wird</rdfs:comment>
        <rdfs:comment xml:lang="en">method of electroplating  in which the current is frequently interrupted or periodically decreased or increased</rdfs:comment>
        <rdfs:label xml:lang="de">Pulse Plating</rdfs:label>
        <rdfs:label xml:lang="en">Pulse Plating</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#PumpManufacturer -->

