        <rdfs:label xml:lang="en">InputFileGeneration</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InsolubleAnode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InsolubleAnode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Anode"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">anode that is insoluble in the electrolyte  and is not dissolved under the conditions prevailing during electrolysis</rdfs:comment>
        <rdfs:comment xml:lang="de">im Elektrolyten unlösliche Anode, die sich unter den bei der	Elektrolyse auftretenden Bedingungen nicht aufgelöst hat</rdfs:comment>
        <rdfs:label xml:lang="en">Insoluble Anode</rdfs:label>
        <rdfs:label xml:lang="de">unlösliche Anode</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InspectionLot -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InspectionLot">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Name"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2859-1:2020-12, DIN EN ISO 9000:2015-11, DIN EN ISO/IEC 17025:2018-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Inspection Lot</rdfs:label>
        <rdfs:label xml:lang="de">Prüflos</rdfs:label>
        <skos:definition xml:lang="de">Ein Prüflos ist eine abgegrenzte Menge von Einheiten (z. B. Teile, Proben oder eine Charge), die unter festgelegten Bedingungen zur Prüfung und Beurteilung der Konformität als eine Einheit behandelt wird. Hauptzweck ist die eindeutige Zuordnung von Prüfungen, Prüfergebnissen und Annahme-/Ablehnentscheidungen zu einem definierten Umfang von Produkten. Ein Prüflos kann (muss aber nicht) mit Herstelllos/Charge identisch sein und wird in Prüfplänen bzw. bei der Probenahme/AQL-Prüfung festgelegt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InstrumentedIndentationMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InstrumentedIndentationMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 14577-1:2015-11, DIN EN ISO 14577-2:2015-11, DIN EN ISO 14577-3:2015-11, DIN EN ISO 14577-4:2015-11</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 14577-1:2015-11, DIN EN ISO 14577-2:2015-11, DIN EN ISO 14577-3:2015-11, DIN EN ISO 14577-4:2016-12, DIN EN ISO 14577-5:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Instrumented indentation measurement</rdfs:label>
        <rdfs:label xml:lang="de">Instrumentierte Eindringprüfung</rdfs:label>
        <skos:definition xml:lang="de">Die instrumentierte Eindringprüfung ist ein Eindringverfahren zur Bestimmung mechanischer Werkstoffkennwerte, bei dem während des Eindringens eines Prüfkörpers in die Probenoberfläche die Prüfkraft und die Eindringtiefe kontinuierlich gemessen und als Kraft‑Eindringtiefe‑Kurve ausgewertet werden. Hauptzweck ist die Ermittlung von Härtekennwerten (z. B. Martenshärte) und weiteren Kenngrößen aus dem Last‑Entlastungs‑Verhalten, ohne dass die Eindruckdiagonalen optisch vermessen werden müssen. Sie ist von klassischen Härteprüfungen nach Vickers/Brinell/Rockwell abzugrenzen, da die Auswertung primär auf der instrumentierten Messkurve basiert.</skos:definition>
        <skos:definition xml:lang="de">Die instrumentierte Eindringprüfung ist ein Härteprüfverfahren, bei dem während des Eindringens eines Prüfkörpers in die Oberfläche kontinuierlich Kraft und Eindringtiefe (bzw. Eindringweg) gemessen und als Kraft‑Eindringtiefe‑Kurve ausgewertet werden. Hauptzweck ist die Bestimmung von Härtekennwerten (z. B. Martenshärte) und weiterer Werkstoffkennwerte aus dem Last‑Entlastungsverhalten, insbesondere für dünne Schichten und Randschichten wie galvanische Überzüge. Im Unterschied zu klassischen Härteprüfungen wird die Eindruckgeometrie nicht optisch vermessen, sondern aus den Messsignalen abgeleitet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IntegratedHeatingFurnace -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IntegratedHeatingFurnace">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CastingEquipment"/>
        <rdfs:comment>A heating furnace, that is integrated in the casting machine</rdfs:comment>
        <rdfs:label xml:lang="en">IntegratedHeatingFurnace</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Interferometer -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Interferometer">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>ISO 25178-600:2019, *Geometrical product specifications (GPS) — Surface texture: Areal — Part 600: Metrological characteristics for areal-topography measuring methods*; JCGM 200:2012, *International vocabulary of metrology (VIM) — Basic and general concepts and associated terms (VIM), 3rd edition*</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Interferometer</rdfs:label>
        <rdfs:label xml:lang="en">Interferometer</rdfs:label>
        <skos:definition xml:lang="de">Ein Interferometer ist ein optisches Messgerät, das aus der Interferenz überlagerter kohärenter Lichtwellen Weglängen- bzw. Höhenunterschiede ableitet. Hauptzweck ist die hochauflösende Bestimmung von Längen, Form- und Oberflächenkenngrößen (z. B. Topographie/Rauheit) über die Auswertung von Interferenzstreifen bzw. phasenbasierten Signalen. In der Galvanotechnik wird es u. a. zur zerstörungsarmen Prüfung von Schicht- und Oberflächeneigenschaften (z. B. Topographieänderungen durch Beschichtung) eingesetzt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Interferometry -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Interferometry">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Measurement"/>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Interpolation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Interpolation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DataTransformation"/>
        <rdfs:label xml:lang="en">Interpolation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Iodine -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Iodine">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Iodine</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IonExchange -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IonExchange">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalProcess"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">reversible process by which ions are interchanged between an ion exchange resin  and a liquid without a substantial structural change of the ion exchange resin</rdfs:comment>
        <rdfs:comment xml:lang="de">reversibler Prozess, bei dem Ionen zwischen einem Ionenaustauschharz und einer Flüssigkeit ohne wesentliche Strukturveränderung des Ionenaustauschharzes ausgetauscht werden</rdfs:comment>
        <rdfs:label xml:lang="en">Ion Exchange</rdfs:label>
        <rdfs:label xml:lang="de">Ionenaustausch</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IonExchangeResin -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IonExchangeResin">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">organic material which can reversibly bind all or selected ions in order to extract them from liquids</rdfs:comment>
        <rdfs:comment xml:lang="de">organisches Material, mit dem alle oder ausgewählte Ionen reversibel gebunden werden können, um diese aus Flüssigkeiten zu extrahieren</rdfs:comment>
        <rdfs:label xml:lang="en">Ion Exchange Resin</rdfs:label>
        <rdfs:label xml:lang="de">Ionenaustauschharz</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Iridium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Iridium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Iridium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Iron -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Iron">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Iron</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Krypton -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Krypton">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Krypton</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#L -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#L">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-4:2019-03, DIN EN ISO/CIE 11664-1:2019-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">L</rdfs:label>
        <rdfs:label xml:lang="de">L (CIELAB-Helligkeit)</rdfs:label>
        <skos:definition xml:lang="de">L* ist die Helligkeitskoordinate im CIE-L*a*b*-Farbraum (CIELAB) und beschreibt die wahrgenommene Lichtheit einer Farbe auf einer Skala von 0 (ideal schwarz) bis 100 (ideal weiß). Hauptzweck ist die quantitative Bewertung und der Vergleich von Helligkeitsunterschieden von Oberflächen (z. B. galvanisch beschichtete Teile) unter festgelegten Messbedingungen. L* ist von den Buntheitskoordinaten a* und b* getrennt definiert und wird aus tristimulusbasierten Messwerten relativ zu einem Referenzweiß berechnet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LIBSMeasurementSystem -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LIBSMeasurementSystem">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <rdfs:comment>A measurement system for the laser induced plasma spectroscopy (LIBS) process</rdfs:comment>
        <rdfs:label xml:lang="en">LIBSMeasurementSystem</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 11664-4:2019-06; DIN EN ISO 11664-1:2019-06; DIN EN ISO 11664-2:2020-12; DIN 5033-1:2017-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">L target value</rdfs:label>
        <rdfs:label xml:lang="de">Zielwert L (CIELAB-Helligkeit)</rdfs:label>
        <skos:definition xml:lang="de">Der Zielwert L ist der festgelegte Sollwert des CIELAB-Helligkeitsparameters L* (Lightness) für eine Oberfläche, ermittelt aus tristimulusbasierten Farbmessungen unter definierten Messbedingungen. Er dient dazu, die gewünschte Helligkeit einer galvanisch erzeugten Oberfläche (z. B. dekorative Schichten) in der Qualitätsprüfung und Prozessregelung eindeutig zu spezifizieren und mit Istwerten zu vergleichen. Der Zielwert ist von a* und b* (Farbkoordinaten) sowie von Glanzmessgrößen zu unterscheiden und ist nur im Kontext der festgelegten Beobachter-/Beleuchtungs- und Messgeometrie eindeutig.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#InfrastructureEquipment"/>
        <rdfs:label xml:lang="en">LabInfrastructureEquipment</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lanthanum -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lanthanum">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Lanthanum</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Laptop -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Laptop">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ITEquipment"/>
        <rdfs:label xml:lang="en">Laptop</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LaserEngraving -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LaserEngraving">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecimenPreparation"/>
        <rdfs:isDefinedBy>DIN EN ISO 11553-1:2020-02, DIN EN ISO 11553-2:2020-02, DIN EN ISO 20653:2023-03</rdfs:isDefinedBy>
        <skos:definition xml:lang="de">Lasergravur ist ein laserbasiertes Verfahren zur Erzeugung einer dauerhaften Kennzeichnung durch lokalen Materialabtrag bzw. eine definierte Vertiefung an der Werkstückoberfläche. Hauptzweck ist die dauerhafte Identifikation (z. B. Seriennummern, Data-Matrix-Codes) oder Funktionskennzeichnung, auch auf metallischen und galvanisch beschichteten Oberflächen. Im Unterschied zu rein farb- bzw. kontraständernden Laserbeschriftungen ist die Lasergravur typischerweise durch eine topografische Änderung (Relief) gekennzeichnet.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LaserInducedPlasmaSpectroscopy -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LaserInducedPlasmaSpectroscopy">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Spectroscopy"/>
        <rdfs:comment>A laser induced plasma spectroscopy process: Minimal invasive process to measure the chemical composition on the material surface (or in a small volume) in high speed.</rdfs:comment>
        <rdfs:label xml:lang="en">LaserInducedPlasmaSpectroscopy</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LaserScanningMicroscope -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LaserScanningMicroscope">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 25178-607:2015-12 (Geometrische Produktspezifikation (GPS) – Oberflächenbeschaffenheit: Flächenhaft – Teil 607: Nennmerkmale von konfokalen Mikroskopen)</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 25178-6:2010-12, DIN EN ISO 25178-607:2015-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Laser Scanning Microscope</rdfs:label>
        <rdfs:label xml:lang="de">Laserscanningmikroskop</rdfs:label>
        <skos:definition xml:lang="de">Ein Laserscanning-Mikroskop ist ein optisches Mikroskop, das eine Probe punkt- oder linienweise mit einem fokussierten Laser abtastet und aus dem detektierten Signal ein Bild bzw. eine Höhen-/Intensitätsverteilung rekonstruiert. Hauptzweck ist die hochauflösende, flächenhafte Charakterisierung von Oberflächen (z. B. Topographie/Rauheit) und Schichtstrukturen, wie sie in der Galvanotechnik zur Prüfung galvanischer Überzüge eingesetzt wird. In der konfokalen Ausführung wird durch eine räumliche Filterung (Pinhole) die Tiefenselektion verbessert und damit eine 3D-Oberflächenmessung ermöglicht.</skos:definition>
        <skos:definition xml:lang="de">Ein Laserscanningmikroskop ist ein optisches Mikroskop, das eine Probe punkt- oder zeilenweise mit einem fokussierten Laserstrahl abtastet und das Signal (z. B. reflektiertes Licht oder Fluoreszenz) detektiert, um daraus ein Bild zu rekonstruieren. Hauptzweck ist die hochauflösende, häufig dreidimensionale Erfassung von Oberflächen- bzw. Strukturdaten, insbesondere bei konfokaler Ausführung zur Unterdrückung von außerhalb der Fokusebene liegenden Signalanteilen. In der Oberflächenmesstechnik wird es typischerweise als konfokales Laser-Scanning-Mikroskop zur flächenhaften Topographie- und Rauheitsmessung eingesetzt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LaserScanningMicroscopy -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LaserScanningMicroscopy">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Microscopy"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 25178-600:2019-03; ISO 21073:2019-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Laser scanning microscopy</rdfs:label>
        <rdfs:label xml:lang="de">Laserscanning-Mikroskopie</rdfs:label>
        <skos:definition xml:lang="de">Laserscanning-Mikroskopie ist ein optisches Mikroskopieverfahren, bei dem eine Probe punkt- oder zeilenweise mit einem fokussierten Laserstrahl abgetastet und das Bild aus dem detektierten Signal rekonstruiert wird. Hauptzweck ist die hochauflösende Abbildung und (je nach Ausführung, z. B. konfokal) die dreidimensionale Erfassung von Oberflächen- und Schichtstrukturen durch optische Schnittbilder. Charakteristisch ist die rasternde Abtastung (Scanning) und die laserbasierte Beleuchtung; bei konfokaler Ausführung wird durch eine Blende außerhalb der Fokusebene stammendes Licht unterdrückt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LayerDefinition -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LayerDefinition">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2064:2020-03; DIN EN ISO 2177:2019-06; DIN EN ISO 2360:2017-12; DIN EN ISO 3497:2000-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Layer Definition</rdfs:label>
        <rdfs:label xml:lang="de">Schichtdefinition</rdfs:label>
        <skos:definition xml:lang="de">Eine Schichtdefinition ist die eindeutige Festlegung, welche Schicht bzw. welcher Schichtanteil in einem Schichtsystem gemeint ist (z. B. Überzug, Zwischenschicht, Diffusionszone) und wie ihre Grenzen gegenüber Grundwerkstoff und benachbarten Schichten bestimmt werden. Hauptzweck ist die eindeutige Zuordnung von Anforderungen, Prüfungen und Messergebnissen (insbesondere der Schichtdicke) zu einer konkret abgegrenzten Schicht. Sie umfasst typischerweise Angaben zur Schichtart, Lage im Schichtaufbau, Mess-/Abgrenzungsregel (z. B. metallographisch, profilometrisch, coulometrisch) und ggf. zur Behandlung von Grenzflächen- oder Diffusionsbereichen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LayerThickness -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LayerThickness">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Dicke einer Schicht</rdfs:comment>
        <rdfs:comment xml:lang="en">Thickness of a layer</rdfs:comment>
        <rdfs:label xml:lang="en">Layer Thickness</rdfs:label>
        <rdfs:label xml:lang="de">Schichtdicke</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LayerThicknessMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LayerThicknessMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of the thickness of a layer</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung der Dicke einer Schicht</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-12, DIN EN ISO 2360:2017-03, DIN EN ISO 1463:2021-08, DIN EN ISO 3497:2000-10, DIN EN ISO 3882:2003-07, DIN EN ISO 3543:2015-07</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-12; DIN EN ISO 2360:2017-12; DIN EN ISO 1463:2021-08; DIN EN ISO 2177:2019-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Layer Thickness Measurement</rdfs:label>
        <rdfs:label xml:lang="de">Schichtdickenmessung</rdfs:label>
        <skos:definition xml:lang="de">Schichtdickenmessung ist die Bestimmung der Dicke einer auf einem Grundwerkstoff aufgebrachten Schicht (z. B. metallische oder anorganische Überzüge) mit einem festgelegten Messverfahren. Hauptzweck ist die Verifikation, dass die geforderte Schichtdicke zur Erfüllung von Funktions- und Qualitätsanforderungen (z. B. Korrosionsschutz, Verschleißschutz, elektrische Eigenschaften) eingehalten wird. Je nach Schicht-/Substratkombination und Anforderung kann die Messung zerstörungsfrei (z. B. magnetisch/Wirbelstrom) oder zerstörend (z. B. Querschliff) erfolgen.</skos:definition>
        <skos:definition xml:lang="de">Schichtdickenmessung ist die Bestimmung der Dicke einer auf einem Grundwerkstoff aufgebrachten Schicht (z. B. metallische Überzüge, Konversionsschichten oder organische Beschichtungen) mit festgelegten Messverfahren und Auswertebedingungen. Hauptzweck ist die Verifizierung, dass die Schichtdicke die spezifizierten Anforderungen (z. B. Mindestdicke, Toleranzen) erfüllt und damit Funktionseigenschaften wie Korrosionsschutz, Verschleißschutz oder elektrische Eigenschaften abgesichert werden. Je nach Schicht-/Substratkombination und geforderter Messunsicherheit kommen zerstörungsfreie (z. B. magnetische/Wirbelstrom-Verfahren) oder zerstörende Verfahren (z. B. mikroskopischer Querschliff, coulometrisches Abtragen) zur Anwendung.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LayerWeight -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LayerWeight">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2177:2020-06, DIN EN ISO 3892:2017-03</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 3892:2001-06; DIN EN ISO 2177:2003-01; DIN EN ISO 1460:2022-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Layer Weight</rdfs:label>
        <rdfs:label xml:lang="de">Schichtgewicht</rdfs:label>
        <skos:definition xml:lang="de">Schicht Gewicht bezeichnet die Masse eines abgeschiedenen Überzugs bezogen auf eine definierte Fläche (Flächenmasse), typischerweise angegeben in g/m². Hauptzweck ist die indirekte Spezifikation bzw. Kontrolle der Überzugsmenge und damit – bei bekannter Dichte – die Ableitung einer mittleren Schichtdicke. Es ist von der Schichtdicke (Längenmaß, z. B. µm) abzugrenzen, da das Schichtgewicht eine Massen- und keine geometrische Kenngröße ist.</skos:definition>
        <skos:definition xml:lang="de">Schichtgewicht ist die auf eine definierte Fläche bezogene Masse einer abgeschiedenen Schicht bzw. eines Überzugs (Masse pro Flächeneinheit). Es dient zur quantitativen Charakterisierung der Auftragsmenge und wird u. a. zur indirekten Bestimmung der Schichtdicke (über Dichte/Umrechnung) sowie zur Prozess- und Qualitätskontrolle verwendet. Es ist von der Schichtdicke zu unterscheiden, da es eine Massen- statt eine Längenangabe ist.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lead -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lead">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Lead</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Length -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Length">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseQuantityKind"/>
        <rdfs:label xml:lang="en">Length</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LengthOfLines -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LengthOfLines">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 1315-1:1993-01 (Größen – Teil 1: Allgemeine Begriffe), ISO 80000-3:2019 (Quantities and units — Part 3: Space and time)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Length Of Lines</rdfs:label>
        <rdfs:label xml:lang="de">Linienlänge</rdfs:label>
        <skos:definition xml:lang="de">Linienlänge ist das Maß der Länge einer Linie bzw. eines Linienzuges, verstanden als Abstand entlang der Linie zwischen zwei festgelegten Punkten. Hauptzweck ist die eindeutige quantitative Beschreibung von Geometrien (z. B. Kanten-, Bahn- oder Konturlängen) als Eingangsgröße für Berechnungen und Spezifikationen. Je nach Anwendung kann die Linienlänge als geradlinige Strecke oder als Bogen-/Kurvenlänge definiert sein und ist von der Sehnenlänge zu unterscheiden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Levelling -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Levelling">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Disposition"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Fähigkeit galvanischer Metallabscheidungsverfahren, eine Oberfläche zu erhalten, die glatter als die des Substrats ist</rdfs:comment>
        <rdfs:comment xml:lang="en">ability of an electroplating process to produce a surface smoother than that of the substrate</rdfs:comment>
        <rdfs:label xml:lang="de">Einebnung</rdfs:label>
        <rdfs:label xml:lang="en">Levelling</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightFixture -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightFixture">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroscopeAccessory"/>
        <rdfs:label xml:lang="en">LightFixture</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightIntensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightIntensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 12665:2018-03, Licht und Beleuchtung – Grundlegende Begriffe und Kriterien für die Festlegung von Anforderungen an die Beleuchtung; DIN 5031-1:1982-03, Strahlungsphysik im optischen Bereich und Lichttechnik – Größen, Formelzeichen und Einheiten der Lichttechnik – Teil 1: Allgemeine Begriffe; DIN EN ISO/CIE 11664-1:2019-03, Farbmetrik – Teil 1: CIE-Standardfarbwertfunktionen (zur photometrischen Bewertung über V(λ) im CIE-System)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Lichtintensität</rdfs:label>
        <rdfs:label xml:lang="en">Light intensity</rdfs:label>
        <skos:definition xml:lang="de">Lichtintensität ist eine photometrische Größe, die die von einer Lichtquelle in eine bestimmte Richtung abgegebene Lichtstärke beschreibt und in Candela (cd) angegeben wird. Hauptzweck ist die quantifizierbare Beschreibung und Vergleichbarkeit der gerichteten Lichtabgabe einer Quelle unter Berücksichtigung der spektralen Hellempfindlichkeit des menschlichen Auges. Sie ist von der Beleuchtungsstärke (auf einer Fläche) und dem Lichtstrom (gesamt abgegebene Lichtmenge) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightMicroscope -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightMicroscope">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MicroscopeEquipment"/>
        <rdfs:comment>Light microscope</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2021-08, Metallische und Oxidschichten – Messung der Schichtdicke – Mikroskopisches Verfahren; DIN EN ISO 9220:2020-07, Metallische Überzüge – Messung der Schichtdicke – Rasterelektronenmikroskopisches Verfahren (als Abgrenzung zur Licht-/optischen Mikroskopie)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">LightMicroscope</rdfs:label>
        <skos:definition xml:lang="de">Ein Lichtmikroskop ist ein optisches Mikroskop, das sichtbares Licht und ein Linsensystem zur vergrößerten Abbildung von Probenstrukturen nutzt. Hauptzweck ist die mikroskopische Beurteilung von Oberflächen und Querschliffen, z. B. zur Bewertung von Schichtaufbau, Gefüge, Defekten oder Grenzflächen in galvanischen Überzügen. Es ist von Elektronenmikroskopen abzugrenzen, die statt Licht Elektronenstrahlen verwenden und typischerweise höhere Auflösungen erreichen.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightMicroscopeMagnification -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightMicroscopeMagnification">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8037:2019-02 (Optik und Photonik — Mikroskope — Allgemeine Spezifikationen für optische Mikroskope)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Light Microscope Magnification</rdfs:label>
        <rdfs:label xml:lang="de">Vergrößerung Lichtmikroskop</rdfs:label>
        <skos:definition xml:lang="de">Die Vergrößerung am Lichtmikroskop ist das dimensionslose Verhältnis zwischen der Größe des vom Mikroskop erzeugten Bildes und der tatsächlichen Größe des beobachteten Objekts. Sie dient dazu, die Abbildungsleistung für die visuelle Beurteilung bzw. Messung (z. B. von Schichtaufbauten oder Gefügemerkmalen) festzulegen und vergleichbar zu machen. Bei zusammengesetzten Lichtmikroskopen ergibt sich die Gesamtvergrößerung üblicherweise als Produkt aus Objektiv- und Okularvergrößerung.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightMicroscopy -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightMicroscopy">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Microscopy"/>
        <rdfs:isDefinedBy>DIN EN ISO 1463:2020-02; DIN EN ISO 9220:2020-11; DIN EN ISO 17639:2022-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">LightMicroscopy</rdfs:label>
        <skos:definition xml:lang="de">Lichtmikroskopie ist ein mikroskopisches Untersuchungsverfahren, bei dem sichtbares Licht und optische Linsen zur Abbildung und Beurteilung von Oberflächen oder Schliffen verwendet werden. Hauptzweck ist die visuelle Bewertung von Mikrostruktur- und Schichtmerkmalen (z. B. Schichtdicke, Poren, Risse, Grenzflächen) im Auf- oder Durchlicht. Sie ist von der Elektronenmikroskopie abzugrenzen, da sie mit sichtbarem Licht arbeitet und typischerweise geringere Auflösung, aber einfachere Probenvorbereitung ermöglicht.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightingTechnology -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LightingTechnology">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN 12665:2018-11, DIN EN 12464-1:2021-11, DIN 5035-1:2020-12, DIN EN ISO/CIE 11664-2:2022-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Beleuchtungstechnologie</rdfs:label>
        <rdfs:label xml:lang="en">Lighting Technology</rdfs:label>
        <skos:definition xml:lang="de">Beleuchtungstechnologie ist die Gesamtheit der technischen Verfahren, Komponenten und Systeme zur Erzeugung, Verteilung und Steuerung von Licht für definierte Seh- oder Prozessaufgaben. Hauptzweck ist das Bereitstellen normgerechter Beleuchtungsbedingungen (z. B. Beleuchtungsstärke, Gleichmäßigkeit, Blendungsbegrenzung, Farbwiedergabe) für Arbeitsplätze, Prüf- und Fertigungsprozesse. In der Galvanotechnik wird Beleuchtungstechnologie insbesondere zur visuellen Beurteilung von Oberflächen (z. B. Glanz, Farbe, Defekte) und zur Prozess- bzw. Arbeitsplatzbeleuchtung eingesetzt, wobei die lichttechnischen Kenngrößen nach einschlägigen Beleuchtungsnormen festzulegen sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LineDetector -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LineDetector">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingEquipment"/>
        <rdfs:comment>A line detector, e.g. used in a computer tomograph</rdfs:comment>
        <rdfs:label xml:lang="en">LineDetector</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LiquidNitrogenTank -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LiquidNitrogenTank">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <rdfs:comment>A tank filled with liquid nitrogen (e.g. used at a scanning electron microscope)</rdfs:comment>
        <rdfs:label xml:lang="en">LiquidNitrogenTank</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Literal -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Literal">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#SpecificDataFormat"/>
        <rdfs:label xml:lang="en">Literal</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lithium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lithium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Lithium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Load -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Load">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2178:2016-06; DIN EN ISO 2819:2018-02; DIN EN ISO 4516:2002-10</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; DIN EN 10002-1:2001-12; DIN EN 60204-1 (VDE 0113-1):2019-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Last</rdfs:label>
        <rdfs:label xml:lang="en">Load</rdfs:label>
        <skos:definition xml:lang="de">Belastung ist die auf ein System, Bauteil oder eine Schicht einwirkende Einwirkung (z. B. Kraft, Druck, Temperaturwechsel oder elektrischer Strom), die eine Beanspruchung verursacht. Hauptzweck der Angabe der Belastung ist die Festlegung und Bewertung von Einsatz- und Prüfbedingungen, unter denen Eigenschaften galvanischer Überzüge (z. B. Haftfestigkeit, Rissneigung, Korrosionsbeständigkeit) beurteilt werden. Je nach Kontext ist zwischen mechanischer Belastung (Last/Beanspruchung) und elektrischer Belastung (Strombelastung im Prozess) zu unterscheiden.</skos:definition>
        <skos:definition xml:lang="de">Eine Last ist eine auf ein Bauteil, eine Beschichtung oder eine Prüfanordnung wirkende mechanische Einwirkung, die als Kraft (oder daraus abgeleitete Beanspruchung) aufgebracht wird. Hauptzweck der Angabe/Anwendung einer Last ist die definierte mechanische Beanspruchung, z. B. zur Bewertung von Eigenschaften galvanischer Überzüge wie Haftfestigkeit oder Verschleißverhalten unter festgelegten Prüfbedingungen. Je nach Kontext kann die Last als statische oder dynamische (wechselnde) Belastung spezifiziert werden und ist von elektrischer „Last“ (Laststrom/Lastwiderstand) abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LoadCell -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LoadCell">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <rdfs:label xml:lang="en">LoadCell</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LoadingTime -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LoadingTime">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 9227:2022-08; DIN EN ISO 16701:2020-06; DIN EN ISO 6892-1:2020-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Belastungszeit</rdfs:label>
        <rdfs:label xml:lang="en">Loading time</rdfs:label>
        <skos:definition xml:lang="de">Belastungszeit ist die festgelegte Zeitdauer, während der eine Probe oder ein beschichtetes Bauteil einer definierten Belastung (z. B. mechanische Beanspruchung, korrosive Atmosphäre oder Prüfmedium) ausgesetzt wird. Sie dient dazu, die Einwirkdauer als Prüfparameter eindeutig festzulegen und damit Prüfergebnisse (z. B. Korrosionsangriff, Schädigung, Haftungs-/Rissverhalten) vergleichbar zu machen. Je nach Prüfverfahren kann sie als kontinuierliche Expositionszeit oder als Summe von Belastungsphasen innerhalb eines Zyklus angegeben werden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lubricant -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lubricant">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Substance"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 51502:2017-06; DIN EN ISO 6743-99:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Lubricant</rdfs:label>
        <rdfs:label xml:lang="de">Schmierstoff</rdfs:label>
        <skos:definition xml:lang="de">Ein Schmierstoff ist ein Stoff, der zwischen sich relativ bewegenden Oberflächen eingebracht wird und dort einen Schmierenden Film bildet. Hauptzweck ist die Verringerung von Reibung und Verschleiß sowie die Unterstützung weiterer Funktionen wie Wärmeabfuhr, Korrosionsschutz und Abdichtung. Schmierstoffe können flüssig (z. B. Öle), halbfest (z. B. Fette) oder fest sein und werden in der Oberflächentechnik u. a. als Prozesshilfsstoffe bzw. als Verunreinigungen mit Relevanz für die Vorbehandlung betrachtet.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LuminousIntensity -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LuminousIntensity">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#BaseQuantityKind"/>
        <rdfs:label xml:lang="en">LuminousIntensity</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lutetium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Lutetium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Lutetium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachinePreparation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachinePreparation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Preparation"/>
        <rdfs:comment>Preparation process of some kind of machine</rdfs:comment>
        <rdfs:label xml:lang="en">MachinePreparation</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachineSoftware -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachineSoftware">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Software"/>
        <rdfs:comment>Machine specific software, e.g. used to control the process or acquire data</rdfs:comment>
        <rdfs:label xml:lang="en">MachineSoftware</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachiningWithGeometricallyDeterminedEdge -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MachiningWithGeometricallyDeterminedEdge">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Separating"/>
        <rdfs:label xml:lang="en">MachiningWithGeometricallyDeterminedEdge</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MacrothrowingPower -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MacrothrowingPower">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Streufähigkeit
Fähigkeit eines Elektrolyts, eine annähernde Gleichmäßigkeit  der Schicht- dicke über die gesamte Oberfläche eines Werkstücks, einschließlich der tiefer gelegenen Bereiche, zu erzeugen</rdfs:comment>
        <rdfs:comment xml:lang="en">throwing power
ability of an electrolyte to approach uniformity of the coating thickness over the entire surface of the work piece including its recesses</rdfs:comment>
        <rdfs:label xml:lang="en">Macrothrowing Power</rdfs:label>
        <rdfs:label xml:lang="de">Makrostreufähigkeit</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Magnesium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Magnesium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Magnesium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MagneticFlux -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MagneticFlux">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">MagneticFlux</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Magnification -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Magnification">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 3059:2012-10, DIN EN ISO 9022-1:2016-06</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Vergrößerung</rdfs:label>
        <rdfs:label xml:lang="en">magnification</rdfs:label>
        <skos:definition xml:lang="de">Vergrößerung ist das Verhältnis einer durch ein optisches System erzeugten Bildgröße zur entsprechenden Objektgröße. Hauptzweck ist die Festlegung und Vergleichbarkeit der Abbildungsmaßstäbe bei visuellen bzw. mikroskopischen Prüfungen, z. B. zur Beurteilung von Oberflächen, Schichtfehlern oder Gefügemerkmalen. Je nach Normkontext wird zwischen Gesamtvergrößerung und (bei digitalen Systemen) Anzeige-/Bildschirmvergrößerung unterschieden.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manganese -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manganese">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Manganese</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturer -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturer">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedParameters"/>
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#IndependentContinuant"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Der Hersteller des Messgeräts.</rdfs:comment>
        <rdfs:comment xml:lang="en">The manufacturer of the measuring device.</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 9000:2015-11; DIN EN ISO/IEC 17000:2020-05</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Hersteller</rdfs:label>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
        <skos:definition xml:lang="de">Ein Hersteller ist eine natürliche oder juristische Person, die ein Produkt herstellt oder herstellen lässt und es unter ihrem Namen oder ihrer Marke in Verkehr bringt. Hauptzweck der Herstellerrolle ist die Sicherstellung der Konformität des Produkts mit festgelegten Anforderungen sowie die Übernahme der Verantwortung für die zugehörige technische Dokumentation und Kennzeichnung. Der Begriff ist von „Lieferant“ oder „Händler“ abzugrenzen, die Produkte bereitstellen, ohne notwendigerweise für Herstellung und Konformität verantwortlich zu sein.</skos:definition>
        <skos:definition xml:lang="de">Ein Hersteller ist eine natürliche oder juristische Person, die ein Produkt herstellt oder herstellen lässt und es unter ihrem Namen oder ihrer Marke in Verkehr bringt. Hauptzweck der Herstellerrolle ist die Übernahme der Verantwortung für die Konformität des Produkts mit den zutreffenden Anforderungen (z. B. Spezifikationen, Prüf- und Kennzeichnungsanforderungen) sowie für die Bereitstellung der zugehörigen Produktinformationen. Der Begriff ist von „Lieferant“ abzugrenenzen, der ein Produkt bereitstellt, ohne zwingend dessen Herstellung oder Inverkehrbringen unter eigenem Namen zu verantworten.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ManufacturerAnode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ManufacturerAnode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturer"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 8044:2020-08; DIN EN ISO 9000:2015-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Hersteller Anode</rdfs:label>
        <rdfs:label xml:lang="en">Manufacturer Anode</rdfs:label>
        <skos:definition xml:lang="de">Ein „Hersteller Anode“ ist die Organisation, die eine Anode (Elektrode, an der Oxidation stattfindet) herstellt und als Produkt in Verkehr bringt bzw. bereitstellt. Hauptzweck/Funktion ist die Fertigung und Spezifikation von Anoden für elektrochemische Prozesse (z. B. galvanische Abscheidung), einschließlich der Sicherstellung definierter Eigenschaften wie Werkstoff, Geometrie und ggf. Beschichtung entsprechend den Anwendungsanforderungen. Abzugrenzen ist dies von Rollen wie Lieferant/Händler (ohne Herstellung) sowie Betreiber/Anwender der Anode im Prozess.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ManufacturerPHElectrode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ManufacturerPHElectrode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturer"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 10523:2012-04; DIN EN 60746-2:2003-07 (IEC 60746-2:2002)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Hersteller PH Elektrode</rdfs:label>
        <rdfs:label xml:lang="en">Manufacturer PH Electrode</rdfs:label>
        <skos:definition xml:lang="de">Ein Hersteller pH‑Elektrode ist eine Organisation, die pH‑Elektroden (typischerweise Glaselektroden als Teil einer pH‑Messkette) entwickelt und fertigt und diese als Produkt in Verkehr bringt. Hauptzweck ist die Bereitstellung spezifikationskonformer pH‑Sensoren einschließlich zugehöriger Produktdokumentation (z. B. Kennwerte, Kalibrier-/Prüfangaben) für die Messung der Wasserstoffionenaktivität bzw. des pH‑Werts. Abzugrenzen ist dies von Anwender/Betreiber (nutzt/kalibriert) und Prüflabor (verifiziert), die nicht notwendigerweise Herstellerfunktionen ausüben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturing -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Manufacturing">
