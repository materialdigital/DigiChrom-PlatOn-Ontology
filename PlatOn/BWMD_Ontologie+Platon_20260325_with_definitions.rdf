    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Germanium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Germanium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Germanium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GlossAngle -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GlossAngle">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2813:2015-02; DIN 67530:1982-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Glanzwinkel</rdfs:label>
        <rdfs:label xml:lang="en">Gloss Angle</rdfs:label>
        <skos:definition xml:lang="de">Der Glanzwinkel ist der in der Glanzmessung festgelegte Winkel der Messgeometrie, der die Richtung des einfallenden und spiegelnd reflektierten Lichtstrahls zur Oberflächennormalen (bzw. die entsprechende Messanordnung) beschreibt. Er dient dazu, den Glanzgrad von Oberflächen unter definierten Bedingungen vergleichbar zu bestimmen, wobei je nach Glanzniveau unterschiedliche Winkel (typisch 20°, 60° oder 85°) verwendet werden. Der Glanzwinkel ist eine Eigenschaft der Messmethode/Geometrie und nicht der Oberfläche selbst.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GlossMeasurement -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GlossMeasurement">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Experiment"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Measurement of the gloss of a surface</rdfs:comment>
        <rdfs:comment xml:lang="de">Messung des Glanzes einer Oberfläche</rdfs:comment>
        <rdfs:isDefinedBy>DIN EN ISO 2813:2015-02; DIN 67530:1982-01</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Glanzmessung</rdfs:label>
        <rdfs:label xml:lang="en">Gloss Measurement</rdfs:label>
        <skos:definition xml:lang="de">Glanzmessung ist die messtechnische Bestimmung des Glanzgrades einer Oberfläche über den Vergleich der gerichteten Reflexion mit einem festgelegten Referenzstandard bei definierten Messgeometrien (z. B. 20°, 60°, 85°). Hauptzweck ist die objektive Bewertung und Spezifikation des visuellen Oberflächeneindrucks (z. B. von galvanischen Überzügen) zur Qualitätskontrolle und zum Vergleich von Oberflächenzuständen. Die Messung erfolgt üblicherweise in Glanzeinheiten (GU) und ist von Beleuchtungs-/Beobachtungsbedingungen sowie Oberflächenstruktur abhängig.</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GlossMeasurementEquipment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GlossMeasurementEquipment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2813:2015-02, DIN EN ISO 7668:2017-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Glanzmessgerät</rdfs:label>
        <rdfs:label xml:lang="en">Gloss Measurement Equipment</rdfs:label>
        <skos:definition xml:lang="de">Ein Glanzmessgerät ist ein optisches Messgerät zur Bestimmung des spiegelnden Glanzes einer Oberfläche durch Messung des reflektierten Lichts bei festgelegter Geometrie (z. B. 20°, 60°, 85°). Hauptzweck ist die quantitative, vergleichbare Bewertung des Oberflächenglanzes (Glanzgrad) von Beschichtungen und metallischen Oberflächen, z. B. zur Prozess- und Qualitätskontrolle in der Galvanotechnik. Die Messung erfolgt in Glanzeinheiten bezogen auf einen Kalibrierstandard (typisch schwarzes Glas) und unter normierten Messbedingungen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GlossUnit -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#GlossUnit">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 2813:2015-02; ASTM D523-14(2018)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Glanz Einheit</rdfs:label>
        <rdfs:label xml:lang="en">Gloss unit</rdfs:label>
        <skos:definition xml:lang="de">Eine Glanz Einheit (GU) ist die dimensionslose Einheit zur Angabe des gemessenen Glanzgrades einer Oberfläche, bestimmt mit einem Glanzmessgerät bei festgelegter Geometrie (z. B. 20°, 60°, 85°) relativ zu einem Referenzstandard. Zweck ist die vergleichbare Quantifizierung der spiegelnden Reflexion von Beschichtungen und metallischen Oberflächen unter definierten Messbedingungen. Die GU ist an die jeweilige Messgeometrie und Kalibrierung gekoppelt und daher nur bei Angabe des Messwinkels und der Normbedingungen eindeutig interpretierbar.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Gold -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Gold">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Gold</rdfs:label>
    </owl:Class>
    


