        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="de">Anteil des gesamten Kathodenstroms, der zur Abscheidung des jeweiligen Metalls verwendet wird</rdfs:comment>
        <rdfs:comment xml:lang="en">proportion of the total cathode current which is used in depositing the metal concerned</rdfs:comment>
        <rdfs:label xml:lang="en">Cathode Efficiency</rdfs:label>
        <rdfs:label xml:lang="de">kathodische Stromausbeute</rdfs:label>
    </owl:Class>
    


