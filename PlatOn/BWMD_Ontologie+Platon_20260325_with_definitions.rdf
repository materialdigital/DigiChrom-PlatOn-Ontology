    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Zirconium -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Zirconium">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ChemicalElement"/>
        <rdfs:label xml:lang="en">Zirconium</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#a -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#a">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-4:2019-03, DIN EN ISO/CIE 11664-6:2016-12</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">a</rdfs:label>
        <rdfs:label xml:lang="de">a (CIELAB Rot-Grün)</rdfs:label>
        <skos:definition xml:lang="de">a* ist die CIELAB-Farbkoordinate, die die Lage einer Farbe auf der Rot–Grün-Achse im CIE-L*a*b*-Farbraum beschreibt. Sie dient zur quantitativen Bewertung und Spezifikation von Farbabweichungen (z. B. bei galvanischen Oberflächen) in Richtung „rötlicher“ (positive a*-Werte) bzw. „grünlicher“ (negative a*-Werte). a* ist Bestandteil der aus tristimulusbasierten Messwerten berechneten CIELAB-Koordinaten und wird typischerweise zusammen mit L* und b* sowie definierten Beobachter-/Beleuchtungsbedingungen angegeben.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#aTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#aTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 11664-4:2019-03, DIN EN ISO 11664-1:2019-03, DIN EN ISO 11664-2:2022-01, DIN EN ISO 11664-3:2019-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Zielwert a (CIELAB Rot-Grün)</rdfs:label>
        <rdfs:label xml:lang="en">a target value</rdfs:label>
        <skos:definition xml:lang="de">Der Zielwert a (CIELAB Rot-Grün) ist der festgelegte Sollwert der CIELAB-Koordinate a* eines Farbortes, die die Lage auf der Rot-Grün-Achse beschreibt (positive Werte Richtung Rot, negative Richtung Grün). Er dient als Referenz zur Bewertung und Steuerung der Farbabweichung von galvanisch erzeugten Oberflächen (z. B. dekorative Beschichtungen) im Rahmen der Farbmessung und Qualitätssicherung. Der Zielwert ist stets zusammen mit den Messbedingungen (Beleuchtungsart, Normalbeobachter, Messgeometrie) festzulegen, da a* davon abhängt.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#b -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#b">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 11664-4:2019-03 (CIE S 014-4/E:2007), DIN EN ISO 11664-6:2016-12 (CIE S 014-6/E:2012)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">b</rdfs:label>
        <rdfs:label xml:lang="de">b (CIELAB Blau-Gelb)</rdfs:label>
        <skos:definition xml:lang="de">b* ist die CIELAB-Farbkoordinate, die die Position einer Farbe auf der Blau–Gelb-Achse im CIE-L*a*b*-Farbraum beschreibt. Sie dient zur quantitativen Angabe und zum Vergleich von Farbabweichungen, z. B. bei der farbmetrischen Beurteilung von Oberflächen und Beschichtungen. Positive b*-Werte entsprechen einer Verschiebung in Richtung Gelb, negative b*-Werte einer Verschiebung in Richtung Blau.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#bTarget -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#bTarget">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#NonDestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO/CIE 11664-4:2019-03; DIN EN ISO/CIE 11664-1:2019-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Zielwert b (CIELAB Blau-Gelb)</rdfs:label>
        <rdfs:label xml:lang="en">b target value</rdfs:label>
        <skos:definition xml:lang="de">Der Zielwert b (CIELAB Blau-Gelb) ist der vorgegebene Sollwert der CIELAB-Koordinate *b\** eines Farborts, die die Farbachse von Blau (negative *b\**-Werte) nach Gelb (positive *b\**-Werte) beschreibt. Er dient als Referenzgröße zur Festlegung und Prüfung der farblichen Übereinstimmung von Oberflächen (z. B. galvanisch beschichteten Teilen) gegenüber einem definierten Standard unter festgelegten Messbedingungen. Der Zielwert ist stets zusammen mit den zugehörigen CIELAB-Parametern (insbesondere *L\**, *a\**) sowie Beleuchtungsart, Normalbeobachter und Messgeometrie zu spezifizieren.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#pH-Electrode -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#pH-Electrode">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#EquipmentRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 10523:2012-04; DIN EN ISO 1842:2010-07</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">pH-Electrode</rdfs:label>
        <rdfs:label xml:lang="de">pH-Elektrode</rdfs:label>
        <skos:definition xml:lang="de">Eine pH-Elektrode ist eine elektrochemische Messelektrode (typischerweise eine Glaselektrode), die als Teil einer potentiometrischen Messkette eine vom pH-Wert abhängige Elektrodenpotenzialdifferenz liefert. Hauptzweck ist die Bestimmung des pH-Werts wässriger Lösungen durch Messung der elektromotorischen Kraft gegen eine Bezugselektrode und Umrechnung gemäß festgelegter Kalibrierung. In der Praxis wird sie häufig als kombinierte pH-Elektrode ausgeführt, bei der Mess- und Bezugselektrode in einem Gehäuse integriert sind.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#pHMeasurementDevice -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#pHMeasurementDevice">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#MeasurementEquipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN 19263:2012-11, DIN EN ISO 10523:2012-04</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">pH Measurement Device</rdfs:label>
        <rdfs:label xml:lang="de">pH-Messgerät</rdfs:label>
        <skos:definition xml:lang="de">Ein pH-Messgerät ist ein Messgerät zur Bestimmung des pH-Werts einer wässrigen Lösung mittels pH-empfindlicher Messelektrode und Bezugselektrode (häufig als kombinierte Elektrode ausgeführt) und zugehöriger Messelektronik. Hauptzweck ist die Ermittlung und Überwachung der Wasserstoffionenaktivität als Kenngröße der Säure- bzw. Alkalität, z. B. zur Prozess- und Badführung in galvanotechnischen Elektrolyten. Es ist von Indikatorpapier/kolorimetrischen Verfahren abzugrenzen, da es eine elektrochemische Messung mit definierter Kalibrierung und Messunsicherheit ermöglicht.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasionResistance(Tribotouch) -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#AbrasionResistance(Tribotouch)">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="en">Resistance of a material to wear under tribological conditions</rdfs:comment>
        <rdfs:comment xml:lang="de">Widerstand eines Materials gegen Abrieb unter tribologischen Bedingungen</rdfs:comment>
        <rdfs:label xml:lang="en">Abrasion Resistance (Tribotouch)</rdfs:label>
        <rdfs:label xml:lang="de">Abriebbeständigkeit (TriboTouch)</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ball/Pin -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ball/Pin">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Equipment"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>IEC 60512-9-1:2011, Connectors for electronic equipment – Tests and measurements – Part 9-1: Endurance tests – Contact resistance tests (Test 9a); IEC 60512-5-2:2002, Connectors for electronic equipment – Tests and measurements – Part 5-2: Current-carrying capacity tests – Test 5b (Contact resistance); ASTM G99-17, Standard Test Method for Wear Testing with a Pin-on-Disk Apparatus</rdfs:isDefinedBy>
        <rdfs:label xml:lang="de">Ball/Pin</rdfs:label>
        <rdfs:label xml:lang="en">Ball/Pin</rdfs:label>
        <skos:definition xml:lang="de">Ball/Pin bezeichnet eine Kontaktpaar-Geometrie aus einer kugelförmigen Kontaktfläche („Ball“) und einem stiftförmigen Gegenkontakt („Pin“), die zur elektrischen Kontaktierung und/oder zur tribologischen Prüfung von Kontaktoberflächen eingesetzt wird. Hauptzweck ist die definierte, reproduzierbare Kontaktzone (Kontaktpunkt/-fläche) zur Bewertung von Kontaktwiderstand, Verschleiß und Schichtverhalten (z. B. Edelmetallüberzüge). In der Galvanotechnik dient die Ball/Pin-Anordnung häufig als Prüfkörper-/Kontaktgeometrie zur Beurteilung galvanischer Überzüge auf elektrischen Kontakten.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ball/PinMaterial -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ball/PinMaterial">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 26423:2016-12 (Feinmechanik — Schichtdickenmessung — Kugelkraterverfahren); DIN EN ISO 1463:2020-08 (Metallische und Oxidschichten — Messung der Schichtdicke — Mikroskopisches Verfahren)</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Ball/Pin Material</rdfs:label>
        <rdfs:label xml:lang="de">Kugel/Stift-Material</rdfs:label>
        <skos:definition xml:lang="de">Kugel/Stift-Material bezeichnet den Werkstoff des Prüfkörpers (Kugel oder Stift), der bei mechanischen/tribologischen Prüf- oder Messverfahren in Kontakt mit einer galvanischen Schicht gebracht wird (z. B. zur Erzeugung eines Kraters oder einer Ritze). Hauptzweck ist die Sicherstellung reproduzierbarer Kontaktbedingungen (Härte, Verschleißverhalten, chemische Beständigkeit), damit Messergebnisse wie Schichtdicke oder Schichtaufbau vergleichbar sind. Das Material ist vom Beschichtungswerkstoff zu unterscheiden und wird in der Regel über normativ vorgegebene Werkstoffe (z. B. Stahl, Hartmetall) bzw. definierte Eigenschaften spezifiziert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ball/PinRadius -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Ball/PinRadius">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 6506-1:2015-02; DIN EN ISO 6507-1:2018-07; DIN EN ISO 14577-1:2015-11</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Ball/Pin Radius</rdfs:label>
        <rdfs:label xml:lang="de">Kugel/Stift-Radius</rdfs:label>
        <skos:definition xml:lang="de">Der Kugel/Stift-Radius ist der Radius der kugelförmigen Oberfläche einer Kugel bzw. der kugelig verrundeten Spitze eines Stifts (z. B. eines Eindringkörpers). Er dient zur eindeutigen geometrischen Festlegung der Kontaktgeometrie und beeinflusst damit Kontaktfläche, Flächenpressung und das Ergebnis bzw. die Vergleichbarkeit von Prüf- oder Prozessbedingungen. In der Normung wird er typischerweise als Kugelradius (aus dem Kugeldurchmesser abgeleitet) oder als Spitzenradius des Eindringkörpers spezifiziert.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


