        <dc:creator>DigiChrom</dc:creator>
        <rdfs:label xml:lang="de">Messung der Knötchenstruktur</rdfs:label>
        <rdfs:label xml:lang="en">Nodular structure measurement</rdfs:label>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


