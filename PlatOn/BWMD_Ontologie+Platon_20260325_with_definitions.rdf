<?xml version="1.0"?>
<rdf:RDF xmlns="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#"
     xml:base="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology">
        <dc:creator xml:lang="en">DigiChrom - MaterialDigital</dc:creator>
        <dcterms:description xml:lang="en">The Plating Ontology (PlatOn) is an application-level semantic framework for the electroplating industry, developed on the basis of the Platform MaterialDigital Core Ontology (PMDco). PlatOn extends the PMDco concepts with domain-specific knowledge required to represent the complete manufacturing and characterization lifecycle of electroplated coatings, with a particular focus on chromium plating technologies.

The scope of PlatOn follows the processing–structure–properties paradigm and encompasses the following domains:

(*) Processes: Representation of electroplating process chains, including substrate preparation, electrolyte preparation, coating deposition, post-treatment, and quality assurance processes.

(*) Structure and Materials: Description of substrates, electrolytes, additives, coated components, coating systems, and their structural characteristics such as layer architecture, coating thickness, surface morphology, and crack networks.

(*) Properties: Specification of coating properties and qualities, including hardness, wear resistance, corrosion resistance, adhesion, roughness, and other performance-related characteristics.

(*) Characterization: Representation of experimental methods, measurement procedures, testing devices, datasets, and observations used to evaluate coating structure and properties.

In addition, PlatOn provides general semantics for representing equipment, process parameters, measurement data, and provenance information, enabling interoperable and traceable digital representations of electroplating processes and coating performance throughout the coating lifecycle.</dcterms:description>
        <dcterms:title xml:lang="en">PlatOn Ontology</dcterms:title>
        <rdfs:comment xml:lang="en">BWMD ontology adapted for the DigiChrom Workshop 20.11.2024</rdfs:comment>
        <rdfs:comment xml:lang="en">Classes classified for compatibility with the beta version Graph Designer App</rdfs:comment>
        <rdfs:label xml:lang="en">BWMD4DigiChrom</rdfs:label>
    </owl:Ontology>
    


