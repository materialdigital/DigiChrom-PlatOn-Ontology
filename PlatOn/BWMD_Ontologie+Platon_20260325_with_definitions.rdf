    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Frequency -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Frequency">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#QuantityKind"/>
        <rdfs:label xml:lang="en">Frequency</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FrequencyOfOscillation -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FrequencyOfOscillation">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ProcessQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-3:2020-09 (Größen und Einheiten – Teil 3: Raum und Zeit), DIN 1313:1998-04 (Größen)</rdfs:isDefinedBy>
        <rdfs:isDefinedBy>DIN EN ISO 80000-3:2020-09; DIN EN 60027-1 (VDE 0880-1):1993-03</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Frequency Of Oscillation</rdfs:label>
        <rdfs:label xml:lang="de">Schwingfrequenz</rdfs:label>
        <skos:definition xml:lang="de">Die Osziellierungsfrequenz ist die Frequenz, mit der ein Bauteil, Werkzeug oder eine Prozessgröße im galvanotechnischen Prozess periodisch hin- und herbewegt bzw. periodisch variiert (Anzahl der Oszillationszyklen pro Zeiteinheit). Hauptzweck ist die gezielte Beeinflussung von Stofftransport, Grenzschichtdicke und damit der Abscheidung (z. B. Schichtdickenverteilung, Struktur, Rauheit) durch definierte periodische Anregung. Sie ist von der Amplitude (Auslenkung) und ggf. der Phasenlage zu unterscheiden, die die Oszillation zusätzlich charakterisieren.</skos:definition>
        <skos:definition xml:lang="de">Die Schwingfrequenz ist die Anzahl der vollständigen Schwingungen eines periodischen Vorgangs pro Zeiteinheit und wird in Hertz (Hz) angegeben. Sie dient zur quantitativen Beschreibung und Festlegung periodischer Anregungen bzw. zeitlich wechselnder Größen (z. B. mechanische Schwingungen oder elektrische Wechselgrößen) in technischen Prozessen und Prüfungen. Von der Kreisfrequenz (Winkelgeschwindigkeit) ist sie durch den Zusammenhang ω = 2π·f abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FrictionCoefficient -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FrictionCoefficient">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CoatingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/ChatGPT"/>
        <rdfs:comment xml:lang="de">Maß für die Reibung zwischen zwei Oberflächen</rdfs:comment>
        <rdfs:comment xml:lang="en">Measure of friction between two surfaces</rdfs:comment>
        <rdfs:label xml:lang="en">Friction Coefficient</rdfs:label>
        <rdfs:label xml:lang="de">Reibungskoeffizient</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FrictionPath -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FrictionPath">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 20808:2019-06, DIN EN 1071-13:2010-02</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Friction Path</rdfs:label>
        <rdfs:label xml:lang="de">Reibweg</rdfs:label>
        <skos:definition xml:lang="de">Der Reibweg ist die während einer Reibbeanspruchung zurückgelegte relative Wegstrecke zwischen zwei in Kontakt stehenden Oberflächen. Er dient als maßgebende Prüf- und Vergleichsgröße zur Beschreibung der Beanspruchungsdauer bzw. -intensität bei Reib- und Verschleißprüfungen. Der Reibweg wird typischerweise als kumulierte Gleitstrecke (z. B. in m) angegeben und ist von der Reibstrecke einzelner Hübe/Zyklen abzugrenzen.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FrictonCoefficient -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FrictonCoefficient">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#DestructiveTestingRelatedQuantity"/>
        <dc:creator>DigiChrom</dc:creator>
        <rdfs:isDefinedBy>DIN EN ISO 80000-4:2020-06; DIN EN ISO 8295:2004-10; DIN EN ISO 7148-2:2012-10</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Fricton Coefficient</rdfs:label>
        <rdfs:label xml:lang="de">Reibungskoeffizient</rdfs:label>
        <skos:definition xml:lang="de">Der Reibungskoeffizient ist eine dimensionslose Kenngröße, die das Verhältnis der Reibkraft zur Normalkraft zwischen zwei sich berührenden Körpern unter definierten Bedingungen beschreibt. Er dient zur quantitativen Charakterisierung des Reibungsverhaltens von Oberflächen bzw. Beschichtungen (z. B. galvanisch abgeschiedene Schichten) in Abhängigkeit von Werkstoffpaarung, Oberflächenzustand und Prüfbedingungen. Üblich ist die Unterscheidung zwischen Haftreibungskoeffizient und Gleitreibungskoeffizient.</skos:definition>
        <skos:definition>tbd</skos:definition>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Fully-AutomaticPlatingTreatment -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Fully-AutomaticPlatingTreatment">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Treating"/>
        <dc:creator>DigiChrom</dc:creator>
        <dc:definedBy rdf:resource="file:///C:/Users/trell/Desktop/DigiChrom-workshop-20112024/Ontology/DigiChrom"/>
        <rdfs:comment xml:lang="en">automatic treatment in which the work pieces  are automatically conveyed through successive cleaning  and plating tanks</rdfs:comment>
        <rdfs:comment xml:lang="de">automatisches Verfahren, bei dem die Werkstücke automatisch durch verschiedene Behälter für die Reinigung  und die Metall- abscheidung befördert werden</rdfs:comment>
        <rdfs:label xml:lang="en">Fully-Automatic Plating Treatment</rdfs:label>
        <rdfs:label xml:lang="de">vollautomatische Behandlung</rdfs:label>
    </owl:Class>
    


    <!-- https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FumeHood -->

    <owl:Class rdf:about="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FumeHood">
        <rdfs:subClassOf rdf:resource="https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#LabInfrastructureEquipment"/>
        <rdfs:comment>Fume hood to suck off toxic gases in the air, e.g. during etching of metallographic specimens.</rdfs:comment>
        <rdfs:label xml:lang="en">FumeHood</rdfs:label>
    </owl:Class>
    


